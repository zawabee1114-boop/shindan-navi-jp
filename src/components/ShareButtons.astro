---
/**
 * ShareButtons.astro - SNSシェアボタン
 * Instagram / X / LINE に対応。
 */
interface Props {
  /** シェアするURL */
  url: string;
  /** シェアテキスト */
  text: string;
  /** ハッシュタグ（カンマ区切りなし・配列で渡す）*/
  hashtags?: string[];
  /** ボタンサイズ */
  size?: 'sm' | 'md' | 'lg';
  /** ラベルを表示するか */
  showLabel?: boolean;
}

const {
  url,
  text,
  hashtags = ['診断ナビ'],
  size = 'md',
  showLabel = true,
} = Astro.props;

const encodedUrl = encodeURIComponent(url);
const encodedText = encodeURIComponent(text);
const xUrl = `https://twitter.com/intent/tweet?text=${encodedText}&url=${encodedUrl}&hashtags=${hashtags.join(',')}`;
const lineUrl = `https://line.me/R/msg/text/?${encodeURIComponent(`${text} ${url}`)}`;
---

<div class={`share-buttons share-buttons--${size}`} aria-label="SNSシェアボタン">
  {showLabel && <p class="share-label">友達に教える</p>}

  <div class="share-btn-group">
    <!-- X（Twitter）-->
    <a
      href={xUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-btn--x"
      aria-label="X（Twitter）でシェア"
    >
      <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.732-8.836L1.254 2.25H8.08l4.258 5.63 5.907-5.63Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>
      </svg>
      <span>X</span>
    </a>

    <!-- LINE -->
    <a
      href={lineUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="share-btn share-btn--line"
      aria-label="LINEでシェア"
    >
      <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.629 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
      </svg>
      <span>LINE</span>
    </a>

    <!-- Instagram（ストーリーズ）: モバイルのみ有効 -->
    <button
      type="button"
      class="share-btn share-btn--instagram"
      id="instagramShareBtn"
      aria-label="Instagramでシェア（モバイルのみ）"
      title="Instagramでシェア"
    >
      <svg class="share-icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
      </svg>
      <span>Instagram</span>
    </button>
  </div>
</div>

<script>
  // Instagram シェア（モバイルのみ動作）
  const igBtn = document.getElementById('instagramShareBtn');
  if (igBtn) {
    igBtn.addEventListener('click', () => {
      // モバイルでは navigator.share を試みる
      if (navigator.share) {
        navigator.share({
          title: document.title,
          url: window.location.href,
        }).catch(() => {
          // ユーザーがキャンセルした場合は何もしない
        });
      } else {
        // デスクトップ: クリップボードにコピー
        navigator.clipboard.writeText(window.location.href).then(() => {
          alert('URLをコピーしました。Instagramに貼り付けてシェアしてください。');
        });
      }
    });
  }
</script>

<style>
  .share-buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sn-space-3);
  }

  .share-label {
    font-size: var(--sn-text-sm);
    color: var(--sn-muted);
    font-weight: 500;
    margin: 0;
  }

  .share-btn-group {
    display: flex;
    gap: var(--sn-space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sn-space-2);
    padding: var(--sn-space-2) var(--sn-space-4);
    border-radius: var(--sn-radius-pill);
    font-size: var(--sn-text-sm);
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: opacity var(--sn-dur-fast) var(--sn-ease), transform var(--sn-dur-fast) var(--sn-ease-bounce);
    min-height: var(--sn-tap-min);
  }

  .share-btn:hover {
    opacity: 0.88;
    transform: scale(1.03);
    text-decoration: none;
  }

  .share-btn--x {
    background: #000000;
    color: #ffffff;
  }

  .share-btn--line {
    background: #00b900;
    color: #ffffff;
  }

  .share-btn--instagram {
    background: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    color: #ffffff;
  }

  .share-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* サイズバリエーション */
  .share-buttons--sm .share-btn {
    padding: var(--sn-space-1) var(--sn-space-3);
    font-size: var(--sn-text-xs);
    /* WCAG 2.1 AA: タップターゲット最小44px */
    min-height: 44px;
  }

  .share-buttons--sm .share-icon {
    width: 14px;
    height: 14px;
  }

  .share-buttons--lg .share-btn {
    padding: var(--sn-space-3) var(--sn-space-6);
    font-size: var(--sn-text-base);
    min-height: 52px;
  }

  .share-buttons--lg .share-icon {
    width: 20px;
    height: 20px;
  }
</style>
