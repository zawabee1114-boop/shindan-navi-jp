---
/**
 * SiteFooter.astro - グローバルフッター
 * 内部リンク最適化: 2026-05-21 更新
 * - 8診断全リンク追加（完璧主義・金銭感覚・星座追加）
 * - 相性ツール・表・星座相性表を追加
 * - シーン軸・FAQ・編集ポリシーを追加
 * - 姉妹サイトリンク追加（相互リンク強化）
 * 2026-05-29 更新: /authors/ リンク追加（MID-1 著者ページ対応）
 */
import siteMeta from '../data/site-meta.json';

const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    heading: '性格診断',
    links: [
      { label: '多重知能テスト', href: '/diagnosis/multi-int/' },
      { label: 'MBTI診断', href: '/diagnosis/mbti/' },
      { label: 'DiSC診断', href: '/diagnosis/disc/' },
      { label: '完璧主義タイプ診断', href: '/diagnosis/perfectionism/' },
      { label: '恋愛スタイル診断', href: '/diagnosis/love-style/' },
      { label: '金銭感覚診断', href: '/diagnosis/money-sense/' },
      { label: '星座性格診断', href: '/diagnosis/seiza/' },
      { label: '血液型性格診断', href: '/diagnosis/ketsuekigata/' },
    ],
  },
  {
    heading: '相性診断',
    links: [
      { label: 'MBTI相性一覧', href: '/diagnosis/mbti-compat/' },
      { label: 'MBTI恋愛相性', href: '/diagnosis/mbti-compat/love/' },
      { label: '血液型相性診断', href: '/diagnosis/blood-compat/' },
      { label: '友達相性診断', href: '/diagnosis/friend-compat/' },
      { label: 'MBTI相性表', href: '/diagnosis/mbti-compat/table/' },
      { label: '血液型相性表', href: '/diagnosis/blood-compat/table/' },
      { label: '星座相性表', href: '/diagnosis/zodiac/compatibility/' },
    ],
  },
  {
    heading: 'シーン別',
    links: [
      { label: '診断一覧', href: '/diagnosis/' },
      { label: 'よくある質問', href: '/faq/' },
      { label: 'PRO会員', href: '/pro/' },
    ],
  },
  {
    heading: 'サイト情報',
    links: [
      { label: '診断ナビについて', href: '/about/' },
      { label: '著者プロフィール', href: '/authors/' },
      { label: '編集ポリシー', href: '/editorial-policy/' },
      { label: 'プライバシーポリシー', href: '/privacy/' },
      { label: '利用規約', href: '/terms/' },
      { label: '免責事項', href: '/disclaimer/' },
      { label: 'お問い合わせ', href: '/contact/' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="container">
    <!-- フッターナビ -->
    <div class="footer-nav">
      {footerLinks.map((group) => (
        <div class="footer-group">
          <h3 class="footer-heading">{group.heading}</h3>
          <ul class="footer-links">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="footer-link">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- 姉妹サイトリンク（内部リンク強化・相互ネットワーク）-->
    <div class="footer-sister">
      <p class="footer-sister-label">姉妹サイト</p>
      <ul class="footer-sister-links">
        <li><a href="https://keisan-navi.jp" class="footer-sister-link" rel="noopener">計算ナビ</a></li>
        <li><a href="https://template-free.jp" class="footer-sister-link" rel="noopener">テンプレートフリー</a></li>
      </ul>
    </div>

    <!-- ブランド・コピーライト -->
    <div class="footer-bottom">
      <p class="footer-brand">
        <span class="footer-logo" aria-hidden="true">🔮</span>
        <strong>{siteMeta.siteName}</strong>
      </p>
      <p class="footer-tagline">{siteMeta.tagline}</p>
      <p class="footer-copyright">
        &copy; {currentYear} {siteMeta.siteName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--sn-text);
    color: var(--sn-muted-light);
    padding-block: var(--sn-space-12) var(--sn-space-8);
    margin-top: var(--sn-space-16);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sn-space-8);
    margin-bottom: var(--sn-space-8);
  }

  @media (min-width: 768px) {
    .footer-nav {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .footer-heading {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-sm);
    font-weight: 700;
    color: #ffffff;
    margin-bottom: var(--sn-space-3);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sn-space-2);
  }

  .footer-link {
    font-size: var(--sn-text-sm);
    color: var(--sn-muted-light);
    text-decoration: none;
    transition: color var(--sn-dur-fast) var(--sn-ease);
  }

  .footer-link:hover {
    color: #ffffff;
    text-decoration: none;
  }

  /* 姉妹サイト */
  .footer-sister {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--sn-space-4);
    margin-bottom: var(--sn-space-6);
    display: flex;
    align-items: center;
    gap: var(--sn-space-4);
    flex-wrap: wrap;
  }

  .footer-sister-label {
    font-size: var(--sn-text-xs);
    color: var(--sn-muted);
    white-space: nowrap;
  }

  .footer-sister-links {
    list-style: none;
    display: flex;
    gap: var(--sn-space-4);
    flex-wrap: wrap;
  }

  .footer-sister-link {
    font-size: var(--sn-text-xs);
    color: var(--sn-muted-light);
    text-decoration: none;
    transition: color var(--sn-dur-fast) var(--sn-ease);
  }

  .footer-sister-link:hover {
    color: #ffffff;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: var(--sn-space-6);
    text-align: center;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sn-space-2);
    font-size: var(--sn-text-lg);
    color: #ffffff;
    margin-bottom: var(--sn-space-2);
  }

  .footer-logo {
    font-size: var(--sn-text-xl);
  }

  .footer-tagline {
    font-size: var(--sn-text-sm);
    color: var(--sn-muted-light);
    margin-bottom: var(--sn-space-4);
  }

  .footer-copyright {
    font-size: var(--sn-text-xs);
    color: var(--sn-muted);
  }
</style>
