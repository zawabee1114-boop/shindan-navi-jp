---
/**
 * LevelBadge.astro - レベル・バッジ表示
 * ゲーミフィケーション要素。受診診断数でLv.1-10。
 */
interface Props {
  /** 現在レベル 1-10 */
  level: number;
  /** 表示名（例: "初心者" / "診断マスター"）*/
  title?: string;
  /** バッジの見た目 */
  variant?: 'default' | 'compact' | 'large';
  /** アニメーション演出 */
  animated?: boolean;
}

const levelTitles: Record<number, string> = {
  1: '初心者',
  2: '探求者',
  3: '発見者',
  4: '分析家',
  5: '理解者',
  6: '洞察者',
  7: '達人',
  8: 'エキスパート',
  9: '賢者',
  10: '診断マスター',
};

const levelColors: Record<number, string> = {
  1:  '#9ca3af',
  2:  '#6b7280',
  3:  '#10b981',
  4:  '#3b82f6',
  5:  '#6366f1',
  6:  '#8b5cf6',
  7:  '#ec4899',
  8:  '#f59e0b',
  9:  '#ef4444',
  10: '#f59e0b',
};

const {
  level,
  title = levelTitles[level] ?? '探求者',
  variant = 'default',
  animated = false,
} = Astro.props;

const clampedLevel = Math.min(Math.max(level, 1), 10);
const color = levelColors[clampedLevel] ?? 'var(--sn-primary)';
const isMaxLevel = clampedLevel === 10;
---

<div
  class={`level-badge level-badge--${variant} ${animated ? 'level-badge--animated' : ''} ${isMaxLevel ? 'level-badge--max' : ''}`}
  style={`--level-color: ${color}`}
  aria-label={`レベル ${clampedLevel} ${title}`}
>
  <span class="level-prefix" aria-hidden="true">Lv.</span>
  <span class="level-number">{clampedLevel}</span>
  {variant !== 'compact' && (
    <span class="level-title">{title}</span>
  )}
  {isMaxLevel && <span class="max-star" aria-hidden="true">★</span>}
</div>

<style>
  .level-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sn-space-1);
    padding: var(--sn-space-1) var(--sn-space-3);
    border-radius: var(--sn-radius-pill);
    background: color-mix(in srgb, var(--level-color) 12%, transparent);
    border: 1.5px solid color-mix(in srgb, var(--level-color) 40%, transparent);
    color: var(--level-color);
    font-weight: 700;
    white-space: nowrap;
  }

  .level-prefix {
    font-size: var(--sn-text-xs);
    font-weight: 700;
    opacity: 0.8;
  }

  .level-number {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-base);
    font-weight: 900;
    line-height: 1;
  }

  .level-title {
    font-size: var(--sn-text-xs);
    font-weight: 700;
  }

  .max-star {
    font-size: var(--sn-text-sm);
    color: var(--sn-accent);
  }

  /* コンパクト */
  .level-badge--compact {
    padding: 2px var(--sn-space-2);
  }

  .level-badge--compact .level-number {
    font-size: var(--sn-text-sm);
  }

  /* ラージ */
  .level-badge--large {
    padding: var(--sn-space-2) var(--sn-space-5);
    border-radius: var(--sn-radius-md);
    gap: var(--sn-space-2);
  }

  .level-badge--large .level-number {
    font-size: var(--sn-text-2xl);
  }

  .level-badge--large .level-title {
    font-size: var(--sn-text-sm);
  }

  /* 最大レベル */
  .level-badge--max {
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--sn-accent) 15%, transparent) 0%,
      color-mix(in srgb, var(--level-color) 15%, transparent) 100%
    );
    border-color: var(--sn-accent);
    animation: none;
  }

  /* アニメーション */
  .level-badge--animated {
    animation: levelPulse 2s var(--sn-ease) infinite;
  }

  @keyframes levelPulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--level-color) 40%, transparent); }
    50% { box-shadow: 0 0 0 4px color-mix(in srgb, var(--level-color) 0%, transparent); }
  }
</style>
