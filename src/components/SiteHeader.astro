---
/**
 * SiteHeader.astro - グローバルヘッダー
 * Phase 3.2: 認証状態表示 + ログアウト UI 追加
 *
 * AuthHeader.tsx を React Island として組み込み
 * ログイン状態は client:only="react" でマウント後に取得
 * CLS 対策: AuthHeader マウント前のプレースホルダー幅を固定
 */
import siteMeta from '../data/site-meta.json';
import AuthHeader from './auth/AuthHeader';

const navItems = [
  { label: '診断一覧', href: '/diagnosis/' },
  { label: '相性診断', href: '/aisei/' },
  { label: '強み発見', href: '/strengths/' },
  { label: 'PRO機能', href: '/pro/' },
];
---

<header class="site-header">
  <div class="container">
    <div class="header-inner">
      <!-- ロゴ -->
      <a href="/" class="site-logo" aria-label={`${siteMeta.siteName} - トップページ`}>
        <!-- TODO: 本番ではSVGロゴに差し替え -->
        <span class="logo-icon" aria-hidden="true">🔮</span>
        <span class="logo-text">{siteMeta.siteName}</span>
      </a>

      <!-- PC ナビ -->
      <nav class="header-nav" aria-label="グローバルナビゲーション">
        <ul class="nav-list">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link">{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- 認証 UI（React Island）-->
      <div class="header-auth" aria-label="認証メニュー">
        <!--
          client:only="react": SSR スキップ（LocalStorage / Supabase はブラウザ専用）
          CLS 対策: --auth-placeholder-w でマウント前の幅を確保
        -->
        <AuthHeader client:only="react" />
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--sn-header-h);
    background: var(--sn-bg-white);
    border-bottom: 1px solid var(--sn-border);
    box-shadow: var(--sn-shadow-xs);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 100%;
    gap: var(--sn-space-4);
  }

  /* ロゴ */
  .site-logo {
    display: flex;
    align-items: center;
    gap: var(--sn-space-2);
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-logo:hover {
    text-decoration: none;
  }

  .logo-icon {
    font-size: var(--sn-text-xl);
    line-height: 1;
  }

  .logo-text {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-lg);
    font-weight: 900;
    color: var(--sn-primary);
    letter-spacing: -0.02em;
  }

  /* PC ナビ */
  .header-nav {
    display: none;
    flex: 1;
    margin-inline: var(--sn-space-4);
  }

  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--sn-space-1);
  }

  .nav-link {
    display: block;
    padding: var(--sn-space-2) var(--sn-space-3);
    border-radius: var(--sn-radius-sm);
    font-size: var(--sn-text-sm);
    font-weight: 500;
    color: var(--sn-text-soft);
    text-decoration: none;
    transition: background-color var(--sn-dur-fast) var(--sn-ease), color var(--sn-dur-fast) var(--sn-ease);
  }

  .nav-link:hover {
    background: var(--sn-primary-bg);
    color: var(--sn-primary);
    text-decoration: none;
  }

  /* 認証エリア */
  .header-auth {
    margin-left: auto;
    flex-shrink: 0;
    /* CLS 対策: マウント前のプレースホルダー幅を確保 */
    min-width: 80px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* PC幅ではメールアドレスを表示 */
  @media (min-width: 900px) {
    .header-auth :global(.auth-header-email) {
      display: block !important;
    }
  }
</style>
