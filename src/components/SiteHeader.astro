---
/**
 * SiteHeader.astro - グローバルヘッダー v2.0
 * Claude Design ハンドオフ準拠: 白半透明 + backdrop-filter
 * 2026-05-22 更新
 *
 * AuthHeader.tsx を React Island として組み込み
 * ログイン状態は client:only="react" でマウント後に取得
 * CLS 対策: AuthHeader マウント前のプレースホルダー幅を固定
 */
import siteMeta from '../data/site-meta.json';
import AuthHeader from './auth/AuthHeader';

const navItems = [
  { label: '診断一覧', href: '/diagnosis/' },
  { label: '相性診断', href: '/aisei/' },
  { label: '強み発見', href: '/strengths/' },
  { label: 'PRO機能', href: '/pro/' },
];
---

<header class="site-header">
  <div class="header-inner-wrap">
    <!-- ロゴ -->
    <a href="/" class="site-logo" aria-label={`${siteMeta.siteName} - トップページ`}>
      <span class="logo-mark" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="14" cy="14" r="14" fill="url(#logo-grad)"/>
          <defs>
            <linearGradient id="logo-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#9b85ff"/>
              <stop offset="100%" stop-color="#6a47ff"/>
            </linearGradient>
          </defs>
          <path d="M14 7l1.5 4.2L20 12.5l-4.2 1.8.7 4.3L14 16.4l-2.5 2.2.7-4.3-4.2-1.8 4.5-1.3L14 7z" fill="white"/>
        </svg>
      </span>
      <span class="logo-text">{siteMeta.siteName}</span>
    </a>

    <!-- PC ナビ -->
    <nav class="header-nav" aria-label="グローバルナビゲーション">
      <ul class="nav-list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- 認証 UI（React Island）-->
    <div class="header-auth" aria-label="認証メニュー">
      <!--
        client:only="react": SSR スキップ（LocalStorage / Supabase はブラウザ専用）
        CLS 対策: min-width でマウント前の幅を確保
      -->
      <AuthHeader client:only="react" />
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--sn-header-h);
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--sn-dur-fast) var(--sn-ease);
  }

  .site-header.is-scrolled {
    box-shadow: var(--shadow-md);
  }

  .header-inner-wrap {
    display: flex;
    align-items: center;
    height: 100%;
    max-width: var(--sn-max-w);
    margin-inline: auto;
    padding-inline: var(--sn-space-4);
    gap: var(--sn-space-4);
  }

  @media (min-width: 640px) {
    .header-inner-wrap {
      padding-inline: var(--sn-space-6);
    }
  }

  /* ロゴ */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .site-logo:hover {
    text-decoration: none;
  }

  .logo-mark {
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .logo-text {
    font-family: 'Inter', 'Noto Sans JP', system-ui, sans-serif;
    font-size: var(--sn-text-lg);
    font-weight: 700;
    color: var(--ink-900);
    letter-spacing: -0.01em;
  }

  /* PC ナビ */
  .header-nav {
    display: none;
    flex: 1;
    margin-inline: var(--sn-space-4);
  }

  @media (min-width: 768px) {
    .header-nav {
      display: block;
    }
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 4px;
  }

  .nav-link {
    display: block;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    font-size: var(--sn-text-sm);
    font-weight: 500;
    color: var(--ink-700);
    text-decoration: none;
    transition: background-color var(--sn-dur-fast) var(--sn-ease), color var(--sn-dur-fast) var(--sn-ease);
  }

  .nav-link:hover {
    background: var(--brand-50);
    color: var(--brand-600);
    text-decoration: none;
  }

  /* 認証エリア */
  .header-auth {
    margin-left: auto;
    flex-shrink: 0;
    /* CLS 対策: マウント前のプレースホルダー幅を確保 */
    min-width: 80px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  /* PC幅ではメールアドレスを表示 */
  @media (min-width: 900px) {
    .header-auth :global(.auth-header-email) {
      display: block !important;
    }
  }

  /* フォーカスリング */
  .nav-link:focus-visible,
  .site-logo:focus-visible {
    outline: 2px solid var(--brand-400);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
</style>
