---
/**
 * AnimalIcons.astro - 16動物キャラ SVGアイコン集約コンポーネント
 *
 * 使い方:
 *   <AnimalIcons animal="lion" size={120} color="#f59e0b" />
 *
 * スタイル: パステル・丸み・フラットイラスト
 * viewBox: 0 0 120 120（全動物統一）
 * WCAG: role="img" + aria-label を親コンポーネント側で付与すること
 */

interface Props {
  /** 動物種別 */
  animal: 'lion' | 'falcon' | 'owl' | 'octopus' | 'dolphin' | 'fox' | 'cat' | 'tiger' |
          'dog' | 'wolf' | 'beaver' | 'eagle' | 'panda' | 'cheetah' | 'rabbit' | 'hedgehog';
  /** SVGの表示サイズ（px） */
  size?: number;
  /** メインカラー（キャラ固有色） */
  color?: string;
  /** 追加クラス */
  class?: string;
}

const {
  animal,
  size = 120,
  color = '#7c5cff',
  class: className = '',
} = Astro.props;
---

{animal === 'lion' && (
  <svg
    viewBox="0 0 120 120"
    width={size}
    height={size}
    class={`animal-icon ${className}`}
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    focusable="false"
  >
    <!-- たてがみ -->
    <circle cx="60" cy="62" r="36" fill={color} opacity="0.25"/>
    <circle cx="60" cy="62" r="30" fill={color} opacity="0.35"/>
    <!-- 顔 -->
    <circle cx="60" cy="62" r="24" fill="#fde68a"/>
    <!-- 耳 -->
    <circle cx="40" cy="40" r="9" fill={color} opacity="0.5"/>
    <circle cx="80" cy="40" r="9" fill={color} opacity="0.5"/>
    <circle cx="40" cy="40" r="5" fill="#fde68a"/>
    <circle cx="80" cy="40" r="5" fill="#fde68a"/>
    <!-- 目 -->
    <circle cx="52" cy="58" r="4.5" fill="#1f2235"/>
    <circle cx="68" cy="58" r="4.5" fill="#1f2235"/>
    <circle cx="53.5" cy="56.5" r="1.5" fill="#fff"/>
    <circle cx="69.5" cy="56.5" r="1.5" fill="#fff"/>
    <!-- 鼻 -->
    <ellipse cx="60" cy="66" rx="5" ry="3.5" fill={color} opacity="0.7"/>
    <!-- 口 -->
    <path d="M55 70 Q60 75 65 70" stroke="#b45309" stroke-width="1.8" fill="none" stroke-linecap="round"/>
    <!-- ひげ -->
    <line x1="36" y1="64" x2="50" y2="66" stroke="#b45309" stroke-width="1.2" opacity="0.5"/>
    <line x1="36" y1="68" x2="50" y2="68" stroke="#b45309" stroke-width="1.2" opacity="0.5"/>
    <line x1="70" y1="66" x2="84" y2="64" stroke="#b45309" stroke-width="1.2" opacity="0.5"/>
    <line x1="70" y1="68" x2="84" y2="68" stroke="#b45309" stroke-width="1.2" opacity="0.5"/>
    <!-- 王冠 -->
    <path d="M46 36 L50 26 L55 32 L60 22 L65 32 L70 26 L74 36 Z" fill={color} opacity="0.9"/>
    <circle cx="60" cy="22" r="3" fill="#fff" opacity="0.9"/>
    <circle cx="50" cy="26" r="2" fill="#fff" opacity="0.7"/>
    <circle cx="70" cy="26" r="2" fill="#fff" opacity="0.7"/>
  </svg>
)}

{animal === 'falcon' && (
