---
/**
 * CharacterDisplay.astro - 16動物キャラ表示
 *
 * Big5 4軸（O/C/E/A）× 各2段階（high/low）= 16パターンの動物SVGを表示する。
 * N（情緒安定性）は別途 Big5MoodMeter で管理。
 *
 * characterId 命名規則: "o-{level}_c-{level}_e-{level}_a-{level}"
 * 例: "o-high_c-high_e-high_a-high" → ライオン王
 *
 * ユーザー向けルール:
 * - Big5/OCEAN/ビッグファイブ という表記はユーザーに見せない
 * - 動物名・特性キーワードで表現する
 *
 * 実装メモ:
 * - AnimalIcons.astro に全16動物SVGを集約
 * - animals.ts に16動物の定義データ
 * - 未知の characterId は絵文字フォールバックで表示
 */
import AnimalIcons from './AnimalIcons.astro';
import { getAnimalById } from '../data/animals';

interface Props {
  /** キャラクターID（Big5 4軸パターン）*/
  characterId: string;
  /** キャラクター表示名 */
  characterName?: string;
  /** 絵文字フォールバック（SVG未定義時の保険） */
  emojiDummy?: string;
  /** 表示サイズ */
  size?: 'sm' | 'md' | 'lg' | 'xl';
  /** ライト版（無料・ぼかし）か完全版（有料）か */
  variant?: 'lite' | 'full';
  /** アニメーション効果 */
  animated?: boolean;
  /** 名前ラベルを非表示にする */
  hideName?: boolean;
}

const {
  characterId,
  characterName,
  emojiDummy = '🦊',
  size = 'md',
  variant = 'lite',
  animated = false,
  hideName = false,
} = Astro.props;

const sizeMap = {
  sm: '64px',
  md: '100px',
  lg: '140px',
  xl: '180px',
};

const svgSizeMap = {
  sm: 64,
  md: 100,
  lg: 140,
  xl: 180,
};

const sizePx = sizeMap[size];
const svgSize = svgSizeMap[size];

// 動物データを取得
const animalData = getAnimalById(characterId);
const displayName = characterName ?? animalData?.name ?? '???';
const animalType = animalData?.animal;
const animalColor = animalData?.color ?? '#7c5cff';
const animalGradient = animalData?.gradient ?? 'linear-gradient(135deg, var(--brand-100) 0%, var(--brand-200) 100%)';
---

<div
  class={`character-display character-display--${size} ${animated ? 'character-display--animated' : ''} ${variant === 'lite' ? 'character-display--lite' : ''}`}
  data-character-id={characterId}
  style={`--char-size: ${sizePx}; --animal-color: ${animalColor};`}
>
  <div
    class="character-frame"
    style={`background: ${animalGradient};`}
    role="img"
    aria-label={`${displayName}のキャラクターアイコン`}
  >
    {animalType ? (
      <AnimalIcons
        animal={animalType as any}
        size={svgSize}
        color={animalColor}
        class="character-svg"
      />
    ) : (
      <span class="character-emoji" aria-hidden="true">{emojiDummy}</span>
    )}
  </div>

  {variant === 'lite' && (
    <div class="lite-overlay" aria-hidden="true">
      <span class="lite-lock">🔒</span>
    </div>
  )}

  {!hideName && (
    <p class="character-name">{displayName}</p>
  )}
</div>

<style>
  .character-display {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sn-space-2);
    width: var(--char-size);
  }

  .character-frame {
    width: var(--char-size);
    height: var(--char-size);
    border-radius: var(--sn-radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--sn-shadow);
    overflow: hidden;
    position: relative;
    border: 2px solid rgba(255, 255, 255, 0.8);
    transition: box-shadow var(--sn-dur-fast) var(--sn-ease);
  }

  .character-frame:hover {
    box-shadow: var(--sn-shadow-md);
  }

  .character-svg {
    display: block;
    /* SVGがフレームを若干はみ出せるよう overflow: visible を維持 */
    overflow: visible;
  }

  .character-emoji {
    font-size: calc(var(--char-size) * 0.5);
    line-height: 1;
  }

  /* ライト版（無料）はぼかし + 鍵アイコン */
  .character-display--lite .character-frame {
    filter: blur(2px);
  }

  .lite-overlay {
    position: absolute;
    inset: 0;
    width: var(--char-size);
    height: var(--char-size);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.4);
    border-radius: var(--sn-radius-lg);
    pointer-events: none;
  }

  .lite-lock {
    font-size: calc(var(--char-size) * 0.3);
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.2));
  }

  .character-name {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-sm);
    font-weight: 700;
    color: var(--sn-text);
    text-align: center;
    margin: 0;
  }

  /* アニメーション */
  .character-display--animated .character-frame {
    animation: characterBounce 2s var(--sn-ease-bounce) infinite;
  }

  @keyframes characterBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* サイズ別の名前フォントサイズ調整 */
  .character-display--sm .character-name {
    font-size: var(--sn-text-xs);
  }

  .character-display--lg .character-name,
  .character-display--xl .character-name {
    font-size: var(--sn-text-base);
  }
</style>
