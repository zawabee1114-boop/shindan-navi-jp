---
/**
 * ProgressBar.astro - 診断進捗バー
 * 診断フロー画面の上部に配置する進捗インジケーター。
 */
interface Props {
  /** 現在の質問番号（1始まり）*/
  current: number;
  /** 総質問数 */
  total: number;
  /** バー色（デフォルト: primaryグラデーション）*/
  color?: string;
  /** ラベルを表示するか */
  showLabel?: boolean;
}

const {
  current,
  total,
  color,
  showLabel = true,
} = Astro.props;

const percentage = Math.min(Math.round((current / total) * 100), 100);
const progressStyle = color
  ? `width: ${percentage}%; background: ${color};`
  : `width: ${percentage}%;`;
---

<div class="progress-wrapper" role="progressbar" aria-valuenow={current} aria-valuemin={1} aria-valuemax={total} aria-label={`質問 ${current} / ${total}`}>
  {showLabel && (
    <div class="progress-label">
      <span class="progress-current">Q{current}</span>
      <span class="progress-fraction">{current} / {total}</span>
    </div>
  )}
  <div class="progress">
    <div class="progress-fill" style={progressStyle}></div>
  </div>
</div>

<style>
  .progress-wrapper {
    width: 100%;
  }

  .progress-label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--sn-space-2);
  }

  .progress-current {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-sm);
    font-weight: 700;
    color: var(--sn-primary);
  }

  .progress-fraction {
    font-size: var(--sn-text-xs);
    color: var(--sn-muted);
  }

  .progress {
    width: 100%;
    height: 8px;
    background: var(--sn-bg-soft);
    border-radius: var(--sn-radius-pill);
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--sn-primary) 0%, var(--sn-secondary) 100%);
    border-radius: var(--sn-radius-pill);
    transition: width var(--sn-dur-base) var(--sn-ease-out);
  }
</style>
