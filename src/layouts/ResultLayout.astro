---
/**
 * ResultLayout.astro - 診断結果ページ共通レイアウト v3
 *
 * フェーズ2 新デザイン対応:
 * - ヒーロー: 診断カラーグラデーション + スパークル装飾
 * - ピル型バッジ（diag-badge クラス）
 * - グラスモーフィズムキャラクターカード
 * - sn-card / sn-cta クラス統一
 * - 5シーン軸 --s-* トークン対応
 *
 * v3 追加（2026-05-23）:
 * - RelatedDiagnoses コンポーネント統合
 * - 統合プロファイル CTA を RelatedDiagnoses 内に集約
 * - 既存 relatedDiagnoses prop は後方互換で残す（廃止予定）
 */

import BaseLayout from './BaseLayout.astro';
import ShareButtons from '../components/ShareButtons.astro';
import Container from '../components/Container.astro';
import PassCta from '../components/PassCta.astro';
import RelatedDiagnoses from '../components/RelatedDiagnoses.astro';

interface RelatedDiagnosis {
  title: string;
  href: string;
  icon: string;
  badge?: string;
}

interface Props {
  /** 診断ID（例: 'mbti'）*/
  diagnosisId: string;
  /**
   * 診断カラークラス（design-system-v2.css の .diag-* クラス）
   * 例: 'diag-mbti' / 'diag-blood' / 'diag-multi' / 'diag-star'
   *     'diag-perfect' / 'diag-disc' / 'diag-love' / 'diag-money'
   */
  diagnosisClass?: string;
  /** タイプ識別子（例: 'ENFP'・URLセーフ）*/
  typeId: string;
  /** タイプ表示名（例: '運動家'）*/
  typeName: string;
  /** 診断表示名（例: 'MBTI'）*/
  diagnosisName: string;
  /** キャラクター絵文字 */
  characterEmoji?: string;
  /** キャラクター名（動物）*/
  characterName?: string;
  /** キャッチコピー */
  tagline: string;
  /** 課金済みか */
  isPaid?: boolean;
  /** シェア用URL */
  shareUrl: string;
  /** ページタイトル */
  pageTitle?: string;
  /** メタディスクリプション */
  pageDescription?: string;
  /**
   * 関連診断リンク（後方互換・廃止予定）
   * v3 以降は RelatedDiagnoses コンポーネントが自動生成するため省略可
   */
  relatedDiagnoses?: RelatedDiagnosis[];
  /** 診断一覧への戻りリンク */
  diagnosisListHref?: string;
  /** 構造化データ */
  jsonLd?: object | object[];
  /** OGP画像URL（絶対URL または /から始まるパス） */
  ogImage?: string;
}

const {
  diagnosisId,
  diagnosisClass = '',
  typeId,
  typeName,
  diagnosisName,
  characterEmoji = '🔮',
  characterName,
  tagline,
  isPaid = false,
  shareUrl,
  pageTitle,
  pageDescription,
  relatedDiagnoses = [],
  diagnosisListHref = '/diagnosis/',
  jsonLd,
  ogImage,
} = Astro.props;

const autoTitle = pageTitle ?? `${typeName}（${typeId}）- ${diagnosisName}の診断結果 | 診断ナビ`;
const autoDesc = pageDescription
  ?? `${diagnosisName}の結果は「${typeName}」です。${tagline} 仕事・恋愛・友人・家族・学校の5軸で詳しく解説します。`;

const shareText = `私の${diagnosisName}は「${typeName}」でした！${tagline} あなたも診断してみて #診断ナビ`;

const tabs = [
  { id: 'overview', label: '概要', icon: '📋', freeAccess: true },
  { id: 'strengths', label: '強み', icon: '💪', freeAccess: true },
  { id: 'weaknesses', label: '注意点', icon: '⚡', freeAccess: true },
  { id: 'work', label: '仕事', icon: '💼', freeAccess: false },
  { id: 'love', label: '恋愛', icon: '💕', freeAccess: false },
  { id: 'friend', label: '友人', icon: '👥', freeAccess: false },
  { id: 'family', label: '家族', icon: '🏠', freeAccess: false },
  { id: 'school', label: '学校', icon: '📚', freeAccess: false },
  { id: 'celebrity', label: '有名人', icon: '⭐', freeAccess: true },
  { id: 'growth', label: '成長', icon: '🌱', freeAccess: false },
];
---

<BaseLayout
  title={autoTitle}
  description={autoDesc}
  canonical={shareUrl}
  jsonLd={jsonLd}
  ogType="article"
  ogImage={ogImage}
  breadcrumbs={[
    { name: '診断一覧', url: diagnosisListHref },
    { name: `${diagnosisName} 結果`, url: shareUrl },
  ]}
>
  <div class="rl-page">

    {/* ---- ヒーロー v2 ---- */}
    <section class={`rl-hero${diagnosisClass ? ' ' + diagnosisClass : ''}`} aria-labelledby="result-type-name">
      <span class="rl-sparkle rl-sparkle-1" aria-hidden="true">✦</span>
      <span class="rl-sparkle rl-sparkle-2" aria-hidden="true">✦</span>
      <span class="rl-sparkle rl-sparkle-3" aria-hidden="true">✧</span>
      <span class="rl-sparkle rl-sparkle-4" aria-hidden="true">✦</span>

      <Container>
        <div class="rl-diag-badge-wrap">
          <span class="diag-badge" aria-label={`${diagnosisName} 診断結果`}>
            <span aria-hidden="true">📊</span>
            {diagnosisName} 診断結果
          </span>
        </div>

        <div class="rl-hero-inner">
          <div class="rl-character" aria-label={characterName ?? typeName} role="img">
            <span class="rl-character-emoji" aria-hidden="true">{characterEmoji}</span>
          </div>

          <div class="rl-hero-info">
            <h1 id="result-type-name" class="rl-type-name">
              {typeName}
              {typeId !== typeName && (
                <span class="rl-type-id num">（{typeId}）</span>
              )}
            </h1>
            {characterName && (
              <p class="rl-character-name">{characterName}タイプ</p>
            )}
            <p class="rl-tagline">{tagline}</p>
            <div class="rl-hero-share-inline">
              <ShareButtons
                url={shareUrl}
                text={shareText}
                hashtags={['診断ナビ', diagnosisId]}
                size="sm"
                showLabel={false}
              />
            </div>
          </div>
        </div>
      </Container>
    </section>

    {/* ---- タブナビゲーション ---- */}
    <div class="rl-tab-nav-wrapper" role="navigation" aria-label="結果セクション">
      <div class="rl-tab-nav" role="tablist" id="result-tabs">
        {tabs.map((tab) => (
          <button
            type="button"
            role="tab"
            class="rl-tab-btn"
            data-tab={tab.id}
            data-free={tab.freeAccess}
            aria-selected="false"
            aria-controls={`panel-${tab.id}`}
            id={`tab-${tab.id}`}
          >
            <span aria-hidden="true">{tab.icon}</span>
            <span class="rl-tab-label">{tab.label}</span>
            {!tab.freeAccess && !isPaid && (
              <span class="rl-tab-lock" aria-label="PASSが必要">🔒</span>
            )}
          </button>
        ))}
      </div>
    </div>

    {/* ---- タブパネル ---- */}
    <div class="rl-panels">
      <Container class="container--content">

        <div role="tabpanel" id="panel-overview" aria-labelledby="tab-overview" class="rl-panel" data-panel="overview">
          <slot name="overview">
            <p class="rl-slot-placeholder">（概要コンテンツは content-writer が執筆予定）</p>
          </slot>
        </div>

        <div role="tabpanel" id="panel-strengths" aria-labelledby="tab-strengths" class="rl-panel rl-panel--hidden" data-panel="strengths">
          <slot name="strengths">
            <p class="rl-slot-placeholder">（強みコンテンツは content-writer が執筆予定）</p>
          </slot>
        </div>

        <div role="tabpanel" id="panel-weaknesses" aria-labelledby="tab-weaknesses" class="rl-panel rl-panel--hidden" data-panel="weaknesses">
          <slot name="weaknesses">
            <p class="rl-slot-placeholder">（注意点コンテンツは content-writer が執筆予定）</p>
          </slot>
        </div>

        <div role="tabpanel" id="panel-work" aria-labelledby="tab-work" class="rl-panel rl-panel--hidden" data-panel="work" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="work">
              <p class="rl-slot-placeholder">（仕事軸コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="仕事" />
            </div>
          )}
        </div>

        <div role="tabpanel" id="panel-love" aria-labelledby="tab-love" class="rl-panel rl-panel--hidden" data-panel="love" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="love">
              <p class="rl-slot-placeholder">（恋愛軸コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="恋愛" />
            </div>
          )}
        </div>

        <div role="tabpanel" id="panel-friend" aria-labelledby="tab-friend" class="rl-panel rl-panel--hidden" data-panel="friend" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="friend">
              <p class="rl-slot-placeholder">（友人軸コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="友人" />
            </div>
          )}
        </div>

        <div role="tabpanel" id="panel-family" aria-labelledby="tab-family" class="rl-panel rl-panel--hidden" data-panel="family" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="family">
              <p class="rl-slot-placeholder">（家族軸コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="家族" />
            </div>
          )}
        </div>

        <div role="tabpanel" id="panel-school" aria-labelledby="tab-school" class="rl-panel rl-panel--hidden" data-panel="school" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="school">
              <p class="rl-slot-placeholder">（学校軸コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="学校・学習" />
            </div>
          )}
        </div>

        <div role="tabpanel" id="panel-celebrity" aria-labelledby="tab-celebrity" class="rl-panel rl-panel--hidden" data-panel="celebrity">
          <slot name="celebrity">
            <p class="rl-slot-placeholder">（有名人コンテンツは content-writer が執筆予定）</p>
          </slot>
        </div>

        <div role="tabpanel" id="panel-growth" aria-labelledby="tab-growth" class="rl-panel rl-panel--hidden" data-panel="growth" data-paid-required={!isPaid}>
          {isPaid ? (
            <slot name="growth">
              <p class="rl-slot-placeholder">（成長コンテンツは content-writer が執筆予定）</p>
            </slot>
          ) : (
            <div class="rl-paywall">
              <PassCta typeName={typeName} diagnosisName={diagnosisName} scene="成長・自己実現" />
            </div>
          )}
        </div>

      </Container>
    </div>

    {/* ---- PASS CTA ---- */}
    {!isPaid && (
      <section class="rl-cta-section" aria-labelledby="pass-cta-heading">
        <Container class="container--narrow">
          <div class="rl-cta-card sn-card">
            <p class="rl-cta-icon" aria-hidden="true">🔓</p>
            <h2 id="pass-cta-heading" class="rl-cta-title">
              {typeName}の全詳細を読む
            </h2>
            <p class="rl-cta-desc">
              仕事・恋愛・友人・家族・学校の5軸で{typeName}を徹底解説。
              AIプロンプトカード・有名人リスト・成長ロードマップ付き。
            </p>
            <ul class="rl-cta-features" aria-label="PASSの特典">
              <li>5軸詳細レポート（各2,000字以上）</li>
              <li>相性計算機の詳細ロック解除</li>
              <li>AIプロンプトカード（ChatGPT/Claude用）</li>
              <li>8診断統合プロファイル</li>
              <li>有効期間: 1年間（更新可）</li>
            </ul>
            <a href="/pro/" class="sn-cta rl-cta-btn">
              <span class="rl-pass-badge sn-pill">¥390</span>
              詳細版を見る（PASS）
            </a>
            <p class="rl-cta-note">月額ではなく1回払い・全診断の詳細に使えます</p>
          </div>
        </Container>
      </section>
    )}

    {/* ---- 関連診断（動的自動最適化 v3） ---- */}
    <RelatedDiagnoses
      diagnosisId={diagnosisId}
      typeId={typeId}
      diagnosisName={diagnosisName}
      typeName={typeName}
      pageUrl={shareUrl}
      inviteHref={`/invite/?from=${diagnosisId}&type=${typeId}`}
    />

    {/* ---- 再シェア ---- */}
    <section class="rl-bottom-share">
      <Container class="container--narrow">
        <p class="rl-bottom-share-title">結果をシェアして友達と比べよう</p>
        <ShareButtons
          url={shareUrl}
          text={shareText}
          hashtags={['診断ナビ', diagnosisId]}
          size="lg"
          showLabel={false}
        />
        <a href={diagnosisListHref} class="rl-back-link">
          <span aria-hidden="true">←</span>
          診断一覧に戻る
        </a>
      </Container>
    </section>
  </div>
</BaseLayout>

<style>
  /* ================================================================
     ResultLayout v3
     ================================================================ */

  .rl-page {
    display: flex;
    flex-direction: column;
    gap: var(--sn-space-12);
    padding-bottom: var(--sn-space-16);
  }

  /* ---- ヒーロー ---- */
  .rl-hero {
    position: relative;
    overflow: hidden;
    padding-block: 48px 56px;
    background: linear-gradient(135deg, #f3efff 0%, #e8e0ff 60%, #ede5ff 100%);
  }

  /* 8診断別ヒーロー背景 */
  .rl-hero.diag-mbti    { background: linear-gradient(135deg, #f3efff 0%, #e8e0ff 60%, #ede5ff 100%); }
  .rl-hero.diag-blood   { background: linear-gradient(135deg, #fff0f1 0%, #ffe4e6 60%, #ffeaec 100%); }
  .rl-hero.diag-multi   { background: linear-gradient(135deg, #fff6ee 0%, #ffe9d5 60%, #fff2e5 100%); }
  .rl-hero.diag-star    { background: linear-gradient(135deg, #eef6ff 0%, #ddeeff 60%, #e8f3ff 100%); }
  .rl-hero.diag-perfect { background: linear-gradient(135deg, #fffbea 0%, #fef3c7 60%, #fffde8 100%); }
  .rl-hero.diag-disc    { background: linear-gradient(135deg, #edfaf7 0%, #d0f5ec 60%, #e4f9f5 100%); }
  .rl-hero.diag-love    { background: linear-gradient(135deg, #fff0f7 0%, #ffe4f2 60%, #ffedf7 100%); }
  .rl-hero.diag-money   { background: linear-gradient(135deg, #fdf8f0 0%, #f5e8d0 60%, #faf3e5 100%); }

  .rl-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 80% 20%, rgba(255,255,255,.4), transparent 60%),
      radial-gradient(40% 30% at 10% 80%, rgba(255,255,255,.3), transparent 50%);
    pointer-events: none;
  }

  @media (min-width: 768px) {
    .rl-hero { padding-block: 64px 72px; }
  }

  /* ---- スパークル ---- */
  .rl-sparkle {
    position: absolute;
    pointer-events: none;
    color: var(--diag-color, var(--brand-500));
    opacity: 0;
    animation: rl-sparkle 3.5s ease-in-out infinite;
    font-style: normal;
    user-select: none;
    font-size: 1rem;
  }

  .rl-sparkle-1 { top: 12%;  left: 8%;   font-size: 1.1rem; animation-delay: 0s;    animation-duration: 4s; }
  .rl-sparkle-2 { top: 18%;  right: 14%; font-size: 0.75rem; animation-delay: 1.2s; animation-duration: 3.5s; }
  .rl-sparkle-3 { bottom: 22%; left: 18%; font-size: 0.65rem; animation-delay: 2.1s; animation-duration: 4.2s; }
  .rl-sparkle-4 { bottom: 14%; right: 8%; font-size: 1rem;   animation-delay: 0.8s; animation-duration: 3.8s; }

  @keyframes rl-sparkle {
    0%, 100% { opacity: 0;    transform: scale(1) rotate(0deg); }
    40%       { opacity: 0.55; transform: scale(1.2) rotate(18deg); }
    60%       { opacity: 0.7;  transform: scale(1.1) rotate(12deg); }
  }

  /* ---- 診断バッジ ---- */
  .rl-diag-badge-wrap {
    margin-bottom: 20px;
    position: relative;
    z-index: 1;
  }

  /* ---- ヒーロー内部 ---- */
  .rl-hero-inner {
    position: relative;
    z-index: 1;
    display: flex;
    gap: var(--sn-space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  /* ---- キャラクター（グラスモーフィズム）---- */
  .rl-character {
    width: 110px;
    height: 110px;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius-xl);
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  @media (min-width: 480px) {
    .rl-character { width: 120px; height: 120px; }
  }

  .rl-character-emoji {
    font-size: 3.5rem;
    line-height: 1;
  }

  @media (min-width: 480px) {
    .rl-character-emoji { font-size: 4rem; }
  }

  /* ---- タイプ情報 ---- */
  .rl-hero-info {
    flex: 1;
    min-width: 220px;
    position: relative;
    z-index: 1;
  }

  .rl-type-name {
    font-family: var(--sn-font-rounded);
    font-size: clamp(1.625rem, 5vw, 2.25rem);
    font-weight: 900;
    color: var(--ink-900);
    line-height: 1.25;
    margin: 0 0 var(--sn-space-2);
    letter-spacing: -0.01em;
  }

  .rl-type-id {
    font-size: clamp(1.125rem, 3vw, 1.375rem);
    font-weight: 700;
    color: var(--ink-500);
  }

  .rl-character-name {
    font-size: var(--sn-text-lg);
    font-weight: 700;
    color: var(--ink-700);
    margin: 0 0 var(--sn-space-2);
  }

  .rl-tagline {
    font-size: var(--sn-text-base);
    color: var(--ink-700);
    line-height: var(--sn-leading-base);
    margin: 0 0 var(--sn-space-4);
    max-width: 500px;
  }

  .rl-hero-share-inline {
    display: flex;
    gap: var(--sn-space-2);
    flex-wrap: wrap;
  }

  /* ---- タブナビ ---- */
  .rl-tab-nav-wrapper {
    position: sticky;
    /* モバイル: MobileHeader（sticky）と被らないよう top:0（積み上がり方式） */
    top: 0;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
    z-index: 20;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  /* PC: SiteHeader（sticky 60px）の下に配置 */
  @media (min-width: 768px) {
    .rl-tab-nav-wrapper {
      top: var(--sn-header-h);
    }
  }
  .rl-tab-nav-wrapper::-webkit-scrollbar { display: none; }

  .rl-tab-nav {
    display: flex;
    min-width: max-content;
    padding-inline: var(--sn-space-4);
  }

  .rl-tab-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sn-space-1);
    padding: var(--sn-space-3) var(--sn-space-4);
    font-size: var(--sn-text-sm);
    font-weight: 700;
    color: var(--ink-500);
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition:
      color var(--sn-dur-fast) var(--sn-ease),
      border-color var(--sn-dur-fast) var(--sn-ease);
    min-height: var(--sn-tap-min);
    font-family: var(--sn-font-rounded);
  }

  .rl-tab-btn:hover { color: var(--brand-600); }

  .rl-tab-btn[aria-selected="true"] {
    color: var(--brand-600);
    border-bottom-color: var(--brand-500);
  }

  .rl-tab-btn:focus-visible {
    outline: 2px solid var(--brand-400);
    outline-offset: -2px;
    border-radius: var(--radius-sm);
  }

  .rl-tab-label { line-height: 1; }
  .rl-tab-lock { font-size: var(--sn-text-xs); opacity: 0.6; }

  /* ---- パネル ---- */
  .rl-panels { min-height: 300px; }

  .rl-panel {
    animation: rl-fadeIn 200ms var(--sn-ease-out) both;
  }

  .rl-panel--hidden { display: none; }

  @keyframes rl-fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rl-slot-placeholder {
    color: var(--ink-400);
    font-size: var(--sn-text-sm);
    text-align: center;
    padding-block: var(--sn-space-8);
  }

  .rl-paywall { padding-block: var(--sn-space-6); }

  /* ---- PASS CTA ---- */
  .rl-cta-section {
    background: var(--brand-50);
    padding-block: var(--sn-space-12);
  }

  .rl-cta-card {
    padding: var(--sn-space-8);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sn-space-4);
  }

  .rl-cta-icon { font-size: 3rem; margin: 0; }

  .rl-cta-title {
    font-family: var(--sn-font-rounded);
    font-size: var(--sn-text-2xl);
    font-weight: 900;
    color: var(--ink-900);
    margin: 0;
  }

  .rl-cta-desc {
