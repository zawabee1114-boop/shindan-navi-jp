---
/**
 * BaseLayout.astro - 診断ナビ 共通レイアウト
 * SEO/AIO/LLMO 基盤設定完了（2026-05-21 更新）
 * フェーズ5: Speakable Schema 全頁拡張（2026-05-23 更新）
 *   - cssSelector を7セレクタに拡張（音声検索 + AI Overview 対応強化）
 * フェーズ4: モバイルUI実装（2026-05-22 更新）
 *   - MobileHeader（グラスモーフィズム・モバイルのみ表示）追加
 *   - MobileTabBar（ボトムタブ・モバイルのみ表示）追加
 *   - PC/モバイル出し分けロジック実装
 *   - body の padding-bottom は MobileTabBar CSS で制御
 * フェーズ6: WebSite SearchAction 実装（2026-05-23 更新）
 *   - /search/?q= ページ追加・SiteLinksSearchBox リッチリザルト対応
 * 準拠基準書: zawa-empire/docs/seo-aio/01-foundations.md / 02-structured-data.md
 *
 * テーマ変更ガイド:
 * - カラー: src/styles/design-tokens.css の --sn-* 変数を変更
 * - フォント: 下記 Google Fonts URL と --sn-font-* を同時変更
 * - OGP画像: public/ogp-default.png を差し替え
 *
 * 環境変数（Cloudflare Pages で設定）:
 * - PUBLIC_GA4_ID: GA4 測定ID（例: G-XXXXXXXXXX）
 * - PUBLIC_ADSENSE_PUB: AdSense パブリッシャーID（デフォルト: ca-pub-3827953973757487）
 * - PUBLIC_GSC_VERIFICATION: Search Console 確認メタタグ
 */
import '../styles/global.css';
import siteMeta from '../data/site-meta.json';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import MobileHeader from '../components/MobileHeader.astro';
import MobileTabBar from '../components/MobileTabBar.astro';

interface Props {
  /** ページタイトル（<title> に使用・主要KWを先頭に・28〜42字推奨）*/
  title: string;
  /** メタディスクリプション（KW自然含有・80〜120字・CTA含む）*/
  description?: string;
  /** canonical URL */
  canonical?: string;
  /** JSON-LD 構造化データ（ページ別・単体 or 配列）*/
  jsonLd?: object | object[];
  /** <main> の追加クラス */
  mainClass?: string;
  /** og:type（デフォルト: website）*/
  ogType?: string;
  /** OGP画像URL（絶対URL または /から始まるパス）*/
  ogImage?: string;
  /** 公開日 YYYY-MM-DD */
  publishDate?: string;
  /** 最終更新日 YYYY-MM-DD */
  lastUpdated?: string;
  /** noindex: trueでメタに noindex 付与（share/me等の動的ページ用）*/
  noindex?: boolean;
  /** ヘッダーを非表示にするか（診断フロー画面等）*/
  hideHeader?: boolean;
  /** フッターを非表示にするか */
  hideFooter?: boolean;
  /** ボトムナビを非表示にするか */
  hideBottomNav?: boolean;
  /**
   * モバイルヘッダーの設定
   * - showBack: 戻るボタン表示（診断フロー・結果ページ等）
   * - backHref: 戻り先URL
   * - rightIcon: 右アイコン種別
   * - pageTitle: ロゴ代わりに表示するページタイトル
   */
  mobileHeader?: {
    showBack?: boolean;
    backHref?: string;
    backLabel?: string;
    rightIcon?: 'bell' | 'upload' | 'menu' | 'none';
    pageTitle?: string;
  };
  /**
   * パンくずリストデータ（BreadcrumbList JSON-LD 生成用）
   * ホームは自動付与されるため不要。2階層目以降を記述する。
   * 例: [{ name: 'MBTI診断', url: '/diagnosis/mbti/' }]
   */
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title,
  description = siteMeta.description,
  canonical,
  jsonLd,
  mainClass = '',
  ogType = 'website',
  ogImage,
  publishDate,
  lastUpdated,
  noindex = false,
  hideHeader = false,
  hideFooter = false,
  hideBottomNav = false,
  mobileHeader = {},
  breadcrumbs,
} = Astro.props;

const SITE_URL = siteMeta.siteUrl;

const pageUrl = canonical ?? new URL(Astro.url.pathname, SITE_URL).href;
const ogImageUrl = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${SITE_URL}${ogImage}`)
  : `${SITE_URL}${siteMeta.ogImage}`;

// title が既に '| 診断ナビ' で終わる場合は重複付加しない（SEO Critical 修正 2026-05-23）
const SITE_NAME = siteMeta.siteName;
const fullTitle = (
  title === SITE_NAME ||
  title.endsWith(' | ' + SITE_NAME) ||
  title.endsWith('| ' + SITE_NAME) ||  // 句読点直後の半角 | パターン
  title.endsWith('｜' + SITE_NAME)  // 全角パイプ｜パターン
)
  ? title
  : title + ' | ' + SITE_NAME;

// ページ別 JSON-LD を配列に正規化
const jsonLdArrayRaw = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];

// Article スキーマに speakable を自動注入（全ページ対応・既存定義がある場合は維持）
const ARTICLE_SPEAKABLE = {
  '@type': 'SpeakableSpecification',
  cssSelector: ['.tldr', '.faq-question', '.science-note-summary'],
} as const;

const jsonLdArray = jsonLdArrayRaw.map((schema: Record<string, unknown>) => {
  if (schema['@type'] === 'Article' && !schema['speakable']) {
    return { ...schema, speakable: ARTICLE_SPEAKABLE };
  }
  return schema;
});

// ============================================================
// 共通 JSON-LD スキーマ（全ページ必須・@id連結設計）
// 準拠: zawa-empire/docs/seo-aio/02-structured-data.md
// ============================================================

// Organization JSON-LD（E-E-A-T強化・@id連結の基盤）
// @id: https://shindan-navi.jp/#organization
// 全ページの WebApplication.author / Article.publisher がここを参照する
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: '診断ナビ編集部',
  alternateName: '診断ナビ',
  url: SITE_URL,
  logo: {
    '@type': 'ImageObject',
    '@id': `${SITE_URL}/#logo`,
    url: `${SITE_URL}/favicon.svg`,
    width: 32,
    height: 32,
    caption: '診断ナビ',
  },
  foundingDate: '2026',
  description: '8つの診断を統合し、仕事・恋愛・友人・家族・学校の5シーンで具体的な行動指針を提供する自己理解プラットフォームを運営する編集部。性格心理学の標準モデルに基づく科学的な性格分類のみを扱い、占いやスピリチュアルは一切扱わない。',
  knowsAbout: [
    { '@type': 'Thing', name: 'MBTI（Myers-Briggs Type Indicator）', sameAs: 'https://www.myersbriggs.org/' },
    { '@type': 'Thing', name: '多重知能理論（Multiple Intelligences）', sameAs: 'https://www.pz.harvard.edu/' },
    { '@type': 'Thing', name: 'DiSC診断（DISC行動スタイル）' },
    { '@type': 'Thing', name: '恋愛スタイル理論（J.A.Lee Love Styles）' },
    { '@type': 'Thing', name: '完璧主義心理学（Multidimensional Perfectionism Scale）' },
    { '@type': 'Thing', name: '5因子性格モデル（Five-Factor Model）', sameAs: 'https://www.apa.org/' },
    { '@type': 'Thing', name: '行動経済学（Behavioral Economics）' },
    { '@type': 'Thing', name: '自己理解・自己分析' },
    { '@type': 'Thing', name: '性格心理学' },
    { '@type': 'Thing', name: '血液型性格診断（日本独自モデル）' },
  ],
  areaServed: { '@type': 'Country', name: '日本' },
  sameAs: [],
};

// WebSite JSON-LD（SiteLinksSearchBox + SearchAction + @id連結）
// urlTemplate は /search/?q= （末尾スラッシュ付き・Astro trailingSlash: always に準拠）
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: siteMeta.siteName,
  alternateName: 'Shindan Navi',
  url: SITE_URL,
  description: siteMeta.description,
  inLanguage: 'ja-JP',
  potentialAction: {
    '@type': 'SearchAction',
    // Fix GSC: target は EntryPoint ネストではなく文字列URLテンプレートが Google 推奨
    // EntryPoint ネストは「解析不能な構造化データ」エラーの原因になる（2026-05-23修正）
    target: `${SITE_URL}/search/?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// BreadcrumbList JSON-LD（breadcrumbs prop があるページのみ生成）
// @id を付与してエンティティグラフに統合
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'ホーム',
          item: SITE_URL,
        },
        ...breadcrumbs.map((crumb, index) => ({
          '@type': 'ListItem',
          position: index + 2,
          name: crumb.name,
          item: crumb.url.startsWith('http') ? crumb.url : `${SITE_URL}${crumb.url}`,
        })),
      ],
    }
  : null;

// Speakable JSON-LD（音声検索対応）
const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: fullTitle,
  description: description,
  inLanguage: 'ja-JP',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${SITE_URL}/#website`,
  },
  // Fix GSC: WebPage.about から Organization 参照を削除
  // WebPage.about は CreativeWork が期待値。Organization は unexpected で解析不能の原因（2026-05-23修正）
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: [
      // 全ページ共通：ページ見出しと TL;DR 要約
      'h1',
      '.tldr',
      // ヒーロー説明文（page-hero-sub: 全コンテンツページ / hero-v2-desc: TOPページ）
      '.page-hero-sub',
      '.hero-v2-desc',
      '.hero-description',
      // 診断結果ページ
      '.result-summary',
      // 定義段落（definition クラス付与ページ）
      '.definition',
      // FAQ 質問テキスト
      '.faq-question',
      // ScienceNote 理論的根拠サマリー
      '.science-note-summary',
    ],
  },
};

// ============================================================
// 計測タグ（直書き・keisan-navi.jp / template-free.jp と同方式）
// ============================================================
const GA4_ID = 'G-S4WP0YRDWW';
const ADSENSE_PUB = 'ca-pub-3827953973757487';
const GSC_VERIFICATION = '';
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Resource Hints: Google Fonts, AdSense, Analytics -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />

  <!--
    Google Fonts: Inter + Noto Sans JP（MID-10 サブセット化 2026-05-29）（非ブロッキング読み込み）
    ウェイト選定根拠: Noto Sans JP 400=本文/500=中見出し/700=太字強調/900=超強調（CharacterCard・DiagnosisStart 等多数）
    Inter 400;500;600;700;800=英数字・UI要素（600,800も複数箇所で使用）
    削除: Noto 600→700でブラウザフォールバック可能, Noto 800→900で不足を補完
    テーマ変更時は下記 URL と design-tokens.css の --sn-font-* を同時変更すること
  -->
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700;900&display=swap"
    />
  </noscript>

  <!-- SEO Meta（準拠: zawa-empire/docs/seo-aio/01-foundations.md §1.3）-->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
  }
  <link rel="canonical" href={pageUrl} />

  <!-- hreflang（日本語単一言語サイト）-->
  <link rel="alternate" hreflang="ja" href={pageUrl} />
  <link rel="alternate" hreflang="x-default" href={pageUrl} />

  <!-- Google Search Console 確認（CEO設定後に有効化）-->
  {GSC_VERIFICATION && (
    <meta name="google-site-verification" content={GSC_VERIFICATION} />
  )}

  <!-- OGP（1200x630 推奨）-->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:alt" content={`${siteMeta.siteName} - ${title}`} />
  <meta property="og:site_name" content={siteMeta.siteName} />
  <meta property="og:locale" content={siteMeta.locale} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={siteMeta.twitterHandle} />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Article 日付メタ -->
  {publishDate && <meta property="article:published_time" content={new Date(publishDate).toISOString()} />}
  {lastUpdated && <meta property="article:modified_time" content={new Date(lastUpdated).toISOString()} />}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Web App Manifest -->
  <link rel="manifest" href="/manifest.json" />

  <!-- Theme color -->
  <meta name="theme-color" content={siteMeta.themeColor} />

  <!-- ============================================================
       JSON-LD 構造化データ（全ページ共通）
       準拠: zawa-empire/docs/seo-aio/02-structured-data.md
       @id 連結:
         Organization/#organization  ← WebSite.publisher / WebPage.about
         WebSite/#website            ← WebPage.isPartOf
         WebPage/#webpage            ← BreadcrumbList / ページ別スキーマ
       ============================================================ -->

  <!-- Organization JSON-LD（E-E-A-T・@id連結の基盤）-->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  <!-- WebSite JSON-LD（SiteLinksSearchBox・SearchAction）-->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />

  <!-- WebPage + Speakable JSON-LD（全ページ・エンティティグラフ統合）-->
  <script type="application/ld+json" set:html={JSON.stringify(speakableSchema)} />

  <!-- BreadcrumbList JSON-LD（breadcrumbs prop があるページのみ）-->
  {breadcrumbSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  )}

  <!-- ページ別 JSON-LD（content-writer / seo-optimizer が個別設定）-->
  {jsonLdArray.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <!-- ============================================================
       Google tag (gtag.js) - GA4
       PUBLIC_GA4_ID 設定後に自動有効化
       ============================================================ -->
  {GA4_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
      <script define:vars={{ GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', GA4_ID);
      </script>
    </>
  )}

  <!-- ============================================================
       Google AdSense
       PUBLIC_ADSENSE_PUB 設定後 or デフォルト ca-pub-3827953973757487 で即発動
       承認前は auto-ads が表示されないため SEO 影響なし
       ============================================================ -->
  {ADSENSE_PUB && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_PUB}`}
      crossorigin="anonymous"
    ></script>
  )}
  <!-- ページ個別の head 追加スロット（zodiac等のインラインJSON-LD用）-->
  <slot name="head" />
</head>
<body class:list={[{ 'has-mobile-tabbar': !hideBottomNav }]}>

  <!--
    PC ヘッダー: 768px 以上のみ表示（SiteHeader.astro 内の CSS で制御）
    モバイルヘッダー: 768px 未満のみ表示（MobileHeader.astro 内の CSS で制御）
    両コンポーネントとも display:none ↔ display:flex をメディアクエリで切り替え
  -->
  {!hideHeader && (
    <>
      {/* PC ヘッダー */}
      <div class="pc-header-wrapper">
        <SiteHeader />
      </div>
      {/* モバイルヘッダー */}
      <MobileHeader
        showBack={mobileHeader.showBack}
        backHref={mobileHeader.backHref}
        backLabel={mobileHeader.backLabel}
        rightIcon={mobileHeader.rightIcon ?? 'bell'}
        pageTitle={mobileHeader.pageTitle}
      />
    </>
  )}

  <main id="main-content" class={mainClass}>
    <slot />
  </main>

  {!hideFooter && <SiteFooter />}

  <!--
    モバイルタブバー: 768px 未満のみ表示
    hideBottomNav=true の場合は非表示（hideHeader=true のページ等）
  -->
  {!hideBottomNav && <MobileTabBar />}

  <!-- ヘッダースクロール浮き（PC ヘッダー用）-->
  <script is:inline>
    (function () {
      var header = document.querySelector('.site-header');
      if (header) {
        window.addEventListener('scroll', function () {
          header.classList.toggle('is-scrolled', window.scrollY > 4);
        }, { passive: true });
      }
    })();
  </script>
</body>
</html>

<style is:global>
  /*
   * PC/モバイル ヘッダー出し分け
   * SiteHeader は PC（>=768px）のみ / MobileHeader は モバイル（<768px）のみ
   */

  /* PC ヘッダーラッパー: モバイルでは非表示 */
  .pc-header-wrapper {
    display: block;
  }

  @media (max-width: 767px) {
    .pc-header-wrapper {
      display: none;
    }
  }

  /*
   * タブバー高さ分の body padding-bottom（モバイルのみ）
   * CLS 対策: タブバーの高さ（76px）+ iOS セーフエリア分を確保
   * has-mobile-tabbar クラスで制御（hideBottomNav=true 時は付与されない）
   */
  @media (max-width: 767px) {
    body.has-mobile-tabbar {
      /* 76px（タブバー） + セーフエリア */
      padding-bottom: calc(76px + env(safe-area-inset-bottom, 0px));
    }
  }

  /* PC では body の padding-bottom をリセット（タブバーは非表示のため） */
  @media (min-width: 768px) {
    body.has-mobile-tabbar {
      /* design-tokens.css の --sn-bottom-nav-h を継承（既存挙動維持）*/
      padding-bottom: var(--sn-bottom-nav-h, 0px);
    }
  }
</style>
