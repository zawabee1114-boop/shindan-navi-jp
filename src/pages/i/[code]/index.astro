---
/**
 * /i/[code]/ - 招待コード受け取りページ
 *
 * 招待コードを受け取った側（ユーザーB）の着地ページ。
 * プライバシーモードに応じて情報を表示し、診断ページへ誘導する。
 *
 * Phase 3.1: LocalStorage からコード情報を参照（クライアントサイド）
 * Phase 3.5: Supabase invitations テーブルから取得
 *
 * export const prerender = false; で SSR 動作
 */

export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';

const { code } = Astro.params;
const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/i/${code}/`;

// OGP 用メタ（from パラメータがあれば利用）
const fromType = Astro.url.searchParams.get('from') ?? '';
const ogTitle = fromType
  ? `${fromType}タイプのユーザーがあなたとの相性を診断したい｜診断ナビ`
  : `あなたとの相性を診断したい人がいます｜診断ナビ`;
const ogDescription = '診断ナビで相性チェック。登録不要・完全無料で今すぐ診断できます。';
---

<BaseLayout
  title={ogTitle}
  description={ogDescription}
  canonical={pageUrl}
  noindex={true}
>
  <Container>
    <div class="invite-page" id="invite-page" data-code={code} data-from={fromType}>

      {/* ローディング状態（JS実行前） */}
      <div class="invite-loading" id="invite-loading" aria-live="polite">
        <div class="invite-loading-icon" aria-hidden="true">🔗</div>
        <p class="invite-loading-text">招待情報を確認しています...</p>
      </div>

      {/* 招待コンテンツ（JS実行後に表示） */}
      <div class="invite-content" id="invite-content" hidden>
        <div class="invite-hero">
          <div class="invite-hero-icon" id="invite-mode-icon" aria-hidden="true">👥</div>
          <h1 class="invite-hero-title" id="invite-hero-title">
            相性診断への招待
          </h1>
          <p class="invite-hero-desc" id="invite-hero-desc">
            招待リンクから来てくださいました。診断を受けて相性を確認しましょう。
          </p>
        </div>

        <div class="invite-from-card" id="invite-from-card">
          <p class="invite-from-label">招待した人の情報</p>
          <p class="invite-from-type" id="invite-from-type">—</p>
        </div>

        <div class="invite-steps">
          <p class="invite-steps-label">診断の流れ</p>
          <ol class="invite-steps-list">
            <li class="invite-steps-item">
              <span class="invite-steps-num" aria-hidden="true">1</span>
              下のボタンから診断を受ける（無料・登録不要）
            </li>
            <li class="invite-steps-item">
              <span class="invite-steps-num" aria-hidden="true">2</span>
              あなたの診断が完了すると相性スコアが表示される
            </li>
            <li class="invite-steps-item">
              <span class="invite-steps-num" aria-hidden="true">3</span>
              詳細レポートは ¥390 PASS で解放
            </li>
          </ol>
        </div>

        <a
          href="/diagnosis/"
          class="invite-cta-btn"
          id="invite-cta-btn"
          aria-label="診断を受けて相性を確認する"
        >
          診断を受けて相性を確認する（無料）
          <span aria-hidden="true">→</span>
        </a>

        <p class="invite-code-display">
          招待コード: <code class="invite-code-value" id="invite-code-display">{code}</code>
        </p>
      </div>

      {/* 無効コード表示 */}
      <div class="invite-invalid" id="invite-invalid" hidden>
        <div class="invite-invalid-icon" aria-hidden="true">⚠️</div>
        <h1 class="invite-invalid-title">招待リンクが無効です</h1>
        <p class="invite-invalid-desc">
          このリンクは有効期限切れ、または無効な招待コードです。<br />
          招待した人に新しいリンクを発行してもらってください。
        </p>
        <a href="/diagnosis/" class="invite-fallback-btn">
          診断ページへ →
        </a>
      </div>
    </div>
  </Container>
</BaseLayout>

<script>
  // クライアントサイドで招待情報を処理
  document.addEventListener('DOMContentLoaded', () => {
    const page = document.getElementById('invite-page');
    const code = page?.dataset.code ?? '';
    const fromType = page?.dataset.from ?? '';

    const loading = document.getElementById('invite-loading');
    const content = document.getElementById('invite-content');
    const invalid = document.getElementById('invite-invalid');

    function showContent() {
      loading?.setAttribute('hidden', '');
      content?.removeAttribute('hidden');
    }

    function showInvalid() {
      loading?.setAttribute('hidden', '');
      invalid?.removeAttribute('hidden');
    }

    // LocalStorage から招待情報を取得
    const STORAGE_KEY = 'shindan_invitations';
    let invitation: {
      code: string;
      mode: string;
      resultId: string;
      diagPath: string;
      createdAt: string;
      expiresAt: string;
    } | null = null;

    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const stored = JSON.parse(raw);
        const inv = stored[code?.toUpperCase()];
        if (inv && new Date(inv.expiresAt) > new Date()) {
          invitation = inv;
        }
      }
    } catch {
      // LocalStorage アクセス失敗は無視
    }

    // コンテンツ表示
    if (code && code.length >= 4) {
      // コードが存在すれば招待として扱う（フォールバック）
      showContent();

      // モードアイコン設定
      const modeIconEl = document.getElementById('invite-mode-icon');
      const titleEl = document.getElementById('invite-hero-title');
      const descEl = document.getElementById('invite-hero-desc');
      const fromTypeEl = document.getElementById('invite-from-type');
      const fromCard = document.getElementById('invite-from-card');
      const ctaBtn = document.getElementById('invite-cta-btn');

      const mode = invitation?.mode ?? 'secret';

      const modeConfig = {
        secret: {
          icon: '❓',
          title: 'あなたとの相性を診断したい人がいます',
          desc: '診断を受けると、相性スコアが表示されます。誰かはわかりません。',
        },
        invite: {
          icon: '👋',
          title: 'あなたへの招待が届きました',
          desc: '診断を受けると、招待した人との相性スコアが表示されます。',
        },
        one_way: {
          icon: '→',
          title: 'あなたとの相性を確認しましょう',
          desc: '招待した人の診断結果との相性スコアが表示されます。',
        },
        full_share: {
          icon: '🤝',
          title: '相互相性チェックへの招待',
          desc: 'お互いの診断結果を基にした相性スコアが表示されます。',
        },
      };

      const config = modeConfig[mode as keyof typeof modeConfig] ?? modeConfig.secret;

      if (modeIconEl) modeIconEl.textContent = config.icon;
      if (titleEl) titleEl.textContent = config.title;
      if (descEl) descEl.textContent = config.desc;

      // fromType があれば表示
      if (fromType && fromCard && fromTypeEl) {
        fromTypeEl.textContent = mode === 'secret' ? '（非公開）' : `${fromType} タイプ`;
      } else if (fromCard) {
        fromCard.setAttribute('hidden', '');
      }

      // CTA ボタンの href を診断パスに設定
      const diagPath = invitation?.diagPath ?? '/diagnosis/';
      if (ctaBtn) {
        (ctaBtn as HTMLAnchorElement).href = `${diagPath}?pair=${invitation?.resultId ?? ''}&invite=${code}`;
      }
    } else {
      showInvalid();
    }
  });
</script>

<style>
.invite-page {
  max-width: 480px;
  margin-inline: auto;
  padding-block: 3rem;
}

/* ローディング */
.invite-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 3rem;
  text-align: center;
}
.invite-loading-icon {
  font-size: 3rem;
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
.invite-loading-text {
  color: var(--sn-muted, #6b7280);
  font-size: 0.95rem;
}

/* 招待コンテンツ */
.invite-content {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.invite-hero {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.75rem;
  padding: 2rem 1.5rem;
  background: linear-gradient(135deg, #eef2ff 0%, #faf5ff 100%);
  border-radius: 1rem;
  border: 1px solid #e0e7ff;
}
.invite-hero-icon {
  font-size: 3rem;
}
.invite-hero-title {
  font-size: 1.25rem;
  font-family: var(--sn-font-rounded, sans-serif);
  font-weight: 900;
  color: var(--sn-text, #1e1b4b);
  margin: 0;
  line-height: 1.4;
}
.invite-hero-desc {
  font-size: 0.9rem;
  color: var(--sn-muted, #4b5563);
  line-height: 1.7;
  margin: 0;
}

.invite-from-card {
  padding: 1rem 1.25rem;
  background: var(--sn-bg-soft, #f9fafb);
  border-radius: 0.75rem;
  border: 1px solid var(--sn-border, #e5e7eb);
}
.invite-from-label {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--sn-primary, #4f46e5);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 0.25rem;
}
.invite-from-type {
  font-size: 1rem;
  font-weight: 700;
  color: var(--sn-text, #1e1b4b);
  margin: 0;
}

.invite-steps {
  padding: 1rem 1.25rem;
  background: #fff;
  border-radius: 0.75rem;
  border: 1px solid var(--sn-border, #e5e7eb);
}
.invite-steps-label {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--sn-muted, #6b7280);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin: 0 0 0.75rem;
}
.invite-steps-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.invite-steps-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.875rem;
  color: var(--sn-text-soft, #374151);
}
.invite-steps-num {
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--sn-primary, #4f46e5);
  color: #fff;
  border-radius: 50%;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
}

.invite-cta-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem 2rem;
  background: var(--sn-primary, #4f46e5);
  color: #fff;
  border-radius: 999px;
  font-weight: 700;
  font-size: 1rem;
  text-decoration: none;
  min-height: 52px;
  transition: transform 0.15s, box-shadow 0.15s;
  box-shadow: 0 4px 12px rgba(79 70 229 / 0.3);
}
.invite-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(79 70 229 / 0.4);
  text-decoration: none;
  color: #fff;
}
.invite-cta-btn:focus-visible {
  outline: 3px solid var(--sn-primary, #4f46e5);
  outline-offset: 3px;
}

.invite-code-display {
  text-align: center;
  font-size: 0.78rem;
  color: var(--sn-muted, #9ca3af);
  margin: 0;
}
.invite-code-value {
  font-family: var(--sn-font-mono, monospace);
  background: var(--sn-bg-soft, #f3f4f6);
  padding: 2px 6px;
  border-radius: 4px;
}

/* 無効コード */
.invite-invalid {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
  padding: 3rem 1.5rem;
}
.invite-invalid-icon {
  font-size: 3rem;
}
.invite-invalid-title {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--sn-text, #1e1b4b);
  margin: 0;
}
.invite-invalid-desc {
  font-size: 0.9rem;
  color: var(--sn-muted, #6b7280);
  line-height: 1.7;
  margin: 0;
}
.invite-fallback-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.75rem 1.75rem;
  background: var(--sn-primary, #4f46e5);
  color: #fff;
  border-radius: 999px;
  font-weight: 700;
  text-decoration: none;
  min-height: 44px;
  transition: opacity 0.15s;
}
.invite-fallback-btn:hover {
  opacity: 0.85;
  text-decoration: none;
  color: #fff;
}
</style>
