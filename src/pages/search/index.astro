---

<BaseLayout
  title="診断を検索 - 診断ナビ"
  description="MBTI・血液型・多重知能・DiSC・完璧主義・恋愛スタイル・星座・金銭感覚。8診断すべてをキーワードで検索できます。"
  canonical="https://shindan-navi.jp/search/"
  breadcrumbs={[{ name: '検索', url: '/search/' }]}
  noindex={true}
>
  <div class="search-page">
    <!-- ヒーローセクション -->
    <section class="search-hero">
      <div class="search-hero-inner">
        <h1 class="search-title">
          <svg class="search-icon-hero" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
          </svg>
          診断を検索
        </h1>
        <p class="search-subtitle">診断名・キーワードで絞り込む</p>

        <!-- 検索フォーム -->
        <form class="search-form" role="search" action="/search/" method="get">
          <div class="search-input-wrap">
            <svg class="search-input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              id="search-input"
              type="search"
              name="q"
              class="search-input"
              placeholder="例: MBTI, 恋愛, 仕事, 相性..."
              autocomplete="off"
              autocorrect="off"
              autocapitalize="off"
              spellcheck="false"
              aria-label="診断を検索"
            />
            <button type="submit" class="search-submit" aria-label="検索">
              検索
            </button>
          </div>
        </form>

        <!-- Google サイト内検索リンク -->
        <p class="search-google-hint">
          より詳しく探す:
          <a
            href="https://www.google.com/search?q=site:shindan-navi.jp+"
            id="google-search-link"
            target="_blank"
            rel="noopener noreferrer"
            class="search-google-link"
          >
            Google でサイト内検索
          </a>
        </p>
      </div>
    </section>

    <!-- 検索結果エリア -->
    <section class="search-results-section">
      <div class="search-results-inner">
        <!-- 検索ステータス -->
        <div id="search-status" class="search-status" aria-live="polite" aria-atomic="true">
          全 <strong id="result-count">{ALL_PAGES.length}</strong> ページ
        </div>

        <!-- 結果リスト -->
        <ul id="result-list" class="result-list" role="list">
          {ALL_PAGES.map((page) => (
            <li class="result-item" data-title={page.title} data-desc={page.description} data-tags={page.tags.join(' ')}>
              <a href={page.url} class="result-link">
                <div class="result-meta">
                  <span
                    class="result-category"
                    style={`background: ${CATEGORY_COLOR[page.category] ?? 'var(--brand-500)'}22; color: ${CATEGORY_COLOR[page.category] ?? 'var(--brand-500)'};`}
                  >
                    {page.category}
                  </span>
                </div>
                <h2 class="result-title">{page.title}</h2>
                <p class="result-desc">{page.description}</p>
                <span class="result-url">{page.url}</span>
              </a>
            </li>
          ))}
        </ul>

        <!-- 0件メッセージ（JS が表示/非表示を制御）-->
        <div id="no-results" class="no-results" hidden>
          <p class="no-results-emoji" aria-hidden="true">&#x1F50D;</p>
          <p class="no-results-text">「<strong id="no-results-query"></strong>」に一致する診断が見つかりません。</p>
          <p class="no-results-hint">別のキーワードで試してみてください。</p>
          <a
            href="https://www.google.com/search?q=site:shindan-navi.jp+"
            id="no-results-google-link"
            target="_blank"
            rel="noopener noreferrer"
            class="no-results-google-btn"
          >
            Google でサイト内を検索する
          </a>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<!--
  クライアントサイド検索ロジック
  - URLパラメータ ?q= を読み取り、即座にフィルタ
  - input イベントでリアルタイムフィルタ
  - JS 無効時: 全リスト表示（graceful degradation）
-->
<script is:inline>
  (function () {
    'use strict';

    var input = document.getElementById('search-input');
    var resultList = document.getElementById('result-list');
    var resultCount = document.getElementById('result-count');
    var searchStatus = document.getElementById('search-status');
    var noResults = document.getElementById('no-results');
    var noResultsQuery = document.getElementById('no-results-query');
    var googleLink = document.getElementById('google-search-link');
    var noResultsGoogleLink = document.getElementById('no-results-google-link');

    if (!input || !resultList) return;

    // Google 検索リンクに q パラメータを反映
    function updateGoogleLinks(q) {
      var encoded = encodeURIComponent(q || '');
      var base = 'https://www.google.com/search?q=site:shindan-navi.jp+';
      if (googleLink) googleLink.href = base + encoded;
      if (noResultsGoogleLink) noResultsGoogleLink.href = base + encoded;
    }

    // フィルタ実行
    function filterResults(q) {
      var query = (q || '').trim().toLowerCase();
      var items = resultList.querySelectorAll('.result-item');
      var visible = 0;

      items.forEach(function (item) {
        var title = (item.dataset.title || '').toLowerCase();
        var desc = (item.dataset.desc || '').toLowerCase();
        var tags = (item.dataset.tags || '').toLowerCase();
        var match = !query || title.indexOf(query) >= 0 || desc.indexOf(query) >= 0 || tags.indexOf(query) >= 0;

        if (match) {
          item.removeAttribute('hidden');
          visible++;
        } else {
          item.setAttribute('hidden', '');
        }
      });

      // カウント更新
      if (resultCount) resultCount.textContent = String(visible);

      // 0件メッセージ
      if (visible === 0 && query) {
        if (noResults) noResults.removeAttribute('hidden');
        if (noResultsQuery) noResultsQuery.textContent = q;
        if (resultList) resultList.setAttribute('hidden', '');
      } else {
        if (noResults) noResults.setAttribute('hidden', '');
        if (resultList) resultList.removeAttribute('hidden');
      }

      updateGoogleLinks(q);
    }

    // URL パラメータから初期クエリ取得
    var params = new URLSearchParams(window.location.search);
    var initialQ = params.get('q') || '';
    if (initialQ) {
      input.value = initialQ;
      filterResults(initialQ);
    } else {
      updateGoogleLinks('');
    }

    // リアルタイム入力フィルタ
    input.addEventListener('input', function () {
      filterResults(input.value);
    });

    // フォーム送信時: ページリロードせず JS でフィルタ（オプション・UX向上）
    var form = input.closest('form');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var q = input.value.trim();
        // URL を更新（ブラウザ履歴に残す）
        var url = new URL(window.location.href);
        url.searchParams.set('q', q);
        window.history.replaceState(null, '', url.toString());
        filterResults(q);
      });
    }
  })();
</script>

