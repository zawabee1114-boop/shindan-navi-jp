  {
    icon: '📊',
    title: '5軸詳細レポート（フル版）',
    desc: '仕事・恋愛・友人・家族・学校の5シーン軸それぞれの詳細分析。無料版の500字から8,000字フル解説に解放。具体的な行動指針・向く環境・注意点を完全網羅。',
  },
  {
    icon: '🔓',
    title: '詳細モード完全解放',
    desc: '全8診断（MBTI・多重知能・DiSC・完璧主義・恋愛スタイル・金銭感覚・友達相性・血液型）の詳細結果を1年間いつでも閲覧できます。',
  },
  {
    icon: '🤖',
    title: 'AIプロンプトカード（5回分）',
    desc: 'ChatGPT・Claude・Geminiで自己分析を深める専用プロンプト5枚分。あなたのタイプに合わせたプロンプトをコピペするだけ。',
  },
  {
    icon: '🐾',
    title: 'Big5キャラ完全解放',
    desc: '16動物キャラの詳細版・レアリティ・性格解説。SNSシェア用の高画質素材付き。',
  },
  {
    icon: '💕',
    title: '相性詳細レポート',
    desc: '5軸（仕事・恋愛・友人・家族・学校）の詳細相性分析。招待相性診断と組み合わせると最大効果を発揮します。',
  },
];

/** 無料 vs PASS vs PRO 比較表 */
const comparisonRows = [
  { feature: '8診断すべて受ける',              free: true,  pass: true,  pro: true  },
  { feature: '診断結果の閲覧（基本版）',         free: true,  pass: true,  pro: true  },
  { feature: '相性診断（こっそりモード）',       free: true,  pass: true,  pro: true  },
  { feature: 'SNSシェア（基本）',               free: true,  pass: true,  pro: true  },
  { feature: '招待相性診断（完全無料）',         free: true,  pass: true,  pro: true  },
  { feature: '統合プロファイル 5軸詳細版',       free: false, pass: true,  pro: true  },
  { feature: '相性詳細レポート（5軸）',          free: false, pass: true,  pro: true  },
  { feature: 'Big5キャラ完全解放',              free: false, pass: true,  pro: true  },
  { feature: 'シェア用SNS素材（高画質）',        free: false, pass: true,  pro: true  },
  { feature: 'AIプロンプトカード（5回分）',      free: false, pass: true,  pro: true  },
  { feature: '詳細モード（8,000字）',            free: false, pass: true,  pro: true  },
  { feature: '広告非表示',                      free: false, pass: false, pro: true  },
  { feature: 'タイムカプセル機能',              free: false, pass: false, pro: true  },
  { feature: 'AIプロンプトカード（月次無制限）', free: false, pass: false, pro: true  },
  { feature: 'N因子時系列グラフ',               free: false, pass: false, pro: true  },
  { feature: '月1限定診断（毎月更新）',          free: false, pass: false, pro: true  },
  { feature: '優先サポート',                    free: false, pass: false, pro: true  },
];

/** FAQ リスト */
const faqs = [
  {
    q: '¥390 PASSとはどのようなサービスですか？',
    a: '診断ナビ PASSは1回限りの買い切りプランです。¥390（税込）をお支払いいただくと、5軸（仕事・恋愛・友人・家族・学校）の詳細レポート・全8診断の詳細結果・AIプロンプトカード5回分を1年間ご利用いただけます。',
  },
  {
    q: '買い切りとはどういう意味ですか？',
    a: '一度¥390をお支払いいただくと、その後の追加課金は一切ありません。月額サブスクではなく、1回払いで1年間有効です。',
  },
  {
    q: '1年後はどうなりますか？',
    a: '有効期限（購入日から1年間）が過ぎると、PASS機能（詳細レポート・詳細モード・AIプロンプトカード）が無料版の状態に戻ります。再度ご利用になる場合は再購入が必要です。',
  },
  {
    q: 'PRO（¥590/月）との違いは何ですか？',
    a: 'PASSは「買い切り・1年有効」のシンプルプランです。PROは「月額サブスク」で、PASS機能に加えてタイムカプセル機能・AIプロンプトカード月次無制限・広告完全非表示・N因子時系列グラフ・月1限定診断が含まれます。まずPASSでお試しいただき、継続利用したい方はPROへのアップグレードをおすすめします。',
  },
  {
    q: '返金はできますか？',
    a: 'デジタルコンテンツの性質上、購入完了後の返金は原則承っておりません。ただしシステム障害等による提供不能の場合は全額返金いたします。詳しくは特定商取引法に基づく表記をご確認ください。',
  },
  {
    q: '支払い方法は何に対応していますか？',
    a: 'クレジットカード（Visa・Mastercard・American Express・JCB）に対応しています。Stripe社の安全な決済システムを使用しています。',
  },
  {
    q: 'PASSを購入するとすぐに使えますか？',
    a: '決済完了後、即時ご利用いただけます。ページをリロードすると詳細レポートが自動的に解放されます。',
  },
  {
    q: 'すべての診断に使えますか？',
    a: 'はい。MBTI・多重知能・DiSC・完璧主義・恋愛スタイル・金銭感覚・友達相性・血液型の全8診断の詳細結果に使えます。',
  },
];

/** JSON-LD: Product + Offer */
const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${pageUrl}#product`,
  name: '診断ナビ PASS',
  description: '8診断の詳細レポート・5軸フル解説・AIプロンプトカード5回分を1年間解放する買い切りプラン。¥390（税込）。',
  url: pageUrl,
  brand: {
    '@type': 'Brand',
    name: '診断ナビ',
    url: siteUrl,
  },
  offers: {
    '@type': 'Offer',
    price: '390',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
    url: pageUrl,
    priceValidUntil: '2026-12-31',
  },
};

/** JSON-LD: FAQPage */
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${pageUrl}#faq`,
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};

/** JSON-LD: BreadcrumbList */
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${pageUrl}#breadcrumb`,
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'ホーム',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: '診断ナビ PASS',
      item: pageUrl,
    },
  ],
};
---

