{isStripeConfigured && (
  <script>
    async function handlePassCheckout() {
      const btn = document.getElementById('pass-checkout-btn');
      if (!btn) return;

      btn.setAttribute('disabled', 'true');
      btn.textContent = '処理中...';

      try {
        const res = await fetch('/api/stripe/checkout-session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'pass' }),
        });
        const data = await res.json();

        if (data.ok && data.url) {
          window.location.href = data.url;
        } else if (data.mock) {
          alert('準備中です。もうしばらくお待ちください。');
        } else {
          alert(`エラー: ${data.message ?? '決済に失敗しました'}`);
        }
      } catch {
        alert('通信エラーが発生しました。しばらく後でお試しください。');
      } finally {
        btn?.removeAttribute('disabled');
        if (btn?.textContent === '処理中...') {
          btn.textContent = '¥390 PASSを今すぐ購入';
        }
      }
    }

    document.getElementById('pass-checkout-btn')
      ?.addEventListener('click', handlePassCheckout);
  </script>
)}

<style>
