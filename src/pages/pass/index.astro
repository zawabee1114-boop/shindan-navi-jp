---
/**
 * /pass/ - 診断ナビ PASS ¥390 購入ページ
 *
 * 仕様:
 *   - 価格: ¥390（税込・買い切り・1年間有効）
 *   - Stripe 未接続時はモック動作（env なし → /pro/ への誘導）
 *   - 新デザイン: page-hero page-hero--purple
 *   - JSON-LD: Product + Offer + FAQPage + BreadcrumbList
 *
 * 作成: 2026-05-22（Critical バグ修正: 全サイト32リンクの404解消）
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/pass/`;
const LAST_UPDATED = '2026-05-22';

const isStripeConfigured = Boolean(
  import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY &&
  import.meta.env.STRIPE_SECRET_KEY
);

/** PASS 特典リスト */
