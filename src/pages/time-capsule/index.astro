---
/**
 * /time-capsule/ - タイムカプセル機能紹介ハブ
 *
 * KW: タイムカプセル 自己 / 過去の自分 比較 / 自己成長 記録
 * 確認日: 2026-05-21
 *
 * 学術根拠:
 *   - Wilson TD, Ross M (2003) "The identity function of autobiographical memory"
 *     Memory, 11(2), 137-150
 *   - Markus H, Nurius P (1986) "Possible selves"
 *     American Psychologist, 41(9), 954-969
 *   - Roberts BW, Walton KE, Viechtbauer W (2006) "Patterns of mean-level change in personality traits"
 *     Psychological Bulletin, 132(1), 1-25
 *
 * SEO/AIO対応:
 * - JSON-LD: WebPage + Article + FAQPage + BreadcrumbList
 * - @id連結: エンティティグラフ形成
 * - PRO訴求CTA（タイムカプセル機能・¥590/月）
 * - TldrBlock / ScienceNote / ReferenceList
 * - FAQ 10問
 * - YMYL回避: 医療診断・治療表記ゼロ
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import TldrBlock from '../../components/TldrBlock.astro';
import ReferenceList from '../../components/ReferenceList.astro';
import ScienceNote from '../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/time-capsule/`;
const CONFIRMED_AT = '2026-05-21';

const references = [
  {
    title: 'The identity function of autobiographical memory: Time is on our side',
    author: 'Wilson TD, Ross M',
    year: 2003,
    journal: 'Memory',
    volume: '11(2), 137-150',
    url: 'https://doi.org/10.1080/741938210',
  },
  {
    title: 'Possible selves',
    author: 'Markus H, Nurius P',
    year: 1986,
    journal: 'American Psychologist',
    volume: '41(9), 954-969',
    url: 'https://doi.org/10.1037/0003-066X.41.9.954',
  },
  {
    title: 'Patterns of mean-level change in personality traits across the life course: A meta-analysis of longitudinal studies',
    author: 'Roberts BW, Walton KE, Viechtbauer W',
    year: 2006,
    journal: 'Psychological Bulletin',
    volume: '132(1), 1-25',
    url: 'https://doi.org/10.1037/0033-2909.132.1.1',
  },
];

const faqs = [
  {
    question: 'タイムカプセルって何ができますか？',
    answer:
      '今日の診断結果と「未来の自分へのメッセージ」を一緒に保存し、設定した時期（3ヶ月・6ヶ月・12ヶ月後）に自動で通知が届きます。当時の診断スコアと現在のスコアをグラフで比較して、自分がどう変化したかを可視化できます。',
  },
  {
    question: 'PROじゃないと使えませんか？',
    answer:
      'タイムカプセル機能はPRO会員（¥590/月）専用の機能です。無料・PASSプランでは利用できません。診断を受けるだけなら無料でご利用いただけます。',
  },
  {
    question: '何ヶ月後に通知が来ますか？',
    answer:
      'カプセル作成時に「3ヶ月後」「6ヶ月後」「12ヶ月後」から選べます。複数の時期を設定することも可能です。通知はメールとブラウザ通知の両方に対応する予定です。',
  },
  {
    question: '書いた手紙は誰かに見られますか？',
    answer:
      '手紙の内容はあなた自身にしか見えません。他のユーザー・スタッフ・外部には一切公開されない非公開データです。プライバシーポリシーに基づき適切に管理されます。',
  },
  {
    question: '過去の診断結果と今の比較ができますか？',
    answer:
      'はい。タイムカプセルを開封するとき、保存当時の8診断スコアと現在のスコアをレーダーチャートと5シーン軸グラフで並べて比較できます。どの特性がどの方向に変化したかを一目で確認できます。',
  },
  {
    question: 'タイムカプセルを削除できますか？',
    answer:
      'はい。設定画面からいつでも削除できます。削除後はデータを復元できませんのでご注意ください。',
  },
  {
    question: '紙の日記と何が違いますか？',
    answer:
      '紙の日記は手書きの記録ですが、タイムカプセルは診断スコアというデータと手紙を一緒に保存します。「気分で書いた日記」ではなく「測定結果に基づいた変化の記録」なので、感覚ではなく数値で自己変化を確認できます。',
  },
  {
    question: '性格が変わっていなかった場合はどうなりますか？',
    answer:
      'スコアが大きく変わっていなかった場合も、「この期間を通じて安定していた」という発見自体が自己理解につながります。また「変化がない」ことと「成長がない」ことは別の話です。安定した特性が確認されることで、自分の核となるパターンを再認識できます。',
  },
  {
    question: '通知メールが届かない場合はどうすればいいですか？',
    answer:
      '迷惑メールフォルダを確認してください。それでも届かない場合は設定画面から通知アドレスを再確認するか、ブラウザ通知を有効にしてください。フィードバックフォームからもご連絡いただけます。',
  },
  {
    question: 'タイムカプセルは何個まで作れますか？',
    answer:
      'PRO会員は複数のカプセルを作成できます。たとえば「転職前」「結婚前」「引っ越し前」のように、ライフイベントごとに別々に記録することができます。上限数は現在設計中で、正式リリース時に確定します。',
  },
];

const jsonLdWebPage = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${PAGE_URL}#webpage`,
  url: PAGE_URL,
  name: 'タイムカプセル｜過去のあなたから今への手紙｜診断ナビ',
  description:
    '診断ナビのタイムカプセル機能。今日の診断結果と未来の自分へのメッセージを保存し、3ヶ月・6ヶ月・12ヶ月後に自動通知。過去と現在の特性変化をグラフで比較できるPRO限定機能。',
  inLanguage: 'ja',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  breadcrumb: { '@id': `${PAGE_URL}#breadcrumb` },
  datePublished: '2026-05-21',
  dateModified: CONFIRMED_AT,
};

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: 'タイムカプセル｜過去のあなたから今のあなたへ手紙を届ける',
  description:
    '診断ナビのタイムカプセル機能を詳しく解説。Wilson & Ross（2003）の自己連続性研究・Markus & Nurius（1986）の可能自己理論をもとに、自己成長の記録・可視化・PRO機能の使い方を紹介。',
  url: PAGE_URL,
  datePublished: '2026-05-21',
  dateModified: CONFIRMED_AT,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  citation: references.map((ref) => ({
    '@type': 'ScholarlyArticle',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    url: ref.url,
  })),
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'タイムカプセル', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebPage, jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];
---

<BaseLayout
  title="タイムカプセル｜過去のあなたから今への手紙｜診断ナビ"
  description="診断結果と未来の自分へのメッセージを保存して、3〜12ヶ月後に届ける。過去と現在の特性変化をグラフで比較できるPRO限定機能。自己連続性研究（Wilson & Ross 2003）に基づく自己成長の可視化。"
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate="2026-05-21"
  lastUpdated={CONFIRMED_AT}
  breadcrumbs={[
    { name: 'タイムカプセル', url: '/time-capsule/' },
  ]}
>
  <link rel="canonical" href={PAGE_URL} slot="head" />

  {/* ========== ヒーロー ========== */}
  <section class="tc-hero" aria-labelledby="tc-hero-h1">
    <div class="tc-hero-inner">
      <div class="tc-hero-badge">Wilson & Ross（2003）自己連続性研究に基づく</div>
      <h1 id="tc-hero-h1" class="tc-hero-h1">
        タイムカプセル<br />
        <span class="tc-hero-sub">過去のあなたから、今のあなたへ手紙を届ける</span>
      </h1>
      <p class="tc-hero-catch">
        3ヶ月前の自分は、今の悩みをどう見ていたか。<br />
        診断ナビのタイムカプセル機能は、あなたの成長を数値で記録します。
      </p>
      <div class="tc-hero-meta">
        <time datetime={CONFIRMED_AT}>{CONFIRMED_AT}</time> 時点の情報
      </div>
      <a href="#pro-cta" class="tc-hero-cta" aria-label="PRO会員の詳細を見る">
        PRO でタイムカプセルを始める
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <Container>
    {/* ========== このページでわかること ========== */}
    <div class="tc-aio-block" role="note" aria-label="このページでわかること">
      <p class="tc-aio-title">このページでわかること</p>
      <ul class="tc-aio-list">
        <li>診断ナビのタイムカプセル機能で「何ができるか」の仕組みと手順</li>
        <li>Wilson & Ross（2003）の自己連続性研究・Markus & Nurius（1986）の可能自己理論の要点</li>
        <li>転職・結婚・出産など5つのライフシーンでの活用例</li>
        <li>PRO会員（¥590/月）でタイムカプセルを使う具体的な方法</li>
        <li>FAQ 10問（プライバシー・通知・複数作成・削除ほか）</li>
      </ul>
    </div>

    {/* ========== TL;DR ========== */}
    <TldrBlock
      title="タイムカプセル機能のポイントまとめ"
      points={[
        '診断ナビのタイムカプセルは「今日の8診断スコア + 未来の自分へのメッセージ」をセットで保存する機能。3ヶ月・6ヶ月・12ヶ月後に自動通知が届く',
        'Wilson & Ross（2003）の自己連続性研究では、過去の自己を振り返ることが現在の自己肯定感・成長認知に寄与することが示されている（Memory 11(2)）',
        'Markus & Nurius（1986）の可能自己理論では、「未来の自分のイメージを具体化すること」が動機づけと行動変化を促すとされている',
        '開封時に「当時のスコア vs 現在のスコア」をレーダーチャートと5シーン軸グラフで比較できる',
        'PRO会員（¥590/月）限定機能。転職・結婚・出産など人生の節目に記録しておくと、後から「あのときの自分」をデータで振り返れる',
      ]}
      updatedAt={CONFIRMED_AT}
      sourceLabel="Wilson & Ross（2003）Memory"
      sourceUrl="https://doi.org/10.1080/741938210"
    />

    {/* ========== H2-1: タイムカプセルとは ========== */}
    <section class="tc-section" aria-labelledby="tc-what-h2">
      <h2 id="tc-what-h2" class="tc-h2">診断ナビのタイムカプセルとは</h2>
      <p class="tc-lead">
        「タイムカプセル」とは、今の自分の状態を記録して未来に届けるしくみです。<br />
        診断ナビのタイムカプセル機能は、心理学的な自己記録ツールとして設計されています。
      </p>
      <p>
        一般的なタイムカプセルは思い出の品を土に埋めますが、<br />
        診断ナビのタイムカプセルは「8つの診断スコア」というデータを封印します。<br />
        感覚的な記憶ではなく、数値として残るため、変化を客観的に確認できます。
      </p>

      <h3 class="tc-h3">なぜ診断スコアを記録することが大切なのか</h3>
      <p>
        Wilson & Ross（2003）は、過去の自己を振り返ることが<br />
        現在の自己評価・成長認知に影響を与えることを示しました。<br />
        人は「過去の自分」と「今の自分」を比べることで、成長を実感します。
      </p>
      <p>
        ただし記憶は変容します。<br />
        「あのとき自分はどうだったか」は、時間が経つと美化・歪曲されることが多い。<br />
        診断スコアという客観的なデータがあれば、記憶に頼らずに比較できます。
      </p>

      <div class="tc-quote-card" role="blockquote" aria-label="研究の要点">
        <p class="tc-quote-label">研究の要点</p>
        <p class="tc-quote-text">
          Wilson & Ross（2003）は、人々が過去の自己を現在の自己より「劣っていた」と認識する傾向を報告した。
          この「自己向上バイアス」は現在の自己を肯定的に評価することに寄与するが、
          同時に実際の変化量を過大評価するリスクもある。
          客観的な記録（スコア・データ）を持つことで、より正確な自己変化の認識が可能になる。
        </p>
        <p class="tc-quote-source">
          出典: Wilson TD, Ross M（2003）<a href="https://doi.org/10.1080/741938210" target="_blank" rel="noopener noreferrer">Memory, 11(2), 137-150</a>
        </p>
      </div>
    </section>

    {/* ========== H2-2: ストーリーセクション ========== */}
    <section class="tc-section" aria-labelledby="tc-story-h2">
      <h2 id="tc-story-h2" class="tc-h2">3ヶ月前の私から、今の私へ</h2>
      <p class="tc-lead">
        タイムカプセルがどう機能するかを、架空のケースでイメージしてみましょう。<br />
        以下は実際の利用ストーリーを参考に構成したサンプルです。
      </p>

      {/* ストーリー1 */}
      <div class="tc-story-card">
        <div class="tc-story-header">
          <div class="tc-story-icon" aria-hidden="true">✉️</div>
          <div class="tc-story-meta">
            <p class="tc-story-name">架空ケース A：転職前後の自己変化</p>
            <p class="tc-story-date">転職直前にタイムカプセルを作成・3ヶ月後に開封</p>
          </div>
        </div>
        <div class="tc-story-letter" role="article" aria-label="タイムカプセルの手紙サンプル">
          <p class="tc-letter-label">転職前日に書いた手紙（サンプル）</p>
          <p class="tc-letter-body">
            「今日、最後の出社日が終わりました。正直、めちゃくちゃ怖いです。<br />
            9年間勤めた会社を辞めて、知らない会社に飛び込む。<br />
            誠実性のスコアが72点あるのに、今は全然自分を信じられない。<br />
            <br />
            3ヶ月後の自分へ。もし後悔していたとしても、それはそれでいい。<br />
            でも、怖がりながらも動いた自分を、どうか責めないでほしい。<br />
            一つだけ聞きたい。外向性のスコア、上がってる？」
          </p>
        </div>
        <div class="tc-story-result">
          <p class="tc-story-result-label">3ヶ月後・開封時のスコア変化</p>
          <div class="tc-score-compare">
            <div class="tc-score-item">
              <span class="tc-score-trait">外向性</span>
              <div class="tc-score-bar-wrap">
                <div class="tc-score-bar tc-score-bar--before" style="width: 48%">
                  <span class="tc-score-bar-label">before 48</span>
                </div>
                <div class="tc-score-bar tc-score-bar--after" style="width: 61%">
                  <span class="tc-score-bar-label">after 61</span>
                </div>
              </div>
            </div>
            <div class="tc-score-item">
              <span class="tc-score-trait">誠実性</span>
              <div class="tc-score-bar-wrap">
                <div class="tc-score-bar tc-score-bar--before" style="width: 72%">
                  <span class="tc-score-bar-label">before 72</span>
                </div>
                <div class="tc-score-bar tc-score-bar--after" style="width: 78%">
                  <span class="tc-score-bar-label">after 78</span>
                </div>
              </div>
            </div>
            <div class="tc-score-item">
              <span class="tc-score-trait">神経症傾向</span>
              <div class="tc-score-bar-wrap">
                <div class="tc-score-bar tc-score-bar--before" style="width: 71%">
                  <span class="tc-score-bar-label">before 71</span>
                </div>
                <div class="tc-score-bar tc-score-bar--after" style="width: 54%">
                  <span class="tc-score-bar-label">after 54</span>
                </div>
              </div>
            </div>
          </div>
          <p class="tc-story-insight">
            外向性と誠実性が上昇し、神経症傾向（不安・気分の波）が低下しました。<br />
            転職前の「怖さ」を正直に書いておいたからこそ、3ヶ月後に「あのときより落ち着いている」と気づけました。
          </p>
        </div>
      </div>

      {/* ストーリー2 */}
      <div class="tc-story-card tc-story-card--alt">
        <div class="tc-story-header">
          <div class="tc-story-icon" aria-hidden="true">🌱</div>
          <div class="tc-story-meta">
            <p class="tc-story-name">架空ケース B：「INFP傾向→INTJ傾向」の1年間</p>
            <p class="tc-story-date">1年前のカプセルを開封したら...</p>
          </div>
        </div>
        <div class="tc-story-body">
          <p>
            1年前、診断ナビの多重知能テストを受けたとき、内省・感情処理・創造的思考のスコアが高かった。<br />
            MBTIでは繰り返しINFP傾向が出ていて、「この性格は変わらないんだろうな」と思っていた。
          </p>
          <p>
            1年後に同じ診断を受けると、論理的思考・組織力・計画性のスコアが上昇していた。<br />
            プロジェクトリーダーを1年間続けた経験が、スコアに現れていた。
          </p>
          <p>
            タイムカプセルの手紙には「もっと計画的な人間になりたい」と書いてあった。<br />
            1年後の自分は、その願いがある程度かなっていることをデータで確認した。
          </p>
          <p class="tc-story-insight-text">
            Roberts ら（2006）は、性格変化は「急に」ではなく「緩やかに・継続的に」起きると示しています。<br />
            1年という期間でも、行動の変化がスコアに反映されることがあります。
          </p>
          <p class="tc-source-note">
            出典: Roberts BW et al.（2006）<a href="https://doi.org/10.1037/0033-2909.132.1.1" target="_blank" rel="noopener noreferrer">Psychological Bulletin, 132(1)</a>
          </p>
        </div>
      </div>

      {/* ストーリー3 */}
      <div class="tc-story-card">
        <div class="tc-story-header">
          <div class="tc-story-icon" aria-hidden="true">💌</div>
          <div class="tc-story-meta">
            <p class="tc-story-name">架空ケース C：過去の悩みを今の自分が読み返したら</p>
            <p class="tc-story-date">6ヶ月前のカプセルを開封した体験</p>
          </div>
        </div>
        <div class="tc-story-body">
          <p>
            6ヶ月前、友人関係のトラブルで協調性スコアが大きく揺れていた時期に書いた手紙がある。<br />
            「なぜ自分はこんなに人間関係でつまずくんだろう」という言葉が書かれていた。
          </p>
          <p>
            6ヶ月後に読み返すと、当時の悩みはほぼ解消されていた。<br />
            スコアも協調性が61→69に上昇していた。
          </p>
          <p>
            過去の手紙を読んで気づいたのは、「6ヶ月前の自分はよく頑張っていた」ということだった。<br />
            当時は必死だったけど、今から見るとあの時期が成長の起点だったとわかる。
          </p>
          <p class="tc-story-insight-text">
            Wilson & Ross（2003）は「過去の自分を振り返ることが、現在の自己肯定感の構築に寄与する」と示しています。<br />
            タイムカプセルはその「振り返り」に、データという確かな足場を与えます。
          </p>
        </div>
      </div>
    </section>

    {/* ========== H2-3: 仕組み ========== */}
    <section class="tc-section" aria-labelledby="tc-how-h2">
      <h2 id="tc-how-h2" class="tc-h2">タイムカプセルの仕組み</h2>
      <p class="tc-lead">
        4ステップで完了します。<br />
        難しい操作はありません。
      </p>

      <ol class="tc-step-list" role="list">
        <li class="tc-step-item">
          <div class="tc-step-num" aria-label="ステップ1">1</div>
          <div class="tc-step-body">
            <h3 class="tc-step-title">今日の診断を受けて、スコアを記録する</h3>
            <p class="tc-step-desc">
              8つの診断（MBTI・強み・多重知能ほか）のスコアが自動で保存されます。<br />
              すでに受けている診断はそのまま使えます。追加での受け直しは不要です。
            </p>
          </div>
        </li>
        <li class="tc-step-item">
          <div class="tc-step-num" aria-label="ステップ2">2</div>
          <div class="tc-step-body">
            <h3 class="tc-step-title">「未来の自分への手紙」を書く</h3>
            <p class="tc-step-desc">
              今の悩み・目標・気持ちを自由に書きます。<br />
              書き方は自由ですが、「今の自分が感じていること」を正直に書くのがおすすめです。<br />
              テンプレートもご用意しています（<a href="/time-capsule/letter/">手紙の書き方</a>を参照）。
            </p>
          </div>
        </li>
        <li class="tc-step-item">
          <div class="tc-step-num" aria-label="ステップ3">3</div>
          <div class="tc-step-body">
            <h3 class="tc-step-title">開封時期を選んで「封印」する</h3>
            <p class="tc-step-desc">
              3ヶ月・6ヶ月・12ヶ月から選択します。<br />
              設定した時期になると、メールとブラウザ通知で「開封の時期です」とお知らせします。<br />
              複数の時期を設定することも可能です。
            </p>
          </div>
        </li>
        <li class="tc-step-item">
          <div class="tc-step-num" aria-label="ステップ4">4</div>
          <div class="tc-step-body">
            <h3 class="tc-step-title">開封して変化を確認する</h3>
