---
/**
 * /dev/auth-test/ - 認証・DB接続 動作確認ページ（開発専用）
 * Phase 3.2: ローカル開発での動作確認用
 * noindex: true
 */

export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import { createServerClient, isServerConfigured } from '../../../lib/supabase/server';

const serverClient = createServerClient();

// import.meta.env をフロントマターで変数化（テンプレートで import.meta.env を使わない）
const envSupabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ? '設定済み' : '未設定';
const envSupabaseAnon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ? '設定済み' : '未設定';
const envServiceRole = import.meta.env.SUPABASE_SERVICE_ROLE_KEY ? '設定済み' : '未設定';
const isConfigured = Boolean(import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY);

const isConfiguredClass = isConfigured ? 'status-ok' : 'status-ng';
const isServerConfiguredClass = isServerConfigured ? 'status-ok' : 'status-ng';
const serverClientStr = serverClient ? '初期化済み' : '未初期化';
const serverClientClass = serverClient ? 'status-ok' : 'status-ng';

// locals から認証情報を取得（middleware が設定済み）
const { user, plan, session } = Astro.locals;

const isLoggedIn = Boolean(user);
const planStr = String(plan ?? 'free');
const userId = user?.id ?? '';
const userEmail = user?.email ?? '';

// アクセストークンプレビュー（型安全）
const anySession = session as { access_token?: string } | null;
const tokenRaw = anySession?.access_token ?? '';
const accessTokenPreview = tokenRaw ? tokenRaw.substring(0, 20) + '...' : 'null';

// DB 情報を取得（ログイン時のみ）
interface UserRow {
  id: string;
  email: string;
  plan: string;
  pass_expires_at: string | null;
  display_name: string | null;
  created_at: string;
  updated_at: string;
}
interface ProfileRow {
  id: string;
  version: string | null;
  snapshot_at: string;
  diagnosis_count: number | null;
  is_current: boolean | null;
}

let dbUserRecord: UserRow | null = null;
let diagnosisCount = 0;
let latestProfiles: ProfileRow[] = [];
let dbError = '';
let hasDbUserRecord = false;
let hasDbError = false;
let hasProfiles = false;

if (user && serverClient) {
  try {
    const { data: userRow, error: userErr } = await serverClient
      .from('users')
      .select('id, email, plan, pass_expires_at, display_name, created_at, updated_at')
      .eq('id', user.id)
      .single();

    if (userErr) {
      dbError = 'users 取得エラー: ' + userErr.message;
      hasDbError = true;
    } else {
      dbUserRecord = userRow as UserRow;
      hasDbUserRecord = true;
    }

    const { count, error: countErr } = await serverClient
      .from('diagnosis_results')
      .select('*', { count: 'exact', head: true })
      .eq('user_id', user.id);

    if (!countErr) diagnosisCount = count ?? 0;

    const { data: profileData, error: profileErr } = await serverClient
      .from('integrated_profiles')
      .select('id, version, snapshot_at, diagnosis_count, is_current')
      .eq('user_id', user.id)
      .order('snapshot_at', { ascending: false })
      .limit(3);

    if (!profileErr) {
      latestProfiles = (profileData ?? []) as ProfileRow[];
      hasProfiles = latestProfiles.length > 0;
    }
  } catch (err) {
    dbError = 'DB接続エラー: ' + String(err);
    hasDbError = true;
  }
}
---

<BaseLayout
  title="認証テスト（開発用）｜診断ナビ"
  description="Phase 3.2 認証フロー・DB接続の動作確認ページ"
  noindex={true}
>
  <Container>
    <div class="auth-test-page">
      <h1 class="auth-test-title">Auth Test（開発専用）</h1>

      <!-- Supabase 設定状態 -->
      <section class="auth-test-section">
        <h2>Supabase 設定状態</h2>
        <table class="auth-test-table">
          <tr>
            <th>PUBLIC_SUPABASE_URL</th>
            <td class={isConfiguredClass}>{envSupabaseUrl}</td>
          </tr>
          <tr>
            <th>PUBLIC_SUPABASE_ANON_KEY</th>
            <td class={isConfiguredClass}>{envSupabaseAnon}</td>
          </tr>
          <tr>
            <th>SUPABASE_SERVICE_ROLE_KEY</th>
            <td class={isServerConfiguredClass}>{envServiceRole}</td>
          </tr>
          <tr>
            <th>サーバークライアント</th>
            <td class={serverClientClass}>{serverClientStr}</td>
          </tr>
        </table>
      </section>

      <!-- セッション情報 -->
      <section class="auth-test-section">
        <h2>セッション情報（middleware.locals）</h2>
        {isLoggedIn && (
          <table class="auth-test-table">
            <tr>
              <th>ステータス</th>
              <td class="status-ok">ログイン済み</td>
            </tr>
            <tr>
              <th>User ID</th>
              <td><code>{userId}</code></td>
            </tr>
            <tr>
              <th>Email</th>
              <td><code>{userEmail}</code></td>
            </tr>
            <tr>
              <th>Plan (locals)</th>
              <td><code>{planStr}</code></td>
            </tr>
            <tr>
              <th>Access Token (先頭20文字)</th>
              <td><code>{accessTokenPreview}</code></td>
            </tr>
          </table>
        )}
        {!isLoggedIn && (
          <div class="auth-test-alert auth-test-alert--warn">
            未ログイン（ゲスト状態）—
            <a href="/login/?redirect=/dev/auth-test/" class="auth-test-link-inline">ログインページへ</a>
          </div>
        )}
      </section>

      <!-- users テーブルレコード (ログイン時のみ) -->
      {isLoggedIn && (
        <section class="auth-test-section">
          <h2>users テーブルレコード</h2>
          {hasDbError && (
            <div class="auth-test-alert auth-test-alert--error">{dbError}</div>
          )}
          {!hasDbError && hasDbUserRecord && dbUserRecord && (
            <table class="auth-test-table">
              <tr><th>id</th><td><code>{dbUserRecord.id}</code></td></tr>
              <tr><th>email</th><td><code>{dbUserRecord.email}</code></td></tr>
              <tr><th>plan</th><td><code class="status-ok">{dbUserRecord.plan}</code></td></tr>
              <tr><th>pass_expires_at</th><td><code>{dbUserRecord.pass_expires_at ?? 'null'}</code></td></tr>
              <tr><th>display_name</th><td><code>{dbUserRecord.display_name ?? 'null'}</code></td></tr>
              <tr><th>created_at</th><td><code>{dbUserRecord.created_at}</code></td></tr>
              <tr><th>updated_at</th><td><code>{dbUserRecord.updated_at}</code></td></tr>
            </table>
          )}
          {!hasDbError && !hasDbUserRecord && (
            <div class="auth-test-alert auth-test-alert--warn">
              users テーブルにレコードがありません（初回ログイン後に自動作成）
            </div>
          )}
        </section>
      )}

      <!-- diagnosis_results (ログイン時のみ) -->
      {isLoggedIn && (
        <section class="auth-test-section">
          <h2>diagnosis_results</h2>
          <p class="auth-test-count">
            DB 保存済み診断結果: <strong>{diagnosisCount} 件</strong>
          </p>
        </section>
      )}

      <!-- integrated_profiles (ログイン時のみ) -->
      {isLoggedIn && (
        <section class="auth-test-section">
          <h2>integrated_profiles（最新3件）</h2>
          {hasProfiles && (
            <table class="auth-test-table">
              <thead>
                <tr>
                  <th>version</th>
                  <th>snapshot_at</th>
                  <th>diagnosis_count</th>
                  <th>is_current</th>
                </tr>
              </thead>
              <tbody>
                {latestProfiles.map((p) => (
                  <tr>
                    <td><code>{p.version ?? '-'}</code></td>
                    <td>{new Date(p.snapshot_at).toLocaleString('ja-JP')}</td>
                    <td>{p.diagnosis_count ?? 0}</td>
                    <td>{p.is_current ? 'YES' : 'no'}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
          {!hasProfiles && (
            <div class="auth-test-alert auth-test-alert--warn">
              統合プロファイルがまだ保存されていません
            </div>
          )}
        </section>
      )}

      <!-- ログアウト (ログイン時のみ) -->
      {isLoggedIn && (
        <section class="auth-test-section">
          <h2>ログアウト</h2>
          <form method="POST" action="/api/auth/signout">
            <button type="submit" class="auth-test-signout-btn">
              ログアウトして / へ
            </button>
          </form>
        </section>
      )}

      <!-- 操作リンク -->
      <section class="auth-test-section">
        <h2>テスト操作</h2>
        <div class="auth-test-links">
          <a href="/login/" class="auth-test-link">ログインページ</a>
          <a href="/signup/" class="auth-test-link">新規登録ページ</a>
          <a href="/profile/" class="auth-test-link">プロフィールページ</a>
          <a href="/diagnosis/" class="auth-test-link">診断一覧</a>
        </div>
      </section>
    </div>
  </Container>
</BaseLayout>

<style>
.auth-test-page {
  max-width: 800px;
  margin-inline: auto;
  padding-block: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.auth-test-title {
  font-size: 1.5rem;
  font-weight: 900;
  color: #1e1b4b;
  margin: 0;
  padding-bottom: 1rem;
  border-bottom: 2px solid #e0e7ff;
}

.auth-test-section {
  background: #fff;
  border: 1px solid #e5e7eb;
  border-radius: 0.75rem;
  padding: 1.25rem;
}

.auth-test-section h2 {
  font-size: 1rem;
  font-weight: 700;
  color: #374151;
  margin: 0 0 0.875rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid #f3f4f6;
}

.auth-test-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}

.auth-test-table th,
.auth-test-table td {
  padding: 0.5rem 0.75rem;
  text-align: left;
  border-bottom: 1px solid #f3f4f6;
}

.auth-test-table th {
  color: #6b7280;
  font-weight: 600;
  width: 40%;
}

.auth-test-table td { color: #1f2937; }

.auth-test-table thead th {
  background: #f9fafb;
  color: #6b7280;
}

code {
  font-family: 'JetBrains Mono', 'Menlo', 'Monaco', monospace;
  font-size: 0.8rem;
  background: #f3f4f6;
  padding: 0.1rem 0.375rem;
  border-radius: 0.25rem;
  color: #374151;
  word-break: break-all;
}

.status-ok { color: #059669; font-weight: 700; }
.status-ng { color: #dc2626; font-weight: 700; }

.auth-test-alert {
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.auth-test-alert--warn {
  background: #fefce8;
  border: 1px solid #fde047;
  color: #854d0e;
}

.auth-test-alert--error {
  background: #fef2f2;
  border: 1px solid #fecaca;
  color: #dc2626;
}

.auth-test-count {
  font-size: 1rem;
  color: #374151;
  margin: 0;
}

.auth-test-links {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.auth-test-link {
  display: inline-flex;
  align-items: center;
  padding: 0.5rem 1rem;
  border: 1.5px solid #4f46e5;
  color: #4f46e5;
  border-radius: 999px;
  font-size: 0.875rem;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.15s;
  min-height: 44px;
}

.auth-test-link:hover {
  background: #4f46e5;
  color: #fff;
  text-decoration: none;
}

.auth-test-link-inline {
  color: #4f46e5;
  font-weight: 700;
  text-decoration: underline;
}

.auth-test-signout-btn {
  padding: 0.625rem 1.25rem;
  background: #ef4444;
  color: #fff;
  border: none;
  border-radius: 999px;
  font-size: 0.9rem;
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  min-height: 44px;
  transition: opacity 0.15s;
}

.auth-test-signout-btn:hover { opacity: 0.85; }
</style>
