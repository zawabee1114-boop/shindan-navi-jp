---
/**
 * /me/invitations/ - 招待ダッシュボード
 *
 * Phase 3.5 静的化リファクタ（fix/invitations-static）:
 * - 旧実装: prerender=false + Astro frontmatter で createServerClient 使用
 *   → output:'static' ビルドで dist 未生成 → 本番404
 *
 * 修正後:
 * - 静的 HTML シェル（noindex・ヒーロー・新規発行ボタン）を Astro で出力
 * - DB 取得・認証確認は InvitationsClient.tsx（React Island）に移譲
 *
 * noindex: 個人データページのため検索除外
 */

// prerender=false を削除 → デフォルト static（output:'static'）で dist 生成される

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import InvitationsClient from '../../../components/me/InvitationsClient';
---

<BaseLayout
  title="招待ダッシュボード - 診断ナビ"
  description="送った招待コードの一覧と相性結果を確認できます"
  noindex={true}
  breadcrumbs={[
    { name: 'マイページ', url: '/me/' },
    { name: '招待ダッシュボード', url: '/me/invitations/' },
  ]}
>
  <!-- ヒーローセクション（静的）-->
  <section class="page-hero page-hero--purple">
    <Container>
      <div class="inv-header-inner">
        <div class="inv-header-icon" aria-hidden="true">🤝</div>
        <div>
          <h1 class="inv-header-title">招待ダッシュボード</h1>
          <p class="inv-header-desc">送った招待コード一覧と相性結果を確認できます</p>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <div class="inv-body">

      <!-- 新規発行ボタン（静的・常時表示）-->
      <div class="inv-new-section">
        <a href="/diagnosis/" class="inv-new-btn" aria-label="新しい招待を発行する">
          <span aria-hidden="true">+</span>
          新しい招待を発行する
        </a>
        <p class="inv-new-note">招待相性は完全無料・無制限</p>
      </div>

      <!-- React Island: 認証確認 + DB 取得 + 統計 + リスト表示 -->
      <InvitationsClient client:load />

    </div>
  </Container>
</BaseLayout>

<style>
.inv-header-inner {
  display: flex;
  align-items: center;
  gap: var(--sn-space-4);
}
.inv-header-icon {
  font-size: 2.5rem;
  width: 64px;
  height: 64px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--sn-primary-bg);
  border-radius: 50%;
  border: 2px solid var(--sn-primary-light);
  flex-shrink: 0;
}
.inv-header-title {
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-2xl);
  font-weight: 900;
  color: var(--sn-text);
  margin: 0;
}
.inv-header-desc {
  font-size: var(--sn-text-sm);
  color: var(--sn-muted);
  margin: var(--sn-space-1) 0 0;
}

.inv-body {
  display: flex;
  flex-direction: column;
  gap: var(--sn-space-6);
  padding-block: var(--sn-space-8);
}

.inv-new-section {
  display: flex;
  align-items: center;
  gap: var(--sn-space-3);
  flex-wrap: wrap;
}
.inv-new-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--sn-space-1);
  padding: var(--sn-space-3) var(--sn-space-5);
  background: var(--sn-primary);
  color: #fff;
  border-radius: var(--sn-radius-pill);
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-sm);
  font-weight: 700;
  text-decoration: none;
  min-height: var(--sn-tap-min);
  transition: transform var(--sn-dur-fast), box-shadow var(--sn-dur-fast);
  box-shadow: 0 4px 12px rgba(99 102 241 / 0.3);
}
.inv-new-btn:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 16px rgba(99 102 241 / 0.4);
  text-decoration: none;
  color: #fff;
}
.inv-new-note {
  font-size: var(--sn-text-xs);
  color: var(--sn-muted);
  margin: 0;
}

/* ===== React Island から使用するクラス ===== */

/* スケルトン */
:global(.inv-skeleton) {
  display: flex;
  flex-direction: column;
  gap: var(--sn-space-3);
}
:global(.inv-skeleton-stat) {
  height: 80px;
  background: var(--sn-bg-soft);
  border-radius: var(--sn-radius-md);
  animation: inv-pulse 1.5s ease-in-out infinite;
}
:global(.inv-skeleton-item) {
  height: 72px;
  background: var(--sn-bg-soft);
  border-radius: var(--sn-radius-md);
  animation: inv-pulse 1.5s ease-in-out infinite;
  animation-delay: 0.2s;
}
@keyframes inv-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* アラート */
:global(.inv-alert) {
  display: flex;
  align-items: center;
  gap: var(--sn-space-2);
  padding: var(--sn-space-3) var(--sn-space-4);
  background: var(--sn-bg-soft);
  border-radius: var(--sn-radius-md);
  border: 1px solid var(--sn-border);
  font-size: var(--sn-text-sm);
  color: var(--sn-text-soft);
}
:global(.inv-alert--error) {
  background: var(--sn-error-bg);
  border-color: color-mix(in srgb, var(--sn-error) 20%, transparent);
  color: var(--sn-error);
}
:global(.inv-alert-link) {
  color: var(--sn-primary);
  font-weight: 700;
  text-decoration: underline;
  margin-left: var(--sn-space-2);
}

/* 統計 */
:global(.inv-stats) {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sn-space-3);
}
:global(.inv-stat-card) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sn-space-1);
  padding: var(--sn-space-4);
  background: var(--sn-bg-white);
  border-radius: var(--sn-radius-md);
  border: 1px solid var(--sn-border);
  text-align: center;
}
:global(.inv-stat-card--used) { border-color: color-mix(in srgb, var(--sn-success) 25%, transparent); }
:global(.inv-stat-card--active) { border-color: color-mix(in srgb, var(--sn-primary) 25%, transparent); }
:global(.inv-stat-num) {
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-2xl);
  font-weight: 900;
  color: var(--sn-primary);
  line-height: 1;
}
:global(.inv-stat-label) {
  font-size: var(--sn-text-xs);
  color: var(--sn-muted);
  font-weight: 700;
}

/* セクション */
:global(.inv-section) { display: flex; flex-direction: column; gap: var(--sn-space-3); }
:global(.inv-section-title) {
  display: flex;
  align-items: center;
  gap: var(--sn-space-2);
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-base);
  font-weight: 900;
  color: var(--sn-text);
  margin: 0;
  cursor: pointer;
  list-style: none;
}
:global(.inv-section-title::-webkit-details-marker) { display: none; }

/* リスト */
:global(.inv-list) {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: var(--sn-space-2);
}
:global(.inv-list--muted) { opacity: 0.7; }

/* カード */
:global(.inv-item) {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--sn-space-4);
  padding: var(--sn-space-4) var(--sn-space-5);
  background: var(--sn-bg-white);
  border-radius: var(--sn-radius-md);
  border: 1px solid var(--sn-border);
  flex-wrap: wrap;
}
:global(.inv-item--used) { border-left: 3px solid var(--sn-success); }
:global(.inv-item--active) { border-left: 3px solid var(--sn-primary); }
:global(.inv-item--expired) { border-left: 3px solid var(--sn-border); opacity: 0.75; }

:global(.inv-item-left) {
  display: flex;
  flex-direction: column;
  gap: var(--sn-space-1);
  flex: 1;
}
:global(.inv-mode-badge) {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 2px 8px;
  border-radius: 999px;
  font-size: var(--sn-text-xs);
  font-weight: 700;
  color: #fff;
  width: fit-content;
}
:global(.inv-mode-badge--muted) { background: var(--sn-muted) !important; }
:global(.inv-item-code) {
  font-size: var(--sn-text-sm);
  color: var(--sn-text-soft);
  margin: 0;
}
:global(.inv-code-text) {
  font-family: var(--sn-font-mono);
  background: var(--sn-bg-soft);
  padding: 1px 5px;
  border-radius: 4px;
  letter-spacing: 0.08em;
  font-size: var(--sn-text-sm);
  color: var(--sn-text);
}
:global(.inv-item-date) {
  font-size: var(--sn-text-xs);
  color: var(--sn-muted);
  margin: 0;
}

:global(.inv-item-right) { flex-shrink: 0; }
:global(.inv-item-actions) {
  display: flex;
  flex-direction: column;
  gap: var(--sn-space-2);
  align-items: flex-end;
}

/* アクションボタン */
:global(.inv-action-btn) {
  padding: var(--sn-space-2) var(--sn-space-4);
  border-radius: var(--sn-radius-pill);
  font-size: var(--sn-text-xs);
  font-weight: 700;
  cursor: pointer;
  font-family: inherit;
  min-height: 36px;
  transition: opacity 0.15s;
  border: 1px solid transparent;
}
:global(.inv-action-btn:hover) { opacity: 0.8; }
:global(.inv-action-btn:disabled) { opacity: 0.5; cursor: not-allowed; }
:global(.inv-action-btn--copy) { background: var(--sn-primary); color: #fff; }
:global(.inv-action-btn--cancel) {
  background: none;
  color: var(--sn-error);
  border-color: color-mix(in srgb, var(--sn-error) 30%, transparent);
}

/* 相性スコア */
:global(.inv-compat-result) { display: flex; flex-direction: column; gap: var(--sn-space-2); align-items: flex-end; }
:global(.inv-compat-score) {
  display: flex;
  align-items: baseline;
  gap: 0.125rem;
}
:global(.inv-compat-score--blurred) { filter: blur(4px); user-select: none; }
:global(.inv-compat-num) {
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-2xl);
  font-weight: 900;
  color: var(--sn-primary);
  line-height: 1;
}
:global(.inv-compat-unit) {
  font-size: var(--sn-text-sm);
  color: var(--sn-muted);
}
:global(.inv-compat-breakdown) {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  min-width: 140px;
}
:global(.inv-compat-axis) {
  display: flex;
  align-items: center;
  gap: var(--sn-space-2);
}
:global(.inv-compat-axis-label) {
  font-size: var(--sn-text-xs);
  color: var(--sn-muted);
  width: 2em;
  flex-shrink: 0;
}
:global(.inv-compat-bar-bg) {
  flex: 1;
  height: 6px;
  background: var(--sn-bg-soft);
  border-radius: 999px;
  overflow: hidden;
}
:global(.inv-compat-bar-fill) {
  height: 100%;
  background: var(--sn-primary);
  border-radius: 999px;
}
:global(.inv-compat-axis-score) {
  font-size: var(--sn-text-xs);
  font-weight: 700;
  color: var(--sn-primary);
  width: 2em;
  text-align: right;
}
:global(.inv-compat-blur-wrapper) { display: flex; flex-direction: column; align-items: flex-end; gap: var(--sn-space-2); }
:global(.inv-pro-unlock-btn) {
  display: inline-flex;
  align-items: center;
  padding: var(--sn-space-1) var(--sn-space-3);
  background: linear-gradient(135deg, #a855f7, #7c3aed);
  color: #fff;
  border-radius: var(--sn-radius-pill);
  font-size: var(--sn-text-xs);
  font-weight: 700;
  text-decoration: none;
  min-height: 32px;
}
:global(.inv-no-score) {
  font-size: var(--sn-text-xs);
  color: var(--sn-muted);
  margin: 0;
}

:global(.inv-expired-details > summary) { cursor: pointer; }
:global(.inv-expired-details[open] > summary) { margin-bottom: var(--sn-space-3); }

/* 空状態 */
:global(.inv-empty) {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sn-space-4);
  padding: var(--sn-space-12) var(--sn-space-4);
  text-align: center;
}
:global(.inv-empty-icon) { font-size: 3.5rem; }
:global(.inv-empty-title) {
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-xl);
  font-weight: 900;
  color: var(--sn-text);
  margin: 0;
}
:global(.inv-empty-desc) {
  font-size: var(--sn-text-sm);
  color: var(--sn-muted);
  line-height: var(--sn-leading-base);
  max-width: 380px;
  margin: 0;
}
:global(.inv-cta-btn) {
  display: inline-flex;
  align-items: center;
  padding: var(--sn-space-3) var(--sn-space-6);
  background: var(--sn-primary);
  color: #fff;
  border-radius: var(--sn-radius-pill);
  font-family: var(--sn-font-rounded);
  font-size: var(--sn-text-base);
  font-weight: 700;
  text-decoration: none;
  min-height: var(--sn-tap-min);
  transition: transform var(--sn-dur-fast), box-shadow var(--sn-dur-fast);
}
:global(.inv-cta-btn:hover) {
  transform: translateY(-1px);
  box-shadow: var(--sn-shadow-md);
  text-decoration: none;
  color: #fff;
}

/* レスポンシブ */
@media (max-width: 640px) {
  .inv-header-inner { flex-direction: column; align-items: flex-start; gap: var(--sn-space-3); }
  :global(.inv-stat-card) { padding: var(--sn-space-3) var(--sn-space-2); }
  :global(.inv-item) { flex-direction: column; }
  :global(.inv-item-right) { width: 100%; }
  :global(.inv-item-actions) { flex-direction: row; align-items: center; }
  :global(.inv-compat-breakdown) { min-width: 100%; }
}
</style>
