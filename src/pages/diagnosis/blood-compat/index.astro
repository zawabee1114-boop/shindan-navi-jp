        {allTypesData.map(({ type, best }) => (
          <div class="bc-ranking-card">
            <h3 class="bc-ranking-type">{typeLabels[type]} のベストマッチ</h3>
            <ol class="bc-ranking-list">
              {best.map((pair, idx) => {
                const partner = pair.type1 === type ? pair.type2 : pair.type1;
                const bg = catBgs[pair.category] ?? '#f9fafb';
                const color = catColors[pair.category] ?? '#6b7280';
                return (
                  <li class="bc-ranking-item" style={`background: ${bg}; border-left: 3px solid ${color};`}>
                    <span class="bc-ranking-num" aria-hidden="true">{idx + 1}</span>
                    <div class="bc-ranking-info">
                      <a
                        href={`/diagnosis/blood-compat/tool/?t1=${type}&t2=${partner}`}
                        class="bc-ranking-pair"
                        style={`color: ${color};`}
                      >
                        {typeLabels[type]} × {typeLabels[partner]}
                        <span class="bc-ranking-score">（{pair.score}点）</span>
                      </a>
                      <p class="bc-ranking-summary">{pair.oneLineSummary}</p>
                    </div>
                  </li>
                );
