---
/**
 * 血液型相性 友達ページ
 * KW: 血液型相性 友達（VOL: 1,300 / SD: 14）
 *
 * 学術根拠:
 * - 古川竹二 (1927) 「血液型による気質の研究」心理学研究
 *   https://www.jstage.jst.go.jp/browse/psycholres
 * - 能見正比古 (1971) 『血液型でわかる相性』青春出版社
 *   https://www.seishun.co.jp/
 * - Sakamoto A, Yamazaki K (2004) International Journal of Psychology 39(4)
 *   https://doi.org/10.1080/00207590344000248
 * - 日本心理学会 公式見解 (2014)
 *   https://psych.or.jp/opinion/bl-personality/
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import { meta as bcMeta, BLOOD_TYPES } from '../../../../data/diagnoses/blood-compat/meta';
import { typesDetail } from '../../../../data/diagnoses/blood-compat/types-detail';
import {
  getCompatibility,
  getCategoryLabel,
  getCategoryColor,
} from '../../../../data/diagnoses/blood-compat/results';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/blood-compat/friend/`;
const UPDATED_AT = '2026-05-21';

const pageTitle = '血液型相性【友達編】A・B・O・AB型の友情パターン完全解説｜診断ナビ';
const pageDesc = '血液型相性を友達・友情の視点で徹底解説。A型・B型・O型・AB型が友達になると？4×4全16パターンの友情相性と、各タイプの友達スタイル・付き合い方のコツを古川（1927）・能見（1971）の研究をもとに紹介。';

// 友情相性の 4×4 マトリクスデータ
const friendMatrixData = BLOOD_TYPES.map((rowType) =>
  BLOOD_TYPES.map((colType) => {
    const compat = getCompatibility(rowType, colType);
    return {
      type1: rowType,
      type2: colType,
      score: compat.score,
      category: compat.category,
      friendCompat: compat.friendCompat,
      oneLineSummary: compat.oneLineSummary,
    };
  })
);

// 各タイプの友情パターン（types-detailのfriendStyleとsceneを活用）
const friendPatterns = BLOOD_TYPES.map((type) => ({
  type,
  detail: typesDetail[type],
  allPairs: BLOOD_TYPES.map((partner) => ({
    partner,
    compat: getCompatibility(type, partner),
  })).sort((a, b) => b.compat.score - a.compat.score),
}));

// FAQ 10問
const faqs = [
  {
    question: '血液型相性で友達になりやすい組み合わせはどれですか？',
    answer:
      '本サイトのスコアでは、A型×A型（86点）、O型×O型（85点）、B型×AB型（80点）が友情相性でも高評価です。ただし日本心理学会（2014）の公式見解（https://psych.or.jp/opinion/bl-personality/）によると血液型と性格の科学的相関は限定的です。実際の友人関係は共通の趣味・価値観・出会いの文脈で形成されます。',
  },
  {
    question: 'A型の人と友達になるコツは何ですか？',
    answer:
      '日本の血液型性格分類（古川 1927・能見 1971）ではA型は「誠実さ・約束を守ること・丁寧な対応」を大切にするとされています。約束の時間をきちんと守り、連絡をしっかり返すことが信頼関係の土台になりやすいです。あくまで傾向として参考にし、個人差があることを前提にしてください。',
  },
  {
    question: 'B型の人は友達を作りにくいといわれるのはなぜですか？',
    answer:
      '「B型は自己中心的」「マイペースすぎる」というのは日本の血液型性格分類による文化的イメージです。日本心理学会（2014）は「血液型と性格の科学的相関は限定的」と明言しており、個人差が非常に大きいです。B型の方が友達を作りにくいという科学的根拠はありません。血液型で人を判断することはブラハラにつながるリスクがあります。',
  },
  {
    question: 'O型は誰とでも友達になれると聞きましたが本当ですか？',
    answer:
      '日本の血液型性格分類（能見 1971）ではO型は「社交的でリーダーシップがある」とされており、幅広い交友関係を持つイメージがあります。ただしこれは文化的なイメージであり、科学的な根拠は限定的です（日本心理学会 2014）。実際に誰とでも打ち解けられるかどうかは個人の性格・経験・状況によります。',
  },
  {
    question: 'AB型は友達が少ないといわれるのはなぜですか？',
    answer:
      '日本の血液型性格分類（能見 1971）ではAB型は「少数の深い関係を好む」とされており、広い交友関係より密な友情を大切にするイメージがあります。ただしこれは文化的イメージであり、科学的根拠は限定的です（日本心理学会 2014）。AB型の方が友達が少ないという事実はなく、血液型で友達の多さを決めつけることは避けてください。',
  },
  {
    question: '血液型が違う友達とはうまくいかないですか？',
    answer:
      '血液型の違いが友人関係に影響するという科学的根拠は認められていません（日本心理学会 2014・Sakamoto & Yamazaki 2004）。異なる血液型同士でも深い友情は多数存在します。本サイトでは「違いがあるからこそ互いを補い合える」という観点から、スコアが低めの組み合わせを「学び合いペア」と表現しています。',
  },
  {
    question: '血液型相性を友達関係に使う正しい方法は何ですか？',
    answer:
      '自己理解のヒントや話題のきっかけとして楽しむことを推奨します。「A型だから細かい」「B型だから自由奔放」と決めつけたり、血液型を理由に友人を排除することはブラハラ（血液型ハラスメント）につながります。血液型はあくまで会話のきっかけのひとつとして、実際の交流を通じて相手を知ることが大切です。',
  },
  {
    question: '友達として最も相性がいい血液型の組み合わせはどれですか？',
    answer:
      '本サイトのデータでは、A型×A型（86点・深く理解し合えるペア）、O型×O型（85点・エネルギーあふれる活気のあるペア）、B型×AB型（80点・個性を認め合える知的なペア）が友情相性でも上位です。ただしこれは日本の血液型文化に基づく傾向値であり、科学的に友情の深さを測定したものではありません。',
  },
  {
    question: '血液型の相性が悪い友達とはどう付き合えばいいですか？',
    answer:
      '本サイトでは「相性が悪い」という表現は使いません。スコアが低い組み合わせは「学び合いペア」「成長機会の多いペア」として表現しています。異なるスタイルを持つ相手から学べることは多く、自分とは違う視点が自分の視野を広げてくれます。相手の価値観を尊重し、対話を重ねることが大切です。',
  },
  {
    question: 'このサイトの血液型相性データはどこから来ていますか？',
    answer:
      '古川竹二（1927）「血液型による気質の研究」・能見正比古（1971）『血液型でわかる相性』の文化的分類研究を参照し、日本の血液型性格分類の傾向値として整理しています。科学的に厳密な統計的相関は限定的との指摘（日本心理学会 2014・Sakamoto & Yamazaki 2004）を踏まえ、文化的話題として参考情報として提示しています。',
  },
];

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: '血液型相性【友達編】A・B・O・AB型の友情パターン完全解説',
  description: pageDesc,
  url: PAGE_URL,
  datePublished: UPDATED_AT,
  dateModified: UPDATED_AT,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  citation: bcMeta.references.map((ref) => ({
    '@type': ref.url.includes('doi.org') ? 'ScholarlyArticle' : 'Book',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    publisher: ref.publisher,
    url: ref.url,
  })),
};

// JSON-LD: FAQPage
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '血液型相性診断', item: `${SITE_URL}/diagnosis/blood-compat/` },
    { '@type': 'ListItem', position: 4, name: '血液型相性 友達', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

// カテゴリ色マッピング
const catColors: Record<string, string> = {
  soulmate: '#8B5CF6',
  good: '#10B981',
  neutral: '#3B82F6',
  growth: '#F59E0B',
  challenge: '#EF4444',
};
const catBgs: Record<string, string> = {
  soulmate: '#f3e8ff',
  good: '#d1fae5',
  neutral: '#dbeafe',
  growth: '#fef3c7',
  challenge: '#fee2e2',
};

const typeLabels: Record<string, string> = { A: 'A型', B: 'B型', O: 'O型', AB: 'AB型' };
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate={UPDATED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '血液型相性診断', url: '/diagnosis/blood-compat/' },
    { name: '血液型相性 友達', url: '/diagnosis/blood-compat/friend/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="page-hero page-hero--coral" aria-labelledby="bf-hero-h1">
    <Container>
      <div class="bf-hero-inner">
        <div class="bf-hero-badge">古川竹二（1927）・能見正比古（1971）研究 + 日本心理学会見解</div>
        <h1 id="bf-hero-h1" class="bf-hero-h1">
          血液型相性【友達編】<br />
          <span class="bf-hero-meta">A・B・O・AB型 全16パターンの友情完全解説</span>
        </h1>
        <p class="bf-hero-catch">
          血液型が違う友達とはどう付き合う？<br />
          各タイプの友情スタイルと、4×4全組み合わせの友達相性を徹底解説
        </p>
        <div class="bf-hero-stats">
          <span class="bf-stat"><strong>4</strong>タイプ</span>
          <span class="bf-stat-sep">×</span>
          <span class="bf-stat"><strong>16</strong>パターン</span>
          <span class="bf-stat-sep">・</span>
          <span class="bf-stat">無料</span>
          <span class="bf-stat-sep">・</span>
          <span class="bf-stat">登録不要</span>
        </div>
        <p class="bf-hero-sub">
          <time datetime={UPDATED_AT}>{UPDATED_AT}</time> 時点の情報
        </p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== このページでわかること ========== */}
    <div class="bf-aio-block" role="note" aria-label="このページでわかること">
      <p class="bf-aio-title">このページでわかること</p>
      <ul class="bf-aio-list">
        <li>A・B・O・AB型 全4タイプの友達としてのスタイル・付き合い方の特徴</li>
        <li>4×4全16パターンの友情相性スコアと、友達として関わる際のポイント</li>
        <li>血液型相性の文化的・科学的位置付け（日本心理学会 2014年公式見解）</li>
        <li>友達との血液型相性を正しく活用する方法とブラハラ警告</li>
      </ul>
      <p class="bf-aio-updated">
        参照元:
        <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">日本心理学会（2014）</a>・
        <a href="https://www.jstage.jst.go.jp/browse/psycholres" target="_blank" rel="noopener noreferrer">古川（1927）</a>・
        <a href="https://www.seishun.co.jp/" target="_blank" rel="noopener noreferrer">能見（1971）</a>
        を確認済。
      </p>
    </div>

    {/* ========== TldrBlock ========== */}
    <TldrBlock
      title="血液型相性 友達編 ポイントまとめ"
      points={[
        '友情相性スコア上位: A型×A型（86点）、O型×O型（85点）、B型×AB型（80点）。同タイプ同士は価値観が近く摩擦が少ない傾向',
        '日本心理学会（2014）公式見解では「血液型と性格の科学的統計的相関は認められない」。友達の相性は血液型より共通の趣味・価値観・対話で形成される',
        '各タイプの友達スタイル: A型は信頼・約束重視。B型は楽しさ・自由な付き合い。O型は社交的で積極的。AB型は少数の深い友情を好む',
        '血液型相性は「友達との会話のきっかけ」として活用。血液型で友達を選別・排除することはブラハラ（血液型ハラスメント）に該当する',
        '「相性が低い組み合わせ」は「最大の学び合いペア」。違いがあるからこそ互いの視野を広げ合える',
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="日本心理学会 公式見解（2014）"
      sourceUrl="https://psych.or.jp/opinion/bl-personality/"
    />

    {/* ========== 科学的位置付け ========== */}
    <section class="bf-section" aria-labelledby="bf-science-h2">
      <h2 id="bf-science-h2" class="bf-h2">血液型相性と友達——文化的・科学的位置付け</h2>
      <div class="bf-science-card">
        <p class="bf-lead">
          血液型性格分類は、1927年に古川竹二が発表した研究を端緒とし、
          1971年に能見正比古が一般に広めた<strong>日本独自の文化的現象</strong>です。
          友達との相性として血液型が話題になるのも、この文化的背景によるものです。
        </p>
        <p class="bf-lead">
          一方で、日本心理学会は2014年の
          <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">公式見解</a>で
          「血液型と性格の間に科学的に明確な統計的相関は認められない」と明言しています。
          Sakamoto &amp; Yamazaki（2004）の研究でも同様の指摘があります。
        </p>
        <div class="bf-disclaimer-box" role="note" aria-label="免責事項">
          <p class="bf-disclaimer-text">
            {bcMeta.disclaimer}
          </p>
        </div>
      </div>
    </section>

    {/* ========== ブラハラ警告 ========== */}
    <section class="bf-section" aria-labelledby="bf-harassment-h2">
      <h2 id="bf-harassment-h2" class="bf-h2">血液型ハラスメント（ブラハラ）への注意</h2>
      <div class="bf-harassment-box" role="alert" aria-label="血液型ハラスメントの警告">
        <p class="bf-harassment-lead">
          血液型を理由に友人を選別・排除することはブラハラに該当する可能性があります。
          以下のような言動は避けてください。
        </p>
        <ul class="bf-harassment-list">
          <li>「B型だから友達になりたくない」と血液型だけで判断する</li>
          <li>「AB型は変わり者だから付き合いにくい」と決めつける</li>
          <li>グループで血液型を理由に誰かを仲間外れにする</li>
          <li>血液型を根拠に友人への役割や行動を押しつける</li>
        </ul>
        <p class="bf-harassment-note">
          本サイトは血液型を「友達との会話のきっかけ・自己理解のヒント」として楽しむことを推奨します。
          血液型による人物の断定・排除を勧める意図は一切ありません。
        </p>
      </div>
    </section>

    {/* ========== 4タイプの友達スタイル ========== */}
    <section class="bf-section" aria-labelledby="bf-types-h2">
      <h2 id="bf-types-h2" class="bf-h2">4タイプ別 友達としてのスタイル・特徴</h2>
      <p class="bf-lead">
        各タイプの友人関係における傾向を解説します。
        あくまで日本の血液型文化に基づく「傾向のイメージ」であり、個人差が大きい点に注意してください。
      </p>

      {friendPatterns.map(({ type, detail }) => (
        <div class="bf-type-card" id={`friend-type-${type}`}>
          <div class="bf-type-header">
            <div class="bf-type-badge">{typeLabels[type]}</div>
            <div class="bf-type-title-block">
              <h3 class="bf-type-name">{detail.name}の友達スタイル</h3>
              <p class="bf-type-nickname">「{detail.nickname}」</p>
            </div>
          </div>

          <div class="bf-friend-style-body">
            <p class="bf-friend-style-text">{detail.friendStyle}</p>
          </div>

          <div class="bf-type-grid">
            <div class="bf-type-col">
              <h4 class="bf-type-col-title bf-type-col-title--good">友達としての強み</h4>
              <ul class="bf-type-list">
                {detail.strengths.slice(0, 3).map((s) => <li>{s}</li>)}
              </ul>
            </div>
            <div class="bf-type-col">
              <h4 class="bf-type-col-title bf-type-col-title--care">友人関係で気をつけたい傾向</h4>
              <ul class="bf-type-list">
                {detail.weaknesses.slice(0, 3).map((w) => <li>{w}</li>)}
              </ul>
            </div>
          </div>

          <h4 class="bf-pair-title">
            {typeLabels[type]}が友達と付き合うとき——全4タイプとの友情相性
          </h4>
          <div class="bf-pair-list">
            {BLOOD_TYPES.map((partner) => {
              const compat = getCompatibility(type, partner);
              const bg = catBgs[compat.category] ?? '#f9fafb';
              const color = catColors[compat.category] ?? '#6b7280';
              return (
                <div class="bf-pair-item" style={`border-left: 4px solid ${color}; background: ${bg};`}>
                  <div class="bf-pair-header">
                    <span class="bf-pair-types" style={`color: ${color};`}>
                      {typeLabels[type]} × {typeLabels[partner]}
                    </span>
                    <span class="bf-pair-score" style={`color: ${color};`}>
                      {compat.score}点
                    </span>
                    <span class="bf-pair-category" style={`color: ${color};`}>
                      {getCategoryLabel(compat.category)}
                    </span>
                  </div>
                  <p class="bf-pair-friend-text">{compat.friendCompat}</p>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </section>

    {/* ========== 4×4 友情相性マトリクス ========== */}
    <section class="bf-section" aria-labelledby="bf-matrix-h2">
      <h2 id="bf-matrix-h2" class="bf-h2">友達としての血液型相性表（4×4 マトリクス）</h2>
      <p class="bf-lead">
        A・B・O・AB型の全16組み合わせを友情の観点でまとめます。
        数値は血液型文化に基づく傾向値であり、科学的測定値ではありません。
      </p>
      <div class="bf-matrix-wrap" role="region" aria-label="友達血液型相性マトリクス" tabindex="0">
        <table class="bf-matrix-table" aria-label="友達血液型相性スコア表">
          <caption class="bf-matrix-caption">
            友達としての血液型相性スコア（0〜100点・傾向値）
          </caption>
          <thead>
            <tr>
              <th class="bf-matrix-corner" scope="col" aria-label="タイプ1とタイプ2">型 ↓ × →</th>
              {BLOOD_TYPES.map((t) => (
                <th scope="col" class="bf-matrix-th">{typeLabels[t]}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {friendMatrixData.map((row, ri) => (
              <tr>
                <th scope="row" class="bf-matrix-th-row">{typeLabels[BLOOD_TYPES[ri]]}</th>
                {row.map((cell, ci) => {
                  const bg = catBgs[cell.category] ?? '#f9fafb';
