---
/**
 * 相性のいい血液型ページ
 * KW: 相性のいい血液型（VOL: 1,000 / SD: 15）
 *
 * 学術根拠:
 * - 古川竹二 (1927) 「血液型による気質の研究」心理学研究
 *   https://www.jstage.jst.go.jp/browse/psycholres
 * - 能見正比古 (1971) 『血液型でわかる相性』青春出版社
 *   https://www.seishun.co.jp/
 * - Sakamoto A, Yamazaki K (2004) International Journal of Psychology 39(4)
 *   https://doi.org/10.1080/00207590344000248
 * - 日本心理学会 公式見解 (2014)
 *   https://psych.or.jp/opinion/bl-personality/
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import { meta as bcMeta, BLOOD_TYPES } from '../../../../data/diagnoses/blood-compat/meta';
import {
  getCompatibility,
  getBestMatches,
  getGrowthMatches,
  getCategoryLabel,
  getCategoryColor,
} from '../../../../data/diagnoses/blood-compat/results';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/blood-compat/best-match/`;
const UPDATED_AT = '2026-05-21';

const pageTitle = '相性のいい血液型ランキング【TOP5・WORST5・シーン別】｜診断ナビ';
const pageDesc = '相性のいい血液型をランキング形式で徹底解説。全10ペアのスコアTOP5・WORST5・恋愛/結婚/友人シーン別ベストマッチを紹介。古川竹二（1927）・能見正比古（1971）の研究と日本心理学会見解を踏まえた正確な解説。';

// 全10ペアを重複なしで取得・スコア順ソート
const allPairsMap: Record<string, ReturnType<typeof getCompatibility>> = {};
BLOOD_TYPES.forEach((t1) => {
  BLOOD_TYPES.forEach((t2) => {
    const key = [t1, t2].sort().join('-');
    if (!allPairsMap[key]) {
      allPairsMap[key] = getCompatibility(t1, t2);
    }
  });
});
const allPairsSorted = Object.values(allPairsMap).sort((a, b) => b.score - a.score);

// TOP5 / WORST5
const top5 = allPairsSorted.slice(0, 5);
const worst5 = [...allPairsSorted].reverse().slice(0, 5);

// タイプ別ベストマッチ（各タイプのスコア1位）
const typeBestMatch = BLOOD_TYPES.map((type) => {
  const best = getBestMatches(type, 1)[0];
  const partner = best.type1 === type ? best.type2 : best.type1;
  return { type, best, partner };
});

// タイプ別「成長機会ペア」（スコア最低・ただし「最悪」ではなく「学び合い」として表示）
const typeGrowthMatch = BLOOD_TYPES.map((type) => {
  const growth = getGrowthMatches(type, 1)[0];
  const partner = growth.type1 === type ? growth.type2 : growth.type1;
  return { type, growth, partner };
});

// 4タイプ × 全ペアのベスト3
const allTypesBest3 = BLOOD_TYPES.map((type) => ({
  type,
  best3: getBestMatches(type, 3),
}));

// FAQ 12問
const faqs = [
  {
    question: '血液型の相性で一番いい組み合わせは何ですか？',
    answer:
      '本サイトのスコアでは、A型×A型（86点）が全10ペア中最高スコアです。2位はO型×O型（85点）、3位はB型×AB型（80点）です。ただしこれは日本の血液型性格分類文化に基づく傾向値であり、日本心理学会（2014年・https://psych.or.jp/opinion/bl-personality/）は血液型と性格の科学的相関は限定的と明言しています。',
  },
  {
    question: 'A型と相性のいい血液型はどれですか？',
    answer:
      '本サイトのスコアでは、A型との相性上位は1位A型（86点・深く理解し合えるペア）、2位AB型（78点・相性の良いペア）、3位O型（75点・相性の良いペア）です。A型×B型は45点（学び合いペア）です。ただしこれは文化的傾向値であり、個人差が大きい点に注意してください。',
  },
  {
    question: 'B型と相性のいい血液型はどれですか？',
    answer:
      '本サイトのスコアでは、B型との相性上位は1位AB型（80点・相性の良いペア）、2位O型（70点・相性の良いペア）、3位B型（65点・バランス型ペア）です。B型×A型は45点（学び合いペア）です。',
  },
  {
    question: 'O型と相性のいい血液型はどれですか？',
    answer:
      '本サイトのスコアでは、O型との相性上位は1位O型（85点・深く理解し合えるペア）、2位A型（75点・相性の良いペア）、3位B型（70点・相性の良いペア）です。O型×AB型は55点（バランス型ペア）です。',
  },
  {
    question: 'AB型と相性のいい血液型はどれですか？',
    answer:
      '本サイトのスコアでは、AB型との相性上位は1位B型（80点・相性の良いペア）、2位A型（78点・相性の良いペア）、3位AB型（68点・バランス型ペア）です。AB型×O型は55点（バランス型ペア）です。',
  },
  {
    question: '相性のいい血液型で結婚を決めてもいいですか？',
    answer:
      '推奨しません。日本心理学会（2014年）は「血液型と性格の間に科学的に明確な統計的相関は認められない」と明言しています（https://psych.or.jp/opinion/bl-personality/）。結婚という重要な決断を血液型スコアで決めることは、科学的根拠のない基準で相手を評価するリスクがあります。実際の対話・共通の価値観・生活観の一致を重視してください。',
  },
  {
    question: '相性のいい血液型同士でも別れることはありますか？',
    answer:
      'あります。血液型相性スコアは日本の文化的分類に基づく傾向値であり、実際の関係は個人の性格・コミュニケーション・環境・タイミングなど多くの要因で決まります。スコアが高くても関係が続くとは限らず、スコアが低くても深い絆を築いているカップルは多数います。',
  },
  {
    question: '血液型相性ランキングのスコアはどのように計算されていますか？',
    answer:
      '能見正比古（1971）の伝統的相性論（青春出版社）を「文化的分類」として参照し、傾向値として0〜100点で数値化しています。科学的な効果量（d値）を測定したものではありません。あくまで日本の血液型文化における「相性のイメージ」を参考情報として整理したものです。',
  },
  {
    question: '相性が悪い血液型の組み合わせとはどう付き合えばいいですか？',
    answer:
      '本サイトでは「相性が悪い」という表現を使いません。スコアが低い組み合わせは「学び合いペア」「成長機会の多いペア」として位置づけています。違うスタイルを持つ相手からは、自分とは異なる視点・価値観・アプローチを学べます。「違い」を問題ではなく資源として捉えることが大切です。',
  },
  {
    question: '「相性のいい血液型」を恋愛で使う際の注意点は？',
    answer:
      '血液型相性は「話題のきっかけ」として楽しむことを推奨します。血液型だけで交際相手を選んだり断ったりすることは、科学的根拠のない判断で相手を評価するリスクがあります。実際に会って話し、価値観や目標の一致を確認することが、良い関係を築く近道です。',
  },
  {
    question: 'MBTIと血液型、相性判断にはどちらが参考になりますか？',
    answer:
      'MBTIはKeirsey（1998）・Jung（1921）の心理学理論に基づいており、血液型性格分類より多くの学術的研究に裏付けられています。日本心理学会（2014）は「血液型と性格の科学的相関は認められない」と明言しています。より参考にしたい場合はMBTI相性（/diagnosis/mbti-compat/）も合わせてご覧ください。',
  },
  {
    question: '血液型相性が悪いと言われる組み合わせでも仲良くなれますか？',
    answer:
      'もちろんです。本サイトのスコアが低い組み合わせでも、実際に深い友情や長続きする恋愛を築いている方は大勢います。血液型は「傾向のイメージ」に過ぎず、実際の関係は対話・相互尊重・共通の経験から形成されます。スコアを固定的な判断基準にしないことを強く推奨します。',
  },
];

// JSON-LD
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: '相性のいい血液型ランキング【TOP5・WORST5・シーン別】',
  description: pageDesc,
  url: PAGE_URL,
  datePublished: UPDATED_AT,
  dateModified: UPDATED_AT,
  inLanguage: 'ja',
  author: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: '診断ナビ' },
  publisher: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: '診断ナビ' },
  citation: bcMeta.references.map((ref) => ({
    '@type': ref.url.includes('doi.org') ? 'ScholarlyArticle' : 'Book',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    publisher: ref.publisher,
    url: ref.url,
  })),
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '血液型相性診断', item: `${SITE_URL}/diagnosis/blood-compat/` },
    { '@type': 'ListItem', position: 4, name: '相性のいい血液型', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

const catColors: Record<string, string> = {
  soulmate: '#8B5CF6',
  good: '#10B981',
  neutral: '#3B82F6',
  growth: '#F59E0B',
  challenge: '#EF4444',
};
const catBgs: Record<string, string> = {
  soulmate: '#f3e8ff',
  good: '#d1fae5',
  neutral: '#dbeafe',
  growth: '#fef3c7',
  challenge: '#fee2e2',
};

const typeLabels: Record<string, string> = { A: 'A型', B: 'B型', O: 'O型', AB: 'AB型' };
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  ogImage="/og/blood-type.svg"
  publishDate={UPDATED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '血液型相性診断', url: '/diagnosis/blood-compat/' },
    { name: '相性のいい血液型', url: '/diagnosis/blood-compat/best-match/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="page-hero page-hero--coral" aria-labelledby="bm-hero-h1">
    <Container>
      <div class="bm-hero-inner">
        <div class="bm-hero-badge">古川竹二（1927）・能見正比古（1971）研究 + 日本心理学会見解</div>
        <h1 id="bm-hero-h1" class="bm-hero-h1">
          相性のいい血液型ランキング<br />
          <span class="bm-hero-meta">【全10ペア TOP5・WORST5・シーン別ベストマッチ】</span>
        </h1>
        <p class="bm-hero-catch">
          A型・B型・O型・AB型、最も相性がいいのはどの組み合わせ？<br />
          恋愛・結婚・友人のシーン別ベストマッチを徹底解説
        </p>
        <div class="bm-hero-stats">
          <span class="bm-stat"><strong>10</strong>ペア</span>
          <span class="bm-stat-sep">全分析</span>
          <span class="bm-stat-sep">・</span>
          <span class="bm-stat">3シーン別</span>
          <span class="bm-stat-sep">・</span>
          <span class="bm-stat">無料</span>
          <span class="bm-stat-sep">・</span>
          <span class="bm-stat">登録不要</span>
        </div>
        <p class="bm-hero-sub">
          <time datetime={UPDATED_AT}>{UPDATED_AT}</time> 時点の情報
        </p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== このページでわかること ========== */}
    <div class="bm-aio-block" role="note" aria-label="このページでわかること">
      <p class="bm-aio-title">このページでわかること</p>
      <ul class="bm-aio-list">
        <li>全10ペアの相性スコアTOP5（最高相性）とWORST5（最大の学び合いペア）</li>
        <li>各タイプの「最高相性ペア」と「成長機会の多いペア」</li>
        <li>恋愛・結婚・友人 シーン別のベストマッチ比較</li>
        <li>スコアの見方と正しい活用法（日本心理学会 2014年公式見解を踏まえて）</li>
      </ul>
      <p class="bm-aio-updated">
        参照元:
        <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">日本心理学会（2014）</a>・
        <a href="https://doi.org/10.1080/00207590344000248" target="_blank" rel="noopener noreferrer">Sakamoto &amp; Yamazaki（2004）</a>
        を確認済。
      </p>
    </div>

    {/* ========== TldrBlock ========== */}
    <TldrBlock
      title="相性のいい血液型 ポイントまとめ"
      points={[
        '全10ペア最高スコア: A型×A型（86点）。2位O型×O型（85点）、3位B型×AB型（80点）、4位A型×AB型（78点）、5位A型×O型（75点）',
        '各タイプの最高相性: A型→A型（86点）、B型→AB型（80点）、O型→O型（85点）、AB型→B型（80点）',
        '日本心理学会（2014）公式見解: 「血液型と性格の科学的統計的相関は認められない」。スコアは文化的傾向値であり科学的測定値ではない',
        '血液型で結婚・交際・友人を選別することは推奨しない。採用で血液型を使うことはブラハラ（血液型ハラスメント）に該当する可能性がある',
        '「相性のいい血液型」は会話のきっかけ・自己理解のヒントとして活用。実際の相性は対話・共通の価値観・コミュニケーションで形成される',
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="日本心理学会 公式見解（2014）"
      sourceUrl="https://psych.or.jp/opinion/bl-personality/"
    />

    {/* ========== TOP5 ランキング ========== */}
    <section class="bm-section" aria-labelledby="bm-top5-h2">
      <h2 id="bm-top5-h2" class="bm-h2">血液型相性ランキング TOP5（最高相性ペア）</h2>
      <p class="bm-lead">
        全10ペアの相性スコアを高い順に並べました。
        スコアは能見正比古（1971）の相性論を「文化的分類」として参照した傾向値です。
        科学的に厳密な相関は限定的です（日本心理学会 2014）。
      </p>
      <ol class="bm-ranking-list">
        {top5.map((pair, idx) => {
          const color = catColors[pair.category] ?? '#6b7280';
          const bg = catBgs[pair.category] ?? '#f9fafb';
          return (
            <li class="bm-ranking-item" style={`border-left: 5px solid ${color}; background: ${bg};`}>
              <div class="bm-ranking-num-block" style={`color: ${color};`}>
                <span class="bm-ranking-pos">{idx + 1}</span>
                <span class="bm-ranking-pos-label">位</span>
              </div>
              <div class="bm-ranking-info">
                <div class="bm-ranking-header">
                  <span class="bm-ranking-pair" style={`color: ${color};`}>
                    {typeLabels[pair.type1]} × {typeLabels[pair.type2]}
                  </span>
                  <span class="bm-ranking-score" style={`color: ${color};`}>{pair.score}点</span>
                  <span class="bm-ranking-cat">{getCategoryLabel(pair.category)}</span>
                </div>
                <p class="bm-ranking-summary">{pair.oneLineSummary}</p>
                <p class="bm-ranking-detail">{pair.detailDescription}</p>
                <div class="bm-ranking-scenes">
                  <div class="bm-ranking-scene">
                    <span class="bm-scene-label">恋愛</span>
                    <p class="bm-scene-text">{pair.loveCompat}</p>
                  </div>
                  <div class="bm-ranking-scene">
                    <span class="bm-scene-label">友人</span>
                    <p class="bm-scene-text">{pair.friendCompat}</p>
                  </div>
                  <div class="bm-ranking-scene">
                    <span class="bm-scene-label">仕事</span>
                    <p class="bm-scene-text">{pair.workCompat}</p>
                  </div>
                </div>
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    {/* ========== WORST5（学び合いペア） ========== */}
    <section class="bm-section" aria-labelledby="bm-worst5-h2">
      <h2 id="bm-worst5-h2" class="bm-h2">学び合いペアランキング（WORST5）</h2>
      <div class="bm-worst-note" role="note">
        <p>
          本サイトでは「相性が悪い」という表現は使いません。
          スコアが低い組み合わせは<strong>「最大の学び合いペア」</strong>として位置づけています。
          違うスタイルがあるからこそ、互いの視野を広げ合える関係になれます。
        </p>
      </div>
      <ol class="bm-ranking-list">
        {worst5.map((pair, idx) => {
          const color = catColors[pair.category] ?? '#6b7280';
          const bg = catBgs[pair.category] ?? '#f9fafb';
          return (
            <li class="bm-ranking-item" style={`border-left: 5px solid ${color}; background: ${bg};`}>
              <div class="bm-ranking-num-block" style={`color: ${color};`}>
                <span class="bm-ranking-pos">{idx + 1}</span>
              </div>
              <div class="bm-ranking-info">
                <div class="bm-ranking-header">
                  <span class="bm-ranking-pair" style={`color: ${color};`}>
                    {typeLabels[pair.type1]} × {typeLabels[pair.type2]}
                  </span>
                  <span class="bm-ranking-score" style={`color: ${color};`}>{pair.score}点</span>
                  <span class="bm-ranking-cat">{getCategoryLabel(pair.category)}</span>
                </div>
                <p class="bm-ranking-summary">{pair.oneLineSummary}</p>
                <p class="bm-ranking-detail">{pair.growthPoint}</p>
              </div>
            </li>
          );
        })}
      </ol>
    </section>

    {/* ========== タイプ別最高相性 ========== */}
    <section class="bm-section" aria-labelledby="bm-type-best-h2">
      <h2 id="bm-type-best-h2" class="bm-h2">タイプ別 最高相性ペア・成長機会ペア</h2>
      <p class="bm-lead">
        各血液型の「スコア最高」ペアと「最も異なるスタイルを持つ」ペアを示します。
      </p>
      <div class="bm-type-best-grid">
        {BLOOD_TYPES.map((type) => {
          const best = typeBestMatch.find((b) => b.type === type)!;
          const growth = typeGrowthMatch.find((g) => g.type === type)!;
          const bestColor = catColors[best.best.category] ?? '#6b7280';
          const bestBg = catBgs[best.best.category] ?? '#f9fafb';
          const growthColor = catColors[growth.growth.category] ?? '#6b7280';
          const growthBg = catBgs[growth.growth.category] ?? '#f9fafb';
          return (
            <div class="bm-type-best-card">
              <div class="bm-type-best-header">
                <div class="bm-type-best-badge">{typeLabels[type]}</div>
                <h3 class="bm-type-best-name">{typeLabels[type]} の相性まとめ</h3>
              </div>
              <div class="bm-type-best-row" style={`background: ${bestBg}; border-left: 3px solid ${bestColor};`}>
                <span class="bm-type-best-label" style={`color: ${bestColor};`}>最高相性</span>
                <div class="bm-type-best-content">
                  <span class="bm-type-best-partner" style={`color: ${bestColor};`}>
                    {typeLabels[type]} × {typeLabels[best.partner]}（{best.best.score}点）
                  </span>
                  <p class="bm-type-best-text">{best.best.oneLineSummary}</p>
                </div>
              </div>
              <div class="bm-type-best-row" style={`background: ${growthBg}; border-left: 3px solid ${growthColor};`}>
                <span class="bm-type-best-label" style={`color: ${growthColor};`}>学び合いペア</span>
                <div class="bm-type-best-content">
                  <span class="bm-type-best-partner" style={`color: ${growthColor};`}>
                    {typeLabels[type]} × {typeLabels[growth.partner]}（{growth.growth.score}点）
                  </span>
                  <p class="bm-type-best-text">{growth.growth.growthPoint}</p>
                </div>
              </div>
              <div class="bm-type-best-top3">
                <p class="bm-type-best-top3-title">ベスト3：</p>
