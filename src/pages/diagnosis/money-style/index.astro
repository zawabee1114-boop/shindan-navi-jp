<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  ogImage="/og/money-style.png"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '金銭感覚診断', url: '/diagnosis/money-style/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="ms-hero" aria-labelledby="ms-hero-h1">
    <Container>
      <div class="ms-hero-inner">
        <div class="ms-hero-badge">Klontz et al. (2011) マネースクリプト理論 準拠 | YMYL配慮・医学的診断ではありません</div>
        <h1 id="ms-hero-h1" class="ms-hero-h1">
          金銭感覚診断<br />
          <span class="ms-hero-meta">【無料・3分・24問・Klontz理論】</span>
        </h1>
        <p class="ms-hero-catch">
          あなたのお金の価値観はどのタイプ？<br />
          回避型・崇拝型・地位型・用心型の4つから判定
        </p>
        <div class="ms-hero-stats">
          <span class="ms-stat"><strong>24</strong>問</span>
          <span class="ms-stat-sep">・</span>
          <span class="ms-stat">約<strong>3</strong>分</span>
          <span class="ms-stat-sep">・</span>
          <span class="ms-stat"><strong>4</strong>タイプ</span>
          <span class="ms-stat-sep">・</span>
          <span class="ms-stat">無料</span>
        </div>
        <a href="#diagnosis-flow" class="ms-cta-btn">
          <span>診断スタート</span>
          <span class="ms-cta-arrow" aria-hidden="true">↓</span>
        </a>
        <p class="ms-hero-sub">登録不要・所要時間3分・途中保存OK</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== AIOブロック（このページでわかること） ========== */}
    <div class="ms-aio-block" role="note" aria-label="このページでわかること">
      <p class="ms-aio-title">このページでわかること</p>
      <ul class="ms-aio-list">
        <li>24問・5段階リッカートで測る金銭感覚4タイプ（Klontz BT et al. 2011年 KMSI準拠）</li>
        <li>タイプ別の消費パターン・貯蓄傾向・キャリアへの影響・他タイプとの相性（スコア付き）</li>
        <li>パートナーとの金銭感覚チェック・4×4相性マトリクス・タイプ別改善ヒント</li>
      </ul>
      <p class="ms-aio-updated">
        <time datetime={meta.updatedAt}>{meta.updatedAt}</time> 時点の情報。
        <a href="https://doi.org/10.4148/jft.v2i1.451" target="_blank" rel="noopener noreferrer">
          Klontz et al. (2011) KMSI
        </a>
        を確認済。本診断は金融商品の推奨・投資助言ではありません。
      </p>
    </div>

    {/* ========== TL;DRブロック（AI Overview引用最適化） ========== */}
    <TldrBlock
