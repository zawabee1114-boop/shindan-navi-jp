    {/* ========== 使い方 ========== */}
    <section class="ms-section" aria-labelledby="ms-how-h2">
      <h2 id="ms-how-h2" class="ms-h2">使い方（3ステップ）</h2>
      <ol class="ms-steps">
        <li class="ms-step">
          <div class="ms-step-num" aria-hidden="true">1</div>
          <div class="ms-step-body">
            <h3 class="ms-step-title">「診断スタート」をタップ</h3>
            <p class="ms-step-desc">
              登録・インストール不要。ブラウザですぐ始められます。
              途中で閉じても24時間以内なら再開できます。
            </p>
          </div>
        </li>
        <li class="ms-step">
          <div class="ms-step-num" aria-hidden="true">2</div>
