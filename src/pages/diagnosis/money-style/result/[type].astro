---
/**
 * 金銭感覚診断 結果ページ（動的ルート）
 * 4タイプ分の結果ページを静的生成する
 *
 * URL: /diagnosis/money-style/result/{typeId}/
 * タイプID: avoidance / worship / status / vigilance
 *
 * SEO/AIO:
 * - JSON-LD: WebApplication + Article + BreadcrumbList
 * - タイプ別メタタイトル・ディスクリプション
 * - 3タイプとの相性ランキング（スコア順）
 * - 消費パターン・貯蓄パターンセクション
 * - パートナーシップでの相性傾向
 * - キャリア・仕事への影響
 * - self-care セクション（このタイプが大切にすべきこと）
 * - YMYL回避: 投資推奨・金融商品比較・税務助言 絶対NG
 * - LGBTQ+配慮: 「パートナー」表現
 * - 「守銭奴」「ケチ」等スティグマ表現NG
 *
 * 確認日: 2026-05-21
 */
import ResultLayout from '../../../../layouts/ResultLayout.astro';
import Container from '../../../../components/Container.astro';
import { types, getOtherTypes } from '../../../../data/diagnoses/money-style/types';
import { meta } from '../../../../data/diagnoses/money-style/meta';
import { getAllPairsForType } from '../../../../data/diagnoses/money-style/compatibility';
import type { MoneyType } from '../../../../data/diagnoses/money-style/questions';

export function getStaticPaths() {
  return Object.keys(types).map((typeId) => ({
    params: { type: typeId },
    props: {
      typeId: typeId as MoneyType,
      typeData: types[typeId as MoneyType],
    },
  }));
}

const { typeId, typeData } = Astro.props;

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/money-style/result/${typeId}/`;

// 3タイプとの相性ランキング（スコア降順）
const compatibilityRanking = getAllPairsForType(typeId);

// タイプ別テーマカラー
const typeColor: Record<MoneyType, string> = {
  avoidance: '#16a34a',
  worship: '#d97706',
  status: '#7c3aed',
  vigilance: '#2563eb',
};

// 相性カテゴリの色
const categoryColor: Record<string, string> = {
  '非常に高い相性': '#16a34a',
  '良い相性': '#2563eb',
  '補完し合える関係': '#d97706',
  '対話が必要なペア': '#7c3aed',
  '学び合いペア': '#dc2626',
};

// FAQs（タイプ別）
const faqs = [
  {
    question: `${typeData.japaneseName}の金銭感覚の特徴は？`,
    answer: typeData.characteristics.slice(0, 3).join('。') + '。',
  },
  {
    question: `${typeData.japaneseName}はどんな強みがありますか？`,
    answer: typeData.strengths.join('。また、') + '。',
  },
  {
    question: `${typeData.japaneseName}が気をつけたい金銭パターンは？`,
    answer:
      typeData.weaknesses[0] +
      '。' +
      typeData.weaknesses[1] +
      '。ただし、これらは弱点ではなく傾向の特徴です。自分のパターンを知ることが改善の第一歩になります。',
  },
  {
    question: `${typeData.japaneseName}と最も相性の良い金銭感覚タイプは？`,
    answer:
      compatibilityRanking.length > 0
        ? `${types[compatibilityRanking[0].typeId].japaneseName}との相性が最も高い傾向があります（スコア: ${compatibilityRanking[0].compatibility.score}/100）。${compatibilityRanking[0].compatibility.oneLineSummary}`
        : '相性は個人差があります。対話を重ねることが最も重要です。',
  },
  {
    question: `${typeData.japaneseName}のキャリアへの影響は？`,
    answer: typeData.careerImplication,
  },
];

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: `金銭感覚診断 結果：${typeData.japaneseName}（${typeData.nameEn}）`,
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description: `金銭感覚診断の結果は「${typeData.japaneseName}」。${typeData.catchphrase}`,
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
};

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  headline: `${typeData.japaneseName}（${typeData.nameEn}）の金銭感覚・消費傾向・相性ランキング完全ガイド`,
  url: PAGE_URL,
  description: `金銭感覚診断の結果「${typeData.japaneseName}」の消費パターン・貯蓄傾向・強み・気をつけたい点・3タイプとの相性ランキングを詳しく解説。Klontz et al.（2011）マネースクリプト理論に基づく自己理解ガイド。`,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  about: {
    '@type': 'Thing',
    name: `${typeData.japaneseName} マネースクリプト`,
    sameAs: 'https://doi.org/10.4148/jft.v2i1.451',
  },
  citation: [
    {
      '@type': 'CreativeWork',
      name: 'Money beliefs and financial behaviors: Development of the Klontz Money Script Inventory',
      author: 'Klontz BT, Britt SL, Mentzer J, Klontz T',
      datePublished: '2011',
      url: 'https://doi.org/10.4148/jft.v2i1.451',
    },
    {
      '@type': 'CreativeWork',
      name: 'Many sides of the coin: The psychology of money usage',
      author: 'Furnham A',
      datePublished: '1984',
    },
  ],
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '金銭感覚診断', item: `${SITE_URL}/diagnosis/money-style/` },
    { '@type': 'ListItem', position: 4, name: typeData.japaneseName, item: PAGE_URL },
  ],
};

// JSON-LD: FAQPage
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

const jsonLdAll = [jsonLdWebApp, jsonLdArticle, jsonLdBreadcrumb, jsonLdFAQ];

// 関連診断
const relatedDiagnoses = [
  { title: '恋愛スタイル診断', href: '/diagnosis/love-style/', icon: '💕', badge: 'おすすめ' },
  { title: 'DiSC診断', href: '/diagnosis/disc/', icon: '💼' },
  { title: '完璧主義診断', href: '/diagnosis/perfectionism/', icon: '🔱' },
  { title: '多重知能テスト', href: '/diagnosis/multi-int/', icon: '🦉' },
];

// description の改行を除去
const descriptionClean = typeData.description.replace(/\n+/g, ' ').trim();
---

<ResultLayout
  diagnosisId="money-style"
  typeId={typeId}
  typeName={typeData.japaneseName}
  diagnosisName="金銭感覚診断"
  characterEmoji={typeData.emoji}
  characterName={typeData.nameEn}
  tagline={typeData.catchphrase}
  shareUrl={PAGE_URL}
  pageTitle={`${typeData.japaneseName}【金銭感覚診断】消費傾向・強み・相性ランキング | 診断ナビ`}
  pageDescription={`金銭感覚診断の結果は「${typeData.japaneseName}（${typeData.nameEn}）」。${typeData.catchphrase} 消費パターン・貯蓄傾向・強み・気をつけたい点・3タイプとの相性ランキングを詳しく解説。Klontz et al.（2011）マネースクリプト理論に基づく自己理解ガイド。`}
  relatedDiagnoses={relatedDiagnoses}
  jsonLd={jsonLdAll}
>
  {/* ========== 概要タブ ========== */}
  <Fragment slot="overview">
    <div class="msr-overview">
      <div class="msr-aio-block">
        <p class="msr-aio-title">このページでわかること</p>
        <ul class="msr-aio-list">
          <li>{typeData.japaneseName}（{typeData.nameEn}）の金銭感覚・消費傾向・貯蓄パターン・特徴・強み・気をつけたい点</li>
          <li>他3タイプとの相性ランキング（スコア順・Klontz et al. 2011年理論に基づく）</li>
          <li>パートナーシップでの相性傾向・キャリアへの影響・このタイプが大切にすべきこと（self-care）</li>
        </ul>
      </div>

      <div class="msr-description">
        {descriptionClean.split('。').filter(s => s.trim()).map((sentence) => (
          <p class="msr-body">{sentence.trim()}。</p>
        ))}
      </div>

      <div class="msr-characteristics">
        <h3 class="msr-h3">このタイプの5つの特徴</h3>
        <ul class="msr-char-list">
          {typeData.characteristics.map((char) => (
            <li class="msr-char-item">
              <span class="msr-char-icon" aria-hidden="true" style={`color: ${typeColor[typeId]}`}>◆</span>
              <span>{char}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="msr-theory-note">
        <p>
          この診断結果はKlontz BT et al.（2011）「Money beliefs and financial behaviors: Development of the Klontz Money Script Inventory」
          （<a href="https://doi.org/10.4148/jft.v2i1.451" target="_blank" rel="noopener noreferrer">Journal of Financial Therapy, DOI確認済</a>）
          に基づく金銭感覚傾向把握のための参考情報です。
          医学的・臨床的な診断ではありません。投資推奨・金融商品比較・税務助言は含みません。
        </p>
      </div>

      <div class="msr-freshness">
        <time datetime={meta.updatedAt}>{meta.updatedAt}</time> 時点の情報。
        月1回以上の鮮度確認を実施しています。
      </div>
    </div>
  </Fragment>

  {/* ========== 強みタブ ========== */}
  <Fragment slot="strengths">
    <div class="msr-strengths">
      <h3 class="msr-section-h3">{typeData.japaneseName}の4つの強み</h3>
      <ul class="msr-strength-list">
        {typeData.strengths.map((s) => (
          <li class="msr-strength-item">
            <span class="msr-strength-icon" aria-hidden="true">✅</span>
            <span>{s}</span>
          </li>
        ))}
      </ul>
    </div>
  </Fragment>

  {/* ========== 注意点タブ ========== */}
  <Fragment slot="weaknesses">
    <div class="msr-weaknesses">
      <h3 class="msr-section-h3">気をつけたい傾向</h3>
      <ul class="msr-weakness-list">
        {typeData.weaknesses.map((w) => (
          <li class="msr-weakness-item">
            <span class="msr-weakness-icon" aria-hidden="true">⚡</span>
            <span>{w}</span>
          </li>
        ))}
      </ul>
      <div class="msr-weakness-note">
        これらは「弱点」ではなく「傾向の特徴」です。
        自分のパターンを理解することが、健全な金銭感覚を育てる第一歩になります。
      </div>
    </div>
  </Fragment>

  {/* ========== 仕事タブ（消費・貯蓄・キャリア） ========== */}
  <Fragment slot="work">
    <div class="msr-work">
      {/* 消費パターン */}
      <div class="msr-pattern-block">
        <h3 class="msr-section-h3">消費パターン</h3>
        <p class="msr-body">{typeData.spendingPattern}</p>
      </div>

      {/* 貯蓄パターン */}
      <div class="msr-pattern-block" style="margin-top: 1.5rem;">
        <h3 class="msr-section-h3">貯蓄パターン</h3>
        <p class="msr-body">{typeData.savingPattern}</p>
      </div>

      {/* キャリア・仕事への影響 */}
      <div class="msr-pattern-block" style="margin-top: 1.5rem;">
        <h3 class="msr-section-h3">キャリア・仕事への影響</h3>
        <p class="msr-body">{typeData.careerImplication}</p>
        <div class="msr-career-note">
          <p>
            本診断はキャリア設計の参考情報です。
            具体的な転職・昇進・収入向上については、専門家（キャリアカウンセラー等）にご相談ください。
          </p>
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 恋愛タブ（相性ランキング・パートナーシップ・self-care） ========== */}
  <Fragment slot="love">
    <div class="msr-love">
      {/* 相性ランキング */}
      <h3 class="msr-section-h3">3タイプとの相性ランキング</h3>
      <p class="msr-love-note">
        Klontz et al.（2011）理論に基づく傾向値です。個人差があり、対話と相互理解が最も重要です。
        「スコアが低い = うまくいかない」ではありません。
      </p>
      <div class="msr-compat-list">
        {compatibilityRanking.map((item, index) => {
          const otherType = types[item.typeId];
          const catColor = categoryColor[item.compatibility.category] ?? '#6b7280';
          return (
            <div class="msr-compat-item">
              <div class="msr-compat-rank" aria-hidden="true">{index + 1}</div>
              <div class="msr-compat-body">
                <div class="msr-compat-header">
                  <span class="msr-compat-emoji">{otherType.emoji}</span>
                  <span class="msr-compat-name">{otherType.japaneseName}</span>
                  <span class="msr-compat-score" style={`color: ${catColor}`}>
                    {item.compatibility.score}/100
                  </span>
                  <span class="msr-compat-category" style={`background: ${catColor}15; color: ${catColor}; border-color: ${catColor}40`}>
                    {item.compatibility.category}
                  </span>
                </div>
                <p class="msr-compat-summary">{item.compatibility.oneLineSummary}</p>
                <p class="msr-compat-detail">{item.compatibility.detailDescription}</p>
                <div class="msr-compat-sub">
                  <div class="msr-compat-sub-item">
                    <span class="msr-compat-sub-label">金銭管理の相性</span>
                    <span class="msr-compat-sub-text">{item.compatibility.moneyManagement}</span>
                  </div>
                  <div class="msr-compat-sub-item">
                    <span class="msr-compat-sub-label">衝突しやすい点</span>
                    <span class="msr-compat-sub-text">{item.compatibility.conflictArea}</span>
                  </div>
                  <div class="msr-compat-sub-item">
                    <span class="msr-compat-sub-label">成長の機会</span>
                    <span class="msr-compat-sub-text">{item.compatibility.growthPotential}</span>
                  </div>
                  <div class="msr-compat-sub-item">
                    <span class="msr-compat-sub-label">カップルへのアドバイス</span>
                    <span class="msr-compat-sub-text">{item.compatibility.adviceForCouple}</span>
                  </div>
                </div>
                <a href={`/diagnosis/money-style/result/${item.typeId}/`} class="msr-compat-link">
                  {otherType.japaneseName}の詳細を見る →
                </a>
              </div>
            </div>
          );
        })}
      </div>

      {/* パートナーシップでの相性傾向 */}
      <div class="msr-partner-block" style="margin-top: 2rem;">
        <h3 class="msr-section-h3">パートナーシップでの相性傾向</h3>
        <p class="msr-body">{typeData.partnerCompatibility}</p>
        <div class="msr-partner-tips">
          <h4 class="msr-h4">結婚・同棲前に話し合うと良いこと</h4>
          <ul class="msr-partner-list">
            <li>毎月の家計分担の方法・共同口座の有無</li>
            <li>貯蓄目標と緊急資金の考え方</li>
            <li>大きな支出をする際の決め方のルール</li>
            <li>将来のライフイベント（住宅・教育費・老後）への備え</li>
          </ul>
        </div>
        <div class="msr-partner-note">
          <p>
            本診断の相性情報は傾向値です。
            パートナーとの金銭感覚のすり合わせに困難を感じる場合は、
            ファイナンシャルプランナー（FP）等の専門家への共同相談を検討してください。
          </p>
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 友人タブ（パートナーシップの補足） ========== */}
  <Fragment slot="friend">
    <div class="msr-friend">
      <h3 class="msr-section-h3">友人・職場での金銭感覚</h3>
      <p class="msr-body">
        金銭感覚は友人・職場の対人関係にも影響することがあります。
        {typeData.japaneseName}の特徴は次の通りです。
      </p>
      <ul class="msr-friend-list">
        {typeData.characteristics.slice(0, 3).map((c) => (
          <li class="msr-friend-item">
            <span class="msr-friend-icon" aria-hidden="true" style={`color: ${typeColor[typeId]}`}>◆</span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
      <div class="msr-friend-note">
        <p>
          職場での金銭感覚の影響（給与交渉・経費精算・チームの予算意識など）については、
          DiSC診断などのキャリア系診断と組み合わせるとより深い自己理解が得られます。
        </p>
        <a href="/diagnosis/disc/" class="msr-friend-link">DiSC診断を受ける →</a>
      </div>
    </div>
  </Fragment>

  {/* ========== 家族タブ ========== */}
  <Fragment slot="family">
    <div class="msr-family">
      <h3 class="msr-section-h3">{typeData.japaneseName}と家族の金銭感覚</h3>
      <p class="msr-body">
        {typeData.japaneseName}の金銭感覚は、家庭内のお金の話し合い・子どもへのお金の教育・
        親との関係においても現れることがあります。
      </p>
      <p class="msr-body">
        {typeData.characteristics[0]}という傾向が、家族内での金銭管理のスタイルに影響することがあります。
      </p>
      <div class="msr-pass-cta">
        <p class="msr-pass-desc">
          家族の金銭感覚について詳しく知りたい場合は、家族全員でそれぞれ診断を受けてみましょう。
        </p>
        <a href="/diagnosis/money-style/" class="msr-pass-btn">
          <span>金銭感覚診断トップへ</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Fragment>

  {/* ========== 学校タブ ========== */}
  <Fragment slot="school">
    <div class="msr-school">
      <h3 class="msr-section-h3">{typeData.japaneseName}のお金の学び方</h3>
      <p class="msr-body">
        金銭感覚は学ぶことで変えることができます。
        Klontz et al.（2011）は「マネースクリプトへの気づきが財務行動の改善の第一歩」であることを示しています。
      </p>
      <div class="msr-learning-block">
        <h4 class="msr-h4">{typeData.japaneseName}におすすめの学び方</h4>
        <ul class="msr-learning-list">
          <li>自分の金銭感覚パターンを日記・メモで記録する</li>
          <li>家計簿アプリ（Money Forward・Zaimなど）で収支を可視化する</li>
          <li>ファイナンシャルプランナー（FP）に1度相談してみる</li>
          <li>パートナーとお互いの診断結果を共有し話し合う</li>
        </ul>
      </div>
      <div class="msr-school-note">
        <p>
          本診断は金融教育の参考情報です。
          具体的な資産形成・節税については必ず専門家にご相談ください。
        </p>
      </div>
    </div>
  </Fragment>

  {/* ========== 有名人タブ ========== */}
  <Fragment slot="celebrity">
    <div class="msr-celebrity">
      <h3 class="msr-section-h3">{typeData.japaneseName}の行動類型</h3>
      <p class="msr-body">
        {typeData.japaneseName}（{typeData.nameEn}）は、Klontz et al.（2011）のKMSIにおいて、
        次のような行動的・心理的特徴を持つ傾向があるとされています。
      </p>
      <ul class="msr-celeb-list">
        {typeData.characteristics.map((c) => (
          <li class="msr-celeb-item">
            <span class="msr-celeb-icon" aria-hidden="true" style={`color: ${typeColor[typeId]}`}>→</span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
      <div class="msr-celeb-note">
        <p>
          特定の個人をタイプに当てはめる診断は、プライバシーへの配慮から掲載を控えています。
          ご自身の傾向の理解にご活用ください。
        </p>
      </div>
    </div>
  </Fragment>

  {/* ========== 成長タブ（self-care） ========== */}
  <Fragment slot="growth">
    <div class="msr-growth">
      <h3 class="msr-section-h3">{typeData.japaneseName}が大切にすべきこと（self-care）</h3>
