---
/**
 * 完璧主義診断 ランディングページ
 * KW: 完璧主義診断（穴場KW・Phase 1第2優先）
 * 学術根拠: Hewitt & Flett (1991) + Frost et al. (1990) + Stoeber & Otto (2006)
 * 確認日: 2026-05-20
 *
 * SEO/AIO対応:
 * - JSON-LD: WebApplication + Quiz + FAQPage + BreadcrumbList
 * - AIOブロック: 「このページでわかること」
 * - YMYL回避: 医学的診断・治療表記ゼロ。傾向把握のみ
 * - 4タイプ（徹底型/こだわり型/先延ばし型/期待型）
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import DiagnosisFlow from '../../../components/DiagnosisFlow';
import { meta } from '../../../data/diagnoses/perfectionism/meta';
import { questions } from '../../../data/diagnoses/perfectionism/questions';
import { calculateResultTypeId } from '../../../data/diagnoses/perfectionism/results';
import TldrBlock from '../../../components/TldrBlock.astro';
import ReferenceList from '../../../components/ReferenceList.astro';
import ScienceNote from '../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/perfectionism/`;

// DiagnosisFlow に渡す questions を diagnosis.ts の Question 型に変換
const flowQuestions = questions.map((q) => ({
  id: String(q.id),
  text: q.text,
}));

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: '完璧主義診断【無料・3分・28問】',
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description:
    'Hewitt & Flett (1991) の多次元完璧主義尺度に基づく無料の完璧主義診断。28問に答えるだけで「徹底型」「こだわり型」「先延ばし型」「期待型」の4タイプを判定。仕事・恋愛・日常での向き合い方がわかります。',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// JSON-LD: Quiz（citation に学術文献を配置）
const jsonLdQuiz = {
  '@context': 'https://schema.org',
  '@type': 'Quiz',
  '@id': `${PAGE_URL}#quiz`,
  name: '完璧主義診断（28問）',
  url: PAGE_URL,
  about: {
    '@type': 'Thing',
    name: '完璧主義（Perfectionism）心理学',
    description: 'Hewitt & FlettおよびFrost et al.が研究した多次元完璧主義の理論',
    sameAs: 'https://doi.org/10.1037/0022-3514.60.3.456',
  },
  educationalLevel: 'HighSchool',
  numberOfQuestions: meta.questionCount,
  assesses: '完璧主義タイプ・仕事スタイル・自己向き合い方',
  dateCreated: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  citation: meta.references.map((ref) => ({
    '@type': 'ScholarlyArticle',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    url: ref.url,
  })),
};

// FAQ 12問（7問→12問に拡充・AI Overview最適化・2026-05-21更新）
const faqs = [
  {
    question: '完璧主義診断とは何ですか？',
    answer:
      '完璧主義診断とは、Hewitt & Flett（1991）の多次元完璧主義尺度（Multidimensional Perfectionism Scale）を参考に設計した自己診断ツールです。「徹底型」「こだわり型」「先延ばし型」「期待型」の4タイプで完璧主義の傾向を分類し、仕事・恋愛・日常での向き合い方を提供します（出典: Hewitt & Flett 1991, JPSP 60(3), https://doi.org/10.1037/0022-3514.60.3.456）。',
  },
  {
    question: '完璧主義の科学的根拠は何ですか？',
    answer:
      '本診断はHewitt & Flett（1991）の多次元完璧主義尺度（MPS）とFrost et al.（1990）のFrost MPSを参考に設計されています。Stoeber & Otto（2006）の研究では、完璧主義は「適応的（adaptive）」と「不適応的（maladaptive）」の2側面があることが示されています（参照: https://doi.org/10.1207/s15327957pspr1004_2）。本診断はその分類を基に4タイプを定義しています。',
  },
  {
    question: '完璧主義は直した方がいいですか？',
    answer:
      '完璧主義は「直す」ものではなく、自分の傾向を理解して「向き合い方を調整する」ものです。Stoeber & Otto（2006）の研究では、完璧主義には「適応的」な側面もあり、高い基準を保ちながら自分を消耗させない工夫が重要とされています（出典: https://doi.org/10.1207/s15327957pspr1004_2）。本診断はその傾向を知るための自己理解ツールです。',
  },
  {
    question: '完璧主義と日常生活の支障は別物ですか？',
    answer:
      '本診断は性格傾向を把握するための自己理解ツールであり、医学的な診断は行いません。完璧主義の傾向が日常生活に大きく影響していると感じる場合は、医師や臨床心理士などの専門家にご相談ください。本診断の結果は、あくまで自己理解の参考としてご活用ください。',
  },
  {
    question: '完璧主義の4タイプの違いは何ですか？',
    answer:
      '「徹底型」は自分への基準が高く、自分自身の納得感を最重視するタイプです。「こだわり型」は手順・精度・整理への強いこだわりを持つタイプです。「先延ばし型」は完璧にできない可能性を恐れて行動の開始が遅れやすいタイプです。「期待型」は他者からの期待に応えようとするプレッシャーが強いタイプです。Hewitt & Flett（1991）の分類（自己志向・他者志向・社会規定）を参考に設計しています。',
  },
  {
    question: 'この診断は何回でも受けられますか？',
    answer:
      '何回でも受けられます。時期によって状況や気持ちが変わると、結果が変わることがあります。複数回試して、傾向の変化を確認するのもひとつの使い方です。回答は24時間ブラウザに保存されます（サーバーには送信されません）。',
  },
  {
    question: '完璧主義は仕事で強みになりますか？',
    answer:
      '完璧主義の傾向は、仕事の種類によっては大きな強みになります。「徹底型」「こだわり型」は品質管理・編集・研究・法務などの精度重視の仕事で力を発揮します。「先延ばし型」はリスク確認・品質保証に強みがあります。「期待型」は顧客対応・チームサポートで共感力が活きます。研究でも、適応的完璧主義は高い職務パフォーマンスと関連する傾向が示されています。',
  },
  {
    question: '完璧主義の人と相性がいいタイプは？',
    answer:
      '本診断では恋愛の傾向も確認できます。タイプによって異なりますが、一般的に「基準を認めてくれる相手」「プレッシャーをかけずに見守ってくれる相手」との関係が安定しやすいとされています。各タイプの結果ページで詳しく解説しています。',
  },
  {
    question: '完璧主義診断とMBTIの違いは何ですか？',
    answer:
      'MBTIは「性格類型（外向/内向・感覚/直感・思考/感情・判断/知覚）」を16タイプで分類します。完璧主義診断は「完璧主義の方向性（自分への・他者への・手順への・他者の期待への）」を4タイプで測定します。組み合わせることで、仕事・恋愛での行動パターンをより立体的に理解できます。',
  },
  {
    question: 'PASSで何が追加されますか？',
    answer:
      '無料の基本診断（4タイプ判定・強み・注意点・恋愛傾向）に加え、¥390のPASSで「仕事・恋愛・友人・家族・学校」の5軸詳細レポートが解放されます。他診断（多重知能・MBTI・DiSC）との統合プロファイルも閲覧できます。',
  },
  {
    question: 'この診断で何かの病気が診断されますか？',
    answer:
      'いいえ。本診断は医療的・臨床的な診断ツールではありません。完璧主義の傾向を自己理解するための参考ツールです。病気・障害の診断は行いません。心身の状態について心配なことがある場合は、必ず医師・臨床心理士などの専門家にご相談ください。',
  },
  {
    question: '診断結果は保存されますか？',
    answer:
      '回答データはブラウザのローカルストレージに7日間保存されます。サーバーへの送信・アカウント登録は不要です。ブラウザのキャッシュを削除すると結果が消えます。複数の診断を組み合わせた統合プロファイルの保存は、PRO会員（¥590/月）からご利用いただけます。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '完璧主義診断', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdQuiz, jsonLdFAQ, jsonLdBreadcrumb];

// 4タイプカード用データ
const typeCards = [
  {
    id: 'thorough',
    name: '徹底型',
    nameEn: 'Self-Oriented',
    catchphrase: 'やるなら100%。自分への基準が誰よりも高い完成追求者',
    icon: '🔱',
    color: '#6366f1',
  },
  {
    id: 'particular',
    name: 'こだわり型',
    nameEn: 'Organization-Oriented',
    catchphrase: '細部にこそ本質が宿る。秩序と精度を愛する職人気質',
    icon: '⚙️',
    color: '#059669',
  },
  {
    id: 'procrastinating',
    name: '先延ばし型',
    nameEn: 'Failure-Avoidant',
    catchphrase: '完璧にできないなら始められない。失敗への恐れが生む慎重さ',
    icon: '⏳',
    color: '#d97706',
  },
  {
    id: 'expecting',
    name: '期待型',
    nameEn: 'Socially-Prescribed',
    catchphrase: '誰かの期待が、私のプレッシャー。承認を求める追求者',
    icon: '🌟',
    color: '#db2777',
  },
];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  ogImage="/og/perfectionism.svg"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '完璧主義診断', url: '/diagnosis/perfectionism/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="pf-hero" aria-labelledby="pf-hero-h1">
    <Container>
      <div class="pf-hero-inner">
        <div class="pf-hero-badge">Hewitt &amp; Flett (1991) 多次元完璧主義尺度に基づく</div>
        <h1 id="pf-hero-h1" class="pf-hero-h1">
          完璧主義診断<br />
          <span class="pf-hero-meta">【無料・3分・28問】</span>
        </h1>
        <p class="pf-hero-catch">
          あなたの「完璧主義」はどのタイプ？<br />
          4タイプから仕事・恋愛・日常の向き合い方を発見しよう
        </p>
        <div class="pf-hero-stats">
          <span class="pf-stat"><strong>28</strong>問</span>
          <span class="pf-stat-sep">・</span>
          <span class="pf-stat">約<strong>3</strong>分</span>
          <span class="pf-stat-sep">・</span>
          <span class="pf-stat"><strong>4</strong>タイプ</span>
          <span class="pf-stat-sep">・</span>
          <span class="pf-stat">無料</span>
        </div>
        <a href="#diagnosis-flow" class="pf-cta-btn">
          <span>診断スタート</span>
          <span class="pf-cta-arrow" aria-hidden="true">↓</span>
        </a>
        <p class="pf-hero-sub">登録不要・所要時間3分・途中保存OK</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TL;DRブロック（AI引用最適化） ========== */}
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        "完璧主義診断はHewitt & Flett（1991）の多次元完璧主義尺度に基づき、28問・約3分で「徹底型」「こだわり型」「先延ばし型」「期待型」の4タイプを判定する無料ツールです",
        "Stoeber & Otto（2006）の研究では完璧主義は「適応的」な側面もあり、高い基準を持ちながら消耗しない工夫が重要とされています",
        "仕事・恋愛・友人・家族・学校の5シーン別行動指針を提供（基本無料・詳細¥390）"
      ]}
      updatedAt={meta.updatedAt}
      sourceLabel="Hewitt & Flett (1991) JPSP"
      sourceUrl="https://doi.org/10.1037/0022-3514.60.3.456"
    />

    {/* ========== 完璧主義診断とは ========== */}
    <section class="pf-section" aria-labelledby="pf-what-h2">
      <h2 id="pf-what-h2" class="pf-h2">完璧主義診断とは</h2>
      <p class="pf-lead">
        完璧主義診断は、心理学者 Paul Hewitt と Gordon Flett が
        1991年に発表した「多次元完璧主義尺度（Multidimensional Perfectionism Scale）」と、
        Frost et al.（1990）の組織化・失敗懸念の研究をもとに設計した自己診断ツールです。
      </p>
      <p class="pf-body">
        完璧主義は「直すべき欠点」ではありません。
        Stoeber &amp; Otto（2006）の研究では、完璧主義には「適応的」な側面と「不適応的」な側面があり、
        自分のタイプを知ることで長く力を発揮する向き合い方が見えてくると示されています
        （<a href="https://doi.org/10.1207/s15327957pspr1004_2" target="_blank" rel="noopener noreferrer">Stoeber &amp; Otto, 2006</a>、2026-05-20確認）。
      </p>
      <div class="pf-info-table-wrap">
        <table class="pf-info-table">
          <caption class="pf-table-caption">完璧主義診断の概要</caption>
          <tbody>
            <tr>
              <th scope="row">理論の根拠</th>
              <td>Hewitt &amp; Flett (1991) MPS + Frost et al. (1990) MPS + Stoeber &amp; Otto (2006)</td>
            </tr>
            <tr>
              <th scope="row">問題数</th>
              <td>28問（各タイプ7問 × 4タイプ）</td>
            </tr>
            <tr>
              <th scope="row">回答方式</th>
              <td>5段階リッカートスケール（1=全く当てはまらない〜5=とても当てはまる）</td>
            </tr>
            <tr>
              <th scope="row">所要時間</th>
              <td>約3分</td>
            </tr>
            <tr>
              <th scope="row">結果タイプ数</th>
              <td>4タイプ（徹底型・こだわり型・先延ばし型・期待型）</td>
            </tr>
            <tr>
              <th scope="row">注意事項</th>
              <td>傾向把握のための参考ツールです。医学的診断は行いません。</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {/* ========== 4タイプ紹介 ========== */}
    <section class="pf-section" aria-labelledby="pf-types-h2">
      <h2 id="pf-types-h2" class="pf-h2">4つの完璧主義タイプ</h2>
      <p class="pf-lead">
        完璧主義は一種類ではありません。
        Hewitt &amp; Flett と Frost et al. の研究から、以下の4つのタイプに分類できます。
        どれが「良い・悪い」ではなく、それぞれ異なる向き合い方があります。
      </p>
      <div class="pf-types-grid">
        {typeCards.map((tc) => (
          <article class="pf-type-card" style={`--type-color: ${tc.color}`}>
            <div class="pf-type-icon" aria-hidden="true">{tc.icon}</div>
            <h3 class="pf-type-name">{tc.name}</h3>
            <p class="pf-type-name-en">{tc.nameEn}</p>
            <p class="pf-type-desc">{tc.catchphrase}</p>
            <a href={`/diagnosis/perfectionism/result/${tc.id}/`} class="pf-type-link">
              {tc.name}の詳細を見る
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      {/* 4タイプ図解（概念図） */}
      <div class="pf-chart-figure" role="figure" aria-labelledby="pf-chart-caption">
        <div class="pf-chart-visual" aria-hidden="true">
          <div class="pf-chart-axis pf-chart-axis--x">
            <span class="pf-axis-label pf-axis-label--left">自己基準<br/>（内向き）</span>
            <div class="pf-axis-line pf-axis-line--h"></div>
            <span class="pf-axis-label pf-axis-label--right">他者基準<br/>（外向き）</span>
          </div>
          <div class="pf-chart-axis pf-chart-axis--y">
            <span class="pf-axis-label pf-axis-label--top">達成志向</span>
            <div class="pf-axis-line pf-axis-line--v"></div>
            <span class="pf-axis-label pf-axis-label--bottom">失敗回避</span>
          </div>
          <div class="pf-chart-quadrant pf-chart-quadrant--tl">
            <span class="pf-quad-icon">🔱</span>
            <span class="pf-quad-name">徹底型</span>
          </div>
          <div class="pf-chart-quadrant pf-chart-quadrant--tr">
            <span class="pf-quad-icon">🌟</span>
            <span class="pf-quad-name">期待型</span>
          </div>
          <div class="pf-chart-quadrant pf-chart-quadrant--bl">
            <span class="pf-quad-icon">⚙️</span>
            <span class="pf-quad-name">こだわり型</span>
          </div>
          <div class="pf-chart-quadrant pf-chart-quadrant--br">
            <span class="pf-quad-icon">⏳</span>
            <span class="pf-quad-name">先延ばし型</span>
          </div>
        </div>
        <p id="pf-chart-caption" class="pf-chart-caption">
          【図1】完璧主義4タイプの分類軸（自己/他者基準 × 達成/失敗回避）。
          Hewitt &amp; Flett (1991) + Stoeber &amp; Otto (2006) の研究傾向を概念図として示したもの。
        </p>
      </div>
    </section>

    {/* ========== 使い方 ========== */}
    <section class="pf-section" aria-labelledby="pf-how-h2">
      <h2 id="pf-how-h2" class="pf-h2">使い方（3ステップ）</h2>
      <ol class="pf-steps">
        <li class="pf-step">
          <div class="pf-step-num" aria-hidden="true">1</div>
          <div class="pf-step-body">
            <h3 class="pf-step-title">「診断スタート」をタップ</h3>
            <p class="pf-step-desc">
              登録・インストール不要。ブラウザですぐ始められます。
              途中で閉じても24時間以内なら再開できます。
            </p>
          </div>
        </li>
        <li class="pf-step">
          <div class="pf-step-num" aria-hidden="true">2</div>
          <div class="pf-step-body">
            <h3 class="pf-step-title">28問に回答する（約3分）</h3>
            <p class="pf-step-desc">
              各質問に「1（全く当てはまらない）〜5（とても当てはまる）」で答えます。
              正解・不正解はありません。今の自分に正直に答えてください。
            </p>
          </div>
        </li>
        <li class="pf-step">
          <div class="pf-step-num" aria-hidden="true">3</div>
          <div class="pf-step-body">
            <h3 class="pf-step-title">タイプ診断結果と向き合い方を確認</h3>
            <p class="pf-step-desc">
              4タイプのうち最もスコアが高いものが「あなたのタイプ」として表示されます。
              仕事・恋愛・CBTセルフケアTipsの詳細は無料で確認できます。
            </p>
          </div>
        </li>
      </ol>
