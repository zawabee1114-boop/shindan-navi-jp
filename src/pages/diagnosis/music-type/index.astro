---
/**
 * 音楽タイプ診断 ハブページ
 * KW: 音楽タイプ診断 / 音楽 性格 タイプ
 * 理論: Rentfrow & Gosling (2003) MUSIC モデル / Gardner (1983) 音楽的知能
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import TldrBlock from '../../../components/TldrBlock.astro';
import ReferenceList from '../../../components/ReferenceList.astro';
import ScienceNote from '../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/music-type/`;

const title = '音楽タイプ診断｜好きな音楽から読み解く5つの性格タイプ';
const description =
  '音楽の好みから性格を読み解く「MUSICモデル」を解説。Mellow・Unpretentious・Sophisticated・Intense・Contemporaryの5タイプと多重知能・MBTIとの相関をわかりやすく紹介します。';

const references = [
  {
    title: 'The do re mi\'s of everyday life: The structure and personality correlates of music preferences',
    author: 'Rentfrow PJ, Gosling SD',
    year: 2003,
    journal: 'Journal of Personality and Social Psychology',
    volume: '84(6), 1236–1256',
    url: 'https://doi.org/10.1037/0022-3514.84.6.1236',
  },
  {
    title: 'The Social and Applied Psychology of Music',
    author: 'North AC, Hargreaves DJ',
    year: 2008,
    publisher: 'Oxford University Press',
    url: 'https://global.oup.com/academic/product/the-social-and-applied-psychology-of-music-9780198567424',
  },
  {
    title: 'Frames of Mind: The Theory of Multiple Intelligences',
    author: 'Gardner H',
    year: 1983,
    publisher: 'Basic Books',
    url: 'https://www.basicbooks.com/titles/howard-gardner/frames-of-mind/9780465024339/',
  },
];

const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  headline: title,
  url: PAGE_URL,
  datePublished: '2026-05-21',
  dateModified: '2026-05-21',
  inLanguage: 'ja',
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  mentions: [
    {
      '@type': 'Person',
      name: 'Peter J. Rentfrow',
      sameAs: 'https://www.psychol.cam.ac.uk/staff/dr-peter-rentfrow',
    },
    {
      '@type': 'Person',
      name: 'Sam Gosling',
      sameAs: 'https://en.wikipedia.org/wiki/Sam_Gosling',
    },
    {
      '@type': 'Person',
      name: 'Howard Gardner',
      sameAs: 'https://en.wikipedia.org/wiki/Howard_Gardner',
    },
  ],
};

const faqs = [
  {
    question: '音楽タイプ診断とは何ですか？',
    answer:
      'ケンブリッジ大学のRentfrow博士らが2003年に発表した研究「MUSICモデル」に基づく、音楽の好みと性格の相関を読み解くツールです。Mellow・Unpretentious・Sophisticated・Intense・Contemporaryの5次元で音楽嗜好を分類し、Big5性格特性との関連を研究しています（出典: Rentfrow & Gosling, 2003, Journal of Personality and Social Psychology）。',
  },
  {
    question: 'MUSICモデルの5タイプはどう違いますか？',
    answer:
      'Mellow（R&B・ソウル系・穏やかな性格傾向）、Unpretentious（カントリー・フォーク系・素朴で協調的な傾向）、Sophisticated（クラシック・ジャズ系・知的好奇心が高い傾向）、Intense（ロック・メタル系・開放性と情熱が高い傾向）、Contemporary（ポップ・ラップ系・外向的で現代的な傾向）の5つです。',
  },
  {
    question: '音楽の好みで本当に性格がわかるのですか？',
    answer:
      'Rentfrow & Gosling（2003）の研究では、音楽嗜好とBig5性格特性に統計的な相関が確認されています。ただし相関は「傾向」であり、音楽の好みで性格を断定することはできません。あくまで自己理解の参考ツールです。',
  },
  {
    question: '多重知能の音楽的知能とどう関係しますか？',
    answer:
      'Howard Gardnerの音楽的知能（Musical Intelligence）は「音・リズム・メロディーへの感受性」を指します。音楽的知能が高い人は音楽の好みもより細分化・洗練される傾向があります。MUSICモデルのSophisticated（洗練）タイプとの関連が特に強い傾向があります（詳細: /diagnosis/music-type/multi-int/）。',
  },
  {
    question: 'MBTIと音楽の好みに関係はありますか？',
    answer:
      '研究では直接のMBTI×音楽対応は検証されていませんが、Big5を介した間接的な関連は示唆されています。たとえばNF型（開放性・協調性が高い傾向）はMellow・Sophisticated寄り、NT型（開放性・論理性が高い傾向）はSophisticated・Intense寄りの相関が見られます。詳細は /diagnosis/music-type/mbti-music/ をご覧ください。',
  },
  {
    question: '好きな音楽ジャンルが複数の場合、タイプはどうなりますか？',
    answer:
      'MUSICモデルは5次元の「スペクトラム（連続量）」です。「Mellowが高くSophisticatedも高い」など複数次元が高いことは珍しくありません。最も得点が高い次元を主タイプ、次点を副タイプとして自己理解に活かすのがおすすめです。',
  },
  {
    question: '音楽を聴く気分によってタイプが変わりますか？',
    answer:
      '気分によって選ぶ音楽は変わります。MUSICモデルが測定するのは「普段の音楽嗜好の傾向」であり、特定の気分での選択と必ずしも一致しない場合があります。気分と音楽の関係は /diagnosis/music-type/mood/ で詳しく解説しています。',
  },
  {
    question: '音楽的知能が低くても音楽の好みはありますか？',
    answer:
      'はい。音楽的知能（音楽の制作・演奏能力の素養）と音楽嗜好（何を好んで聴くか）は異なる概念です。音楽的知能が高くない人でも明確な音楽の好みを持ち、MUSICモデルで特定のタイプに分類されることは十分あります。',
  },
  {
    question: 'このページの情報はいつ確認されましたか？',
    answer:
      '2026-05-21時点での情報です。参考文献の学術論文（Rentfrow & Gosling, 2003）はDOIリンクで確認済みです。',
  },
  {
    question: '音楽タイプ診断は医療・心理診断ですか？',
    answer:
      '違います。本ページは自己理解・傾向把握のための参考情報です。心理疾患・発達障害等の医学的評価には使用できません。これらに関する相談は医師・臨床心理士にお願いします。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ];

const musicTypes = [
  {
    id: 'mellow',
    name: 'Mellow（メロウ）',
    genres: 'R&B / ソウル / ソフトロック',
    color: '#7c3aed',
    emoji: '🎷',
    desc: '穏やかでロマンティックな音楽を好む傾向があります。感情的な深さを持ち、人間関係を大切にする協調的なタイプです。Big5の協調性・外向性と正の相関が示されています。',
    personality: '温かい・共感的・穏やか・ロマンティック',
  },
  {
    id: 'unpretentious',
    name: 'Unpretentious（素朴）',
    genres: 'カントリー / フォーク / ポップ',
    color: '#059669',
    emoji: '🎸',
    desc: '気取らない素朴な音楽を好む傾向があります。誠実で地に足のついた生き方を重視し、慣れ親しんだコミュニティや価値観を大切にするタイプです。',
    personality: '誠実・堅実・親しみやすい・安定志向',
  },
  {
    id: 'sophisticated',
    name: 'Sophisticated（洗練）',
    genres: 'クラシック / ジャズ / オペラ',
    color: '#2563eb',
    emoji: '🎻',
    desc: '複雑で知的な音楽を好む傾向があります。Big5の開放性と強い正の相関が報告されています。美的感覚が鋭く、知的好奇心が旺盛なタイプです。',
    personality: '知的・審美眼が高い・創造的・洗練',
  },
  {
    id: 'intense',
    name: 'Intense（情熱）',
    genres: 'ロック / メタル / パンク / ハードコア',
    color: '#dc2626',
    emoji: '🎤',
    desc: '激しく感情的な音楽を好む傾向があります。Big5の開放性と正の相関があり、感情表現が強く独自の価値観を持つ傾向があります。',
    personality: '情熱的・独立心が強い・表現力豊か・頑固',
  },
  {
    id: 'contemporary',
    name: 'Contemporary（現代）',
    genres: 'ポップ / ラップ / ヒップホップ / EDM',
    color: '#d97706',
    emoji: '🎧',
    desc: '現代的でリズミカルな音楽を好む傾向があります。外向性・協調性と正の相関が示されており、社交的で流行に敏感なタイプです。',
    personality: '外向的・社交的・トレンド感覚・活動的',
  },
];

const mbtiMusic = [
  { mbti: 'NFタイプ（INFP/ENFJ等）', music: 'Mellow / Sophisticated', reason: '開放性・協調性が高い傾向。感情的深みのある音楽との親和性が高い' },
  { mbti: 'NTタイプ（INTJ/ENTP等）', music: 'Sophisticated / Intense', reason: '開放性が高く、複雑な構造への関心が強い傾向' },
  { mbti: 'SFタイプ（ISFJ/ESFP等）', music: 'Unpretentious / Contemporary', reason: '協調性が高く、なじみのある音楽を好む傾向' },
  { mbti: 'STタイプ（ISTJ/ESTJ等）', music: 'Unpretentious / Contemporary', reason: '安定性・誠実性が高く、シンプルで明瞭な音楽を好む傾向' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate="2026-05-21"
  lastUpdated="2026-05-21"
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '音楽タイプ診断', url: '/diagnosis/music-type/' },
  ]}
>
  <section class="page-hero page-hero--purple" aria-labelledby="mt-h1">
    <Container>
      <div class="mt-hero-inner">
        <div class="mt-hero-badge">Rentfrow & Gosling（2003）MUSICモデル</div>
        <h1 id="mt-h1" class="mt-h1">
          音楽タイプ診断<br />
          <span class="mt-h1-sub">好きな音楽から読み解く5つの性格タイプ</span>
        </h1>
        <p class="mt-hero-lead">
          あなたが好む音楽のジャンルや雰囲気は、性格の傾向と深く関わっています。<br />
          科学研究に基づく「MUSICモデル」で、音楽と自己理解を深めましょう。
        </p>
        <div class="mt-hero-tags">
          <span class="mt-tag">自己理解</span>
          <span class="mt-tag">無料</span>
          <span class="mt-tag">5タイプ</span>
          <span class="mt-tag">科学研究ベース</span>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        'ケンブリッジ大学Rentfrow & Gosling（2003）の研究で、音楽の好みはMellow・Unpretentious・Sophisticated・Intense・Contemporaryの5次元（MUSICモデル）で分類でき、Big5性格特性と相関することが示されています',
        '音楽的知能（Howard Gardner, 1983）が高い人はSophisticatedタイプとの親和性が高く、多重知能テストと組み合わせることで音楽との関わり方への理解が深まります',
        'MBTIのNFタイプはMellow・Sophisticated寄り、NTタイプはSophisticated・Intense寄りの傾向が研究から示唆されています（詳細: /diagnosis/music-type/mbti-music/）',
      ]}
      updatedAt="2026-05-21"
      sourceLabel="Rentfrow & Gosling (2003) DOI: 10.1037/0022-3514.84.6.1236"
      sourceUrl="https://doi.org/10.1037/0022-3514.84.6.1236"
    />

    <section class="mt-section" aria-labelledby="mt-what-h2">
      <h2 id="mt-what-h2" class="mt-h2">音楽の好みで性格がわかる？MUSICモデルとは</h2>
      <p class="mt-lead">
        ケンブリッジ大学のPeter Rentfrow博士とテキサス大学のSam Gosling教授は、
        2003年の研究論文でMUSICモデルを発表しました。
        音楽嗜好とBig5性格特性の間に統計的な相関があることを示しています
        （<a href="https://doi.org/10.1037/0022-3514.84.6.1236" target="_blank" rel="noopener noreferrer">Rentfrow & Gosling, 2003, JPSP</a>、2026-05-21確認）。
      </p>
      <p class="mt-body">
        MUSICモデルは頭文字をとった5次元の枠組みです。
        「音楽で性格が決まる」のではなく、
        「性格の傾向が音楽の好みに反映される」という考え方です。
      </p>
      <div class="mt-model-table-wrap">
        <table class="mt-model-table">
          <caption class="mt-caption">MUSICモデル5次元の概要（Rentfrow & Gosling, 2003）</caption>
          <thead>
            <tr>
              <th scope="col">次元</th>
              <th scope="col">代表ジャンル</th>
              <th scope="col">Big5との相関（研究傾向値）</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>M</strong>ellow（穏やか）</td>
              <td>R&B・ソウル・ソフトロック</td>
              <td>協調性+・外向性+</td>
            </tr>
            <tr>
              <td><strong>U</strong>npretentious（素朴）</td>
              <td>カントリー・フォーク</td>
              <td>誠実性+・神経症傾向-</td>
            </tr>
            <tr>
              <td><strong>S</strong>ophisticated（洗練）</td>
              <td>クラシック・ジャズ・オペラ</td>
              <td>開放性+・知性+</td>
            </tr>
            <tr>
              <td><strong>I</strong>ntense（情熱）</td>
              <td>ロック・メタル・パンク</td>
              <td>開放性+・神経症傾向 複雑</td>
            </tr>
            <tr>
              <td><strong>C</strong>ontemporary（現代）</td>
              <td>ポップ・ラップ・EDM</td>
              <td>外向性+・協調性+</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-note">
        ※相関は研究上の傾向値です。個人差があり、音楽の好みで性格を断定することはできません。
      </p>
    </section>

    <ScienceNote
      basisText="Rentfrow PJ & Gosling SD（2003）『The do re mi's of everyday life』Journal of Personality and Social Psychology, 84(6), 1236–1256。及びGardner H（1983）Frames of Mind。"
      basisUrl="https://doi.org/10.1037/0022-3514.84.6.1236"
      basisLabel="Rentfrow & Gosling (2003) 原論文（2026-05-21確認）"
      notMedical={true}
      updatedAt="2026-05-21"
      additionalNote="本ページは自己理解・傾向把握のための参考情報です。音楽療法・医療的効能の主張はしていません。"
    />

    <section class="mt-section" aria-labelledby="mt-types-h2">
      <h2 id="mt-types-h2" class="mt-h2">音楽性格5タイプ（MUSICモデル）の詳細</h2>
      <p class="mt-lead">
        各タイプの特徴と主なジャンル傾向を紹介します。
        自分がどのタイプに近いか考えながら読んでみてください。
      </p>
      <div class="mt-types-grid">
        {musicTypes.map((type) => (
          <article class="mt-type-card" style={`border-top-color: ${type.color}`}>
            <div class="mt-type-header">
              <span class="mt-type-emoji" aria-hidden="true">{type.emoji}</span>
              <h3 class="mt-type-name" style={`color: ${type.color}`}>{type.name}</h3>
            </div>
            <p class="mt-type-genres">{type.genres}</p>
            <p class="mt-type-desc">{type.desc}</p>
            <div class="mt-type-personality">
              <span class="mt-personality-label">性格傾向:</span>
              <span>{type.personality}</span>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-section" aria-labelledby="mt-musical-h2">
      <h2 id="mt-musical-h2" class="mt-h2">多重知能の音楽的知能との関係</h2>
      <p class="mt-lead">
        Howard Gardner（1983）が提唱した「音楽的知能（Musical Intelligence）」は、
        音・リズム・メロディー・音色への感受性と制作能力を指します
        （<a href="https://www.pz.harvard.edu/projects/multiple-intelligences" target="_blank" rel="noopener noreferrer">ハーバード大学 Project Zero</a>、2026-05-21確認）。
      </p>
      <div class="mt-mi-compare">
        <div class="mt-mi-card">
          <h3 class="mt-mi-title">音楽的知能（多重知能）</h3>
          <ul class="mt-mi-list">
            <li>音・リズム・メロディーへの感受性</li>
            <li>音楽の創作・演奏・分析能力の素養</li>
            <li>音楽を「作る・演じる」側の才能軸</li>
            <li>Gardner (1983) が定義した8知能の一つ</li>
          </ul>
        </div>
        <div class="mt-mi-card">
          <h3 class="mt-mi-title">MUSICモデル（音楽嗜好）</h3>
          <ul class="mt-mi-list">
            <li>どんなジャンル・雰囲気を好むかの傾向</li>
            <li>音楽を「聴く・楽しむ」側の好み軸</li>
            <li>Big5性格特性との相関研究</li>
            <li>Rentfrow & Gosling (2003) が開発</li>
          </ul>
        </div>
      </div>
      <p class="mt-body">
        音楽的知能が高いとされる人ほど、音楽の細部（和声・リズム・対位法等）に
        関心が向く傾向があり、MUSICモデルのSophisticated次元（クラシック・ジャズ）との
        親和性が高い場合があります。
        ただし、音楽的知能とMUSICモデルの直接対応を示す研究は現時点では限られており、
        あくまで傾向の参考としてご活用ください。
      </p>
      <div class="mt-link-box">
        <a href="/diagnosis/music-type/multi-int/" class="mt-link-btn">
          音楽的知能の詳細を見る（多重知能×音楽）
          <span aria-hidden="true"> →</span>
        </a>
        <a href="/diagnosis/multi-int/" class="mt-link-btn mt-link-btn--sub">
          多重知能テストを受ける（無料・64問）
          <span aria-hidden="true"> →</span>
        </a>
      </div>
    </section>

    <section class="mt-section" aria-labelledby="mt-mbti-h2">
      <h2 id="mt-mbti-h2" class="mt-h2">MBTI × 音楽傾向の相関（研究的示唆）</h2>
      <p class="mt-lead">
        MBTIとMUSICモデルを直接対応させた研究は限られていますが、
        Big5を介した間接的な相関から以下の傾向が示唆されています。
        あくまで参考情報です。
      </p>
      <div class="mt-mbti-table-wrap">
        <table class="mt-mbti-table">
          <caption class="mt-caption">MBTIタイプ群と音楽傾向の示唆（参考・個人差あり）</caption>
          <thead>
            <tr>
              <th scope="col">MBTIタイプ群</th>
              <th scope="col">音楽傾向（示唆）</th>
              <th scope="col">背景</th>
            </tr>
          </thead>
          <tbody>
            {mbtiMusic.map((row) => (
              <tr>
                <td>{row.mbti}</td>
                <td><strong>{row.music}</strong></td>
                <td>{row.reason}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-note">
        ※上記はBig5研究を介した示唆です。MBTIと音楽嗜好を直接測定した大規模研究の報告は確認できていません（2026-05-21時点）。
      </p>
      <div class="mt-link-box">
        <a href="/diagnosis/music-type/mbti-music/" class="mt-link-btn">
          MBTI × 音楽の詳細を見る
          <span aria-hidden="true"> →</span>
        </a>
      </div>
    </section>

    <section class="mt-section" aria-labelledby="mt-related-h2">
      <h2 id="mt-related-h2" class="mt-h2">音楽タイプの関連ページ</h2>
