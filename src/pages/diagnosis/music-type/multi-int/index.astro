const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/music-type/multi-int/`;

const title = '多重知能と音楽的知能｜Gardner理論で読み解く音楽の才能と特徴';
const description =
  'Howard Gardner（1983）が提唱した「音楽的知能（Musical Intelligence）」の特徴・職業適性・他の知能との組み合わせパターンを解説。子どもの音楽的知能を伸ばすヒントと、多重知能テストへの動線も紹介します。';

const references = [
