  url: PAGE_URL,
  datePublished: '2026-05-21',
  dateModified: '2026-05-21',
  inLanguage: 'ja',
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
  mentions: [
    {
      '@type': 'Person',
      name: 'Howard Gardner',
      sameAs: 'https://en.wikipedia.org/wiki/Howard_Gardner',
    },
    {
      '@type': 'Thing',
      name: '多重知能理論（Multiple Intelligences Theory）',
      sameAs: 'https://www.pz.harvard.edu/projects/multiple-intelligences',
    },
  ],
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={PAGE_URL}
  jsonLd={[jsonLdArticle, jsonLdFAQ]}
  ogType="article"
  publishDate="2026-05-21"
  lastUpdated="2026-05-21"
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '音楽タイプ診断', url: '/diagnosis/music-type/' },
    { name: '多重知能×音楽', url: '/diagnosis/music-type/multi-int/' },
  ]}
>
  <section class="mi-hero" aria-labelledby="mi-h1">
    <Container>
      <div class="mi-hero-inner">
        <div class="mi-badge">Howard Gardner（1983/1999）音楽的知能理論</div>
        <h1 id="mi-h1" class="mi-h1">
          多重知能と音楽的知能<br />
          <span class="mi-h1-sub">Gardner理論で読み解く音楽の才能と特徴</span>
        </h1>
        <p class="mi-hero-lead">
          「音楽的知能（Musical Intelligence）」とはどんな能力なのか。<br />
          特徴・職業適性・他の知能との組み合わせを詳しく解説します。
        </p>
      </div>
    </Container>
  </section>

  <Container>
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        'Gardner（1983）の音楽的知能は「音・リズム・メロディーへの感受性と音楽を制作・演奏・鑑賞する能力」を指し、8つの知能のひとつとしてハーバード大学 Project Zeroが継続研究しています',
        '音楽的知能が高い人は音程のずれへの敏感さ・リズム感・感情の音楽的表現に優れる傾向があり、音楽家・音響エンジニア・音楽教師・声優など多様な職種で才能を活かせます',
        '音楽的知能は他の知能（言語・論理・対人・内省等）との組み合わせによって才能の発揮方向が変わります。多重知能テスト（/diagnosis/multi-int/）で自分の8知能プロファイルを確認できます',
      ]}
      updatedAt="2026-05-21"
      sourceLabel="ハーバード大学 Project Zero 公式"
      sourceUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
    />

    <section class="mi-section" aria-labelledby="mi-what-h2">
      <h2 id="mi-what-h2" class="mi-h2">音楽的知能とは何ですか？（Gardner理論）</h2>
      <p class="mi-lead">
        Howard Gardner（1983）は著書「Frames of Mind」で、知能を8つの独立した領域に分けて捉えました。
        音楽的知能（Musical Intelligence）はその8つのうちの一つです
        （<a href="https://www.pz.harvard.edu/projects/multiple-intelligences" target="_blank" rel="noopener noreferrer">ハーバード大学 Project Zero</a>、2026-05-21確認）。
      </p>
      <p class="mi-body">
        音楽的知能は「音・リズム・メロディー・音色・和声への感受性と、音楽を認識・分析・制作・演奏する能力の素養」と定義されています。
        ただし、音楽的知能の高さは音楽の職業的な成功を保証するものではなく、
        他の知能との組み合わせや環境・努力が同様に重要です。
      </p>
      <div class="mi-def-box">
        <dl class="mi-def-list">
          <div class="mi-def-row">
            <dt>提唱者</dt>
            <dd>Howard Gardner（ハーバード大学名誉教授）</dd>
          </div>
          <div class="mi-def-row">
            <dt>発表年</dt>
            <dd>1983年「Frames of Mind」/ 1999年「Intelligence Reframed」で更新</dd>
          </div>
          <div class="mi-def-row">
            <dt>定義</dt>
            <dd>音・リズム・メロディー・音色への感受性と、音楽の制作・演奏・鑑賞能力の素養</dd>
          </div>
          <div class="mi-def-row">
            <dt>研究機関</dt>
            <dd>
              ハーバード大学 Project Zero（
              <a href="https://www.pz.harvard.edu/projects/multiple-intelligences" target="_blank" rel="noopener noreferrer">公式</a>
              ）が継続研究中
            </dd>
          </div>
          <div class="mi-def-row">
            <dt>注意</dt>
            <dd>自己理解・傾向把握のための枠組みです。能力の絶対評価・医療診断には使用できません</dd>
          </div>
        </dl>
      </div>
    </section>

    <ScienceNote
      basisText="Gardner H（1983）Frames of Mind（Basic Books）および Gardner H（1999）Intelligence Reframed（Basic Books）。ハーバード大学 Project Zeroが継続研究中（2026-05-21確認）。"
      basisUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
      basisLabel="Project Zero 公式（2026-05-21確認）"
      notMedical={true}
      updatedAt="2026-05-21"
      additionalNote="音楽的知能の高低は学習障害・発達障害の判定には使用できません。専門家（医師・臨床心理士）へご相談ください。"
    />

    <section class="mi-section" aria-labelledby="mi-strengths-h2">
      <h2 id="mi-strengths-h2" class="mi-h2">音楽的知能が高い人の特徴</h2>
      <p class="mi-lead">
        以下はGardner（1983）の理論に基づく傾向の整理です。
        全ての特徴を持つ必要はなく、一部に強みが現れる場合もあります。
      </p>
      <ul class="mi-strengths-list">
        {strengths.map((s) => (
          <li class="mi-strength-item">
            <span class="mi-strength-icon" aria-hidden="true">🎵</span>
            <span>{s}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="mi-section" aria-labelledby="mi-jobs-h2">
      <h2 id="mi-jobs-h2" class="mi-h2">職業適性：音楽的知能が活きる仕事</h2>
      <p class="mi-lead">
        音楽的知能が高い傾向がある人が力を発揮しやすい職種を整理しました。
        他の知能との組み合わせによって、さらに適性の幅が広がります。
      </p>
      <div class="mi-jobs-grid">
        {jobs.map((job) => (
          <article class="mi-job-card">
            <h3 class="mi-job-title">{job.title}</h3>
            <p class="mi-job-desc">{job.desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mi-section" aria-labelledby="mi-combos-h2">
      <h2 id="mi-combos-h2" class="mi-h2">他の知能との組み合わせパターン</h2>
      <p class="mi-lead">
        多重知能理論では、人は8つの知能を組み合わせて独自の強みを形成します。
        音楽的知能がどの知能と組み合わさるかで、才能の発揮方向が変わります。
      </p>
      <div class="mi-combos-list">
        {combos.map((c) => (
          <article class="mi-combo-card">
            <h3 class="mi-combo-name">{c.combo}</h3>
            <p class="mi-combo-desc">{c.desc}</p>
            <p class="mi-combo-examples">
              <strong>向く職種・活動:</strong> {c.examples}
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="mi-section" aria-labelledby="mi-kids-h2">
      <h2 id="mi-kids-h2" class="mi-h2">子どもの音楽的知能を伸ばすヒント</h2>
      <p class="mi-lead">
        Gardner理論では、知能は経験・環境・継続的な接触で発達すると考えます。
        以下は参考ヒントです。医療・療育的なアドバイスではありません。
      </p>
      <div class="mi-kids-disclaimer">
        <strong>YMYL注記:</strong>
        本セクションは「参考ヒント」の提供のみです。
        発達障害・学習障害等の医療的な評価や支援が必要な場合は、
        医師・専門家にご相談ください。
      </div>
      <ol class="mi-kids-list">
        {kidsHints.map((h, i) => (
          <li class="mi-kids-item">
            <div class="mi-kids-num" aria-hidden="true">{i + 1}</div>
            <div class="mi-kids-body">
              <h3 class="mi-kids-title">{h.hint}</h3>
              <p class="mi-kids-detail">{h.detail}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <section class="mi-section" aria-labelledby="mi-cta-h2">
      <h2 id="mi-cta-h2" class="mi-h2">多重知能テストで音楽的知能を確認する</h2>
      <p class="mi-lead">
        診断ナビの多重知能テスト（64問・無料）では、
        音楽的知能を含む8知能すべてのスコアを確認できます。
        自分の強みの「かたち」を発見しましょう。
      </p>
      <div class="mi-cta-box">
        <div class="mi-cta-inner">
          <p class="mi-cta-text">
