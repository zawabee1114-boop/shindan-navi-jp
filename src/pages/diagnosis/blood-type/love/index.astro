---
/**
 * 血液型×恋愛ページ
 * KW: 血液型 恋愛 / 血液型 恋愛傾向
 *
 * 学術根拠:
 * - 古川竹二 (1927) 「血液型による気質の研究」心理学研究
 *   https://www.jstage.jst.go.jp/browse/psycholres
 * - 能見正比古 (1971) 『血液型でわかる相性』青春出版社
 *   https://www.seishun.co.jp/
 * - Sakamoto A, Yamazaki K (2004) International Journal of Psychology 39(4)
 *   https://doi.org/10.1080/00207590344000248
 * - 日本心理学会 公式見解 (2014)
 *   https://psych.or.jp/opinion/bl-personality/
 *
 * 禁止事項:
 * - 「血液型で結婚を決めなさい」等の断定
 * - 心理的決定論（「この血液型とは絶対うまくいかない」）
 * - YMYL: 医療・精神疾患言及
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import { meta as bcMeta, BLOOD_TYPES } from '../../../../data/diagnoses/blood-compat/meta';
import { typesDetail } from '../../../../data/diagnoses/blood-compat/types-detail';
import { getCompatibility, getCategoryLabel, getBestMatches } from '../../../../data/diagnoses/blood-compat/results';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/blood-type/love/`;
const UPDATED_AT = '2026-05-21';

const pageTitle = '血液型と恋愛傾向【A・B・O・AB型の恋愛スタイルと4×4相性マトリクス】｜診断ナビ';
const pageDesc = '血液型と恋愛の関係を徹底解説。A型・B型・O型・AB型の恋愛傾向・強み・気をつけたい点と4×4全16パターンの恋愛相性マトリクスを掲載。「血液型で結婚決めない」明示付き。古川（1927）・能見（1971）・日本心理学会（2014）見解を踏まえた解説。';

// 恋愛傾向の詳細データ
const loveData = [
  {
    type: 'A' as const,
    loveStyle: typesDetail['A'].loveStyle,
    loveStrengths: [
      '誠実さと一途さで深い信頼関係を築ける',
      '相手の気持ちを細やかに配慮する思いやり',
      '約束や記念日を大切にするロマンチックな面',
      'ゆっくりと時間をかけて関係を深めていく安心感',
    ],
    loveCautions: [
      '完璧主義が出て、相手や自分に過度な期待をしてしまう面',
      '心配や不安を抱え込んで伝えられないことがある',
      '変化や急な展開への適応に時間がかかる場合がある',
    ],
    loveStyle2: 'まず相手を観察し、信頼できると感じてから徐々に心を開いていきます。交際に発展するまでに時間がかかる傾向がありますが、一度始まった関係は誠実に継続します。記念日やイベントを大切にし、相手への配慮を細部で示します。',
    NGPattern: '「なんとなく」「いい加減」な関係は長続きしにくいです。誠実さを大切にする傾向があるため、約束を守らない・気まぐれな対応が続くと距離を置くことがあります。',
  },
  {
    type: 'B' as const,
    loveStyle: typesDetail['B'].loveStyle,
    loveStrengths: [
      '好きになったら一直線の純粋な情熱',
      '相手の個性・自由を尊重する関係を作れる',
      '一緒にいると楽しい時間を自然に生み出せる',
      '束縛しない、されたくない関係で相手を解放できる',
    ],
    loveCautions: [
      '気ままな行動が相手に不安を与える場合がある',
      '感情表現が直接的すぎて相手を驚かせることがある',
      '関係の継続に必要な「日常の安定感」の構築が課題になる面',
    ],
    loveStyle2: '好きになった相手には積極的にアプローチします。束縛を嫌い、お互いの自由を大切にした関係を求めます。「一緒にいて楽しい」を最重視し、毎日の生活より非日常の体験を共有することに喜びを感じます。',
    NGPattern: '「重い束縛」「細かいルール」「マイペースを認めない関係」は長続きしにくいです。自分のペースを尊重してくれる相手との関係が自然に長続きします。',
  },
  {
    type: 'O' as const,
    loveStyle: typesDetail['O'].loveStyle,
    loveStrengths: [
      '積極的なアプローチで関係を素早く発展させられる',
      '相手を大切にする強い気持ちと行動力',
      '一緒に目標に向かって進める伴走者としての強さ',
      '明るく前向きな雰囲気が関係に活気をもたらす',
    ],
    loveCautions: [
      '競争心が恋愛に持ち込まれ「勝ち負け」の意識が出ることがある',
      '大雑把すぎて相手の細やかな気持ちを見落とす場面がある',
      '自分のペースを優先しすぎて相手のニーズを後回しにする場合がある',
    ],
    loveStyle2: '気になった相手には迷わずアプローチします。エネルギーと行動力で関係を積極的に進めていく傾向があります。相手と一緒に目標を持って進む関係を理想とし、「二人で一緒に成長する」ことに喜びを感じます。',
    NGPattern: '「モヤモヤを引っ張る曖昧な関係」「受け身すぎる展開」は長続きしにくいです。積極的な相手との関係が自然に活発になります。',
  },
  {
    type: 'AB' as const,
    loveStyle: typesDetail['AB'].loveStyle,
    loveStrengths: [
      '心を開いた相手には深く誠実に向き合う一途さ',
      '知的な会話や内面のつながりを大切にする深さ',
      '相手の個性と独自性を尊重できる理解力',
      '感情より対話で関係を深める合理的な姿勢',
    ],
    loveCautions: [
      '内面を言葉にするのに時間がかかり、相手が不安に感じることがある',
      '気分による態度の変化（A面とB面の切り替え）が誤解を招く場合がある',
      '「好き」という気持ちを言葉で伝えるのが後回しになりやすい面',
    ],
    loveStyle2: '「友達と恋人」の線引きが内面にはっきりあります。交際に至るまでじっくりと相手を見極める傾向があり、一度心を開いた相手とは誠実で深い関係を築きます。知的なつながりと相互理解を関係の核にしたいと思っています。',
    NGPattern: '「中身のない関係」「根拠のない感情的な言い合い」は長続きしにくいです。論理的な対話ができ、お互いの独自性を尊重し合える相手との関係が続きます。',
  },
];

// 4×4 恋愛相性マトリクス
const loveMatrixData = BLOOD_TYPES.map((rowType) =>
  BLOOD_TYPES.map((colType) => {
    const compat = getCompatibility(rowType, colType);
    return {
      type1: rowType,
      type2: colType,
      score: compat.score,
      category: compat.category,
      loveCompat: compat.loveCompat,
      oneLineSummary: compat.oneLineSummary,
    };
  })
);

// FAQ 10問
const faqs = [
  {
    question: '血液型で結婚相手を選んでいいですか？',
    answer:
      '推奨しません。日本心理学会（2014年）は「血液型と性格の間に科学的に明確な統計的相関は認められない」と明言しています（https://psych.or.jp/opinion/bl-personality/）。血液型スコアで結婚相手を選ぶことは、科学的根拠のない基準で重要な人生の決断を行うリスクがあります。実際の対話・価値観の一致・生活観の共有を基準にしてください。',
  },
  {
    question: 'A型と相性がいい血液型は恋愛でどれですか？',
    answer:
      '本サイトの恋愛相性スコアでは、A型のベストマッチはA型（86点）、次いでAB型（78点）、O型（75点）の順です。ただしこれは日本の血液型文化に基づく傾向値であり、科学的な恋愛相性の測定ではありません（日本心理学会 2014）。個人の性格・価値観・コミュニケーションスタイルによって実際の相性は大きく変わります。',
  },
  {
    question: 'B型は恋愛で束縛されるのが嫌いですか？',
    answer:
      '日本の血液型性格分類（能見 1971）ではB型は「自由を大切にしマイペース」とされており、束縛を嫌うイメージがあります。ただしこれは文化的イメージであり、科学的根拠は限定的です（日本心理学会 2014）。実際にB型の全員が束縛を嫌うわけではなく、個人差が非常に大きいです。',
  },
  {
    question: 'O型は恋愛でリーダーシップを発揮しますか？',
    answer:
      '日本の血液型性格分類（能見 1971）ではO型は「積極的・社交的・リーダーシップ」とされており、恋愛でも積極的にアプローチするイメージがあります。ただしこれは文化的イメージであり、科学的根拠は限定的です（日本心理学会 2014）。実際の恋愛スタイルは個人の経験・環境によって異なります。',
  },
  {
    question: 'AB型は恋愛で冷たいと言われるのはなぜですか？',
    answer:
      '日本の血液型性格分類（能見 1971）ではAB型は「知的・合理的・二面性」とされており、感情より理性を優先するイメージが「冷たい」という印象につながることがあります。ただしこれは文化的イメージであり、科学的根拠は限定的です（日本心理学会 2014）。AB型の方が「冷たい」という事実はなく、血液型でキャラクターを決めつけることはブラハラにつながります。',
  },
  {
    question: '血液型で恋愛相性を判断する正しい方法は？',
    answer:
      '血液型相性は「恋愛の話題のきっかけ・自己理解のヒント」として楽しむことを推奨します。スコアが高いからといって必ずうまくいくわけでも、低いからといって恋愛が続かないわけでもありません。実際の相性は対話・共通の価値観・コミュニケーションの積み重ねで形成されます。',
  },
  {
    question: '血液型相性が低い相手とでも長続きする恋愛はできますか？',
    answer:
      'できます。本サイトのスコアが低い組み合わせでも、深い絆を築いているカップルは多数います。本サイトでは「相性が低い」という表現は使わず、「学び合いペア」として位置づけています。違うスタイルを持つ相手との恋愛は、互いの視野を広げ成長につながることがあります。',
  },
  {
    question: '血液型ハラスメントを恋愛で受けた場合どうすればいいですか？',
    answer:
      '「B型は嫌い」「AB型とは付き合えない」と血液型を理由に恋愛を断られることや、交際中に血液型を持ち出して性格を決めつけられることはブラハラ的な言動です。日本心理学会（2014年）は「血液型と性格の科学的相関は認められない」と明言しています。血液型で人格を否定するような言動は相手に伝え、改善されなければ関係を見直すことを検討してください。',
  },
  {
    question: '血液型と恋愛に関する科学的研究はありますか？',
    answer:
      'Sakamoto & Yamazaki（2004年、International Journal of Psychology 39(4)、https://doi.org/10.1080/00207590344000248）は、血液型ステレオタイプの影響を「自己成就予言」の観点から検討し、血液型と性格の相関は限定的と結論しています。日本心理学会（2014年）も同様の公式見解を示しています。',
  },
  {
    question: '血液型占いと血液型相性診断の違いは何ですか？',
    answer:
      '本サイトは「占い」ではなく、日本の血液型性格分類文化（古川 1927・能見 1971）に基づく傾向値を参考情報として提示しています。「運命」「必然」「逃れられない相性」という占い的な解釈は行っていません。血液型は「性格を決める要素」ではなく「会話のきっかけ・自己理解のヒント」として活用することを推奨します。',
  },
];

// JSON-LD
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: '血液型と恋愛傾向【A・B・O・AB型の恋愛スタイルと4×4相性マトリクス】',
  description: pageDesc,
  url: PAGE_URL,
  datePublished: UPDATED_AT,
  dateModified: UPDATED_AT,
  inLanguage: 'ja',
  author: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: '診断ナビ' },
  publisher: { '@type': 'Organization', '@id': `${SITE_URL}/#organization`, name: '診断ナビ' },
  citation: bcMeta.references.map((ref) => ({
    '@type': ref.url.includes('doi.org') ? 'ScholarlyArticle' : 'Book',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    publisher: ref.publisher,
    url: ref.url,
  })),
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '血液型相性診断', item: `${SITE_URL}/diagnosis/blood-compat/` },
    { '@type': 'ListItem', position: 4, name: '血液型と恋愛', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

const catColors: Record<string, string> = {
  soulmate: '#8B5CF6',
  good: '#10B981',
  neutral: '#3B82F6',
  growth: '#F59E0B',
  challenge: '#EF4444',
};
const catBgs: Record<string, string> = {
  soulmate: '#f3e8ff',
  good: '#d1fae5',
  neutral: '#dbeafe',
  growth: '#fef3c7',
  challenge: '#fee2e2',
};

const typeLabels: Record<string, string> = { A: 'A型', B: 'B型', O: 'O型', AB: 'AB型' };
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  ogImage="/og/blood-type.png"
  publishDate={UPDATED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '血液型相性診断', url: '/diagnosis/blood-compat/' },
    { name: '血液型と恋愛', url: '/diagnosis/blood-type/love/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="page-hero page-hero--coral" aria-labelledby="bl-hero-h1">
    <Container>
      <div class="bl-hero-inner">
        <div class="bl-hero-badge">古川竹二（1927）・能見正比古（1971）研究 + 日本心理学会見解</div>
        <h1 id="bl-hero-h1" class="bl-hero-h1">
          血液型と恋愛傾向<br />
          <span class="bl-hero-meta">【A・B・O・AB型の恋愛スタイルと4×4相性マトリクス】</span>
        </h1>
        <p class="bl-hero-catch">
          血液型で恋愛のスタイルはどう違う？<br />
          4タイプの恋愛傾向・強み・相性を全16パターンで徹底解説
        </p>
        <div class="bl-hero-notice" role="note">
          <p>
            「血液型で結婚を決めない」「血液型で恋人を断らない」を前提に、
            話題のきっかけ・自己理解のヒントとしてお楽しみください。
          </p>
        </div>
        <p class="bl-hero-sub">
          <time datetime={UPDATED_AT}>{UPDATED_AT}</time> 時点の情報
        </p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== このページでわかること ========== */}
    <div class="bl-aio-block" role="note" aria-label="このページでわかること">
      <p class="bl-aio-title">このページでわかること</p>
      <ul class="bl-aio-list">
        <li>A・B・O・AB型 4タイプの恋愛傾向・強み・気をつけたい傾向の詳細</li>
        <li>4×4全16パターンの恋愛相性スコアとコメント（マトリクス形式）</li>
        <li>各タイプの「恋愛での強み」「続きやすい関係のパターン」</li>
        <li>「血液型で結婚を決めない」明示と日本心理学会（2014）の公式見解</li>
      </ul>
      <p class="bl-aio-updated">
        参照元:
        <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">日本心理学会（2014）</a>・
        <a href="https://www.jstage.jst.go.jp/browse/psycholres" target="_blank" rel="noopener noreferrer">古川（1927）</a>・
        <a href="https://doi.org/10.1080/00207590344000248" target="_blank" rel="noopener noreferrer">Sakamoto &amp; Yamazaki（2004）</a>
        を確認済。
      </p>
    </div>

    {/* ========== TldrBlock ========== */}
    <TldrBlock
      title="血液型と恋愛 ポイントまとめ"
      points={[
        'A型恋愛傾向: 誠実・一途・丁寧。信頼を積み重ねる安定した関係を好む傾向',
        'B型恋愛傾向: 積極的・自由・束縛なし。一緒にいて楽しい時間を重視する傾向',
        'O型恋愛傾向: 行動力・情熱・伴走者。相手と一緒に目標に向かって進む関係を好む傾向',
        'AB型恋愛傾向: 知的つながり・一途・深さ。心を開いた相手とは深く誠実に向き合う傾向',
        '【重要】血液型で結婚・交際を決めることは推奨しない。日本心理学会（2014）「血液型と性格の科学的相関は認められない」。実際の相性は対話・価値観で形成される',
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="日本心理学会 公式見解（2014）"
      sourceUrl="https://psych.or.jp/opinion/bl-personality/"
    />

    {/* ========== 免責・科学的位置付け ========== */}
    <section class="bl-section" aria-labelledby="bl-science-h2">
      <h2 id="bl-science-h2" class="bl-h2">血液型と恋愛——文化的・科学的位置付け</h2>
      <div class="bl-science-card">
        <p class="bl-lead">
          血液型性格分類は古川竹二（1927）の研究を端緒とし、
          能見正比古（1971）が一般に広めた<strong>日本独自の文化的現象</strong>です。
          恋愛における血液型の話題も、この文化的背景から生まれています。
        </p>
        <p class="bl-lead">
          一方で、日本心理学会は2014年の
          <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">公式見解</a>で
          「血液型と性格の間に科学的に明確な統計的相関は認められない」と明言しています。
          Sakamoto &amp; Yamazaki（2004）も同様に「血液型と性格の相関は限定的」と結論しています。
        </p>
        <div class="bl-notice-grid">
          <div class="bl-notice-ok">
            <p class="bl-notice-label">推奨する活用法</p>
            <p>恋愛の話題・自己理解・コミュニケーションのきっかけとして楽しむ</p>
          </div>
          <div class="bl-notice-ng">
            <p class="bl-notice-label">推奨しない活用法</p>
            <p>血液型だけで恋人・結婚相手を選ぶ・断る。血液型で相手を決めつける</p>
          </div>
        </div>
        <div class="bl-disclaimer-box" role="note">
          <p class="bl-disclaimer-text">{bcMeta.disclaimer}</p>
        </div>
      </div>
    </section>

    {/* ========== 4タイプの恋愛傾向 ========== */}
    <section class="bl-section" aria-labelledby="bl-types-h2">
      <h2 id="bl-types-h2" class="bl-h2">4タイプ別 恋愛傾向の詳細</h2>
      <p class="bl-lead">
        日本の血液型性格分類（古川 1927・能見 1971）に基づく恋愛傾向のイメージです。
        「文化的傾向」として参考にし、個人差が大きいことを前提にお読みください。
