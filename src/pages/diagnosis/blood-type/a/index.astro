---
/**
 * A型 性格・特徴 詳細ページ
 * KW: A型 性格 / A型 特徴
 *
 * 学術根拠:
 * - 古川竹二 (1927) 「血液型による気質の研究」心理学研究 第2巻第4号
 * - 能見正比古 (1971) 『血液型でわかる相性』青春出版社
 * - Sakamoto A, Yamazaki K (2004) International Journal of Psychology 39(4)
 *   https://doi.org/10.1080/00207590344000248
 * - 日本心理学会 公式見解（2014）https://psych.or.jp/opinion/bl-personality/
 * - 縄田健悟 (2014) 心理学研究 85(2) https://doi.org/10.4992/jjpsy.85.13E0025
 *
 * YMYL回避: 医療・精神疾患・治療言及ゼロ
 * disclaimer: 必須表示（科学的相関は限定的）
 * ブラハラ警告: 必須セクション
 *
 * 確認日: 2026-05-21
 */

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';
import { typesDetail } from '../../../../data/diagnoses/blood-compat/types-detail';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/blood-type/a/`;
const UPDATED_AT = '2026-05-21';

const detail = typesDetail['A'];

const references = [
  {
    title: '血液型による気質の研究',
    author: '古川竹二',
    year: 1927,
    publisher: '心理学研究 第2巻第4号',
    url: 'https://www.jstage.jst.go.jp/browse/psycholres',
  },
  {
    title: '血液型でわかる相性',
    author: '能見正比古',
    year: 1971,
    publisher: '青春出版社',
    url: 'https://www.seishun.co.jp/',
  },
  {
    title: 'Blood-typical Personality Stereotypes and Self-fulfilling Prophecy',
    author: 'Sakamoto A, Yamazaki K',
    year: 2004,
    publisher: 'International Journal of Psychology, 39(4), 275-285',
    url: 'https://doi.org/10.1080/00207590344000248',
  },
  {
    title: '「血液型と性格」の関連についての公式見解',
    author: '日本心理学会',
    year: 2014,
    publisher: '日本心理学会',
    url: 'https://psych.or.jp/opinion/bl-personality/',
  },
  {
    title: '血液型と性格は無関係——血液型刻印効果の危険性',
    author: '縄田健悟',
    year: 2014,
    publisher: '心理学研究 85(2)',
    url: 'https://doi.org/10.4992/jjpsy.85.13E0025',
  },
];

const faqs = [
  {
    question: 'A型の性格の特徴を一言で表すと？',
    answer:
      '日本の血液型性格分類（古川 1927・能見 1971）では「几帳面な調和派」と表現されます。計画性・責任感・協調性が高い傾向があるとされていますが、科学的相関は限定的です（日本心理学会 2014）。個人差が大きい点に注意してください。',
  },
  {
    question: 'A型が几帳面と言われる理由は何ですか？',
    answer:
      '古川竹二（1927）の研究でA型は「几帳面・神経質・内省的」な気質傾向が記述されたことが起源とされています。その後、能見正比古（1971）が日本全国に血液型性格論を広めた際にA型のイメージとして定着しました。ただし日本心理学会（2014）は「血液型と性格の科学的相関は認められない」と明言しています。',
  },
  {
    question: 'A型の人に向いている仕事は何ですか？',
    answer:
      '血液型と職業適性の科学的相関は確認されていません（日本心理学会 2014）。ただし日本の文化的分類の傾向として、計画性・細部への注意・責任感が必要な業務（品質管理・事務・プロジェクト管理など）との親和性が語られることがあります。実際の適職判断には適性検査・キャリアカウンセリングをご活用ください。',
  },
  {
    question: 'A型の恋愛傾向はどうですか？',
    answer:
      '日本の血液型性格分類では、A型は「誠実・丁寧・一度信頼した相手には深くコミットする」傾向があるとされています。ただしこれは文化的イメージであり科学的根拠は限定的です。実際の恋愛傾向は育ちや個人の経験に大きく依存します。',
  },
  {
    question: 'A型の人が疲れやすい原因は何ですか？',
    answer:
      '日本の血液型分類では「完璧主義・心配事を内側に抱え込む傾向」がA型の気をつけたい点として語られます。しかし疲れやすさは血液型より生活習慣・睡眠・ストレス環境の影響が大きく、心身の不調がある場合は医師への相談を推奨します。',
  },
  {
    question: 'A型とB型の相性はどうですか？',
    answer:
      '血液型相性の科学的根拠は限定的です（日本心理学会 2014）。日本の文化的分類ではA型の「秩序重視」とB型の「マイペース」のスタイルの違いが目立つとされますが、実際の人間関係は価値観・コミュニケーション・互いへの理解で大きく変わります。詳細は血液型相性診断（/diagnosis/blood-compat/）をご覧ください。',
  },
  {
    question: 'A型が血液型で決めつけられることへの対処法は？',
    answer:
      '血液型による決めつけは「血液型ハラスメント（ブラハラ）」に該当する場合があります。日本心理学会（2014）は「血液型と性格の科学的相関は認められない」と明言しており、「A型だから〇〇のはず」という固定観念には根拠がありません。必要に応じて「血液型で性格は決まらない」と冷静に伝えることが有効です。',
  },
  {
    question: 'A型の強みを仕事で活かすコツは？',
    answer:
      '日本の血液型分類で語られるA型の傾向（計画性・細部への注意・誠実な責任感）を活かすには、締め切りを明確にした仕事・品質管理・文書整理などが相性がよいとされます。ただし能力の根拠は血液型ではなく個人の経験・スキルにあります。',
  },
  {
    question: 'A型の完璧主義を和らげる方法はありますか？',
    answer:
      '日本の血液型分類でA型に語られる完璧主義傾向は文化的イメージです。「80点で合格」「完了 > 完璧」といった思考の切り替えが有効とされますが、実際のアプローチは個人差が大きく、心身の不調がある場合は専門家へのご相談を推奨します。',
  },
  {
    question: 'A型の人数は日本で何人いますか？',
    answer:
      '日本では血液型別人口比率はA型が約38%と最も多く（日本赤十字社の献血統計）、B型30%・O型22%・AB型10%程度とされています（参照: 日本赤十字社 https://www.jrc.or.jp/mr/blood_type/）。確認日: 2026-05-21。',
  },
];

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: 'A型の性格・特徴を徹底解説【几帳面・気配り・完璧主義の傾向とは】',
  description:
    '古川竹二（1927）・能見正比古（1971）の研究をもとにA型の性格特徴を詳解。強み・気をつけたい傾向・仕事・恋愛・友人・家族スタイル・ブラハラ警告・FAQ10問を収録。科学的相関は限定的との免責明示あり。',
  url: PAGE_URL,
  datePublished: UPDATED_AT,
  dateModified: UPDATED_AT,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
};

// JSON-LD: FAQPage
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '血液型タイプ別', item: `${SITE_URL}/diagnosis/blood-type/` },
    { '@type': 'ListItem', position: 4, name: 'A型の性格', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];
---

<BaseLayout
  title="A型の性格・特徴を徹底解説【几帳面・気配り・完璧主義の傾向とは】｜診断ナビ"
  description="古川竹二（1927）・能見正比古（1971）の研究をもとにA型の性格特徴を解説。強み4項目・気をつけたい傾向4項目・仕事/恋愛/友人/家族スタイル・ブラハラ警告・FAQ10問収録。科学的相関は限定的との免責明示あり。"
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  ogImage="/og/blood-type.png"
  publishDate={UPDATED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '血液型タイプ別', url: '/diagnosis/blood-type/' },
    { name: 'A型の性格', url: '/diagnosis/blood-type/a/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="page-hero page-hero--coral" aria-labelledby="bt-hero-h1">
    <Container>
      <div class="bt-hero-inner">
        <div class="bt-hero-badge">古川竹二（1927）・能見正比古（1971）研究 + 日本心理学会見解</div>
        <h1 id="bt-hero-h1" class="bt-hero-h1">
          A型の性格・特徴<br />
          <span class="bt-hero-sub-title">几帳面・気配り・完璧主義の傾向を徹底解説</span>
        </h1>
        <p class="bt-hero-catch">
          日本で最も人口が多いA型。「几帳面」「責任感が強い」のイメージはどこから来るのか。<br />
          古川竹二（1927）以来の文化的分類を正確に整理し、強みと気をつけたい傾向を解説します。
        </p>
        <div class="bt-hero-stats">
          <span class="bt-stat">日本人口の約<strong>38%</strong></span>
          <span class="bt-stat-sep">・</span>
          <span class="bt-stat">確認日: <time datetime={UPDATED_AT}>{UPDATED_AT}</time></span>
        </div>
        <div class="bt-disclaimer-top" role="note" aria-label="免責事項">
          <p>
            本ページは日本の血液型性格分類文化を参考情報として解説します。
            科学的に厳密な統計的相関は限定的です（<a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">日本心理学会公式見解 2014</a>）。
            自己理解の参考としてお楽しみください。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== AIOブロック（このページでわかること） ========== */}
    <div class="bt-aio-block" role="note" aria-label="このページでわかること">
      <p class="bt-aio-title">このページでわかること</p>
      <ul class="bt-aio-list">
        <li>A型の性格傾向（几帳面・気配り・完璧主義・協調性）の文化的・歴史的背景</li>
        <li>強み4項目・気をつけたい傾向4項目・仕事/恋愛/友人/家族スタイル</li>
        <li>A型あるある場面3例・ブラハラ（血液型ハラスメント）警告</li>
        <li>FAQ 10問・血液型相性診断・他タイプへの内部リンク</li>
      </ul>
      <p class="bt-aio-updated">
        学術根拠:
        <a href="https://www.jstage.jst.go.jp/browse/psycholres" target="_blank" rel="noopener noreferrer">古川（1927）</a>・
        <a href="https://doi.org/10.1080/00207590344000248" target="_blank" rel="noopener noreferrer">Sakamoto & Yamazaki（2004）</a>・
        <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">日本心理学会（2014）</a>
        を確認済。
      </p>
    </div>

    {/* ========== TL;DR ========== */}
    <TldrBlock
      title="A型性格 ポイントまとめ"
      points={[
        '古川竹二（1927）の研究でA型は「几帳面・神経質・内省的」な気質傾向として最初に記述された。能見正比古（1971）により日本全国に普及した',
        '日本の文化的分類での主な傾向: 計画性・細部への注意・誠実な責任感・チームの和を保とうとする協調性',
        '気をつけたい傾向: 完璧主義による自他への高い基準・心配事を内側に溜め込みやすさ・変化への適応に時間がかかる点',
        '日本心理学会（2014）・縄田（2014）は「血液型と性格の科学的相関は認められない」と明言。傾向はあくまで文化的分類のイメージ',
        'A型は日本の血液型人口で最多（約38%）。血液型で人を決めつける「ブラハラ」には注意が必要',
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="日本心理学会 公式見解（2014）"
      sourceUrl="https://psych.or.jp/opinion/bl-personality/"
    />

    {/* ========== A型性格の文化的・歴史的背景 ========== */}
    <section class="bt-section" aria-labelledby="bt-history-h2">
      <h2 id="bt-history-h2" class="bt-h2">A型性格の文化的・歴史的背景</h2>
      <p class="bt-lead">
        A型の「几帳面」というイメージはどこから来るのでしょうか。
        日本の血液型性格分類の起源を正確に整理します。
      </p>
      <div class="bt-history-card">
        <div class="bt-history-item">
          <span class="bt-history-year">1927年</span>
          <div class="bt-history-body">
            <p class="bt-history-title">古川竹二「血液型による気質の研究」</p>
            <p class="bt-history-text">
              日本で最初の血液型性格分類研究として
              <a href="https://www.jstage.jst.go.jp/browse/psycholres" target="_blank" rel="noopener noreferrer">心理学研究 第2巻第4号</a>
              に発表。A型を「几帳面・神経質・内省的」、B型を「社交的・自己中心的」などと記述。
              学術的な批判も多く、後に再現性の問題が指摘されている。
            </p>
          </div>
        </div>
        <div class="bt-history-item">
          <span class="bt-history-year">1971年</span>
          <div class="bt-history-body">
            <p class="bt-history-title">能見正比古『血液型でわかる相性』（青春出版社）</p>
            <p class="bt-history-text">
              <a href="https://www.seishun.co.jp/" target="_blank" rel="noopener noreferrer">青春出版社</a>
              刊。学術研究ではなくポップサイエンス的な普及書として日本全国に血液型性格論を広める。
              A型＝几帳面・責任感のイメージが日本文化に定着した直接的なきっかけ。
            </p>
          </div>
        </div>
        <div class="bt-history-item">
          <span class="bt-history-year">2004年</span>
          <div class="bt-history-body">
            <p class="bt-history-title">Sakamoto & Yamazaki「Blood-typical Personality Stereotypes and Self-fulfilling Prophecy」</p>
            <p class="bt-history-text">
              <a href="https://doi.org/10.1080/00207590344000248" target="_blank" rel="noopener noreferrer">International Journal of Psychology 39(4)</a>
              。血液型ステレオタイプが「自己成就予言」として機能することを指摘。
              「A型だから几帳面に行動しようとする」心理メカニズムを示唆。
            </p>
          </div>
        </div>
        <div class="bt-history-item">
          <span class="bt-history-year">2014年</span>
          <div class="bt-history-body">
            <p class="bt-history-title">日本心理学会 公式見解 + 縄田健悟 研究</p>
            <p class="bt-history-text">
              日本心理学会が
              <a href="https://psych.or.jp/opinion/bl-personality/" target="_blank" rel="noopener noreferrer">公式見解</a>
              として「血液型と性格の科学的統計的相関は認められない」と表明。
              縄田（2014）は
              <a href="https://doi.org/10.4992/jjpsy.85.13E0025" target="_blank" rel="noopener noreferrer">大規模調査</a>
              で血液型刻印効果の危険性を示した。
            </p>
          </div>
        </div>
      </div>
      <p class="bt-note">
        以上から、A型の性格イメージは「科学的事実」ではなく
        「日本独自の文化的分類のイメージ」として把握することが重要です。
      </p>
    </section>

    {/* ========== 強みと気をつけたい傾向 ========== */}
    <section class="bt-section" aria-labelledby="bt-traits-h2">
      <h2 id="bt-traits-h2" class="bt-h2">A型の強みと気をつけたい傾向</h2>
      <p class="bt-lead">
        以下は日本の血液型性格分類（古川 1927・能見 1971）に基づく傾向のイメージです。
        個人差が大きく、科学的相関は限定的です。
      </p>
      <div class="bt-traits-grid">
        <div class="bt-traits-col bt-traits-col--strengths">
          <h3 class="bt-traits-title bt-traits-title--strengths">強みと得意なこと</h3>
          <ul class="bt-traits-list">
            {detail.strengths.map((s) => (
              <li class="bt-traits-item">
                <span class="bt-traits-icon bt-traits-icon--ok" aria-hidden="true">+</span>
                <span>{s}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bt-traits-col bt-traits-col--weaknesses">
          <h3 class="bt-traits-title bt-traits-title--weaknesses">気をつけたい傾向</h3>
          <ul class="bt-traits-list">
            {detail.weaknesses.map((w) => (
              <li class="bt-traits-item">
                <span class="bt-traits-icon bt-traits-icon--caution" aria-hidden="true">!</span>
                <span>{w}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="bt-disclaimer-box" role="note" aria-label="免責事項">
        <p>
          上記はあくまで日本の文化的分類による傾向のイメージです。
          血液型で個人の能力・性格・将来を断定することはできません（日本心理学会 2014）。
        </p>
      </div>
    </section>

    {/* ========== 仕事・恋愛・友人・家族スタイル ========== */}
    <section class="bt-section" aria-labelledby="bt-styles-h2">
      <h2 id="bt-styles-h2" class="bt-h2">A型の各場面での傾向</h2>
      <p class="bt-lead">
        日本の血液型文化で語られる、仕事・恋愛・友人・家族場面での傾向をまとめます。
        いずれも「文化的分類のイメージ」であり個人差が大きい点に注意してください。
      </p>
      <div class="bt-styles-grid">
        <div class="bt-style-card">
          <div class="bt-style-icon" aria-hidden="true">&#128188;</div>
          <h3 class="bt-style-title">仕事スタイル</h3>
          <p class="bt-style-body">{detail.workStyle}</p>
          <ul class="bt-style-examples">
            <li>計画書・議事録・マニュアル作成など文書系業務</li>
            <li>品質チェック・確認作業・進行管理</li>
            <li>期限・約束事の厳守が求められるポジション</li>
          </ul>
        </div>
        <div class="bt-style-card">
          <div class="bt-style-icon" aria-hidden="true">&#10084;</div>
          <h3 class="bt-style-title">恋愛スタイル</h3>
          <p class="bt-style-body">{detail.loveStyle}</p>
          <ul class="bt-style-examples">
            <li>誠実さを最優先し、関係を丁寧に育てる</li>
            <li>記念日・約束を大切にする傾向がある</li>
            <li>不安や心配を内に溜め込みやすい点に注意</li>
          </ul>
        </div>
        <div class="bt-style-card">
          <div class="bt-style-icon" aria-hidden="true">&#128101;</div>
          <h3 class="bt-style-title">友人関係スタイル</h3>
