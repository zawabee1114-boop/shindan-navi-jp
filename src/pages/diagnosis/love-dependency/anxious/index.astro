/**
 * 不安型 愛着スタイル 詳細ページ
 * KW: 不安型 愛着スタイル / 恋愛 不安型 / 恋愛 見捨てられ不安
 * 学術根拠:
 *   - Ainsworth MDS (1978) Patterns of Attachment
 *   - Hazan C, Shaver PR (1987) DOI: 10.1037/0022-3514.52.3.511
 *   - Mikulincer M, Shaver PR (2007) Attachment in Adulthood
 *
 * YMYL最重要:
 *   - 「不安型愛着障害」「依存症」等の医学用語 絶対NG
 *   - 「治療」「治す」NG → 「向き合い方」「self-care」「マネジメント」
 *   - 全ページに「公認心理師・臨床心理士相談推奨」を明示
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';
import RelatedDiagnoses from '../../../../components/RelatedDiagnoses.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/love-dependency/anxious/`;
const UPDATED_AT = '2026-05-21';

const references = [
  {
    title: 'Patterns of Attachment: A Psychological Study of the Strange Situation',
    author: 'Ainsworth MDS, Blehar MC, Waters E, Wall S',
    year: 1978,
    publisher: 'Lawrence Erlbaum Associates',
