    title: '自分だけの時間・趣味を守る',
    desc: 'パートナーと関係のない「自分のための時間」を週に一度以上設けます。相手のことを考えない時間を持つことが、自己の回復につながります。',
  },
  {
    icon: '🗣️',
    title: '信頼できる人に話す',
    desc: '友人・家族・相談窓口・専門家に「自分が感じていること」を話すことで、パターンへの外部からの視点が得られます。一人で抱え込まないことが大切です。',
  },
];

const boundaryExamples = [
  { bad: '「自分が我慢すれば関係は続く」', good: '「自分が消耗したら関係も長続きしない」' },
