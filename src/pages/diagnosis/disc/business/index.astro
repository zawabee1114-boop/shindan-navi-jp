  description={description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate="2026-05-21"
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'DiSC診断', url: '/diagnosis/disc/' },
    { name: 'DiSC 仕事・ビジネス活用', url: '/diagnosis/disc/business/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="biz-hero" aria-labelledby="biz-h1">
    <Container>
      <div class="biz-hero-inner">
        <p class="biz-hero-badge">DiSC&#174; Wiley社登録商標 | Marston (1928) 学術根拠付き | 2026-05-21 更新</p>
