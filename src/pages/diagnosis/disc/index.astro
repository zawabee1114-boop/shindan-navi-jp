---
/**
 * DiSC診断 ランディングページ
 * KW: DiSC診断（VOL2,900/SD11/CPC¥191・Phase 1第7優先）
 * 学術根拠: Marston (1928) + Clarke (1956) + Wiley DiSC公式 (2024)
 * 確認日: 2026-05-20
 *
 * SEO/AIO対応:
 * - JSON-LD: WebApplication + Quiz + FAQPage + BreadcrumbList + citation
 * - AIOブロック: 「このページでわかること」
 * - YMYL回避: 医学的診断ゼロ。採用・評価への使用推奨なし明記
 * - DiSC®はWiley社の登録商標。商標表記を冒頭・footnoteで明記
 * - 4タイプ（D/i/S/C）のビジネス活用特化
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import DiagnosisFlow from '../../../components/DiagnosisFlow';
import { meta } from '../../../data/diagnoses/disc/meta';
import { questions } from '../../../data/diagnoses/disc/questions';
import { calculateResultTypeId } from '../../../data/diagnoses/disc/results';
import TldrBlock from '../../../components/TldrBlock.astro';
import ReferenceList from '../../../components/ReferenceList.astro';
import ScienceNote from '../../../components/ScienceNote.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/disc/`;

// DiagnosisFlow に渡す questions を diagnosis.ts の Question 型に変換
const flowQuestions = questions.map((q) => ({
  id: String(q.id),
  text: q.text,
}));

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: 'DiSC診断【無料・3分・28問・公式根拠付】',
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description:
    'Marston (1928) のDiSC理論に基づく無料診断。28問に答えるだけでD（主導型）・i（感化型）・S（安定型）・C（慎重型）の4タイプを判定。リーダーシップ・チームビルディング・職場コミュニケーションへの活用方法がわかります。',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// JSON-LD: Quiz（citation に学術文献を配置）
const jsonLdQuiz = {
  '@context': 'https://schema.org',
  '@type': 'Quiz',
  '@id': `${PAGE_URL}#quiz`,
  name: 'DiSC診断（28問）',
  url: PAGE_URL,
  about: {
    '@type': 'Thing',
    name: 'DiSC理論（Dominance / influence / Steadiness / Conscientiousness）',
    description: 'Marston (1928) が提唱したDiSC行動スタイル4次元モデル',
    sameAs: 'https://www.discprofile.com/what-is-disc/overview',
  },
  educationalLevel: 'HighSchool',
  numberOfQuestions: meta.questionCount,
  assesses: 'DiSCタイプ・職場での行動スタイル・リーダーシップ・チームビルディング',
  dateCreated: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  citation: meta.references.map((ref) => ({
    '@type': 'CreativeWork',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    url: ref.url,
  })),
};

// FAQ 12問（8問→12問に拡充・AI Overview最適化・2026-05-21更新）
const faqs = [
  {
    question: 'DiSC診断とは何ですか？',
    answer:
      'DiSC診断とは、心理学者William Moulton Marston（1928）が著書「Emotions of Normal People」で提唱した行動スタイル理論に基づく自己診断ツールです。D（Dominance・主導型）・i（influence・感化型）・S（Steadiness・安定型）・C（Conscientiousness・慎重型）の4タイプで職場での行動スタイルを可視化します（出典: Wiley DiSC公式 https://www.discprofile.com/what-is-disc/overview、2026-05-21確認）。',
  },
  {
    question: 'DiSC診断に科学的根拠はありますか？',
    answer:
      'DiSC理論はWilliam Moulton Marston（1928）の著書「Emotions of Normal People」（Routledge）を起源とし、Walter Clarke（1956）、John Geier（1970年代）を経てWiley社が現代版として整備した行動スタイルモデルです（参照: https://www.discprofile.com/what-is-disc/history-of-disc、2026-05-21確認）。本診断はDiSC理論に基づく自己理解ツールであり、Wiley社の公式アセスメントとは別のものです。',
  },
  {
    question: 'MBTIとDiSCの違いは何ですか？',
    answer:
      'MBTIは「どのように世界を認識し判断するか」（内向/外向・感覚/直感・思考/感情・判断/知覚）の16タイプ分類です。DiSCは「職場・対人関係での行動スタイル」（D/i/S/C）に特化した4タイプモデルです。MBTIは性格・認知の傾向全般を測り、DiSCはビジネス文脈・チームビルディング・リーダーシップ開発での活用を想定して設計されています。',
  },
  {
    question: '公式DiSC（Wiley社）との違いは何ですか？',
    answer:
      'Wiley社の公式DiSC®アセスメント（https://www.discprofile.com/）は有料の認定プログラムで、研究データと詳細解釈レポートが含まれます。本診断はDiSC理論の学術的知見に基づく無料の自己理解ツールであり、Wiley社の製品ではありません。職場での本格導入にはWiley社の認定プログラムをご検討ください。「DiSC®」はWiley社の登録商標です。',
  },
  {
    question: 'DiSCの4タイプの組み合わせはありますか？',
    answer:
      '実際のDiSCプロファイルでは4タイプが複合することが多く、Wiley社の研究では12の複合スタイルが定義されています（参照: https://www.discprofile.com/what-is-disc/disc-styles、2026-05-21確認）。本診断では最もスコアの高いタイプを「主タイプ」として判定します。複合スタイルの詳細分析はWiley社の公式アセスメントで確認できます。',
  },
  {
    question: '仕事でDiSCを活用する方法は？',
    answer:
      'DiSCは主に3つの場面で活用されます。1. チームビルディング（メンバー相互の行動スタイル理解）、2. 1on1・コーチング（上司と部下の対話スタイルの最適化）、3. リーダーシップ開発（自分の強みと盲点の把握）です。Wiley社によると、DiSCは世界75か国・年間100万人以上の組織研修で活用されています（https://www.everythingdisc.com/、2026-05-21確認）。',
  },
  {
    question: 'DiSC診断の結果は変わることがありますか？',
    answer:
      'DiSCの行動スタイルはある程度安定していますが、役割・環境・ストレス状況によって変化することがあります。同じ人でも「職場での自分」と「プライベートの自分」でスコアが異なることがあります。本診断は何回でも受けられます。3〜6ヶ月後に再受診して変化を確認するのもおすすめです。',
  },
  {
    question: 'リーダーに向いているDiSCタイプは何ですか？',
    answer:
      'DiSCではどのタイプもリーダーになれると考えます。D型は推進力・決断力で牽引するリーダー、i型は共感・巻き込み力で人をまとめるリーダー、S型は安定・信頼で長期的に支えるリーダー、C型は専門性・分析力で判断の質を高めるリーダーとして活躍します。リーダーシップスタイルが異なるだけであり、どれが優れているということはありません。',
  },
  {
    question: 'DiSCで採用や人事評価をしていいですか？',
    answer:
      'DiSCを採用・評価・昇進の基準に使うことは推奨しません。行動スタイルの好みは多様であり、特定のタイプを「優れている」とすることは公平採用の観点から問題になる可能性があります。Wiley社も「DiSCは採用選考ツールではない」と明記しています（https://www.discprofile.com/what-is-disc/overview、2026-05-21確認）。本診断は自己理解・チームコミュニケーション改善の目的でご活用ください。',
  },
  {
    question: '何問・何分かかりますか？',
    answer:
      '全28問で、目安は約3分です。各質問に「1（全く当てはまらない）〜5（とても当てはまる）」の5段階で回答します。登録不要・スマートフォンでも快適に受診できます。途中で中断しても24時間以内なら再開可能です。',
  },
  {
    question: '何回受けても同じ結果になりますか？',
    answer:
      '同じ傾向が安定して出ることが多いですが、受診時の状況（仕事のストレス・プライベートの影響）によって変わることもあります。複数回受けて傾向を確認すると、「自分の行動スタイルの幅」として参考になります。',
  },
  {
    question: 'PASSで何が追加されますか？',
    answer:
      '無料の基本診断（4タイプ判定・強み・注意点・向いている職種）に加え、¥390のPASSで「仕事・恋愛・友人・家族・学校」の5軸詳細レポートが解放されます。他診断（多重知能・MBTI・完璧主義）との統合プロファイルも閲覧できます。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: 'DiSC診断', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdQuiz, jsonLdFAQ, jsonLdBreadcrumb];

// 4タイプカード用データ
const typeCards = [
  {
    id: 'D',
    name: '主導型',
    nameEn: 'Dominance',
    catchphrase: '結果を出すために動く、スピードと実行力の牽引者',
    icon: '🦁',
    color: '#dc2626',
  },
  {
    id: 'i',
    name: '感化型',
    nameEn: 'influence',
    catchphrase: '人を巻き込み、場を明るくする生まれながらのムードメーカー',
    icon: '🌟',
    color: '#d97706',
  },
  {
    id: 'S',
    name: '安定型',
    nameEn: 'Steadiness',
    catchphrase: 'チームの土台を支える、忍耐と協調の縁の下の力持ち',
    icon: '🌿',
    color: '#16a34a',
  },
  {
    id: 'C',
    name: '慎重型',
    nameEn: 'Conscientiousness',
    catchphrase: '正確性とデータで判断する、品質と根拠の専門家',
    icon: '🔬',
    color: '#2563eb',
  },
];

// ビジネス活用シーン
const businessUses = [
  {
    icon: '👥',
    title: 'チームビルディング研修',
    desc: 'メンバー全員がDiSCタイプを把握することで、「なぜあの人と噛み合わないか」が客観的に見えてきます。スタイルの違いを「個性」として活かすチーム文化の構築に活用できます。',
  },
  {
    icon: '💼',
    title: '営業職の自己分析',
    desc: 'D型は結果重視の強引さ、i型は共感力・関係構築、S型は誠実なフォロー、C型はデータ提示・専門的提案と、それぞれ異なる営業スタイルの強みがあります。自分のスタイルを知ることで顧客対応が変わります。',
  },
  {
    icon: '🎯',
    title: 'リーダーシップ開発',
    desc: '「どのタイプのリーダーが正解か」はありません。D型・i型・S型・C型それぞれのリーダーシップスタイルを理解することで、自分の強みを伸ばしながら盲点を補完する戦略が立てられます。',
  },
  {
    icon: '🤝',
    title: '1on1ミーティングの質向上',
    desc: '上司と部下のDiSCタイプが異なる場合、コミュニケーションのすれ違いが起きやすくなります。相手のスタイルに合わせた対話設計（フィードバックの伝え方・意思決定のタイミング）に活用できます。',
  },
];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'DiSC診断', url: '/diagnosis/disc/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="disc-hero" aria-labelledby="disc-hero-h1">
    <Container>
      <div class="disc-hero-inner">
        <div class="disc-hero-badge">Marston (1928) DiSC理論に基づく | DiSC&#174;はWiley社の登録商標</div>
        <h1 id="disc-hero-h1" class="disc-hero-h1">
          DiSC診断<br />
          <span class="disc-hero-meta">【無料・3分・28問・公式根拠付】</span>
        </h1>
        <p class="disc-hero-catch">
          あなたの職場での行動スタイルはどのタイプ？<br />
          D（主導型）・i（感化型）・S（安定型）・C（慎重型）から分析
        </p>
        <div class="disc-hero-stats">
          <span class="disc-stat"><strong>28</strong>問</span>
          <span class="disc-stat-sep">・</span>
          <span class="disc-stat">約<strong>3</strong>分</span>
          <span class="disc-stat-sep">・</span>
          <span class="disc-stat"><strong>4</strong>タイプ</span>
          <span class="disc-stat-sep">・</span>
          <span class="disc-stat">無料</span>
        </div>
        <a href="#diagnosis-flow" class="disc-cta-btn">
          <span>診断スタート</span>
          <span class="disc-cta-arrow" aria-hidden="true">↓</span>
        </a>
        <p class="disc-hero-sub">登録不要・所要時間3分・途中保存OK</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TL;DRブロック（AI引用最適化） ========== */}
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        "DiSC診断はMarston（1928）の行動スタイル理論に基づき、D（主導型）・i（感化型）・S（安定型）・C（慎重型）の4タイプで職場での行動傾向を28問・約3分で測定する無料ツールです",
        "Wiley社がEveryting DiSC®として整備し、世界75か国・年間100万人以上の組織研修で活用されています（DiSC®はWiley社の登録商標。本診断はWiley社の公式アセスメントではありません）",
        "チームビルディング・1on1・リーダーシップ開発に活用でき、採用・評価には使用しないことが推奨されています"
      ]}
      updatedAt={meta.updatedAt}
      sourceLabel="Wiley DiSC公式"
      sourceUrl="https://www.discprofile.com/what-is-disc/overview"
    />

    {/* ========== DiSC診断とは ========== */}
    <section class="disc-section" aria-labelledby="disc-what-h2">
      <h2 id="disc-what-h2" class="disc-h2">DiSC診断とは</h2>
      <p class="disc-lead">
        DiSC診断は、心理学者 William Moulton Marston が 1928年に著書
        「Emotions of Normal People」で提唱した行動スタイル理論をもとにした自己理解ツールです。
        その後 Walter Clarke（1956年）、John Geier（1970年代）を経て、
        Wiley 社が「Everything DiSC&#174;」として現代版に整備し、世界中のビジネス研修で活用されています
        （<a href="https://www.discprofile.com/what-is-disc/history-of-disc" target="_blank" rel="noopener noreferrer">DiSC公式・歴史ページ</a>、2026-05-20確認）。
      </p>
      <p class="disc-body">
        「DiSC&#174;」はWiley社の登録商標です。
        本診断はDiSC理論の学術的知見に基づく自己理解ツールであり、Wiley社の公式アセスメントとは別のものです。
        職場での本格導入・認定プログラムについては
        <a href="https://www.discprofile.com/" target="_blank" rel="noopener noreferrer">Wiley DiSC公式サイト</a>
        をご確認ください。
      </p>
      <div class="disc-info-table-wrap">
        <table class="disc-info-table">
          <caption class="disc-table-caption">DiSC診断の概要（2026-05-20時点）</caption>
          <tbody>
            <tr>
              <th scope="row">理論の根拠</th>
              <td>Marston WM (1928) + Clarke WV (1956) + Wiley DiSC公式系譜</td>
            </tr>
            <tr>
              <th scope="row">問題数</th>
              <td>28問（各タイプ7問 × 4タイプ）</td>
            </tr>
            <tr>
              <th scope="row">回答方式</th>
              <td>5段階リッカートスケール（1=全く当てはまらない〜5=とても当てはまる）</td>
            </tr>
            <tr>
              <th scope="row">所要時間</th>
              <td>約3分</td>
            </tr>
            <tr>
              <th scope="row">結果タイプ数</th>
              <td>4タイプ（D：主導型・i：感化型・S：安定型・C：慎重型）</td>
            </tr>
            <tr>
              <th scope="row">主な活用場面</th>
              <td>リーダーシップ研修・チームビルディング・1on1・営業スタイル分析</td>
            </tr>
            <tr>
              <th scope="row">注意事項</th>
              <td>採用・評価への使用は推奨しません。自己理解・チームコミュニケーション改善に活用してください。</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {/* ========== 4タイプ紹介 ========== */}
    <section class="disc-section" aria-labelledby="disc-types-h2">
      <h2 id="disc-types-h2" class="disc-h2">4つのDiSCタイプ</h2>
      <p class="disc-lead">
        DiSCは「どのタイプが優れているか」ではなく、それぞれの行動スタイルの傾向と強みを理解するモデルです。
        Marston（1928）は環境への反応パターンをD・i・S・Cの4軸で分類しました。
      </p>
      <div class="disc-types-grid">
        {typeCards.map((tc) => (
          <article class="disc-type-card" style={`--type-color: ${tc.color}`}>
            <div class="disc-type-icon" aria-hidden="true">{tc.icon}</div>
            <h3 class="disc-type-name">{tc.name}</h3>
            <p class="disc-type-name-en">{tc.nameEn}</p>
            <p class="disc-type-desc">{tc.catchphrase}</p>
            <a href={`/diagnosis/disc/result/${tc.id}/`} class="disc-type-link">
              {tc.name}の詳細を見る
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>

      {/* DiSC 4タイプ概念図（課題/人間志向 × 疑問/主張志向の軸） */}
      <div class="disc-chart-figure" role="figure" aria-labelledby="disc-chart-caption">
        <div class="disc-chart-visual" aria-hidden="true">
          <div class="disc-chart-axis disc-chart-axis--x">
            <span class="disc-axis-label disc-axis-label--left">疑問・分析志向<br/>（問う）</span>
            <div class="disc-axis-line disc-axis-line--h"></div>
            <span class="disc-axis-label disc-axis-label--right">主張・行動志向<br/>（動く）</span>
          </div>
          <div class="disc-chart-axis disc-chart-axis--y">
            <span class="disc-axis-label disc-axis-label--top">課題志向<br/>（タスク優先）</span>
            <div class="disc-axis-line disc-axis-line--v"></div>
            <span class="disc-axis-label disc-axis-label--bottom">人間志向<br/>（関係優先）</span>
          </div>
          <div class="disc-chart-quadrant disc-chart-quadrant--tl">
            <span class="disc-quad-icon">🦁</span>
            <span class="disc-quad-name">D（主導型）</span>
          </div>
          <div class="disc-chart-quadrant disc-chart-quadrant--tr">
            <span class="disc-quad-icon">🌟</span>
            <span class="disc-quad-name">i（感化型）</span>
          </div>
          <div class="disc-chart-quadrant disc-chart-quadrant--bl">
            <span class="disc-quad-icon">🔬</span>
            <span class="disc-quad-name">C（慎重型）</span>
          </div>
          <div class="disc-chart-quadrant disc-chart-quadrant--br">
            <span class="disc-quad-icon">🌿</span>
            <span class="disc-quad-name">S（安定型）</span>
          </div>
        </div>
        <p id="disc-chart-caption" class="disc-chart-caption">
