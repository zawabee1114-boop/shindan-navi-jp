<BaseLayout
  title={title}
  description={description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate="2026-05-21"
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'DiSC診断', url: '/diagnosis/disc/' },
    { name: '4タイプまとめ', url: '/diagnosis/disc/types-summary/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="ts-hero" aria-labelledby="ts-h1">
    <Container>
      <div class="ts-hero-inner">
        <p class="ts-hero-badge">DiSC&#174; Wiley社登録商標 | Marston (1928) 学術根拠付き | 2026-05-21 更新</p>
        <h1 id="ts-h1" class="ts-h1">
          DiSC 4タイプ完全まとめ
        </h1>
        <p class="ts-hero-sub">
          D（主導型）・i（感化型）・S（安定型）・C（慎重型）の特徴・強み・相性を一覧解説
        </p>
        <div class="ts-hero-tags">
          <span class="ts-tag">特徴・強み・弱み</span>
          <span class="ts-tag">向いている職種</span>
          <span class="ts-tag">16組合せ相性表</span>
          <span class="ts-tag">FAQ 10問</span>
        </div>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TldrBlock（AIO引用最適化） ========== */}
    <TldrBlock
      title="このページでわかること"
      points={[
        "DiSC® 4タイプ（D＝主導型・i＝感化型・S＝安定型・C＝慎重型）の特徴・強み・弱み・向いている職種を1ページで網羅（Marston 1928 / Wiley DiSC公式根拠付き）",
        "4タイプ × 4タイプ 16組合せの「コミュニケーション相性まとめ」で、職場の対人関係改善に活用できる",
        "自分のタイプが不明な方は無料のDiSC診断（28問・約3分）ですぐ確認可能"
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="Wiley DiSC公式"
      sourceUrl="https://www.discprofile.com/what-is-disc/overview"
    />

    {/* ========== DiSC理論の定義 ========== */}
    <section class="ts-section" aria-labelledby="ts-what-h2">
      <h2 id="ts-what-h2" class="ts-h2">DiSC理論とは（定義）</h2>
      <p class="ts-lead">
        DiSCとは、心理学者 William Moulton Marston が 1928年に著書
        「Emotions of Normal People」（Routledge）で提唱した行動スタイル理論です。
        その後 Walter Clarke（1956年）、John Geier（1970年代）を経て、
        Wiley社が「Everything DiSC&#174;」として整備しました
        （<a href="https://www.discprofile.com/what-is-disc/history-of-disc" target="_blank" rel="noopener noreferrer">Wiley DiSC・歴史ページ</a>、2026-05-21確認）。
      </p>
      <div class="ts-info-table-wrap">
        <table class="ts-info-table">
          <caption class="ts-table-caption">DiSC 4タイプの基本定義（2026-05-21時点）</caption>
          <thead>
            <tr>
              <th scope="col">タイプ</th>
              <th scope="col">英語名</th>
              <th scope="col">Marston定義</th>
              <th scope="col">キーワード</th>
            </tr>
          </thead>
          <tbody>
            {typeDetails.map((t) => (
              <tr>
                <th scope="row" style={`color: ${t.color}; font-weight: 700;`}>
                  {t.emoji} {t.name}（{t.id}型）
                </th>
                <td>{t.nameEn}</td>
                <td>{t.description}</td>
                <td><span class="ts-kw-tag" style={`background: ${t.bgColor}; color: ${t.color};`}>{t.keyword}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="ts-note">
        「DiSC&#174;」はJohn Wiley &amp; Sons, Inc. の登録商標です。
        本ページはDiSC理論に基づく自己理解コンテンツであり、Wiley社の公式アセスメントとは別のものです。
      </p>
    </section>

    {/* ========== 4タイプ詳細カード ========== */}
    <section class="ts-section" aria-labelledby="ts-types-h2">
      <h2 id="ts-types-h2" class="ts-h2">各タイプの詳細解説</h2>
      <p class="ts-lead">
        4タイプそれぞれの特徴・強み・弱み・向いている職種・コミュニケーションスタイルを詳しく解説します。
      </p>
      {typeDetails.map((t) => (
        <article
          class="ts-type-card"
          id={`type-${t.id}`}
          style={`border-top-color: ${t.color}; --type-bg: ${t.bgColor}; --type-border: ${t.borderColor}; --type-color: ${t.color};`}
          aria-labelledby={`type-${t.id}-h3`}
        >
          <div class="ts-type-header">
            <span class="ts-type-emoji" aria-hidden="true">{t.emoji}</span>
            <div>
              <h3 id={`type-${t.id}-h3`} class="ts-type-name" style={`color: ${t.color}`}>
                {t.id}型（{t.name}・{t.nameEn}）
              </h3>
              <p class="ts-type-keyword">{t.keyword}</p>
            </div>
          </div>
          <p class="ts-type-desc">{t.description}</p>

          <div class="ts-type-grid">
            <div class="ts-type-col">
              <h4 class="ts-type-col-title ts-col-strength">強み</h4>
              <ul class="ts-type-list">
                {t.strengths.map((s) => <li>{s}</li>)}
              </ul>
