---
/**
 * 恋愛スタイル診断 結果ページ（動的ルート）
 * 6タイプ分の結果ページを静的生成する
 *
 * URL: /diagnosis/love-style/result/{typeId}/
 * タイプID: eros / ludus / storge / pragma / mania / agape
 *
 * SEO/AIO:
 * - JSON-LD: WebApplication + Article + BreadcrumbList
 * - タイプ別メタタイトル・ディスクリプション
 * - 5タイプとの相性ランキング（スコア順）
 * - 友情関係への転用セクション
 * - self-care セクション（このタイプが大切にすべきこと）
 * - YMYL回避: 「mania型=依存症」等のラベリングNG
 * - LGBTQ+配慮: 「パートナー/相手」表現
 *
 * 確認日: 2026-05-21
 */
import ResultLayout from '../../../../layouts/ResultLayout.astro';
import Container from '../../../../components/Container.astro';
import { types, getOtherTypes } from '../../../../data/diagnoses/love-style/types';
import { meta } from '../../../../data/diagnoses/love-style/meta';
import { getAllPairsForType } from '../../../../data/diagnoses/love-style/compatibility';
import type { LoveStyleType } from '../../../../data/diagnoses/love-style/questions';

export function getStaticPaths() {
  return Object.keys(types).map((typeId) => ({
    params: { type: typeId },
    props: {
      typeId: typeId as LoveStyleType,
      typeData: types[typeId as LoveStyleType],
    },
  }));
}

const { typeId, typeData } = Astro.props;

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/love-style/result/${typeId}/`;

// 5タイプとの相性ランキング（スコア降順）
const compatibilityRanking = getAllPairsForType(typeId);

// タイプ別テーマカラー
const typeColor: Record<LoveStyleType, string> = {
  eros: '#dc2626',
  ludus: '#d97706',
  storge: '#16a34a',
  pragma: '#2563eb',
  mania: '#7c3aed',
  agape: '#0891b2',
};

// 思考傾向グラフ用ラベル（Big5/OCEAN表記禁止）
const radarLabels = [
  { key: 'O', label: '好奇心・探求' },
  { key: 'C', label: '計画性・丁寧さ' },
  { key: 'E', label: '行動力・積極性' },
  { key: 'A', label: '共感力・協調性' },
  { key: 'N', label: '感情の繊細さ' },
] as const;

// 相性カテゴリの色
const categoryColor: Record<string, string> = {
  '非常に高い相性': '#16a34a',
  '良い相性': '#2563eb',
  '補完し合える関係': '#d97706',
  '成長機会の多いペア': '#7c3aed',
  '対比から学べる関係': '#dc2626',
};

// FAQs（タイプ別）
const faqs = [
  {
    question: `${typeData.japaneseName}の恋愛傾向の特徴は？`,
    answer: typeData.characteristics.slice(0, 3).join('。') + '。',
  },
  {
    question: `${typeData.japaneseName}はどんな強みがありますか？`,
    answer: typeData.strengths.join('。また、') + '。',
  },
  {
    question: `${typeData.japaneseName}が気をつけたい恋愛パターンは？`,
    answer: typeData.weaknesses[0] + '。' + typeData.weaknesses[1] + '。ただし、これらは弱点ではなく強みと表裏一体の傾向です。',
  },
  {
    question: `${typeData.japaneseName}と最も相性の良いタイプは？`,
    answer:
      compatibilityRanking.length > 0
        ? `${types[compatibilityRanking[0].typeId].japaneseName}との相性が最も高い傾向があります（スコア: ${compatibilityRanking[0].compatibility.score}/100）。${compatibilityRanking[0].compatibility.oneLineSummary}`
        : '相性は個人差があります。対話を重ねることが最も重要です。',
  },
  {
    question: `${typeData.japaneseName}の友情パターンは？`,
    answer: typeData.friendshipPattern,
  },
];

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: `恋愛スタイル診断 結果：${typeData.japaneseName}`,
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description: `恋愛スタイル診断の結果は「${typeData.japaneseName}」。${typeData.catchphrase}`,
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
};

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  headline: `${typeData.japaneseName}（${typeData.nameEn}）の恋愛傾向・強み・相性ランキング完全ガイド`,
  url: PAGE_URL,
  description: `恋愛スタイル診断の結果「${typeData.japaneseName}」の恋愛傾向・強み・気をつけたい点・5タイプとの相性ランキングを詳しく解説。J.A.Lee（1973）理論に基づく自己理解ガイド。`,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  about: {
    '@type': 'Thing',
    name: `${typeData.japaneseName} 恋愛スタイル`,
    sameAs: 'https://doi.org/10.1037/0022-3514.50.2.392',
  },
  citation: [
    {
      '@type': 'CreativeWork',
      name: 'Colours of Love',
      author: 'Lee JA',
      datePublished: '1973',
    },
    {
      '@type': 'CreativeWork',
      name: 'A Theory and Method of Love',
      author: 'Hendrick C, Hendrick S',
      datePublished: '1986',
      url: 'https://doi.org/10.1037/0022-3514.50.2.392',
    },
  ],
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '恋愛スタイル診断', item: `${SITE_URL}/diagnosis/love-style/` },
    { '@type': 'ListItem', position: 4, name: typeData.japaneseName, item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdArticle, jsonLdBreadcrumb];

// 関連診断
const relatedDiagnoses = [
  { title: 'MBTI恋愛相性診断', href: '/diagnosis/mbti-compat/love/', icon: '💑', badge: 'おすすめ' },
  { title: '友達相性診断', href: '/diagnosis/friend-compat/', icon: '🤝' },
  { title: '完璧主義診断', href: '/diagnosis/perfectionism/', icon: '🔱' },
  { title: '多重知能テスト', href: '/diagnosis/multi-int/', icon: '🦉' },
];

// description の改行を除去
const descriptionClean = typeData.description.replace(/\n+/g, ' ').trim();
---

<ResultLayout
  diagnosisId="love-style"
  diagnosisClass="diag-love"
  typeId={typeId}
  typeName={typeData.japaneseName}
  diagnosisName="恋愛スタイル診断"
  characterEmoji={typeData.emoji}
  characterName={typeData.nameEn}
  tagline={typeData.catchphrase}
  shareUrl={PAGE_URL}
  pageTitle={`${typeData.japaneseName}【恋愛スタイル診断】恋愛傾向・強み・相性ランキング | 診断ナビ`}
  pageDescription={`恋愛スタイル診断の結果は「${typeData.japaneseName}（${typeData.nameEn}）」。${typeData.catchphrase} 恋愛傾向・強み・気をつけたい点・5タイプとの相性ランキングを詳しく解説。J.A.Lee（1973）理論に基づく自己理解ガイド。`}
  relatedDiagnoses={relatedDiagnoses}
  jsonLd={jsonLdAll}
>
  {/* ========== 概要タブ ========== */}
  <Fragment slot="overview">
    <div class="lsr-overview">
      <div class="lsr-aio-block">
        <p class="lsr-aio-title">このページでわかること</p>
        <ul class="lsr-aio-list">
          <li>{typeData.japaneseName}（{typeData.nameEn}）の恋愛傾向・特徴・強み・気をつけたい点</li>
          <li>他5タイプとの相性ランキング（スコア順・J.A.Lee理論に基づく）</li>
          <li>友情関係への応用方法・このタイプが恋愛で大切にすべきこと（self-care）</li>
        </ul>
      </div>

      <div class="lsr-description">
        {descriptionClean.split('。').filter(s => s.trim()).map((sentence) => (
          <p class="lsr-body">{sentence.trim()}。</p>
        ))}
      </div>

      <div class="lsr-characteristics">
        <h3 class="lsr-h3">このタイプの5つの特徴</h3>
        <ul class="lsr-char-list">
          {typeData.characteristics.map((char) => (
            <li class="lsr-char-item">
              <span class="lsr-char-icon" aria-hidden="true" style={`color: ${typeColor[typeId]}`}>◆</span>
              <span>{char}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="lsr-theory-note">
        <p>
          この診断結果はJ.A.Lee（1973）「Colours of Love」およびHendrick & Hendrick（1986）Love Attitudes Scale
          （<a href="https://doi.org/10.1037/0022-3514.50.2.392" target="_blank" rel="noopener noreferrer">DOI確認済</a>）
          に基づく恋愛傾向把握のための参考情報です。
          医学的・臨床的な診断ではありません。
        </p>
      </div>

      <div class="lsr-freshness">
        <time datetime={meta.updatedAt}>{meta.updatedAt}</time> 時点の情報。
        月1回以上の鮮度確認を実施しています。
      </div>
    </div>
  </Fragment>

  {/* ========== 強みタブ ========== */}
  <Fragment slot="strengths">
    <div class="lsr-strengths">
      <h3 class="lsr-section-h3">{typeData.japaneseName}の4つの強み</h3>
      <ul class="lsr-strength-list">
        {typeData.strengths.map((s) => (
          <li class="lsr-strength-item">
            <span class="lsr-strength-icon" aria-hidden="true">✅</span>
            <span>{s}</span>
          </li>
        ))}
      </ul>
    </div>
  </Fragment>

  {/* ========== 注意点タブ ========== */}
  <Fragment slot="weaknesses">
    <div class="lsr-weaknesses">
      <h3 class="lsr-section-h3">気をつけたい傾向</h3>
      <ul class="lsr-weakness-list">
        {typeData.weaknesses.map((w) => (
          <li class="lsr-weakness-item">
            <span class="lsr-weakness-icon" aria-hidden="true">⚡</span>
            <span>{w}</span>
          </li>
        ))}
      </ul>
      <div class="lsr-weakness-note">
        これらは「弱点」ではなく「強みと表裏一体の傾向」です。
        自分のスタイルを理解することで、パートナーとの対話に活かせます。
      </div>
    </div>
  </Fragment>

  {/* ========== 恋愛タブ（相性ランキング・self-care） ========== */}
  <Fragment slot="love">
    <div class="lsr-love">
      {/* 相性ランキング */}
      <h3 class="lsr-section-h3">5タイプとの相性ランキング</h3>
      <p class="lsr-love-note">
        J.A.Lee（1973）理論に基づく傾向値です。個人差があり、対話と相互理解が最も重要です。
      </p>
      <div class="lsr-compat-list">
        {compatibilityRanking.map((item, index) => {
          const otherType = types[item.typeId];
          const catColor = categoryColor[item.compatibility.category] ?? '#6b7280';
          return (
            <div class="lsr-compat-item">
              <div class="lsr-compat-rank" aria-hidden="true">{index + 1}</div>
              <div class="lsr-compat-body">
                <div class="lsr-compat-header">
                  <span class="lsr-compat-emoji">{otherType.emoji}</span>
                  <span class="lsr-compat-name">{otherType.japaneseName}</span>
                  <span class="lsr-compat-score" style={`color: ${catColor}`}>
                    {item.compatibility.score}/100
                  </span>
                  <span class="lsr-compat-category" style={`background: ${catColor}15; color: ${catColor}; border-color: ${catColor}40`}>
                    {item.compatibility.category}
                  </span>
                </div>
                <p class="lsr-compat-summary">{item.compatibility.oneLineSummary}</p>
                <p class="lsr-compat-detail">{item.compatibility.detailDescription}</p>
                <div class="lsr-compat-sub">
                  <div class="lsr-compat-sub-item">
                    <span class="lsr-compat-sub-label">うまくいくシーン</span>
                    <span class="lsr-compat-sub-text">{item.compatibility.workingTogether}</span>
                  </div>
                  <div class="lsr-compat-sub-item">
                    <span class="lsr-compat-sub-label">成長の機会</span>
                    <span class="lsr-compat-sub-text">{item.compatibility.growthPotential}</span>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      {/* 相性タイプ概要カード */}
      <div class="lsr-compat-types">
        <h3 class="lsr-section-h3" style="margin-top: 2rem;">相性の良いタイプ（上位2タイプ）</h3>
        <div class="lsr-compat-good-grid">
          {typeData.compatibleTypes.map((ct) => {
            const ct_data = types[ct.typeId];
            return (
              <a href={`/diagnosis/love-style/result/${ct.typeId}/`} class="lsr-compat-good-card" style={`--ct-color: ${typeColor[ct.typeId]}`}>
                <span class="lsr-compat-good-emoji">{ct_data.emoji}</span>
                <span class="lsr-compat-good-name">{ct_data.japaneseName}</span>
                <span class="lsr-compat-good-reason">{ct.reason}</span>
              </a>
            );
          })}
        </div>

        <h3 class="lsr-section-h3" style="margin-top: 1.5rem;">成長機会の多いタイプ</h3>
        <p class="lsr-challenge-note">
          「成長機会の多いタイプ」は、対話を重ねることで互いに多くを学べる関係です。
        </p>
        <div class="lsr-compat-good-grid">
          {typeData.challengingTypes.map((ct) => {
            const ct_data = types[ct.typeId];
            return (
              <a href={`/diagnosis/love-style/result/${ct.typeId}/`} class="lsr-compat-challenge-card" style={`--ct-color: ${typeColor[ct.typeId]}`}>
                <span class="lsr-compat-good-emoji">{ct_data.emoji}</span>
                <span class="lsr-compat-good-name">{ct_data.japaneseName}</span>
                <span class="lsr-compat-good-reason">{ct.reason}</span>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 友人タブ（友情パターン） ========== */}
  <Fragment slot="friend">
    <div class="lsr-friend">
      <h3 class="lsr-section-h3">{typeData.japaneseName}の友情パターン</h3>
      <p class="lsr-body">{typeData.friendshipPattern}</p>
      <div class="lsr-friend-note">
        <p>
          J.A.Lee（1973）の研究では、恋愛スタイルは友情関係にも影響することが示されています。
          自分のスタイルを友人関係に応用することで、友情の特徴が理解しやすくなります。
        </p>
      </div>

      <div class="lsr-pass-cta">
        <p class="lsr-pass-desc">
          友人関係での詳細な相性分析は友達相性診断で確認できます。
        </p>
        <a href="/diagnosis/friend-compat/" class="lsr-pass-btn">
          <span>友達相性診断を受ける</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Fragment>

  {/* ========== 家族タブ ========== */}
  <Fragment slot="family">
    <div class="lsr-family">
      <div class="lsr-pass-preview">
        <h3 class="lsr-section-h3">{typeData.japaneseName}の家族関係</h3>
        <p class="lsr-body">
          {typeData.japaneseName}の恋愛スタイルは、家族への接し方にも影響します。
          {typeData.characteristics[3]}
        </p>
        <div class="lsr-pass-cta">
          <p class="lsr-pass-desc">
            家族関係での{typeData.japaneseName}の傾向詳細は¥390 PASSで確認できます。
          </p>
          <a href="/pass/" class="lsr-pass-btn">
            <span>¥390 PASSで家族レポートを読む</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 学校タブ ========== */}
  <Fragment slot="school">
    <div class="lsr-school">
      <div class="lsr-pass-preview">
        <h3 class="lsr-section-h3">{typeData.japaneseName}の学習・成長スタイル</h3>
        <div class="lsr-pass-cta">
          <p class="lsr-pass-desc">
            {typeData.japaneseName}に合った成長・学習のヒントは¥390 PASSで確認できます。
          </p>
          <a href="/pass/" class="lsr-pass-btn">
            <span>¥390 PASSで詳細を読む</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 有名人タブ ========== */}
  <Fragment slot="celebrity">
    <div class="lsr-celebrity">
      <h3 class="lsr-section-h3">{typeData.japaneseName}の行動類型</h3>
      <div class="lsr-pass-preview">
        <div class="lsr-pass-cta">
          <p class="lsr-pass-desc">
            {typeData.japaneseName}の行動パターンが見える類型の詳細は¥390 PASSで確認できます。
          </p>
          <a href="/pass/" class="lsr-pass-btn">
            <span>¥390 PASSで詳細を読む</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </Fragment>

  {/* ========== 成長タブ（self-care） ========== */}
  <Fragment slot="growth">
    <div class="lsr-growth">
      <h3 class="lsr-section-h3">{typeData.japaneseName}が恋愛で大切にすべきこと</h3>
      <p class="lsr-growth-note">
        恋愛スタイルの傾向を理解した上で、自分らしく関係を育てるためのガイドラインです。
        専門的なカウンセリングの代替ではありません。
      </p>
      <div class="lsr-selfcare-block">
        <p class="lsr-body">{typeData.selfCare}</p>
      </div>

      <h3 class="lsr-section-h3" style="margin-top: 1.5rem;">実践ヒント（5ステップ）</h3>
      <ul class="lsr-tips-list">
        <li class="lsr-tips-item">
          <div class="lsr-tips-num" style={`background: ${typeColor[typeId]}`} aria-hidden="true">1</div>
          <p class="lsr-tips-body">
            自分が「{typeData.japaneseName}」であることを言語化しておく。
            「私の恋愛スタイルは{typeData.catchphrase}という傾向があります」と伝えられると、パートナーとの理解がスムーズになります。
          </p>
        </li>
        <li class="lsr-tips-item">
          <div class="lsr-tips-num" style={`background: ${typeColor[typeId]}`} aria-hidden="true">2</div>
          <p class="lsr-tips-body">
            パートナーの恋愛スタイルを確認する。
            お互いのタイプを知ることで、「なぜこのすれ違いが起きているか」の原因が見えやすくなります。
            恋愛スタイルは対話のきっかけとして活用してください。
          </p>
        </li>
        <li class="lsr-tips-item">
          <div class="lsr-tips-num" style={`background: ${typeColor[typeId]}`} aria-hidden="true">3</div>
          <p class="lsr-tips-body">
            「{typeData.strengths[0]}」という強みを意識的に発揮できる場面を増やす。
            強みを自覚した上で関係に活かすことで、パートナーへの貢献が明確になります。
          </p>
        </li>
        <li class="lsr-tips-item">
          <div class="lsr-tips-num" style={`background: ${typeColor[typeId]}`} aria-hidden="true">4</div>
          <p class="lsr-tips-body">
            気をつけたい傾向のうち、最もよく出るパターンを1つ選んで意識する。
            {typeData.weaknesses[0]}。
            週1回の振り返りで「今週はどうだったか」を確認するとパターンが変わりやすくなります。
          </p>
        </li>
        <li class="lsr-tips-item">
          <div class="lsr-tips-num" style={`background: ${typeColor[typeId]}`} aria-hidden="true">5</div>
          <p class="lsr-tips-body">
            相性ランキングを参考に、成長機会の多いタイプとの対話を深める。
            違うスタイルのパートナーや友人との丁寧な対話が、自分の恋愛スタイルの幅を広げます。
          </p>
        </li>
      </ul>
      <div class="lsr-pass-cta">
        <p class="lsr-pass-desc">
          他の診断と組み合わせた統合プロファイルは /pro で確認できます。
        </p>
        <a href="/pro/" class="lsr-pass-btn">
          <span>統合プロファイルで過去と比較する</span>
          <span aria-hidden="true">→</span>
        </a>
        <p class="lsr-pass-sub">複数診断の統合管理・AIプロンプトカード付き</p>
      </div>
    </div>
  </Fragment>
</ResultLayout>

{/* ========== 結果ページ追加コンテンツ（ResultLayout外） ========== */}
<Container>
