---
/**
 * 恋愛スタイル診断 ランディングページ
 * KW: 恋愛スタイル診断（VOL3,600/SD20・Phase 1第9優先）
 * 学術根拠: J.A.Lee (1973) + Hendrick & Hendrick (1986) Love Attitudes Scale
 * 確認日: 2026-05-21
 *
 * SEO/AIO対応:
 * - JSON-LD: WebApplication + Quiz + FAQPage + BreadcrumbList
 * - AIOブロック: 「このページでわかること」
 * - YMYL回避: 医学用語NG・「恋愛傾向」表現・「メンヘラ」等NG
 * - LGBTQ+配慮: 「パートナー/相手」表現
 * - 心理的決定論NG: 「傾向がある」表現
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import DiagnosisFlow from '../../../components/DiagnosisFlow';
import { meta } from '../../../data/diagnoses/love-style/meta';
import { questions } from '../../../data/diagnoses/love-style/questions';
import { calculateResultTypeId } from '../../../data/diagnoses/love-style/results';
import TldrBlock from '../../../components/TldrBlock.astro';
import ReferenceList from '../../../components/ReferenceList.astro';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/love-style/`;

// DiagnosisFlow に渡す questions を diagnosis.ts の Question 型に変換
const flowQuestions = questions.map((q) => ({
  id: String(q.id),
  text: q.text,
}));

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: '恋愛スタイル診断【無料・3分・30問・J.A.Lee理論】',
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description:
    'John Alan Lee（1973）の6タイプ恋愛理論に基づく無料診断。30問で情熱型（Eros）・遊戯型（Ludus）・友愛型（Storge）・実利型（Pragma）・感情型（Mania）・献身型（Agape）から恋愛スタイルを判定します。',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// JSON-LD: Quiz（citation に学術文献を配置）
const jsonLdQuiz = {
  '@context': 'https://schema.org',
  '@type': 'Quiz',
  '@id': `${PAGE_URL}#quiz`,
  name: '恋愛スタイル診断（30問）',
  url: PAGE_URL,
  about: {
    '@type': 'Thing',
    name: '恋愛スタイル6タイプ理論（Eros / Ludus / Storge / Pragma / Mania / Agape）',
    description: 'J.A.Lee（1973）が提唱した恋愛の6タイプ分類モデル',
    sameAs: 'https://doi.org/10.1037/0022-3514.50.2.392',
  },
  educationalLevel: 'HighSchool',
  numberOfQuestions: meta.questionCount,
  assesses: '恋愛スタイル・恋愛傾向・パートナーとの相性・友情パターン',
  dateCreated: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  citation: meta.references.map((ref) => ({
    '@type': 'CreativeWork',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    url: ref.url,
  })),
};

// FAQ 12問（8問→12問に拡充・AI Overview最適化・2026-05-21更新）
const faqs = [
  {
    question: '恋愛スタイル診断とは何ですか？',
    answer:
      '恋愛スタイル診断とは、カナダの社会学者 J.A.Lee が1973年の著書「The Colors of Love」で提唱した恋愛類型論に基づく自己診断ツールです。情熱型（Eros）・遊戯型（Ludus）・友愛型（Storge）・実利型（Pragma）・感情型（Mania）・献身型（Agape）の6スタイルで恋愛傾向を分類します（参照: Lee JA (1973). The Colors of Love. New Press.）。',
  },
  {
    question: '恋愛スタイル診断の科学的根拠は？',
    answer:
      'J.A.Lee（1973）の理論をもとに、Hendrick & Hendrick（1986）がLove Attitudes Scale（LAS）を開発・信頼性検証し、心理学研究で広く使用されています（参照: Hendrick C & Hendrick SS, 1986, Journal of Personality and Social Psychology, 50(2), 392-402）。本診断はその知見を参考に、日本語環境向けに設計した自己理解ツールです。',
  },
  {
    question: '恋愛スタイルは変わることがありますか？',
    answer:
      'はい、変わることがあります。Lee（1973）の研究でも、恋愛スタイルは経験・成長・環境の変化によって変容することが示されています。同じ人でも20代と30代では結果が異なる場合があります。本診断は「今の傾向」を把握するためのツールです。',
  },
  {
    question: '6タイプの違いを教えてください',
    answer:
      '情熱型（Eros）：強い感情的惹かれを重視。遊戯型（Ludus）：自由と軽やかさを大切にする。友愛型（Storge）：友情から育まれる安定した愛。実利型（Pragma）：価値観・将来設計の一致を重視。感情型（Mania）：強い感情の波と深いつながりへの希求。献身型（Agape）：見返りを求めない深い愛情。（J.A.Lee 1973に基づく分類）',
  },
  {
    question: '自分の恋愛スタイルを知るメリットは何ですか？',
    answer:
      'Hendrick & Hendrick（1986）の研究では、恋愛スタイルへの理解が関係満足度と関連することが示されています。自分の傾向を知ることで、パートナーとの期待値のすり合わせがしやすくなり、すれ違いを減らす対話のきっかけになります。',
  },
  {
    question: '感情型（Mania）は依存傾向があるということですか？',
    answer:
      'いいえ、そうではありません。感情型は「恋愛への真剣さと強い感情表現の傾向」を示す恋愛スタイルです。医学的な依存症や執着の障害とは全く異なります。感情型の方の深い愛情は、誠実さとパートナーへの真剣さの表れでもあります。',
  },
  {
    question: '結婚に向いているタイプは何ですか？',
    answer:
      '研究（Hendrick & Hendrick 1992）では、Storge（友愛型）とPragma（実利型）が長期的な関係満足度と相関しやすい傾向が示されています。ただし、どのタイプでも自分のスタイルを理解してパートナーと対話できることが、最も重要です。',
  },
  {
    question: '献身型（Agape）は自己犠牲しすぎる傾向がありますか？',
    answer:
      '献身型は相手の幸せを自分の喜びとする傾向が強い恋愛スタイルです。この傾向は深い誠実さの表れでもありますが、自分のニーズを後回しにしすぎると消耗することがあります。自分を大切にすることも、長期的に相手を支えるための選択です。',
  },
  {
    question: '同じタイプ同士の相性はどうですか？',
    answer:
      'タイプによって異なります。友愛型同士・献身型同士は価値観の共鳴がしやすく、安定しやすいです。遊戯型同士も自由の感覚が合います。感情型同士は深い理解はしやすいですが、感情の波が重なると衝突しやすくなる場合があります。同タイプでも対話が最も重要です。',
  },
  {
    question: 'この診断は恋愛だけに使えますか？',
    answer:
      '友情関係・職場の対人関係にも応用できます。各タイプページに「友情パターン」の説明を掲載しています。恋愛スタイルは友人への接し方にも影響することが研究（Lee 1973）で示されており、人間関係全般の自己理解ツールとして活用できます。',
  },
  {
    question: '恋愛スタイル診断とMBTIの違いは何ですか？',
    answer:
      'MBTIは「性格全般の認知・判断傾向」を16タイプで分類します。恋愛スタイル診断は「恋愛における価値観・行動傾向」を6スタイルで分類します。組み合わせることで、「どんな人か（MBTI）×恋愛でどう動くか（恋愛スタイル）」の立体的な自己理解が得られます。',
  },
  {
    question: 'PASSで何が追加されますか？',
    answer:
      '無料の基本診断（6タイプ判定・強み・注意点）に加え、¥390のPASSで「仕事・恋愛・友人・家族・学校」の5軸詳細レポートが解放されます。他診断（多重知能・DiSC・完璧主義）との統合プロファイルも閲覧できます。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '恋愛スタイル診断', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdQuiz, jsonLdFAQ, jsonLdBreadcrumb];

// 6タイプカード用データ
const typeCards = [
  {
    id: 'eros',
    japaneseName: '情熱型',
    nameEn: 'Eros',
    catchphrase: '運命の出会いを信じる、情熱と直感の恋愛家',
    icon: '❤️',
    color: '#dc2626',
  },
  {
    id: 'ludus',
    japaneseName: '遊戯型',
    nameEn: 'Ludus',
    catchphrase: '自由に楽しむ、恋愛の達人スタイル',
    icon: '🃏',
    color: '#d97706',
  },
  {
    id: 'storge',
    japaneseName: '友愛型',
    nameEn: 'Storge',
    catchphrase: '信頼と時間が育む、友情から始まる深い絆',
    icon: '🌿',
    color: '#16a34a',
  },
  {
    id: 'pragma',
    japaneseName: '実利型',
    nameEn: 'Pragma',
    catchphrase: '現実と感情を両立させる、賢明な恋愛設計者',
    icon: '🔑',
    color: '#2563eb',
  },
  {
    id: 'mania',
    japaneseName: '感情型',
    nameEn: 'Mania',
    catchphrase: '愛の深さを全力で感じる、感情の豊かな恋愛家',
    icon: '🌊',
    color: '#7c3aed',
  },
  {
    id: 'agape',
    japaneseName: '献身型',
    nameEn: 'Agape',
    catchphrase: '見返りを求めない、深く静かな無償の愛',
    icon: '🕊️',
    color: '#0891b2',
  },
];

// 恋愛スタイルが人生に与える影響（セクション用）
const lifeImpacts = [
  {
    icon: '💬',
    title: 'パートナーとの対話パターン',
    desc: '恋愛スタイルによって、コミュニケーションの好みや期待値が異なります。情熱型は感情的な共鳴を求め、実利型は論理的な対話を好む傾向があります。自分のスタイルを知ることで、「なぜパートナーと話し合いがうまくいかないか」の原因が見えやすくなります。',
  },
  {
    icon: '🤝',
    title: '友情・人間関係への影響',
    desc: 'Lee（1973）の研究では、恋愛スタイルは友情関係にも影響することが示されています。献身型は友人のために自然に動き、遊戯型は広いネットワークを好みます。自分のスタイルを友人関係に応用することで、人間関係の多くが腑に落ちる気づきを得られます。',
  },
  {
    icon: '📈',
    title: '長期的なパートナーシップ',
    desc: 'Hendrick & Hendrick（1986）のLove Attitudes Scale研究では、恋愛スタイルと関係満足度の関連が示されています。自分のスタイルを自覚し、パートナーとの期待値を丁寧にすり合わせることが、長期的な関係満足の基盤になります。',
  },
];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  ogImage="/og/love-style.svg"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '恋愛スタイル診断', url: '/diagnosis/love-style/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="ls-hero" aria-labelledby="ls-hero-h1">
    <Container>
      <div class="ls-hero-inner">
        <div class="ls-hero-badge">J.A.Lee (1973) 恋愛6タイプ理論 | Hendrick & Hendrick (1986) LAS 準拠</div>
        <h1 id="ls-hero-h1" class="ls-hero-h1">
          恋愛スタイル診断<br />
          <span class="ls-hero-meta">【無料・3分・30問・J.A.Lee理論】</span>
        </h1>
        <p class="ls-hero-catch">
          あなたの恋愛スタイルはどのタイプ？<br />
          情熱型・遊戯型・友愛型・実利型・感情型・献身型の6つから判定
        </p>
        <div class="ls-hero-stats">
          <span class="ls-stat"><strong>30</strong>問</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat">約<strong>3</strong>分</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat"><strong>6</strong>タイプ</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat">無料</span>
        </div>
        <a href="#diagnosis-flow" class="ls-cta-btn">
          <span>診断スタート</span>
          <span class="ls-cta-arrow" aria-hidden="true">↓</span>
        </a>
        <p class="ls-hero-sub">登録不要・所要時間3分・途中保存OK</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TL;DRブロック（AI引用最適化） ========== */}
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        "恋愛スタイル診断はJ.A.Lee（1973）の恋愛類型論に基づき、情熱型・遊戯型・友愛型・実利型・感情型・献身型の6スタイルを28問・約3分で判定する無料ツールです",
        "Hendrick & Hendrick（1986）の研究では、恋愛スタイルの理解が関係満足度と関連することが示されています",
        "恋愛・友情・職場の人間関係全般の自己理解に活用でき、パートナーとの対話のきっかけになります"
      ]}
      updatedAt={meta.updatedAt}
      sourceLabel="Hendrick & Hendrick (1986) Love Attitudes Scale"
      sourceUrl="https://doi.org/10.1177/0146167286124002"
    />

    {/* ========== 恋愛スタイル理論とは ========== */}
    <section class="ls-section" aria-labelledby="ls-what-h2">
      <h2 id="ls-what-h2" class="ls-h2">恋愛スタイル診断とは</h2>
      <p class="ls-lead">
        恋愛スタイル診断は、カナダの社会学者 John Alan Lee が 1973年の著書
        「Colours of Love: An Exploration of the Ways of Loving」で提唱した恋愛6タイプ理論をもとにした自己理解ツールです。
        その後 Clyde Hendrick & Susan Hendrick（1986年）が「Love Attitudes Scale（LAS）」として検証・体系化し、
        世界中の恋愛心理学研究で活用されています
        （<a href="https://doi.org/10.1037/0022-3514.50.2.392" target="_blank" rel="noopener noreferrer">Hendrick & Hendrick 1986, DOI確認済</a>）。
      </p>
      <p class="ls-body">
        この診断は医学的・臨床的な評価ではなく、恋愛傾向を把握するための参考ツールです。
        「どのタイプが良い・悪い」ではなく、それぞれのスタイルの特徴と強みを理解することを目的としています。
      </p>
      <div class="ls-info-table-wrap">
        <table class="ls-info-table">
          <caption class="ls-table-caption">恋愛スタイル診断の概要（2026-05-21時点）</caption>
          <tbody>
            <tr>
              <th scope="row">理論の根拠</th>
              <td>J.A.Lee (1973) Colours of Love + Hendrick & Hendrick (1986) Love Attitudes Scale</td>
            </tr>
            <tr>
              <th scope="row">問題数</th>
              <td>30問（各タイプ5問 × 6タイプ）</td>
            </tr>
            <tr>
              <th scope="row">回答方式</th>
              <td>5段階リッカートスケール（1=全く当てはまらない〜5=とても当てはまる）</td>
            </tr>
            <tr>
              <th scope="row">所要時間</th>
              <td>約3分</td>
            </tr>
            <tr>
              <th scope="row">結果タイプ数</th>
              <td>6タイプ（情熱型・遊戯型・友愛型・実利型・感情型・献身型）</td>
            </tr>
            <tr>
              <th scope="row">対象シーン</th>
              <td>恋愛・友情・人間関係全般の自己理解</td>
            </tr>
            <tr>
              <th scope="row">注意事項</th>
              <td>医学的診断ではありません。「恋愛傾向」の参考情報としてご活用ください。</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {/* ========== 6タイプ紹介 ========== */}
    <section class="ls-section" aria-labelledby="ls-types-h2">
      <h2 id="ls-types-h2" class="ls-h2">6つの恋愛スタイル</h2>
      <p class="ls-lead">
        J.A.Lee（1973）は恋愛を「色のように混ざり合う6つのスタイル」として分類しました。
        どのタイプが優れているかではなく、それぞれの傾向と強みを理解することが目的です。
      </p>
      <div class="ls-types-grid">
        {typeCards.map((tc) => (
          <article class="ls-type-card" style={`--type-color: ${tc.color}`}>
            <div class="ls-type-icon" aria-hidden="true">{tc.icon}</div>
            <h3 class="ls-type-name">{tc.japaneseName}</h3>
            <p class="ls-type-name-en">{tc.nameEn}</p>
            <p class="ls-type-desc">{tc.catchphrase}</p>
            <a href={`/diagnosis/love-style/result/${tc.id}/`} class="ls-type-link">
              {tc.japaneseName}の詳細を見る
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </section>

    {/* ========== 恋愛スタイルが人生に与える影響 ========== */}
    <section class="ls-section" aria-labelledby="ls-impact-h2">
      <h2 id="ls-impact-h2" class="ls-h2">恋愛スタイルが人間関係に与える影響</h2>
      <p class="ls-lead">
        Hendrick & Hendrick（1986）の Love Attitudes Scale 研究では、
        恋愛スタイルが関係満足度・対話パターン・友情にも影響することが示されています。
        自分のスタイルを理解することで、人間関係全般の改善につながります。
      </p>
      <div class="ls-impact-grid">
        {lifeImpacts.map((impact) => (
          <div class="ls-impact-card">
            <div class="ls-impact-icon" aria-hidden="true">{impact.icon}</div>
            <h3 class="ls-impact-title">{impact.title}</h3>
            <p class="ls-impact-desc">{impact.desc}</p>
          </div>
        ))}
      </div>
    </section>

    {/* ========== 使い方 ========== */}
    <section class="ls-section" aria-labelledby="ls-how-h2">
      <h2 id="ls-how-h2" class="ls-h2">使い方（3ステップ）</h2>
      <ol class="ls-steps">
        <li class="ls-step">
          <div class="ls-step-num" aria-hidden="true">1</div>
          <div class="ls-step-body">
            <h3 class="ls-step-title">「診断スタート」をタップ</h3>
            <p class="ls-step-desc">
              登録・インストール不要。ブラウザですぐ始められます。
              途中で閉じても24時間以内なら再開できます。
            </p>
          </div>
        </li>
        <li class="ls-step">
          <div class="ls-step-num" aria-hidden="true">2</div>
          <div class="ls-step-body">
            <h3 class="ls-step-title">30問に回答する（約3分）</h3>
            <p class="ls-step-desc">
              各質問に「1（全く当てはまらない）〜5（とても当てはまる）」で答えます。
              「恋愛・人間関係での自分」を意識しながら正直に答えると精度が上がります。
            </p>
          </div>
