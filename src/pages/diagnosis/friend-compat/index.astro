  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '友達相性診断', url: '/diagnosis/friend-compat/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="fc-hero" aria-labelledby="fc-hero-h1">
    <div class="fc-hero-inner">
      <div class="fc-hero-badge">Big Five + FIRO-B + Hartup友情研究に基づく</div>
      <h1 id="fc-hero-h1" class="fc-hero-h1">
        友達相性診断<br />
        <span class="fc-hero-meta">【無料・5分・24問】</span>
      </h1>
      <p class="fc-hero-catch">
        あなたはどの友達タイプ？<br />
