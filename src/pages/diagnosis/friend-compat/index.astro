        <span class="fc-stat-sep">・</span>
        <span class="fc-stat">約<strong>5</strong>分</span>
        <span class="fc-stat-sep">・</span>
        <span class="fc-stat"><strong>6</strong>タイプ</span>
        <span class="fc-stat-sep">・</span>
        <span class="fc-stat">無料</span>
        <span class="fc-stat-sep">・</span>
        <span class="fc-stat">招待機能付き</span>
