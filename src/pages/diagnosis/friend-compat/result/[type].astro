---
/**
 * 友達相性診断 結果ページ（動的ルート）
 * 6タイプ分の結果ページを静的生成する
 *
 * URL: /diagnosis/friend-compat/result/{typeId}/
 * タイプID: mood-maker / listener / leader / lone-wolf / harmonizer / analyst
 *
 * SEO/AIO:
 * - JSON-LD: WebApplication + Article + BreadcrumbList
 * - タイプ別メタタイトル・ディスクリプション
 * - 6タイプ別相性ミニグリッド
 * - ★招待モード CTA（重要・大きく）
 * - YMYL回避: 医学的判断ゼロ
 *
 * 確認日: 2026-05-20
 */
import ResultLayout from '../../../../layouts/ResultLayout.astro';
import Container from '../../../../components/Container.astro';
import { types } from '../../../../data/diagnoses/friend-compat/types';
import { meta } from '../../../../data/diagnoses/friend-compat/meta';
import {
  getCompatibility,
  CATEGORY_LABELS,
  CATEGORY_COLORS,
} from '../../../../data/diagnoses/friend-compat/compatibility';
import type { FriendType } from '../../../../data/diagnoses/friend-compat/questions';
import TldrBlock from '../../../../components/TldrBlock.astro';
import ScienceNote from '../../../../components/ScienceNote.astro';
import ReferenceList from '../../../../components/ReferenceList.astro';

export function getStaticPaths() {
  return Object.keys(types).map((typeId) => ({
    params: { type: typeId },
    props: { typeId: typeId as FriendType, typeData: types[typeId as FriendType] },
  }));
}

const { typeId, typeData } = Astro.props;

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/friend-compat/result/${typeId}/`;

// 思考傾向グラフ用ラベル（Big5/OCEAN/ビッグファイブ表記禁止）
const traitLabels = [
  { key: 'O', label: '好奇心・探求' },
  { key: 'C', label: '計画性・丁寧さ' },
  { key: 'E', label: '行動力・積極性' },
  { key: 'A', label: '共感力・協調性' },
  { key: 'N', label: '感情の繊細さ' },
] as const;

// 全タイプとの相性データを取得
const compatibilities = (Object.keys(types) as FriendType[]).map((otherType) => ({
  otherType,
  otherData: types[otherType],
  compat: getCompatibility(typeId as FriendType, otherType),
}));

// FAQs（タイプ別）
const faqs = [
  {
    question: `${typeData.japaneseName}はどんな友達グループに向いていますか？`,
    answer: typeData.bestRoleInGroup,
  },
  {
    question: `${typeData.japaneseName}の友達としての強みは？`,
    answer: typeData.friendStrengths.slice(0, 3).join('。また、') + '。',
  },
  {
    question: `${typeData.japaneseName}が気をつけたい傾向は？`,
    answer: typeData.friendWeaknesses.slice(0, 2).join('。さらに、') + '。状況を理解することで、より良い友情を育てられます。',
  },
  {
    question: `${typeData.japaneseName}と最も相性がいいタイプは？`,
    answer: (() => {
      const sorted = [...compatibilities].sort((a, b) => b.compat.score - a.compat.score);
      const top2 = sorted.slice(0, 2);
      return `${typeData.japaneseName}と相性がいいのは「${top2[0].otherData.japaneseName}」（スコア${top2[0].compat.score}）と「${top2[1].otherData.japaneseName}」（スコア${top2[1].compat.score}）です。${top2[0].compat.oneLineSummary}という関係です。詳しくは下の相性グリッドをご確認ください。`;
    })(),
  },
  {
    question: '招待機能はどう使うの？',
    answer:
      '結果ページ下部の「友達と相性チェック」ボタンから招待URLを生成できます。LINEやDMで友達に送るだけで、相手は登録不要でそのまま診断・相性確認ができます。招待は何回でも、何人でも完全無料です。',
  },
];

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: `友達相性診断 - ${typeData.japaneseName}の結果`,
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
};

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  headline: `${typeData.japaneseName}（${typeData.nameEn}）の特徴・グループポジション・相性完全ガイド`,
  url: PAGE_URL,
  description: `友達相性診断の結果「${typeData.japaneseName}」。${typeData.catchphrase} グループでの役割・6タイプ別相性・友情エピソードを詳しく解説。`,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  about: {
    '@type': 'Thing',
    name: '友情・対人関係 心理学',
    sameAs: 'https://doi.org/10.2307/1131834',
  },
  citation: meta.references.map((r) => ({
    '@type': 'CreativeWork',
    name: r.title,
    ...(r.author ? { author: r.author } : {}),
    datePublished: String(r.year),
    ...(r.url ? { url: r.url } : {}),
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: '友達相性診断', item: `${SITE_URL}/diagnosis/friend-compat/` },
    { '@type': 'ListItem', position: 4, name: typeData.japaneseName, item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdArticle, jsonLdBreadcrumb];

// 関連診断
const relatedDiagnoses = [
  { title: 'MBTI相性診断', href: '/diagnosis/mbti-compat/', icon: '🧩', badge: '人気' },
  { title: '多重知能テスト', href: '/diagnosis/multi-int/', icon: '🦉' },
  { title: '完璧主義診断', href: '/diagnosis/perfectionism/', icon: '🔱' },
  { title: 'DiSC診断', href: '/diagnosis/disc/', icon: '💼' },
];

// 招待用URLモック（実装はui-ux-designerが担当）
const inviteBaseUrl = `${SITE_URL}/invite/friend-compat/?from=${typeId}`;
---

<ResultLayout
  diagnosisId="friend-compat"
  diagnosisClass="diag-love"
  typeId={typeId}
  typeName={typeData.japaneseName}
  diagnosisName="友達相性診断"
  characterEmoji={typeData.emoji}
  characterName={typeData.nameEn}
  tagline={typeData.catchphrase}
  shareUrl={PAGE_URL}
  pageTitle={`${typeData.japaneseName}【友達相性診断】特徴・グループ役割・6タイプ相性 | 診断ナビ`}
  pageDescription={`友達相性診断の結果は「${typeData.japaneseName}」。${typeData.catchphrase} グループでの役割・友情エピソード・6タイプ別相性スコアを詳しく解説。招待機能で友達と無料で相性チェック。`}
  relatedDiagnoses={relatedDiagnoses}
  jsonLd={jsonLdAll}
  ogImage={`/og/result/friend-compat/${typeId}.png`}
>
  {/* ========== 概要タブ ========== */}
  <Fragment slot="overview">
    <div class="fcr-overview">
      <TldrBlock
        title="このページでわかること"
        points={[
          `${typeData.japaneseName}(${typeData.nameEn})の傾向・グループでの振る舞い・友人エピソード`,
          `5タイプとの友人相性ランキング（スコア順）`,
          `職場・学校での対人傾向（Hartup 1996 + Costa & McCrae 1992 理論に基づく）`,
        ]}
        updatedAt={meta.updatedAt}
        sourceLabel="Hartup WW (1996) - Psychological Science"
        sourceUrl="https://doi.org/10.2307/1131834"
      />

      <div class="fcr-description">
        {typeData.description.split('\n').filter((s: string) => s.trim()).map((para: string) => (
          <p class="fcr-body">{para.trim()}</p>
        ))}
      </div>

      <div class="fcr-role-block">
        <h3 class="fcr-h3">グループでの理想ポジション</h3>
        <div class="fcr-role-content">
          {typeData.bestRoleInGroup.split('\n').filter((s: string) => s.trim()).map((para: string) => (
            <p class="fcr-body">{para.trim()}</p>
          ))}
        </div>
      </div>

      <ScienceNote
        basisText={meta.scientificBasis}
        basisUrl="https://doi.org/10.2307/1131834"
        basisLabel="Hartup WW (1996) - Psychological Science"
        notMedical={true}
        updatedAt={meta.updatedAt}
      />
      <ReferenceList references={meta.references} confirmedAt={meta.updatedAt} />
    </div>
  </Fragment>

  {/* ========== 強みタブ ========== */}
  <Fragment slot="strengths">
    <div class="fcr-strengths">
      <h3 class="fcr-section-h3">{typeData.japaneseName}の友達としての4つの強み</h3>
      <ul class="fcr-strength-list">
        {typeData.friendStrengths.map((s: string) => (
          <li class="fcr-strength-item">
            <span class="fcr-strength-icon" aria-hidden="true">✅</span>
            <span>{s}</span>
          </li>
        ))}
      </ul>
    </div>
  </Fragment>

  {/* ========== 注意点タブ ========== */}
  <Fragment slot="weaknesses">
    <div class="fcr-weaknesses">
      <h3 class="fcr-section-h3">気をつけたい4つの傾向</h3>
      <ul class="fcr-weakness-list">
        {typeData.friendWeaknesses.map((w: string) => (
          <li class="fcr-weakness-item">
            <span class="fcr-weakness-icon" aria-hidden="true">⚡</span>
            <span>{w}</span>
          </li>
        ))}
      </ul>
      <div class="fcr-weakness-note">
        気をつけたい傾向は「直すべき欠点」ではなく、「強みと表裏一体の特性」です。
        傾向を知ることで、より良い友情の築き方が見えてきます。
      </div>
    </div>
  </Fragment>

  {/* ========== 友人タブ（友情エピソード・フル公開） ========== */}
  <Fragment slot="friend">
    <div class="fcr-friend">
      <h3 class="fcr-section-h3">{typeData.japaneseName}のよくある友情エピソード</h3>
      <div class="fcr-scenes">
        {typeData.typicalScenes.map((scene: { title: string; content: string }) => (
          <div class="fcr-scene-card">
            <h4 class="fcr-scene-title">{scene.title}</h4>
            <p class="fcr-scene-content">{scene.content}</p>
          </div>
        ))}
      </div>
    </div>
  </Fragment>

  {/* ========== 仕事タブ（PASS壁） ========== */}
  <Fragment slot="work">
    <div class="fcr-work">
      <div class="fcr-pass-cta">
        <p class="fcr-pass-desc">
          {typeData.japaneseName}が活きやすい職場環境・仕事スタイル・向いている職種の詳細は
          ¥390 PASSで確認できます。
        </p>
        <a href="/pass/" class="fcr-pass-btn">
          <span>¥390 PASSで仕事レポートを読む</span>
          <span aria-hidden="true">→</span>
        </a>
        <p class="fcr-pass-sub">買切 / 全診断に使用可 / 登録不要</p>
      </div>
    </div>
  </Fragment>

  {/* ========== 恋愛タブ（PASS壁） ========== */}
  <Fragment slot="love">
    <div class="fcr-love">
      <div class="fcr-pass-cta">
        <p class="fcr-pass-desc">
          {typeData.japaneseName}の恋愛傾向・相性タイプ・パートナーとの関係の詳細は¥390 PASSで確認できます。
        </p>
        <a href="/pass/" class="fcr-pass-btn">
          <span>¥390 PASSで恋愛レポートを読む</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Fragment>

  {/* ========== 家族タブ（PASS壁） ========== */}
  <Fragment slot="family">
    <div class="fcr-family">
      <div class="fcr-pass-cta">
        <p class="fcr-pass-desc">
          {typeData.japaneseName}の家族関係・親子・兄弟との関わり方の詳細は¥390 PASSで確認できます。
        </p>
        <a href="/pass/" class="fcr-pass-btn">
          <span>¥390 PASSで家族レポートを読む</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Fragment>

  {/* ========== 学校タブ（PASS壁） ========== */}
  <Fragment slot="school">
    <div class="fcr-school">
      <div class="fcr-pass-cta">
        <p class="fcr-pass-desc">
          {typeData.japaneseName}に合ったクラス・部活・サークルでの立ち回り方は¥390 PASSで確認できます。
        </p>
        <a href="/pass/" class="fcr-pass-btn">
          <span>¥390 PASSで学校レポートを読む</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </Fragment>

  {/* ========== 有名人タブ（架空類型） ========== */}
  <Fragment slot="celebrity">
    <div class="fcr-celebrity">
      <h3 class="fcr-section-h3">{typeData.japaneseName}の友情スタイル類型</h3>
      <p class="fcr-celebrity-note">
        以下は{typeData.japaneseName}の傾向が見られる行動パターンの例です。
        架空の類型であり、特定の個人を指すものではありません。
      </p>
      <ul class="fcr-famous-list">
        {typeData.typicalScenes.map((scene: { title: string; content: string }) => (
          <li class="fcr-famous-item">
            <h4 class="fcr-famous-title">{scene.title}</h4>
            <p class="fcr-famous-note">{scene.content}</p>
          </li>
        ))}
      </ul>
    </div>
  </Fragment>

  {/* ========== 成長タブ（PASS壁） ========== */}
  <Fragment slot="growth">
    <div class="fcr-growth">
      <div class="fcr-pass-cta">
        <p class="fcr-pass-desc">
          {typeData.japaneseName}が友情をさらに深めるための実践Tips・週次プランは¥390 PASSで確認できます。
        </p>
        <a href="/pass/" class="fcr-pass-btn">
          <span>¥390 PASSで成長プランを読む</span>
          <span aria-hidden="true">→</span>
        </a>
        <p class="fcr-pass-sub">AIプロンプトカード付き・複数診断の統合管理</p>
      </div>
    </div>
  </Fragment>
</ResultLayout>

{/* ========== 結果ページ追加コンテンツ（ResultLayout外） ========== */}
<Container>
  {/* ========== 6タイプ別相性ミニグリッド ========== */}
  <section class="fcr-compat-section" aria-labelledby="fcr-compat-h2">
    <h2 id="fcr-compat-h2" class="fcr-compat-h2">6タイプ別 相性グリッド</h2>
    <p class="fcr-compat-note">
      {typeData.japaneseName}と他の全タイプとの相性スコアです。
      Hartup（1996）の友情研究に基づく傾向値です。「相性が低い」のではなく「学び合いが多いペア」として理解してください。
    </p>
    <div class="fcr-compat-grid">
      {compatibilities.map(({ otherType, otherData, compat }) => (
        <div
          class={`fcr-compat-card fcr-compat-card--${compat.category} ${otherType === typeId ? 'fcr-compat-card--self' : ''}`}
        >
          <div class="fcr-compat-header">
            <span class="fcr-compat-emoji" aria-hidden="true">{otherData.emoji}</span>
            <div>
              <p class="fcr-compat-name">{otherData.japaneseName}</p>
              {otherType === typeId && <span class="fcr-compat-self-badge">あなた</span>}
            </div>
            <div class="fcr-compat-score-wrap">
              <span
                class="fcr-compat-category"
                style={`background: ${CATEGORY_COLORS[compat.category]}`}
              >
                {CATEGORY_LABELS[compat.category]}
              </span>
              <span class="fcr-compat-score">{compat.score}</span>
            </div>
          </div>
          <div class="fcr-compat-bar-bg">
            <div
              class="fcr-compat-bar-fill"
              style={`width: ${compat.score}%; background: ${CATEGORY_COLORS[compat.category]}`}
            ></div>
          </div>
          <p class="fcr-compat-summary">{compat.oneLineSummary}</p>
          {otherType !== typeId && (
            <a href={`/diagnosis/friend-compat/result/${otherType}/`} class="fcr-compat-link">
              {otherData.japaneseName}の詳細 →
            </a>
          )}
        </div>
      ))}
    </div>
    <p class="fcr-compat-disclaimer">
      ※相性スコアは傾向値です。実際の友情は経験・環境・コミュニケーションによって大きく変わります。
    </p>
  </section>

  {/* ========== ★招待モード CTA（重要・大きく） ========== */}
  <section class="fcr-invite-section" aria-labelledby="fcr-invite-h2">
    <h2 id="fcr-invite-h2" class="fcr-invite-h2">友達と相性チェック（招待機能）</h2>
    <div class="fcr-invite-badge">完全無料・無制限・登録不要</div>
    <p class="fcr-invite-lead">
      この相性表を友達に見せて、一緒に相性を確かめてみましょう。
      招待は何人でも・何回でも無料です。
    </p>

    {/* 招待モード選択UI */}
    <div class="fcr-invite-modes">
      <div class="fcr-invite-mode-grid">
        <a
          href={`${inviteBaseUrl}&mode=secret`}
          class="fcr-invite-mode-btn fcr-invite-mode-btn--secret"
        >
          <span class="fcr-invite-mode-icon" aria-hidden="true">🤫</span>
          <span class="fcr-invite-mode-label">こっそりモード</span>
          <span class="fcr-invite-mode-desc">相手に自分のタイプを知らせずにチェック</span>
        </a>
        <a
          href={`${inviteBaseUrl}&mode=invite`}
          class="fcr-invite-mode-btn fcr-invite-mode-btn--invite"
        >
          <span class="fcr-invite-mode-icon" aria-hidden="true">🔗</span>
          <span class="fcr-invite-mode-label">招待モード</span>
          <span class="fcr-invite-mode-desc">友達も診断して双方の相性スコアを確認</span>
        </a>
        <a
          href={`${inviteBaseUrl}&mode=one-way`}
          class="fcr-invite-mode-btn fcr-invite-mode-btn--oneway"
        >
          <span class="fcr-invite-mode-icon" aria-hidden="true">📤</span>
          <span class="fcr-invite-mode-label">片方向モード</span>
          <span class="fcr-invite-mode-desc">自分の結果だけを友達に見せる</span>
        </a>
        <a
          href={`${inviteBaseUrl}&mode=full`}
          class="fcr-invite-mode-btn fcr-invite-mode-btn--full"
        >
          <span class="fcr-invite-mode-icon" aria-hidden="true">🤝</span>
          <span class="fcr-invite-mode-label">完全共有モード</span>
          <span class="fcr-invite-mode-desc">双方の詳細結果と相性スコアを完全共有</span>
        </a>
      </div>
    </div>

    <div class="fcr-invite-share">
      <p class="fcr-invite-share-label">この結果をシェアする</p>
      <div class="fcr-invite-share-btns">
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`友達相性診断で「${typeData.japaneseName}」でした！${typeData.catchphrase} あなたも試してみて`)}&url=${encodeURIComponent(PAGE_URL)}&hashtags=友達相性診断,診断ナビ`}
          target="_blank"
          rel="noopener noreferrer"
          class="fcr-share-btn fcr-share-btn--x"
        >
          <span aria-hidden="true">𝕏</span> Xでシェア
        </a>
        <a
          href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(PAGE_URL)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="fcr-share-btn fcr-share-btn--line"
        >
          <span aria-hidden="true">💬</span> LINEで送る
        </a>
      </div>
    </div>
  </section>

  {/* ========== 思考傾向グラフ（Big5非開示） ========== */}
  <section class="fcr-trait-section" aria-labelledby="fcr-trait-h2">
    <h2 id="fcr-trait-h2" class="fcr-trait-h2">特性傾向グラフ</h2>
    <p class="fcr-trait-note">
      {typeData.japaneseName}の研究傾向値をグラフ化したものです。
      個人差があります（参考値）。
    </p>
    <div class="fcr-trait-bars" role="list" aria-label="特性傾向グラフ">
      {traitLabels.map(({ key, label }) => {
        const score = typeData.big5[key as keyof typeof typeData.big5];
        return (
          <div class="fcr-trait-row" role="listitem">
            <span class="fcr-trait-label">{label}</span>
            <div
              class="fcr-trait-bar-bg"
              role="meter"
              aria-valuenow={score}
              aria-valuemin={0}
              aria-valuemax={100}
              aria-label={`${label}: ${score}%`}
            >
              <div class="fcr-trait-bar-fill" style={`width: ${score}%`}></div>
            </div>
            <span class="fcr-trait-val">{score}</span>
          </div>
        );
      })}
    </div>
  </section>

