---
/**
 * 診断ページ スタブ（Phase 0）
 * content-writer が本文を執筆する。
 * ui-ux-designer が診断フローコンポーネントを実装する。
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
const diagName = 'この診断';
---
<BaseLayout title={`${diagName} - 診断ナビ`} description="診断説明（content-writerが執筆）">
  <Container>
    <div style="padding-block: 4rem; text-align: center;">
      <p style="font-size: 3rem; margin-bottom: 1rem;">🔮</p>
      <h1 style="font-family: var(--sn-font-rounded); font-size: 1.5rem; margin-bottom: 1rem;">診断準備中</h1>
      <p style="color: var(--sn-muted);">Phase 1 にてコンテンツ・診断フローを実装します</p>
      <a href="/diagnosis/" style="display:inline-block; margin-top:2rem; color:var(--sn-primary);">← 診断一覧に戻る</a>
    </div>
  </Container>
</BaseLayout>
