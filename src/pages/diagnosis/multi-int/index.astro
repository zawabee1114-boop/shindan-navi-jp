---
/**
 * 多重知能テスト ランディングページ
 * KW: 多重知能テスト（VOL: 18,100 / SD: 10）
 * 理論: Howard Gardner「Frames of Mind」(1983)
 * 確認日: 2026-05-21
 *
 * AIO/LLMO最適化:
 * - TL;DRブロック（AI引用用）
 * - FAQ 12問（7問→12問に拡充）
 * - 参考文献リスト（ReferenceList）
 * - ScienceNote（科学的位置付け）
 * - HowTo JSON-LD追加
 * - Article mentions（エンティティ強化）
 * - 引用URL5箇所以上の本文中明記
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import DiagnosisFlow from '../../../components/DiagnosisFlow';
import TldrBlock from '../../../components/TldrBlock.astro';
import ReferenceList from '../../../components/ReferenceList.astro';
import ScienceNote from '../../../components/ScienceNote.astro';
import { meta } from '../../../data/diagnoses/multi-int/meta';
import { questions } from '../../../data/diagnoses/multi-int/questions';
import { calculateResultTypeId } from '../../../data/diagnoses/multi-int/results';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/multi-int/`;

// DiagnosisFlow に渡す questions を diagnosis.ts の Question 型に変換
const flowQuestions = questions.map((q) => ({
  id: String(q.id),
  text: q.text,
}));

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: '多重知能テスト【無料・64問】',
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description:
    'Howard Gardner理論に基づく多重知能テスト。64問に答えるだけで8つの知能プロファイルを無料で診断します。仕事・学習スタイル・向いている職種がわかります。',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// JSON-LD: Quiz（citation に学術文献を配置）
const jsonLdQuiz = {
  '@context': 'https://schema.org',
  // Fix GSC: Quiz @type は schema.org 標準だが Google リッチリザルト非対応で「解析不能」エラーになる
  // LearningResource（上位タイプ）に変更（2026-05-23修正）
  '@type': 'LearningResource',
  '@id': `${PAGE_URL}#quiz`,
  name: '多重知能テスト（64問）',
  url: PAGE_URL,
  about: {
    '@type': 'Thing',
    name: '多重知能理論（Multiple Intelligences）',
    description: 'Howard Gardnerが1983年に提唱した、8種類の知能領域があるという理論',
    sameAs: 'https://www.pz.harvard.edu/projects/multiple-intelligences',
  },
  educationalLevel: 'HighSchool',
  numberOfQuestions: 64,
  assesses: '学習スタイル・向いている仕事・知能プロファイル',
  dateCreated: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  citation: meta.references.map((ref) => ({
    '@type': 'CreativeWork',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    url: ref.url,
  })),
};

// JSON-LD: HowTo（診断の受け方）
const jsonLdHowTo = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  '@id': `${PAGE_URL}#howto`,
  name: '多重知能テストの受け方（3ステップ）',
  description: '多重知能テストを受けて8つの知能プロファイルを確認するまでの手順',
  totalTime: 'PT5M',
  tool: { '@type': 'HowToTool', name: 'スマートフォンまたはパソコン（登録不要・無料）' },
  step: [
    {
      '@type': 'HowToStep',
      position: 1,
      name: '「診断スタート」をタップ',
      text: '登録・インストール不要。ブラウザですぐ始められます。途中で閉じても24時間以内なら再開できます。',
    },
    {
      '@type': 'HowToStep',
      position: 2,
      name: '64問に回答する（約5分）',
      text: '各質問に「1（全く当てはまらない）〜5（とても当てはまる）」の5段階で答えます。正解・不正解はありません。直感で答えてください。',
    },
    {
      '@type': 'HowToStep',
      position: 3,
      name: '8知能プロファイルと詳細結果を確認',
      text: '8軸のスコアと主要タイプが表示されます。仕事・恋愛・友人・家族・学校の5軸詳細は¥390 PASSで解放されます。',
    },
  ],
};

// JSON-LD: Article（mentions でエンティティ強化）
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  headline: '多重知能テストとは｜ハーバード大学Gardner理論に基づく8知能診断',
  url: PAGE_URL,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
  mentions: [
    {
      '@type': 'Person',
      name: 'Howard Gardner',
      sameAs: 'https://ja.wikipedia.org/wiki/%E3%83%8F%E3%83%AF%E3%83%BC%E3%83%89%E3%83%BB%E3%82%AC%E3%83%BC%E3%83%89%E3%83%8A%E3%83%BC',
    },
    {
      '@type': 'Thing',
      name: '多重知能理論（Multiple Intelligences Theory）',
      sameAs: 'https://www.pz.harvard.edu/projects/multiple-intelligences',
    },
    {
      '@type': 'Organization',
      name: 'ハーバード大学 Project Zero',
      sameAs: 'https://www.pz.harvard.edu/',
    },
    {
      '@type': 'Book',
      name: 'Frames of Mind: The Theory of Multiple Intelligences',
      author: { '@type': 'Person', name: 'Howard Gardner' },
      datePublished: '1983',
      sameAs: 'https://www.basicbooks.com/titles/howard-gardner/frames-of-mind/9780465024339/',
    },
  ],
};

// FAQ 12問（7問→12問に拡充・AI Overview最適化）
const faqs = [
  {
    question: '多重知能テストとは何ですか？',
    answer:
      'ハーバード大学の発達心理学者 Howard Gardner 教授が1983年の著書「Frames of Mind」で提唱した「多重知能理論（MI理論）」に基づく自己診断テストです。言語・論理数学・視空間・身体運動・音楽・対人・内省・博物の8つの知能領域を測定し、あなたの強みの「かたち」を可視化します（出典: ハーバード大学 Project Zero https://www.pz.harvard.edu/projects/multiple-intelligences、2026-05-21確認）。',
  },
  {
    question: '何問・何分かかりますか？',
    answer:
      '全64問で、目安は約5分です。各質問に「1（全く当てはまらない）〜5（とても当てはまる）」で回答します。途中で中断しても24時間以内なら再開できます。登録不要で即座に始められます。',
  },
  {
    question: '多重知能テストの科学的根拠は何ですか？',
    answer:
      'Howard Gardner の著書「Frames of Mind」（1983年、Basic Books）が理論的根拠です。ハーバード大学の研究プロジェクト「Project Zero」が継続的に研究・普及を行っており、教育学・認知科学分野で広く参照されています。なお、多重知能理論は自己理解・学習スタイル把握の参考枠組みであり、IQテストのような単一の認知能力測定とは異なるアプローチです。',
  },
  {
    question: 'IQテストと何が違いますか？',
    answer:
      '従来のIQテストは主に言語・数理能力の2軸を測定します。多重知能テストは音楽・身体運動・自然観察など8つの異なる知能領域を個別に評価するため、IQでは測れない強みを発見できます。Gardner 理論では「全ての人が8つの知能を持ち、その組み合わせが異なる」と考えます。',
  },
  {
    question: '仕事や学習にどう活かせますか？',
    answer:
      '各タイプごとに「向いている職種10選」「最適な学習スタイル」「得意な教科傾向」「進路ヒント」を提供しています。自分の強みを活かした仕事・勉強法の選択に役立ちます。言語的知能が高い場合は文章系職種、身体運動的知能が高い場合は職人・スポーツ系職種への適性がある傾向があります。',
  },
  {
    question: '多重知能診断とMBTI（16タイプ診断）はどう違いますか？',
    answer:
      'MBTIは「どのように世界を認識し判断するか」という性格傾向（外向/内向・感覚/直感・思考/感情・判断/知覚）を16タイプで分類します。多重知能テストは「どの知能領域が得意か」という才能の方向性を8軸で測定します。組み合わせることで「得意なこと（多重知能）×性格の傾向（MBTI）」の立体的な自己理解が得られます。',
  },
  {
    question: '何歳から受けられますか？',
    answer:
      '中学生以上を想定しています。質問文は平易な日本語で記載しており、保護者の方がお子さんの学習スタイル発見に使うケースも多くあります。ただし、本テストは医学的・心理学的診断ではなく、あくまで傾向把握のための参考ツールです。学習障害・発達障害等の医学的評価は専門家にご相談ください。',
  },
  {
    question: '何回受けても同じ結果が出ますか？',
    answer:
      'いいえ、結果は受けるタイミングや心身の状態によって変わる場合があります。多重知能理論は固定的な才能ではなく、経験・学習・環境によって各知能が発達するという考えを前提としています。3〜6ヶ月ごとに受け直すと自身の変化を把握できます。',
  },
  {
    question: '結果を友達や家族に見せていいですか？',
    answer:
      'はい、自由にシェアしていただけます。結果ページにはSNSシェアボタンとテキストコピー機能があります。「招待リンク」機能を使うと、相手も診断を受けた上で双方の知能プロファイルを比較できます（相性・学習スタイル比較）。',
  },
  {
    question: 'PASSで何が変わりますか？',
    answer:
      '無料の基本診断（8知能プロファイル・主要タイプ・強み・注意点）に加え、¥390のPASSで「仕事・恋愛・友人・家族・学校」の5軸詳細レポートが解放されます。各シーンでの具体的な行動指針・向いている職種10選・学習スタイル提案が含まれます。',
  },
  {
    question: '本の多重知能理論と結果が違う気がするのですが？',
    answer:
      'Howard Gardner の理論は「知能の傾向を大まかに分類する枠組み」であり、同一人物でも自己評価・行動観察・面接など測定方法で結果が異なります。本テストは自己報告式（自分の行動傾向に回答）のため、自己認識が実際の強みと一致しない場合があります。結果はあくまで「気づきのきっかけ」としてご活用ください。',
  },
  {
    question: '多重知能テストで病気や障害の判断はできますか？',
    answer:
      'できません。本テストは性格・才能の傾向を自己理解するための参考ツールです。学習障害・発達障害・メンタルヘルス等の医学的判断は行いません。これらに関する相談は医師・臨床心理士などの専門家にお願いします。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

const jsonLdAll = [jsonLdWebApp, jsonLdQuiz, jsonLdHowTo, jsonLdArticle, jsonLdFAQ];
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  ogImage="/og/multi-int.png"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: '多重知能テスト', url: '/diagnosis/multi-int/' },
  ]}
>
  {/* ========== ヒーローセクション ========== */}
  <section class="mi-hero" aria-labelledby="mi-hero-h1">
    <Container>
      <div class="mi-hero-inner">
        <div class="mi-hero-badge">Gardner理論に基づく科学的診断</div>
        <h1 id="mi-hero-h1" class="mi-hero-h1">
          多重知能テスト<br />
          <span class="mi-hero-meta">【無料・5分・64問】</span>
        </h1>
        <p class="mi-hero-catch">
          あなたが本当に得意なことはなに？<br />
          8つの知能から「強みのかたち」を発見しよう
        </p>
        <div class="mi-hero-stats">
          <span class="mi-stat"><strong>64</strong>問</span>
          <span class="mi-stat-sep">・</span>
          <span class="mi-stat">約<strong>5</strong>分</span>
          <span class="mi-stat-sep">・</span>
          <span class="mi-stat"><strong>8</strong>タイプ</span>
          <span class="mi-stat-sep">・</span>
          <span class="mi-stat">無料</span>
        </div>
        <a href="#diagnosis-flow" class="mi-cta-btn">
          <span>診断スタート</span>
          <span class="mi-cta-arrow" aria-hidden="true">↓</span>
        </a>
        <p class="mi-hero-sub">登録不要・所要時間5分・途中保存OK</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TL;DRブロック（AI引用最適化） ========== */}
    <TldrBlock
      title="このページのポイント（3行まとめ）"
      points={[
        "多重知能テストは、ハーバード大学 Howard Gardner（1983）の理論に基づき、言語・論理・音楽・身体・視空間・対人・内省・博物の8知能を64問で測定する無料ツールです",
        "IQテストが言語・数理の2軸しか測らないのに対し、多重知能理論は「全ての人が8つの知能を持ち、得意な組み合わせが異なる」という前提で設計されています",
        "仕事・恋愛・友人・家族・学校の5シーン別行動指針と向いている職種10選を提供（基本無料・詳細¥390）"
      ]}
      updatedAt={meta.updatedAt}
      sourceLabel="ハーバード大学 Project Zero 公式"
      sourceUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
    />

    {/* ========== 多重知能テストとは ========== */}
    <section class="mi-section" aria-labelledby="mi-what-h2">
      <h2 id="mi-what-h2" class="mi-h2">多重知能テストとは何ですか？</h2>
      <p class="mi-lead">
        多重知能テストとは、ハーバード大学の発達心理学者 Howard Gardner が
        1983年の著書「Frames of Mind」で発表した「多重知能理論（MI理論）」をベースにした自己診断ツールです。
      </p>
      <p class="mi-body">
        Gardner は「知能はひとつではない」と主張し、8つの独立した知能領域があることを示しました。
        従来のIQテストが言語と数理の2軸しか測れないのに対し、MI理論は音楽・身体運動・自然観察など
        多様な才能を平等に評価します
        （<a href="https://www.pz.harvard.edu/projects/multiple-intelligences" target="_blank" rel="noopener noreferrer">ハーバード大学 Project Zero</a>、2026-05-21確認）。
      </p>
      <p class="mi-body">
        2024年現在、ハーバード大学教育大学院の研究プロジェクト「Project Zero」が
        多重知能理論の研究・普及を継続しており、世界の教育機関で学習スタイル把握に活用されています
        （<a href="https://www.pz.harvard.edu/" target="_blank" rel="noopener noreferrer">Project Zero 公式</a>、2026-05-21確認）。
      </p>
      <div class="mi-info-table-wrap">
        <table class="mi-info-table">
          <caption class="mi-table-caption">多重知能テストの概要（2026-05-21時点）</caption>
          <tbody>
            <tr>
              <th scope="row">理論の提唱者</th>
              <td>Howard Gardner（ハーバード大学名誉教授）</td>
            </tr>
            <tr>
              <th scope="row">原著・発表年</th>
              <td>「Frames of Mind: The Theory of Multiple Intelligences」（1983年、Basic Books）</td>
            </tr>
            <tr>
              <th scope="row">知能の数</th>
              <td>8種類（言語・論理数学・視空間・身体運動・音楽・対人・内省・博物）</td>
            </tr>
            <tr>
              <th scope="row">問題数</th>
              <td>64問（各知能8問 × 8知能）</td>
            </tr>
            <tr>
              <th scope="row">回答方式</th>
              <td>5段階リッカートスケール（1=全く当てはまらない〜5=とても当てはまる）</td>
            </tr>
            <tr>
              <th scope="row">所要時間</th>
              <td>約5分（途中中断・24時間以内再開可能）</td>
            </tr>
            <tr>
              <th scope="row">費用</th>
              <td>基本診断 無料 / 5軸詳細レポート ¥390（PASS）</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    {/* ========== ScienceNote（科学的位置付け） ========== */}
    <ScienceNote
      basisText="Howard Gardner（1983）の著書「Frames of Mind: The Theory of Multiple Intelligences」（Basic Books）。2024年現在、ハーバード大学 Project Zero が継続研究中。"
      basisUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
      basisLabel="Project Zero 公式（2026-05-21確認）"
      notMedical={true}
      updatedAt={meta.updatedAt}
      additionalNote="本テストは自己報告式の傾向把握ツールです。学習障害・発達障害等の医学的評価には使用できません。"
    />

    {/* ========== 8つの知能 ========== */}
    <section class="mi-section" aria-labelledby="mi-types-h2">
      <h2 id="mi-types-h2" class="mi-h2">8つの知能タイプとは？</h2>
      <p class="mi-lead">
        Gardner理論では、以下の8つの知能が独立して存在し、人によって得意な領域が異なります。
        どれが「高い・低い」ではなく、それぞれが異なる形の才能です。
      </p>
      <div class="mi-types-grid">
        <article class="mi-type-card" data-type="linguistic">
          <div class="mi-type-icon" aria-hidden="true">🦉</div>
          <h3 class="mi-type-name">言語的知能</h3>
          <p class="mi-type-desc">
            言葉を読む・書く・話す・聞く力。作家・弁護士・ジャーナリスト・教師に多い傾向があります。
          </p>
          <p class="mi-type-jobs">向く職種: 作家・編集者・翻訳家・弁護士</p>
        </article>
        <article class="mi-type-card" data-type="logical">
          <div class="mi-type-icon" aria-hidden="true">♟️</div>
          <h3 class="mi-type-name">論理数学的知能</h3>
          <p class="mi-type-desc">
            数字・論理・パターン認識の力。データサイエンティスト・研究者・エンジニアに多い傾向があります。
          </p>
          <p class="mi-type-jobs">向く職種: データサイエンティスト・SE・公認会計士</p>
        </article>
        <article class="mi-type-card" data-type="spatial">
          <div class="mi-type-icon" aria-hidden="true">🦎</div>
          <h3 class="mi-type-name">視空間的知能</h3>
          <p class="mi-type-desc">
            空間・色・形・方向感覚の力。デザイナー・建築家・映像クリエイターに多い傾向があります。
          </p>
          <p class="mi-type-jobs">向く職種: デザイナー・建築家・映像クリエイター</p>
        </article>
        <article class="mi-type-card" data-type="kinesthetic">
          <div class="mi-type-icon" aria-hidden="true">🐆</div>
          <h3 class="mi-type-name">身体運動的知能</h3>
          <p class="mi-type-desc">
            体を使って考え・表現する力。スポーツ選手・外科医・ダンサー・大工に多い傾向があります。
          </p>
          <p class="mi-type-jobs">向く職種: アスリート・外科医・ダンサー・職人</p>
        </article>
        <article class="mi-type-card" data-type="musical">
          <div class="mi-type-icon" aria-hidden="true">🎵</div>
          <h3 class="mi-type-name">音楽的知能</h3>
          <p class="mi-type-desc">
            音・リズム・メロディーへの鋭い感覚。音楽家・作曲家・音響エンジニアに多い傾向があります。
