    questionCount: 60,
    categoryKey: 'mbti' as const,
  },
  {
    title: '血液型性格診断',
    icon: '🩸',
    description: '日本独自×Big5換算で科学的に相性スコアを計算。',
    href: '/diagnosis/ketsuekigata/',
    badge: '無料',
    badgeClass: 'badge-free',
    duration: '約3分',
    questionCount: 20,
    categoryKey: 'blood' as const,
  },
  {
    title: 'DiSC診断',
    icon: '💼',
    description: '仕事・職場コミュニケーションに最強の4タイプ診断。',
    href: '/diagnosis/disc/',
    badge: '仕事に必見',
    badgeClass: 'badge-primary',
    duration: '約4分',
    questionCount: 28,
    categoryKey: 'disc' as const,
  },
  {
    title: '完璧主義タイプ診断',
    icon: '⭐',
    description: '心理学CBTベース。完璧主義が強みか罠かを診断。',
    href: '/diagnosis/perfectionism/',
    badge: '無料',
    badgeClass: 'badge-free',
    duration: '約3分',
    questionCount: 24,
