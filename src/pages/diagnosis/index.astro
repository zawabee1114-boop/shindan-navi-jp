    badgeClass: 'badge-primary',
    duration: '約4分',
    questionCount: 30,
    categoryKey: 'love' as const,
  },
  {
    title: '星座性格診断',
    icon: '✨',
    description: '西洋占星術×性格科学。エンタメ×サイエンスで解説。',
    href: '/diagnosis/seiza/',
    badge: 'エンタメ',
    badgeClass: 'badge-primary',
    duration: '即時',
    categoryKey: 'seiza' as const,
  },
  {
    title: '金銭感覚診断',
    icon: '💰',
    description: '行動経済学ベース。お金の使い方タイプを分析。',
    href: '/diagnosis/money-sense/',
    badge: '無料',
    badgeClass: 'badge-free',
