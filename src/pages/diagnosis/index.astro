    badge: '最優先・VOL18,100',
    badgeClass: 'badge-free',
    duration: '約5分',
    questionCount: 40,
    categoryKey: 'multi-int' as const,
  },
  {
    title: 'MBTI診断',
    icon: '🔮',
    description: '16タイプの性格を5軸で徹底分析。相性診断にも対応。',
    href: '/diagnosis/mbti/',
    badge: '人気No.1',
    badgeClass: 'badge-primary',
