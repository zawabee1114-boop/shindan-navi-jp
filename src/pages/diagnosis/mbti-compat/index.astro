---
/**
 * MBTI相性一覧 メインハブページ
 * KW: MBTI相性一覧（VOL: 9,900 / SD: 11-12）
 * 学術根拠:
 *   - Keirsey D (1998) Please Understand Me II
 *   - Jung CG (1921) Psychological Types
 *   - Beebe J (2017) Energies and Patterns in Psychological Type
 *   - Myers IB (1998) MBTI Manual
 * 確認日: 2026-05-20
 *
 * SEO/AIO対応:
 * - JSON-LD: WebApplication + Article + FAQPage + BreadcrumbList
 * - @id連結: エンティティグラフ形成
 * - 全16タイプ × ベスト3 / 成長機会3ペア 動的生成
 * - 4気質グループ別相性概観
 * - FAQ 8問
 * - YMYL回避: 医学的診断・治療表記ゼロ
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import { meta, MBTI_TYPES } from '../../../data/diagnoses/mbti-compat/meta';
import {
  getBestMatches,
  getWorstMatches,
  getCategoryLabel,
  getCategoryColor,
} from '../../../data/diagnoses/mbti-compat/results';
import { temperamentGroups } from '../../../data/diagnoses/mbti-compat/groups';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/mbti-compat/`;

// 16タイプ × ベスト3 / 成長機会3 を静的生成時に計算
const allTypesData = MBTI_TYPES.map((type) => ({
  type,
  best: getBestMatches(type, 3),
  growth: getWorstMatches(type, 3),
}));

// 気質グループ配列（表示順）
const temperamentOrder = ['NT', 'NF', 'SJ', 'SP'] as const;

// FAQ 8問
const faqs = [
  {
    question: 'MBTI相性に科学的根拠はありますか？',
    answer:
      'Keirsey（1998）の気質理論・Jung（1921）の認知機能論・Beebe（2017）の機能スタック理論を組み合わせた分析に基づいています。ただし、相性は「傾向」であり、個人差・環境・関係の深さによって大きく変わります。本ツールは傾向把握のための参考情報であり、科学的測定ではありません。',
  },
  {
    question: '「成長機会が多いペア」とは絶対にうまくいかないのですか？',
    answer:
      'そうではありません。Jung（1921）の個性化理論では、最も異なる認知スタイルを持つ相手から最大の気づきと成長が得られると述べています。コミュニケーションの意識的な努力が必要ですが、深い相互理解に至れば強力な補完関係になれます。',
  },
  {
    question: '同じタイプ同士（例: INTJ×INTJ）の相性はどうですか？',
    answer:
      '同タイプ同士は価値観や思考スタイルが近いため、初期の共感度は高い傾向があります。一方、Beebe（2017）の機能スタック理論では、補完関係がないため互いの盲点（劣等機能）が重なりやすい点に注意が必要です。本サイトの相性表では同タイプ同士のスコアも確認できます。',
  },
  {
    question: '機能スタック（Beebe理論）とは何ですか？',
    answer:
      'Beebe（2017）が提唱した、各MBTIタイプが持つ8つの認知機能（Ni/Ne/Si/Se/Ti/Te/Fi/Fe）の優先順位モデルです。主機能（dominant）・補助機能（auxiliary）・三次機能（tertiary）・劣等機能（inferior）の4段階があり、補完的なペアが深い相互理解につながりやすいとされています。',
  },
  {
    question: 'MBTI公式と16Personalitiesなど非公式テストの違いは何ですか？',
    answer:
      'MBTI®はThe Myers-Briggs Companyが管理する公式アセスメントで、認定資格保有者が実施します。16Personalities等の無料テストは類似の軸で測定しますが、結果が一致しないケースもあります。本サイトの相性データはMBTIの理論的枠組み（Jung/Myers/Keirsey）に基づいており、どちらのテストの結果にも対応しています。',
  },
  {
    question: '自分のMBTIタイプがわからない場合はどうすれば良いですか？',
    answer:
      '無料で試せる方法として、16Personalities（https://www.16personalities.com/ja）が代表的です。より精度の高い結果を求める場合はMBTI公式の認定資格保有者によるセッションをお勧めします。本サイトでも将来的に自社主診断を追加予定です。',
  },
  {
    question: '相性スコアの計算ロジックを教えてください。',
    answer:
      '機能スタック整合度（30点）・Keirsey気質一致（20点）・4文字中の一致数（20点）・J/P補完性（15点）・E/Iバランス（15点）の5軸合計100点で算出しています。90点以上をソウルメイト型・70-89点を良好型・50-69点をバランス型・30-49点を成長機会型・29点以下を最大成長機会型と分類しています。',
  },
  {
    question: 'このサイトでMBTI診断そのものはできますか？',
    answer:
      '現時点ではMBTI相性の分析ツールを提供しています（/diagnosis/mbti-compat/tool/）。タイプ特定の診断については16Personalities（外部サービス）をご活用ください。自社主診断は将来追加予定です。',
  },
];

// JSON-LD: WebApplication
const jsonLdWebApp = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${PAGE_URL}#webapp`,
  name: 'MBTI相性一覧【全16タイプ完全版】',
  url: PAGE_URL,
  applicationCategory: 'EducationalApplication',
  operatingSystem: 'Web',
  description: meta.description,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'JPY',
    availability: 'https://schema.org/InStock',
  },
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
    url: SITE_URL,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
  },
};

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: 'MBTI相性一覧【全16タイプ完全版・公式根拠付】',
  description: meta.description,
  url: PAGE_URL,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  citation: meta.references.map((ref) => ({
    '@type': 'Book',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    publisher: ref.publisher,
    url: ref.url,
  })),
};

// JSON-LD: FAQPage
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: answer,
    },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: 'MBTI相性一覧', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

// カテゴリ色マッピング（CSS変数）
const categoryColorVar: Record<string, string> = {
  soulmate: 'var(--mc-soulmate)',
  good: 'var(--mc-good)',
  neutral: 'var(--mc-neutral)',
  tough: 'var(--mc-tough)',
  opposite: 'var(--mc-opposite)',
};
---

<BaseLayout
  title={meta.title}
  description={meta.description}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'MBTI相性一覧', url: '/diagnosis/mbti-compat/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="mc-hero" aria-labelledby="mc-hero-h1">
    <Container>
      <div class="mc-hero-inner">
        <div class="mc-hero-badge">Keirsey / Jung / Beebe 理論に基づく相性分析</div>
        <h1 id="mc-hero-h1" class="mc-hero-h1">
          MBTI相性一覧<br />
          <span class="mc-hero-meta">【全16タイプ完全版・256組み合わせ収録】</span>
        </h1>
        <p class="mc-hero-catch">
          あなたのタイプと相手のタイプ、どんな補完関係がある？<br />
          気質理論・機能スタック理論から相性の傾向を徹底解説
        </p>
        <div class="mc-hero-stats">
          <span class="mc-stat"><strong>16</strong>タイプ</span>
          <span class="mc-stat-sep">×</span>
          <span class="mc-stat"><strong>256</strong>通り</span>
          <span class="mc-stat-sep">・</span>
          <span class="mc-stat">無料</span>
          <span class="mc-stat-sep">・</span>
          <span class="mc-stat">登録不要</span>
        </div>
        <div class="mc-hero-cta-group">
          <a href="/diagnosis/mbti-compat/tool/" class="mc-cta-btn mc-cta-btn--primary">
            タイプを選んで相性を見る →
          </a>
          <a href="/diagnosis/mbti-compat/table/" class="mc-cta-btn mc-cta-btn--secondary">
            16×16 相性マトリクスを見る
          </a>
        </div>
        <p class="mc-hero-sub">
          <time datetime={meta.updatedAt}>{meta.updatedAt}</time> 時点の情報・月1回更新
        </p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== AIOブロック ========== */}
    <div class="mc-aio-block" role="note" aria-label="このページでわかること">
      <p class="mc-aio-title">このページでわかること</p>
      <ul class="mc-aio-list">
        <li>全16タイプ × 256組み合わせの相性スコアとカテゴリ（Keirsey 1998 / Beebe 2017理論）</li>
        <li>NT・NF・SJ・SP 4気質グループ別の相性パターン概観</li>
        <li>各タイプのベストマッチ3組・成長機会の多いペア3組の一覧表</li>
        <li>相性スコアの計算ロジックと、スコアが高い・低いペアの特徴</li>
      </ul>
      <p class="mc-aio-updated">
        学術根拠:
        <a href="https://keirsey.com/product/please-understand-me-ii/" target="_blank" rel="noopener noreferrer">Keirsey（1998）</a>・
        <a href="https://press.princeton.edu/books/paperback/9780691018133/psychological-types" target="_blank" rel="noopener noreferrer">Jung（1921）</a>・
        <a href="https://www.routledge.com/Energies-and-Patterns-in-Psychological-Type-The-reservoir-of-consciousness/Beebe/p/book/9781138859760" target="_blank" rel="noopener noreferrer">Beebe（2017）</a>
        を確認済。
      </p>
    </div>

    {/* ========== 相性スコアの読み解き方 ========== */}
    <section class="mc-section" aria-labelledby="mc-score-h2">
      <h2 id="mc-score-h2" class="mc-h2">相性スコアの読み解き方</h2>
      <p class="mc-lead">
        本サイトの相性スコアは0〜100点で表示します。
        スコアは「相性の優劣」ではなく「補完性・類似性の強さ」を表します。
        Keirsey（1998）とBeebe（2017）の理論に基づき、5つのカテゴリで分類しています。
      </p>
      <div class="mc-category-grid">
        <div class="mc-category-card" style={`border-left-color: var(--mc-soulmate)`}>
          <div class="mc-category-score">90〜100点</div>
          <div class="mc-category-label" style={`color: var(--mc-soulmate)`}>ソウルメイト型</div>
          <p class="mc-category-desc">
            Beebe（2017）の機能スタック理論が示す最も補完的なペア。
            互いの主機能が相手の劣等機能を自然に補い、深い相互理解が育ちやすい。
            Jung（1921）の認知機能補完関係に相当します。
          </p>
        </div>
        <div class="mc-category-card" style={`border-left-color: var(--mc-good)`}>
          <div class="mc-category-score">70〜89点</div>
          <div class="mc-category-label" style={`color: var(--mc-good)`}>良好型</div>
          <p class="mc-category-desc">
            Keirsey（1998）の気質分析で近接する特性を持つペア。
            自然な親和性と協力関係が生まれやすく、摩擦が少ない組み合わせ。
            価値観の共有と異なる強みの補完が共存します。
          </p>
        </div>
        <div class="mc-category-card" style={`border-left-color: var(--mc-neutral)`}>
          <div class="mc-category-score">50〜69点</div>
          <div class="mc-category-label" style={`color: var(--mc-neutral)`}>バランス型</div>
          <p class="mc-category-desc">
            意識的な対話で相互理解が深まるペア。
            異なる強みをそれぞれ持ち、補完できる組み合わせ。
            コミュニケーションへの意識的な投資で関係の質が上がります。
          </p>
        </div>
        <div class="mc-category-card" style={`border-left-color: var(--mc-tough)`}>
          <div class="mc-category-score">30〜49点</div>
          <div class="mc-category-label" style={`color: var(--mc-tough)`}>成長機会型</div>
          <p class="mc-category-desc">
            アプローチの違いが多い分、学び合いの機会も豊富なペア。
            Jung（1921）の個性化プロセスが促進される組み合わせ。
            定期的な対話と理解の積み重ねが重要です。
          </p>
        </div>
        <div class="mc-category-card" style={`border-left-color: var(--mc-opposite)`}>
          <div class="mc-category-score">0〜29点</div>
          <div class="mc-category-label" style={`color: var(--mc-opposite)`}>最大成長機会型</div>
          <p class="mc-category-desc">
            最も異なる認知スタイルを持つペア。
            Beebe（2017）が示す「shadow functions」との接触は最大の自己理解を促します。
            継続的な対話と相互尊重が鍵となる組み合わせです。
          </p>
        </div>
      </div>
    </section>

    {/* ========== 4気質グループ別 相性概観 ========== */}
    <section class="mc-section" aria-labelledby="mc-temperament-h2">
      <h2 id="mc-temperament-h2" class="mc-h2">4気質グループ別 相性パターン概観</h2>
      <p class="mc-lead">
        Keirsey（1998）は16タイプをNT・NF・SJ・SPの4気質グループに分類しました。
        同じ気質内では価値観が近いため理解しやすく、異なる気質との関係では新たな視点が得られます。
        以下は各気質グループ間の相性パターンの概観です（個人差があります）。
      </p>

      {temperamentOrder.map((tempId) => {
        const group = temperamentGroups[tempId];
        return (
          <div class="mc-temp-block" data-temp={tempId}>
            <h3 class="mc-temp-h3">
              <span class="mc-temp-badge" data-temp={tempId}>{tempId}</span>
              {group.name}（{group.nameEn}）: {group.types.join(' / ')}
            </h3>
            <p class="mc-temp-desc">{group.description}</p>
            <div class="mc-temp-compat-grid">
              {temperamentOrder.map((targetId) => {
                const targetGroup = temperamentGroups[targetId];
                const isSame = tempId === targetId;
                const isAdjacent =
                  (tempId === 'NT' && targetId === 'NF') ||
                  (tempId === 'NF' && targetId === 'NT') ||
                  (tempId === 'SJ' && targetId === 'SP') ||
                  (tempId === 'SP' && targetId === 'SJ');
                const level = isSame ? 'same' : isAdjacent ? 'adjacent' : 'opposite';
                const levelLabel = isSame ? '同気質・高共感' : isAdjacent ? '近接気質・親和性あり' : '異気質・相互補完';
                return (
                  <div class="mc-temp-compat-card" data-level={level}>
                    <div class="mc-temp-compat-pair">
                      <span class="mc-temp-badge mc-temp-badge--sm" data-temp={tempId}>{tempId}</span>
                      <span class="mc-temp-compat-arrow" aria-hidden="true">×</span>
                      <span class="mc-temp-badge mc-temp-badge--sm" data-temp={targetId}>{targetId}</span>
                    </div>
                    <div class="mc-temp-compat-label">{levelLabel}</div>
                    <p class="mc-temp-compat-note">
                      {isSame && `同気質のため価値観・優先事項が近く、初期の共感が高い傾向。一方、同じ盲点を持ちやすい点に注意が必要です。`}
                      {isAdjacent && `${group.nameEn}と${targetGroup.nameEn}は近接する気質。共通の強みを持ちながら、異なるアプローチで補完し合える組み合わせです。`}
                      {!isSame && !isAdjacent && `${group.nameEn}と${targetGroup.nameEn}は価値観の差が大きい分、互いに新鮮な視点をもたらします。意識的な対話が関係の鍵になります。`}
                    </p>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </section>

    {/* ========== 16タイプ別 ベスト3 / 成長機会3 一覧表 ========== */}
    <section class="mc-section" aria-labelledby="mc-table-h2">
      <h2 id="mc-table-h2" class="mc-h2">16タイプ別 ベストマッチ3組・成長機会ペア3組</h2>
      <p class="mc-lead">
        各タイプごとに、相性スコア上位3組（ベストマッチ）と
        最も異なるアプローチを持つ3組（成長機会の多いペア）を一覧にまとめています。
        Keirsey（1998）・Beebe（2017）の理論に基づく傾向値です。個人差があります。
      </p>
      <div class="mc-type-table-wrap" role="region" aria-label="16タイプ別相性一覧">
        <table class="mc-type-table">
          <caption class="mc-table-caption">
            16タイプ別 相性傾向一覧（Keirsey 1998 / Beebe 2017理論に基づく傾向値・2026-05-20時点）
          </caption>
          <thead>
            <tr>
              <th scope="col" class="mc-th mc-th--type">タイプ</th>
              <th scope="col" class="mc-th mc-th--best">ベストマッチ上位3組</th>
              <th scope="col" class="mc-th mc-th--growth">成長機会の多いペア3組</th>
            </tr>
          </thead>
          <tbody>
            {allTypesData.map(({ type, best, growth }) => (
              <tr class="mc-tr">
                <th scope="row" class="mc-td mc-td--type">
                  <a href={`/diagnosis/mbti-compat/tool/?t1=${type}`} class="mc-type-link">
                    {type}
                  </a>
                </th>
                <td class="mc-td">
                  <ul class="mc-pair-list">
                    {best.map((d) => {
                      const partner = d.type1 === type ? d.type2 : d.type1;
                      return (
                        <li>
                          <a
                            href={`/diagnosis/mbti-compat/tool/?t1=${type}&t2=${partner}`}
                            class="mc-pair-link"
                          >
                            <span
                              class="mc-pair-score"
                              style={`background: ${getCategoryColor(d.category)}22; color: ${getCategoryColor(d.category)}`}
                            >
                              {d.score}点
                            </span>
                            <span class="mc-pair-name">{partner}</span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </td>
                <td class="mc-td">
                  <ul class="mc-pair-list">
                    {growth.map((d) => {
                      const partner = d.type1 === type ? d.type2 : d.type1;
                      return (
                        <li>
                          <a
                            href={`/diagnosis/mbti-compat/tool/?t1=${type}&t2=${partner}`}
                            class="mc-pair-link mc-pair-link--growth"
                          >
                            <span
                              class="mc-pair-score"
                              style={`background: ${getCategoryColor(d.category)}22; color: ${getCategoryColor(d.category)}`}
                            >
                              {d.score}点
                            </span>
                            <span class="mc-pair-name">{partner}</span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mc-table-note">
        ※ スコアは傾向値です。個人差・関係の深さ・環境によって大きく変わります。
        詳細は
        <a href="/diagnosis/mbti-compat/tool/">MBTI相性診断ツール</a>
        または
        <a href="/diagnosis/mbti-compat/table/">16×16相性マトリクス</a>
        でご確認ください。
      </p>
    </section>

    {/* ========== CTAセクション ========== */}
    <section class="mc-cta-section" aria-labelledby="mc-cta-h2">
      <h2 id="mc-cta-h2" class="mc-h2 mc-h2--center">さらに詳しく相性を調べる</h2>
      <div class="mc-cta-cards">
        <a href="/diagnosis/mbti-compat/tool/" class="mc-cta-card">
          <div class="mc-cta-icon" aria-hidden="true">🔍</div>
          <div class="mc-cta-card-body">
