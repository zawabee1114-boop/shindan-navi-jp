---
/**
 * MBTI相性表ビジュアル ページ（16×16マトリクス）
 * KW: MBTI相性表（VOL: 8,100 / SD: 17）
 * 学術根拠:
 *   - Keirsey D (1998) Please Understand Me II
 *   - Beebe J (2017) Energies and Patterns in Psychological Type
 *   - Jung CG (1921) Psychological Types
 * 確認日: 2026-05-20
 *
 * SEO/AIO対応:
 * - JSON-LD: Article + FAQPage + BreadcrumbList + @id連結
 * - 16×16 = 256セル全表示（静的生成）
 * - ホバーツールチップ（CSS only）
 * - クリックでツールページへジャンプ（?t1=X&t2=Y）
 * - レスポンシブ: モバイルは横スクロール
 * - CLS < 0.1: contain: layout でマトリクス領域を封じ込め
 * - WCAG 2.1 AA: scope / aria-label / focus-visible
 * - YMYL回避: 傾向値であることを明記
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Container from '../../../../components/Container.astro';
import { meta, MBTI_TYPES } from '../../../../data/diagnoses/mbti-compat/meta';
import {
  getCompatibility,
  getCategoryLabel,
  getCategoryColor,
  getBestMatches,
  getWorstMatches,
} from '../../../../data/diagnoses/mbti-compat/results';

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/mbti-compat/table/`;

// 全256ペアのデータを静的生成
const matrixData = MBTI_TYPES.map((rowType) =>
  MBTI_TYPES.map((colType) => getCompatibility(rowType, colType))
);

// 高スコアペア TOP10（重複除外・ユニーク化）
const allPairs: Array<{ score: number; t1: string; t2: string; category: string; summary: string }> = [];
const seen = new Set<string>();
for (const rowType of MBTI_TYPES) {
  for (const colType of MBTI_TYPES) {
    if (rowType === colType) continue;
    const key = [rowType, colType].sort().join('-');
    if (!seen.has(key)) {
      seen.add(key);
      const d = getCompatibility(rowType, colType);
      allPairs.push({
        score: d.score,
        t1: rowType,
        t2: colType,
        category: d.category,
        summary: d.oneLineSummary,
      });
    }
  }
}
const sortedByScore = [...allPairs].sort((a, b) => b.score - a.score);
const topHighPairs = sortedByScore.slice(0, 10);
const topLowPairs = sortedByScore.slice(-10).reverse();

// カテゴリ別CSS変数
const catColorVar: Record<string, string> = {
  soulmate: 'var(--mcm-soulmate)',
  good: 'var(--mcm-good)',
  neutral: 'var(--mcm-neutral)',
  tough: 'var(--mcm-tough)',
  opposite: 'var(--mcm-opposite)',
};
const catBgVar: Record<string, string> = {
  soulmate: 'var(--mcm-soulmate-bg)',
  good: 'var(--mcm-good-bg)',
  neutral: 'var(--mcm-neutral-bg)',
  tough: 'var(--mcm-tough-bg)',
  opposite: 'var(--mcm-opposite-bg)',
};


// JSX内型キャスト回避ヘルパー
function pairColor(category: string): string {
  return catColorVar[category] ?? 'var(--mcm-neutral)';
}
function pairLabel(category: string): string {
  const labels: Record<string, string> = {
    soulmate: 'ソウルメイト型',
    good: '相性の良いペア',
    neutral: 'バランス型',
    tough: '成長機会の多いペア',
    opposite: '最大の成長機会ペア',
  };
  return labels[category] ?? category;
}

// FAQ
const faqs = [
  {
    question: 'MBTI相性表の見方を教えてください。',
    answer:
      '縦列（行）が「タイプ1（自分）」、横列（列）が「タイプ2（相手）」です。交わるセルにスコアと色が表示されます。紫がソウルメイト型・緑が良好型・青がバランス型・黄が成長機会型・赤が最大成長機会型です。セルをクリックすると詳細が確認できます。',
  },
  {
    question: '表のスコアは対称ですか（INTJ×ENFPとENFP×INTJは同じ？）。',
    answer:
      'はい、同じです。相性は双方向であり、INTJ×ENFPとENFP×INTJは同一のスコアと相性説明が表示されます。本サイトでは256セル全てをデータとして保持していますが、実質的なユニークペアは128通りです。',
  },
  {
    question: '同タイプ同士（対角線）のスコアが高くないのはなぜですか？',
    answer:
      'Beebe（2017）の機能スタック理論では、同タイプ同士は主機能が同一のため「補完関係」が生まれにくい傾向があります。気質（Keirsey 1998）は一致しますが、J/P補完（15点）と機能スタック補完（30点）が加算されにくいため、中程度のスコアになりやすいです。',
  },
  {
    question: '一番相性の良いタイプの組み合わせはどれですか？',
    answer:
      'Beebe（2017）の機能スタック補完理論から、INTJ×ENFP・INFJ×ENTP・ISTJ×ESFP・ISFJ×ESTPなどが高スコアになりやすい傾向があります。詳細は本ページの「高スコアペアTOP10」セクションをご覧ください。',
  },
  {
    question: 'スコアが低いペアは本当に合わないのですか？',
    answer:
      'スコアは「補完性・類似性の強さ」の傾向値であり、相性の優劣ではありません。Jung（1921）の個性化理論では、最も異なる認知スタイルを持つ相手から最大の自己理解と成長が得られると述べています。全てのペアに価値があります。',
  },
];

// JSON-LD
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: 'MBTI相性表【16×16全256組み合わせ・カラーマトリクス】',
  description:
    '全16タイプ×16タイプ=256通りのMBTI相性をカラーコード付きマトリクスで一覧表示。Keirsey（1998）・Beebe（2017）・Jung（1921）理論に基づく相性スコアと傾向値を収録。',
  url: PAGE_URL,
  datePublished: meta.publishedAt,
  dateModified: meta.updatedAt,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  citation: meta.references.map((ref) => ({
    '@type': 'Book',
    name: ref.title,
    author: ref.author,
    datePublished: String(ref.year),
    publisher: ref.publisher,
    url: ref.url,
  })),
};

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: 'MBTI相性一覧', item: `${SITE_URL}/diagnosis/mbti-compat/` },
    { '@type': 'ListItem', position: 4, name: 'MBTI相性表', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];
---

<BaseLayout
  title="MBTI相性表【16×16全256組み合わせ・カラーマトリクス】｜診断ナビ"
  description="全16タイプ×16タイプ=256通りのMBTI相性をカラーコード付き一覧表で比較。スコアをクリックすると相性詳細・仕事・恋愛・成長ポイントが確認できます。Keirsey/Beebe/Jung理論に基づく傾向値。"
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate={meta.publishedAt}
  lastUpdated={meta.updatedAt}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'MBTI相性一覧', url: '/diagnosis/mbti-compat/' },
    { name: 'MBTI相性表', url: '/diagnosis/mbti-compat/table/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="mcm-hero" aria-labelledby="mcm-hero-h1">
    <Container>
      <div class="mcm-hero-inner">
        <div class="mcm-hero-badge">Keirsey（1998）× Beebe（2017）× Jung（1921）</div>
        <h1 id="mcm-hero-h1" class="mcm-hero-h1">
          MBTI相性表<br />
          <span class="mcm-hero-meta">【16×16全256組み合わせ・カラーマトリクス】</span>
        </h1>
        <p class="mcm-hero-catch">
          縦に自分のタイプ・横に相手のタイプを探してください。
          交わるセルに相性スコアと色が表示されます。
        </p>
        <div class="mcm-hero-stats">
          <span><strong>256</strong>通りのデータ収録</span>
          <span class="mcm-sep" aria-hidden="true">・</span>
          <span>カラーコード5段階</span>
          <span class="mcm-sep" aria-hidden="true">・</span>
          <span>クリックで詳細表示</span>
        </div>
        <p class="mcm-hero-updated">
          <time datetime={meta.updatedAt}>{meta.updatedAt}</time> 時点の情報
        </p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== AIOブロック ========== */}
    <div class="mcm-aio-block" role="note" aria-label="このページでわかること">
      <p class="mcm-aio-title">このページでわかること</p>
      <ul class="mcm-aio-list">
        <li>全16タイプ×16タイプ（256通り）の相性スコアをカラーコード付きマトリクスで一覧表示</li>
        <li>各セルをクリックすると仕事・恋愛・成長ポイント詳細が確認できます</li>
        <li>高スコアペアTOP10・成長機会の多いペアTOP10・同タイプ同士の傾向解説</li>
        <li>Keirsey（1998）・Beebe（2017）・Jung（1921）理論に基づく傾向値</li>
      </ul>
    </div>

    {/* ========== 凡例 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-legend-h2">
      <h2 id="mcm-legend-h2" class="mcm-h2">カラー凡例</h2>
      <div class="mcm-legend" role="list" aria-label="相性カテゴリのカラー凡例">
        {[
          { cat: 'soulmate', label: 'ソウルメイト型', score: '90〜100点', note: '機能スタック補完（Beebe 2017）' },
          { cat: 'good',     label: '良好型',         score: '70〜89点',  note: '気質近接・自然な親和性（Keirsey 1998）' },
          { cat: 'neutral',  label: 'バランス型',     score: '50〜69点',  note: '意識的な対話で深まるペア' },
          { cat: 'tough',    label: '成長機会型',     score: '30〜49点',  note: '学び合い・個性化促進（Jung 1921）' },
          { cat: 'opposite', label: '最大成長機会型', score: '0〜29点',   note: '最も異なる認知スタイル' },
        ].map(({ cat, label, score, note }) => (
          <div class="mcm-legend-item" role="listitem">
            <div
              class="mcm-legend-color"
              style={`background: ${catBgVar[cat]}; border-color: ${catColorVar[cat]}`}
            >
              <span style={`color: ${catColorVar[cat]}`} class="mcm-legend-score-num">-</span>
            </div>
            <div class="mcm-legend-body">
              <span class="mcm-legend-label" style={`color: ${catColorVar[cat]}`}>{label}</span>
              <span class="mcm-legend-score">{score}</span>
              <span class="mcm-legend-note">{note}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* ========== 16×16 マトリクス ========== */}
    <section class="mcm-section" aria-labelledby="mcm-matrix-h2">
      <h2 id="mcm-matrix-h2" class="mcm-h2">16×16 MBTI相性マトリクス</h2>
      <p class="mcm-lead">
        縦（行）＝タイプ1（あなた）、横（列）＝タイプ2（相手）。
        セルをクリックすると相性詳細ページへ移動します。
        スコアは傾向値です（個人差あり）。
      </p>
      <div class="mcm-matrix-wrap" role="region" aria-label="MBTI相性マトリクス" style="contain: layout;">
        <table class="mcm-matrix" role="grid">
          <caption class="mcm-table-caption">
            MBTI相性表（全16タイプ×16タイプ = 256通り・Keirsey 1998 / Beebe 2017理論・2026-05-20時点）
          </caption>
          <thead>
            <tr>
              <th scope="col" class="mcm-th mcm-th--corner">
                <span aria-label="縦: あなたのタイプ / 横: 相手のタイプ">
                  ↓ あなた<br />→ 相手
                </span>
              </th>
              {MBTI_TYPES.map((colType) => (
                <th scope="col" class="mcm-th mcm-th--header">
                  {colType}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {MBTI_TYPES.map((rowType, rowIdx) => (
              <tr>
                <th scope="row" class="mcm-th mcm-th--row">
                  {rowType}
                </th>
                {matrixData[rowIdx].map((cellData, colIdx) => {
                  const colType = MBTI_TYPES[colIdx];
                  const isSelf = rowType === colType;
                  return (
                    <td
                      class="mcm-cell"
                      data-category={cellData.category}
                      data-self={isSelf ? 'true' : 'false'}
                    >
                      <a
                        href={`/diagnosis/mbti-compat/tool/?t1=${rowType}&t2=${colType}`}
                        class="mcm-cell-link"
                        aria-label={`${rowType} × ${colType}: ${cellData.score}点 ${getCategoryLabel(cellData.category)}。${cellData.oneLineSummary}`}
                        title={cellData.oneLineSummary}
                      >
                        <span class="mcm-cell-score">{cellData.score}</span>
                      </a>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mcm-matrix-note">
        ※ スコアは傾向値です。個人差・関係の深さ・環境によって大きく異なります。
        全てのペアに補完性と成長機会があります。
      </p>
    </section>

    {/* ========== 相性表の読み方 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-howread-h2">
      <h2 id="mcm-howread-h2" class="mcm-h2">相性表の読み方</h2>
      <p class="mcm-lead">
        MBTI相性表を最大限に活用するための3つのポイントです。
      </p>
      <div class="mcm-howread-grid">
        <div class="mcm-howread-card">
          <div class="mcm-howread-icon" aria-hidden="true">1</div>
          <h3 class="mcm-howread-title">自分のタイプの行を横に見る</h3>
          <p class="mcm-howread-body">
            自分のタイプが書かれた行を左から右に見ると、
            16種類の相手タイプそれぞれとの相性スコアが一覧できます。
            色が紫・緑のセルほど補完性が高い傾向です。
          </p>
        </div>
        <div class="mcm-howread-card">
          <div class="mcm-howread-icon" aria-hidden="true">2</div>
          <h3 class="mcm-howread-title">対角線（同タイプ同士）の特徴</h3>
          <p class="mcm-howread-body">
            左上から右下への対角線は同タイプ同士のスコアです。
            Beebe（2017）によると同タイプは気質（Keirsey 1998）が一致するため
            理解はしやすいが、機能スタックの補完関係が生まれにくい傾向があります。
          </p>
        </div>
        <div class="mcm-howread-card">
          <div class="mcm-howread-icon" aria-hidden="true">3</div>
          <h3 class="mcm-howread-title">表は対称（転置）です</h3>
          <p class="mcm-howread-body">
            INTJ行×ENFP列のスコアと、ENFP行×INTJ列のスコアは同じです。
            相性は双方向であるため、視点を変えても同じ結果になります。
          </p>
        </div>
      </div>
    </section>

    {/* ========== 高スコアペア TOP10 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-high-h2">
      <h2 id="mcm-high-h2" class="mcm-h2">高スコアペア TOP10</h2>
      <p class="mcm-lead">
        Beebe（2017）の機能スタック補完とKeirsey（1998）の気質分析から導出した
        相性スコア上位ペアです。傾向値であり個人差があります。
      </p>
      <ol class="mcm-ranking-list" aria-label="高スコアペアランキング">
        {topHighPairs.map((pair, i) => (
          <li class="mcm-ranking-item">
            <span class="mcm-rank-num" data-rank={i < 3 ? 'top' : 'normal'} aria-hidden="true">
              {i + 1}
            </span>
            <a
              href={`/diagnosis/mbti-compat/tool/?t1=${pair.t1}&t2=${pair.t2}`}
              class="mcm-ranking-link"
            >
              <span class="mcm-ranking-pair">
                {pair.t1} × {pair.t2}
              </span>
              <span
                class="mcm-ranking-score-badge"
                style={`background: ${pairColor(pair.category)}22; color: ${pairColor(pair.category)}`}
              >
                {pair.score}点
              </span>
              <span class="mcm-ranking-label">
                {pairLabel(pair.category)}
              </span>
            </a>
            <p class="mcm-ranking-summary">{pair.summary}</p>
          </li>
        ))}
      </ol>
    </section>

    {/* ========== 成長機会の多いペア TOP10 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-low-h2">
      <h2 id="mcm-low-h2" class="mcm-h2">成長機会の多いペア TOP10</h2>
      <p class="mcm-lead">
        最もスコアが低いペアは、Jung（1921）の個性化理論において
        最大の自己理解と成長をもたらす組み合わせとも言えます。
        「合わない」ではなく「最も異なる視点を持つ」ペアです。
      </p>
      <ol class="mcm-ranking-list" aria-label="成長機会の多いペアランキング">
        {topLowPairs.map((pair, i) => (
          <li class="mcm-ranking-item">
            <span class="mcm-rank-num" aria-hidden="true">{i + 1}</span>
            <a
              href={`/diagnosis/mbti-compat/tool/?t1=${pair.t1}&t2=${pair.t2}`}
              class="mcm-ranking-link"
            >
              <span class="mcm-ranking-pair">
                {pair.t1} × {pair.t2}
              </span>
              <span
                class="mcm-ranking-score-badge"
                style={`background: ${pairColor(pair.category)}22; color: ${pairColor(pair.category)}`}
              >
                {pair.score}点
              </span>
              <span class="mcm-ranking-label">
                {pairLabel(pair.category)}
              </span>
            </a>
            <p class="mcm-ranking-summary">{pair.summary}</p>
          </li>
        ))}
      </ol>
    </section>

    {/* ========== 同タイプ同士の傾向 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-selfpair-h2">
      <h2 id="mcm-selfpair-h2" class="mcm-h2">同タイプ同士（例: INTJ×INTJ）の相性パターン</h2>
      <p class="mcm-lead">
        同じMBTIタイプ同士はどんな特徴があるのでしょうか？
        Beebe（2017）とKeirsey（1998）の理論から見えてくる傾向をまとめます。
      </p>
      <div class="mcm-selfpair-grid">
        <div class="mcm-selfpair-card mcm-selfpair-card--pro">
          <h3 class="mcm-selfpair-title">同タイプ同士の強み</h3>
          <ul class="mcm-selfpair-list">
            <li>同じ気質（NT/NF/SJ/SP）のため価値観・優先事項が近く、初期の共感・理解が速い</li>
            <li>コミュニケーションスタイルが似ているため誤解が生まれにくい傾向</li>
            <li>同じ認知スタイルを持つため、仕事上の意思決定や問題解決のアプローチが揃いやすい</li>
          </ul>
        </div>
        <div class="mcm-selfpair-card mcm-selfpair-card--con">
          <h3 class="mcm-selfpair-title">同タイプ同士の注意点</h3>
          <ul class="mcm-selfpair-list">
            <li>Beebe（2017）によると、同タイプは同一の「劣等機能（inferior function）」を共有するため、同じ盲点を持ちやすい</li>
            <li>互いに異なる強みを補完する「機能スタック補完」が生まれにくい傾向</li>
            <li>「共感はしやすいが刺激が少ない」と感じることがある（Jung 1921）</li>
          </ul>
        </div>
      </div>
      <p class="mcm-selfpair-note">
        ※ 同タイプでも、育ち・環境・経験の違いによって大きく異なる個人が生まれます。
        これはあくまでタイプ傾向の参考情報です。
      </p>
    </section>

    {/* ========== 学術根拠 ========== */}
    <section class="mcm-section" aria-labelledby="mcm-refs-h2">
      <h2 id="mcm-refs-h2" class="mcm-h2">学術根拠・参考文献</h2>
      <div class="mcm-refs-list">
        {meta.references.map((ref) => (
          <div class="mcm-ref-item">
            <a href={ref.url} target="_blank" rel="noopener noreferrer" class="mcm-ref-link">
              {ref.title}
            </a>
            <span class="mcm-ref-meta">{ref.author}（{ref.year}）/ {ref.publisher}</span>
          </div>
