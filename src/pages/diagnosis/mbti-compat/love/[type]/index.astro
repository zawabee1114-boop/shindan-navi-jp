---
/**
 * MBTI恋愛相性 16タイプ別ページ（動的生成）
 * KW: {タイプ} 恋愛相性（各タイプ）
 * Phase 1 第5優先
 *
 * 学術根拠:
 *   - Keirsey D (1998) Please Understand Me II
 *   - Jung CG (1921) Psychological Types
 *   - Beebe J (2017) Energies and Patterns in Psychological Type
 *   - Myers IB (1998) MBTI Manual
 *   - Sternberg RJ (1986) A triangular theory of love. Psychological Review, 93(2), 119-135
 *     https://doi.org/10.1037/0033-295X.93.2.119
 *
 * SEO/AIO対応:
 * - JSON-LD: Article + FAQPage + BreadcrumbList（@id連結）
 * - 16タイプ × 恋愛特性・強み・注意点
 * - 15タイプとの恋愛相性ランキング（loveCompat スコア順）
 * - ソウルメイト系TOP3・学び合いペアTOP3・同タイプ同士
 * - YMYL回避: 医学的診断・治療表記ゼロ
 * - 「相性悪い」NG → 「成長機会の多いペア」表現
 *
 * 確認日: 2026-05-20
 */
import BaseLayout from '../../../../../layouts/BaseLayout.astro';
import Container from '../../../../../components/Container.astro';
import { MBTI_TYPES } from '../../../../../data/diagnoses/mbti-compat/meta';
import type { MBTIType } from '../../../../../data/diagnoses/mbti-compat/meta';
import { meta as mbtiCompatMeta } from '../../../../../data/diagnoses/mbti-compat/meta';
import { typesDetail } from '../../../../../data/diagnoses/mbti-compat/types-detail';
import {
  getAllPairsForType,
  getCompatibility,
  getCategoryLabel,
  getCategoryColor,
} from '../../../../../data/diagnoses/mbti-compat/results';

export async function getStaticPaths() {
  return MBTI_TYPES.map((type) => ({
    params: { type },
  }));
}

const { type } = Astro.params as { type: MBTIType };
const detail = typesDetail[type];

const SITE_URL = 'https://shindan-navi.jp';
const PAGE_URL = `${SITE_URL}/diagnosis/mbti-compat/love/${type}/`;
const PARENT_URL = `${SITE_URL}/diagnosis/mbti-compat/love/`;

const PUBLISHED_AT = '2026-05-20';
const UPDATED_AT = '2026-05-20';

// 15タイプとの恋愛相性（スコア降順）
const allPairs = getAllPairsForType(type).sort((a, b) => b.score - a.score);

// ソウルメイト系（スコア上位3・85点以上が理想だが少ない場合は上位3固定）
const soulmatePairs = allPairs.slice(0, 3);

// 学び合いペア（スコア下位3）
const growthPairs = [...allPairs].sort((a, b) => a.score - b.score).slice(0, 3);

// 同タイプ同士
const selfPair = getCompatibility(type, type);

// 気質バッジ色マッピング
const tempColor: Record<string, string> = {
  NT: '#4f46e5',
  NF: '#059669',
  SJ: '#b45309',
  SP: '#dc2626',
};

// タイプ別 恋愛文脈の強み（機能スタック視点）
const loveLensDesc: Record<string, string> = {
  INTJ: `Ni（内向的直観）主導の長期ビジョンで、パートナーシップも深く設計します。感情表現は少なめですが、信頼した相手への誠実さは揺るぎないものがあります。`,
  INTP: `Ti（内向的思考）の論理構造を通じて愛情を表現する傾向があります。知的共鳴のある相手への深い献身と、自分の思考空間を尊重してくれる関係が合います。`,
  ENTJ: `Te（外向的思考）とNi（内向的直観）の組み合わせで、関係を能動的に構築します。対等なパートナーシップを求め、共に目標を持てる関係に充実感を覚えます。`,
  ENTP: `Ne（外向的直観）の豊かなアイデアで関係に刺激をもたらします。知的な議論を楽しめる相手との関係が長続きしやすく、退屈を嫌うため変化と新鮮さが大切です。`,
  INFJ: `Ni（内向的直観）とFe（外向的感情）の組み合わせで、深い感情的なつながりを求めます。相手の内面を直感的に感じ取り、魂レベルの共鳴を大切にします。`,
  INFP: `Fi（内向的感情）の深い価値観体系が恋愛の基盤です。真の自己を受け入れてくれる相手との深い精神的な絆を最重視します。`,
  ENFJ: `Fe（外向的感情）主導で、パートナーの成長と幸福を深く気にかけます。感情的なサポートが自然にできる半面、自分のニーズを後回しにしがちな点に注意が必要です。`,
  ENFP: `Ne（外向的直観）とFi（内向的感情）の組み合わせで、理想の関係に強い情熱を持ちます。相手の可能性を信じ、ともに成長する関係に深い充実感を覚えます。`,
  ISTJ: `Si（内向的感覚）主導の安定性と誠実さが恋愛の基盤です。言葉より行動で愛情を示し、長期的なコミットメントと責任感が際立ちます。`,
  ISFJ: `Si（内向的感覚）とFe（外向的感情）の組み合わせで、献身的なサポートが自然にできます。相手の細かなニーズに気づき、安定した温かい関係を大切にします。`,
  ESTJ: `Te（外向的思考）主導で関係を能動的に管理します。責任感と明確なコミットメントを大切にし、長期的な安定を基盤にした関係を築きます。`,
  ESFJ: `Fe（外向的感情）主導で、調和と相手への配慮を最優先にします。感情的な温かさと実際的なサポートで、パートナーに安心感をもたらします。`,
  ISTP: `Ti（内向的思考）とSe（外向的感覚）の組み合わせで、現実的な問題解決と実際的なサポートを示します。束縛より自由を好み、お互いの独立性を尊重する関係が合います。`,
  ISFP: `Fi（内向的感情）の深い価値観と、Se（外向的感覚）の今この瞬間の体験を大切にします。真の自己表現ができる安全な関係を求めます。`,
  ESTP: `Se（外向的感覚）主導で、今この瞬間の楽しさと刺激を大切にします。行動でサポートを示し、体験を共有することで絆を深める傾向があります。`,
  ESFP: `Se（外向的感覚）とFe（外向的感情）の組み合わせで、ともに楽しむことへの強い情熱があります。自発的な楽しさと温かさで関係に活力をもたらします。`,
};

// 恋愛文脈の注意点
const loveCautionDesc: Record<string, string> = {
  INTJ: `感情表現が少なく、愛情が伝わりにくい場合があります。パートナーの感情ニーズを定期的に確認する意識が、関係の安定につながります。`,
  INTP: `感情より論理を優先しすぎる場面があります。パートナーの感情的なニーズを論理で解決しようとせず、まず「聴く」姿勢が大切です。`,
  ENTJ: `主導的な姿勢がパートナーの自律性を損なう場合があります。支配より協力を意識し、相手の意見を積極的に取り入れる対話が重要です。`,
  ENTP: `アイデアや議論への熱中が、パートナーとの感情的なつながりを後回しにする場合があります。定期的に感情面の対話を意識することが関係を深めます。`,
  INFJ: `理想が高く、現実とのギャップに傷つきやすい面があります。完璧な関係より「成長する関係」という視点が、長期的な充実につながります。`,
  INFP: `理想化しすぎて、現実のパートナーとの差にがっかりする場合があります。相手の実際の姿を大切にする視点と、適切な期待値の調整が重要です。`,
  ENFJ: `自分の感情ニーズを後回しにして疲弊する場合があります。与えるだけでなく「受け取ること」も関係の健全さに必要だと意識することが大切です。`,
  ENFP: `理想の関係を追い求めすぎて、現実の関係の価値を見落とす場合があります。「今ここにある関係」を丁寧に育てる視点が長続きの鍵です。`,
  ISTJ: `変化への抵抗が、パートナーの成長や変化のニーズと摩擦を生む場合があります。柔軟性を意識し、新しい経験を共に試みる開放性が関係を豊かにします。`,
  ISFJ: `自分の意見・感情・限界を伝えにくい傾向があります。遠慮なく自分のニーズを伝えることが、より対等で健全な関係につながります。`,
  ESTJ: `効率や論理でパートナーを評価してしまう場合があります。愛情は「成果」でなく「存在」に向けるという視点が、深い関係を育てます。`,
  ESFJ: `批判を過剰に気にして、自分の意見を言えない場合があります。適切に自己主張することが、より対等で充実した関係を作ります。`,
  ISTP: `感情表現が少なく、パートナーに「つながっている感覚」を感じさせにくい場合があります。定期的に気持ちを言葉にする練習が関係の深化につながります。`,
  ISFP: `批判を個人攻撃として受け取りやすく、傷つきやすい面があります。フィードバックと批判を区別し、建設的な対話を育てる姿勢が大切です。`,
  ESTP: `長期的なコミットメントより刺激を優先しがちな面があります。関係の安定性をパートナーが必要としているサインに気づく観察力が大切です。`,
  ESFP: `衝動的な楽しさを優先して、パートナーとの将来計画を後回しにする場合があります。定期的に関係の方向性について対話する時間を持つことが重要です。`,
};

// FAQ 3問（各タイプ固有）
const faqs = [
  {
    question: `${type}の恋愛相性が最も高いタイプはどれですか？`,
    answer:
      `スコア上位のペアは${soulmatePairs.map((d) => (d.type1 === type ? d.type2 : d.type1)).join('・')}です。Beebe（2017）の機能スタック理論とKeirsey（1998）の気質分析に基づく傾向値であり、個人差があります。詳細な相性内容は各ペアの相性チェックツールでご確認ください。`,
  },
  {
    question: `${type}と相性スコアが低いタイプとの恋愛は難しいですか？`,
    answer:
      `スコアが低いペアは「成長機会の多いペア」として捉えていただければ幸いです。Sternberg（1986）の愛の三角形理論が示すように、恋愛関係の質は「親密性・情熱・コミットメント」の意識的な積み重ねによって決まります。スコアは出発点の傾向であり、関係の質を決定するものではありません。`,
  },
  {
    question: `${type}同士（${type}×${type}）の恋愛相性はどうですか？`,
    answer:
      `同タイプ同士の相性スコアは${selfPair.score}点（${getCategoryLabel(selfPair.category)}）です。価値観・思考スタイルが近いため初期の共感度は高い傾向がありますが、Beebe（2017）の機能スタック理論では、同タイプは補完関係を持たないため互いの盲点が重なりやすい点に注意が必要です。`,
  },
];

// JSON-LD: Article
const jsonLdArticle = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${PAGE_URL}#article`,
  mainEntityOfPage: { '@type': 'WebPage', '@id': PAGE_URL },
  headline: `【${type}】の恋愛相性 完全ガイド｜全15タイプとのランキング`,
  description: `${type}（${detail.name}）の恋愛傾向・15タイプとの恋愛相性ランキング。Keirsey・Jung・Beebe・Sternberg理論に基づく傾向値。`,
  url: PAGE_URL,
  datePublished: PUBLISHED_AT,
  dateModified: UPDATED_AT,
  inLanguage: 'ja',
  author: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: '診断ナビ',
  },
  citation: [
    ...mbtiCompatMeta.references.map((ref) => ({
      '@type': 'Book',
      name: ref.title,
      author: ref.author,
      datePublished: String(ref.year),
      publisher: ref.publisher,
      url: ref.url,
    })),
    {
      '@type': 'ScholarlyArticle',
      name: 'A triangular theory of love',
      author: 'Sternberg RJ',
      datePublished: '1986',
      publisher: 'Psychological Review',
      url: 'https://doi.org/10.1037/0033-295X.93.2.119',
    },
  ],
};

// JSON-LD: FAQPage
const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${PAGE_URL}#faq`,
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

// JSON-LD: BreadcrumbList
const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '診断一覧', item: `${SITE_URL}/diagnosis/` },
    { '@type': 'ListItem', position: 3, name: 'MBTI相性一覧', item: `${SITE_URL}/diagnosis/mbti-compat/` },
    { '@type': 'ListItem', position: 4, name: 'MBTI恋愛相性', item: PARENT_URL },
    { '@type': 'ListItem', position: 5, name: `${type}の恋愛相性`, item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

const pageTitle = `${type}の恋愛相性【全15タイプ別ランキング】｜診断ナビ`;
const pageDesc = `${type}（${detail.name}）の恋愛傾向・${type}との相性が高いタイプ・成長機会のあるペアを全15タイプ別に解説。Keirsey・Jung・Beebe・Sternberg理論に基づく傾向値。無料・登録不要。`;

// temp color for this type
const myTempColor = tempColor[detail.temperament] ?? '#6d28d9';
---

<BaseLayout
  title={pageTitle}
  description={pageDesc}
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="article"
  publishDate={PUBLISHED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '診断一覧', url: '/diagnosis/' },
    { name: 'MBTI相性一覧', url: '/diagnosis/mbti-compat/' },
    { name: 'MBTI恋愛相性', url: '/diagnosis/mbti-compat/love/' },
    { name: `${type}の恋愛相性`, url: `/diagnosis/mbti-compat/love/${type}/` },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="mlt-hero" aria-labelledby="mlt-hero-h1" style={`--type-color: ${myTempColor}`}>
    <div class="mlt-hero-inner">
      <div class="mlt-hero-badge">Keirsey / Jung / Beebe / Sternberg 理論</div>
      <div class="mlt-hero-type" aria-hidden="true">{type}</div>
      <h1 id="mlt-hero-h1" class="mlt-hero-h1">
        【{type}】の恋愛相性<br />
        <span class="mlt-hero-meta">完全ガイド｜全15タイプ別ランキング</span>
      </h1>
      <p class="mlt-hero-catch">
        {detail.name}（{type}）の恋愛傾向と、15タイプとの相性を詳しく解説します。
        気質理論・機能スタック・愛の三角形理論から傾向を分析しています。
      </p>
      <div class="mlt-hero-cta-group">
        <a href={`/diagnosis/mbti-compat/tool/?t1=${type}`} class="mlt-cta-btn mlt-cta-btn--primary">
          相手タイプと相性チェック →
        </a>
        <a href="/diagnosis/mbti-compat/love/" class="mlt-cta-btn mlt-cta-btn--secondary">
          16タイプ一覧に戻る
        </a>
      </div>
      <p class="mlt-hero-sub">
        <time datetime={UPDATED_AT}>{UPDATED_AT}</time> 時点の情報・月1回更新
      </p>
    </div>
  </section>

  <Container>
    {/* ========== AIOブロック ========== */}
    <div class="mlt-aio-block" role="note" aria-label="このページでわかること">
      <p class="mlt-aio-title">このページでわかること</p>
      <ul class="mlt-aio-list">
        <li>{type}（{detail.name}）の恋愛傾向・loveStyle（Beebe 2017 / Keirsey 1998理論）</li>
        <li>15タイプとの恋愛相性スコアランキング（降順）</li>
        <li>恋愛文脈での強み・気をつけたい傾向</li>
        <li>ソウルメイト系TOP3・学び合いペアTOP3・同タイプ同士の相性</li>
      </ul>
      <p class="mlt-aio-updated">
        学術根拠:
        <a href="https://keirsey.com/product/please-understand-me-ii/" target="_blank" rel="noopener noreferrer">Keirsey（1998）</a>・
        <a href="https://press.princeton.edu/books/paperback/9780691018133/psychological-types" target="_blank" rel="noopener noreferrer">Jung（1921）</a>・
        <a href="https://www.routledge.com/Energies-and-Patterns-in-Psychological-Type-The-reservoir-of-consciousness/Beebe/p/book/9781138859760" target="_blank" rel="noopener noreferrer">Beebe（2017）</a>・
        <a href="https://doi.org/10.1037/0033-295X.93.2.119" target="_blank" rel="noopener noreferrer">Sternberg（1986）</a>
        を確認済。
      </p>
    </div>

    {/* ========== タイプ基本情報 ========== */}
    <section class="mlt-section" aria-labelledby="mlt-profile-h2">
      <h2 id="mlt-profile-h2" class="mlt-h2" style={`border-bottom-color: ${myTempColor}`}>
        {type}（{detail.name}）の基本プロフィール
      </h2>
      <div class="mlt-profile-grid">
        <div class="mlt-profile-main">
          <div class="mlt-profile-head">
            <span class="mlt-type-badge" style={`background: ${myTempColor}`}>{type}</span>
            <div class="mlt-profile-names">
              <span class="mlt-profile-name">{detail.name}</span>
              <span class="mlt-profile-nick">別名: {detail.nickname}</span>
            </div>
            <span class="mlt-temp-tag" style={`background: ${myTempColor}22; color: ${myTempColor}; border: 1px solid ${myTempColor}44`}>
              {detail.temperament}気質
            </span>
          </div>
          <div class="mlt-func-stack">
            <span class="mlt-func-label">機能スタック（Beebe 2017）:</span>
            <span class="mlt-func-item mlt-func-d">主機能: {detail.functionStack.dominant}</span>
            <span class="mlt-func-item mlt-func-a">補助: {detail.functionStack.auxiliary}</span>
            <span class="mlt-func-item mlt-func-t">三次: {detail.functionStack.tertiary}</span>
            <span class="mlt-func-item mlt-func-i">劣等: {detail.functionStack.inferior}</span>
          </div>
        </div>
        <div class="mlt-profile-desc">
          <p class="mlt-lead">{detail.description}</p>
        </div>
      </div>
    </section>

    {/* ========== 恋愛特性 ========== */}
    <section class="mlt-section" aria-labelledby="mlt-love-h2">
      <h2 id="mlt-love-h2" class="mlt-h2" style={`border-bottom-color: ${myTempColor}`}>
        {type}の恋愛傾向
      </h2>
      <div class="mlt-love-block">
        <p class="mlt-love-style">{detail.loveStyle}</p>
        <p class="mlt-love-lens">{loveLensDesc[type]}</p>
      </div>
      <div class="mlt-love-cards">
        <div class="mlt-love-card mlt-love-card--strength">
          <h3 class="mlt-love-card-title">恋愛における強み</h3>
          <ul class="mlt-love-list">
            {detail.strengths.map((s) => (
              <li class="mlt-love-item mlt-love-item--strength">{s}</li>
            ))}
          </ul>
        </div>
        <div class="mlt-love-card mlt-love-card--caution">
          <h3 class="mlt-love-card-title">気をつけたい傾向</h3>
          <p class="mlt-love-caution-desc">{loveCautionDesc[type]}</p>
          <ul class="mlt-love-list">
            {detail.weaknesses.map((w) => (
              <li class="mlt-love-item mlt-love-item--caution">{w}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* ========== ソウルメイト系 TOP3 ========== */}
    <section class="mlt-section" aria-labelledby="mlt-soulmate-h2">
      <h2 id="mlt-soulmate-h2" class="mlt-h2" style={`border-bottom-color: ${myTempColor}`}>
        {type}との恋愛相性 ソウルメイト系TOP3
      </h2>
      <p class="mlt-lead">
        Beebe（2017）の機能スタック理論とKeirsey（1998）の気質分析で
        補完性・類似性が高い上位3タイプです。
        スコアは傾向値であり、個人差があります。
      </p>
      <div class="mlt-soulmate-cards">
        {soulmatePairs.map((d, i) => {
          const partner = d.type1 === type ? d.type2 : d.type1;
          const partnerDetail = typesDetail[partner];
          const color = getCategoryColor(d.category);
          return (
            <div class="mlt-soulmate-card">
              <div class="mlt-soulmate-rank" aria-hidden="true">#{i + 1}</div>
              <div class="mlt-soulmate-head">
                <span class="mlt-soulmate-type" style={`background: ${tempColor[partnerDetail.temperament] ?? '#6b7280'}`}>
                  {partner}
                </span>
                <span class="mlt-soulmate-name">{partnerDetail.name}</span>
