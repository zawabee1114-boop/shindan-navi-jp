        "isPartOf": { "@type": "WebSite", "url": "https://shindan-navi.jp" },
        "publisher": {
          "@type": "Organization",
          "name": "診断ナビ編集部",
          "url": "https://shindan-navi.jp",
          "email": "zawalab.info@gmail.com"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://shindan-navi.jp/" },
          { "@type": "ListItem", "position": 2, "name": "編集ポリシー", "item": "https://shindan-navi.jp/editorial-policy/" }
        ]
      }
    ])}
  </script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--sn-font-family);
      background: var(--sn-bg);
      color: var(--sn-text);
      line-height: var(--sn-leading-base);
      font-size: var(--sn-text-base);
    }
    .container { max-width: var(--sn-max-w-content); margin: 0 auto; padding: 0 var(--sn-space-4); }
    /* ヘッダー */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--sn-border); height: var(--sn-header-h);
    }
    .site-header .inner {
      max-width: var(--sn-max-w); margin: 0 auto;
      padding: 0 var(--sn-space-4); height: 100%;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo { font-family: var(--sn-font-rounded); font-size: var(--sn-text-xl); font-weight: 700; color: var(--sn-primary); text-decoration: none; }
    .header-cta {
      display: inline-flex; align-items: center; gap: var(--sn-space-2);
      background: var(--sn-primary); color: #fff; font-size: var(--sn-text-sm);
      font-weight: 700; padding: var(--sn-space-2) var(--sn-space-4);
      border-radius: var(--sn-radius-pill); text-decoration: none; min-height: var(--sn-tap-min);
    }
    /* パンくず */
    .breadcrumb { font-size: var(--sn-text-sm); color: var(--sn-muted); padding: var(--sn-space-4) var(--sn-space-4); }
    .breadcrumb a { color: var(--sn-muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--sn-primary); }
    /* ページヒーロー */
    .page-hero {
      background: linear-gradient(135deg, #f0fdf4 0%, #eef2ff 100%);
      padding: var(--sn-space-12) 0; text-align: center; margin-bottom: var(--sn-space-10);
    }
    .page-hero h1 { font-family: var(--sn-font-rounded); font-size: var(--sn-text-3xl); font-weight: 700; margin-bottom: var(--sn-space-3); }
    .page-hero p { color: var(--sn-muted); font-size: var(--sn-text-sm); }
    /* 本文 */
    .policy-section { margin-bottom: var(--sn-space-10); }
    .policy-heading {
      font-family: var(--sn-font-rounded); font-size: var(--sn-text-xl); font-weight: 700;
      margin-bottom: var(--sn-space-5); padding-bottom: var(--sn-space-3);
      border-bottom: 2px solid var(--sn-primary-bg);
      display: flex; align-items: center; gap: var(--sn-space-2);
    }
    .policy-subheading {
      font-size: var(--sn-text-base); font-weight: 700;
      margin: var(--sn-space-5) 0 var(--sn-space-3);
      color: var(--sn-text);
    }
    p.policy-text {
      font-size: var(--sn-text-sm); color: var(--sn-text-soft);
      line-height: var(--sn-leading-relaxed); margin-bottom: var(--sn-space-4);
    }
    .policy-list {
      list-style: none; display: flex; flex-direction: column; gap: var(--sn-space-2);
      margin-bottom: var(--sn-space-5);
    }
    .policy-list li {
      display: flex; align-items: flex-start; gap: var(--sn-space-2);
      font-size: var(--sn-text-sm); color: var(--sn-text-soft);
      line-height: var(--sn-leading-relaxed);
    }
    .policy-list li::before { content: "✓"; color: var(--sn-success); font-weight: 700; flex-shrink: 0; margin-top: 2px; }
    .policy-list.cross li::before { content: "✕"; color: var(--sn-error); }
    .policy-box {
      background: var(--sn-primary-bg); border-radius: var(--sn-radius);
      padding: var(--sn-space-5) var(--sn-space-6); margin-bottom: var(--sn-space-5);
      border-left: 3px solid var(--sn-primary);
    }
    .policy-box-title { font-weight: 700; margin-bottom: var(--sn-space-3); font-size: var(--sn-text-sm); }
    .policy-box p { font-size: var(--sn-text-sm); color: var(--sn-text-soft); line-height: var(--sn-leading-relaxed); }
    .policy-warn {
      background: #fff7ed; border-radius: var(--sn-radius);
      padding: var(--sn-space-5) var(--sn-space-6); margin-bottom: var(--sn-space-5);
      border-left: 3px solid var(--sn-warning);
    }
    .policy-warn-title { font-weight: 700; margin-bottom: var(--sn-space-3); font-size: var(--sn-text-sm); color: var(--sn-accent-dark); }
    .policy-warn p { font-size: var(--sn-text-sm); color: var(--sn-text-soft); line-height: var(--sn-leading-relaxed); }
    .meta-text { font-size: var(--sn-text-xs); color: var(--sn-muted); margin-bottom: var(--sn-space-2); }
    /* フッター */
    .site-footer {
      background: var(--sn-text); color: rgba(255,255,255,0.7);
      padding: var(--sn-space-10) 0 var(--sn-space-8); margin-top: var(--sn-space-16);
    }
    .footer-inner { max-width: var(--sn-max-w); margin: 0 auto; padding: 0 var(--sn-space-4); }
    .footer-logo { font-family: var(--sn-font-rounded); font-size: var(--sn-text-xl); color: #fff; font-weight: 700; text-decoration: none; display: block; margin-bottom: var(--sn-space-2); }
    .footer-links { display: flex; flex-wrap: wrap; gap: var(--sn-space-6); margin: var(--sn-space-6) 0; }
    .footer-links a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: var(--sn-text-sm); }
    .footer-links a:hover { color: #fff; }
    .footer-bottom { font-size: var(--sn-text-xs); border-top: 1px solid rgba(255,255,255,0.1); padding-top: var(--sn-space-6); }
  </style>
  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-S4WP0YRDWW"></script>
