// 2026-05-20 time点の情報・content-writer 執筆
const title = "編集ポリシー | 診断ナビ";
const description = "診断ナビの編集ポリシーです。コンテンツ作成基準、AI支援の透明化、著作権・引用ポリシー、訂正方針、YMYLへの対応方針について説明します。";
const canonicalURL = "https://shindan-navi.jp/editorial-policy/";
---

<!DOCTYPE html>
<html lang="ja">
<head>
