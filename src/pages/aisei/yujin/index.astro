---
/**
 * /aisei/yujin/ - 友達相性ページ（友人軸統合プロファイル接続版）
 * 第3巡AIO/LLMO強化: TldrBlock + ScienceNote + FAQ + mentions JSON-LD 追加
 *
 * 友人軸: 友達相性タイプ + 対人的知能 + DiSC の組み合わせを統合表示
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import IntegratedProfileViewer from '../../../components/IntegratedProfileViewer';
import TldrBlock from '../../../components/TldrBlock.astro';
import ScienceNote from '../../../components/ScienceNote.astro';

const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/aisei/yujin/`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': pageUrl,
    url: pageUrl,
    name: '友人関係の特性 | 統合プロファイル - 診断ナビ',
    description: '友達相性タイプ・対人的知能・DiSCを統合した友人軸プロファイル。社交性・共感力・グループでの立ち位置の傾向を確認できます。',
    dateModified: '2026-05-21',
    isPartOf: { '@type': 'WebSite', '@id': `${siteUrl}/#website`, url: siteUrl },
    mentions: [
      { '@type': 'Thing', name: 'DiSC理論', sameAs: 'https://www.discprofile.com/' },
      { '@type': 'Thing', name: '多重知能（対人的知能）', sameAs: 'https://www.pz.harvard.edu/projects/multiple-intelligences' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: '相性診断', item: `${siteUrl}/aisei/` },
      { '@type': 'ListItem', position: 3, name: '友達相性', item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title="友人関係の特性 | 統合プロファイル - 診断ナビ"
  description="友達相性タイプ・対人的知能（Gardner理論）・DiSCを統合した友人軸プロファイル。社交性・共感力・グループでの立ち位置の傾向を確認できます。"
  canonical={pageUrl}
  jsonLd={jsonLd}
  noindex={true}
  breadcrumbs={[
    { name: '相性診断', url: '/aisei/' },
    { name: '友達相性', url: '/aisei/yujin/' },
  ]}
  lastUpdated="2026-05-21"
>
  <!-- ヘッダー -->
  <section class="axis-header axis-header--friend">
    <span class="axis-sparkle axis-sparkle-1" aria-hidden="true">✦</span>
    <span class="axis-sparkle axis-sparkle-2" aria-hidden="true">✧</span>
    <span class="axis-sparkle axis-sparkle-3" aria-hidden="true">✦</span>
    <Container>
      <div class="axis-header-inner">
        <div class="axis-icon" aria-hidden="true">👥</div>
        <div>
          <h1 class="axis-title">友人関係での特性</h1>
          <p class="axis-lead">
            8診断を統合した、あなたの友人軸プロファイルです。<br>
            社交性・共感力・グループでの立ち位置を確認できます。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- TldrBlock -->
  <Container>
    <TldrBlock
      title="友人軸プロファイルとは"
      points={[
        "友達相性タイプ（6タイプ）・対人的知能（Gardner理論）・DiSC（4スタイル）の3診断を統合した友人軸の特性表示",
        "社交性・共感力・グループでの立ち位置・友情の維持スタイルの傾向を参考情報として確認できる",
        "Gardner理論では「対人的知能」が高い人は他者の感情・意図・動機を読み取る能力に優れるとされる"
      ]}
      updatedAt="2026-05-21"
      sourceLabel="Harvard University Project Zero"
      sourceUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
    />
  </Container>

  <!-- 統合プロファイル（友人軸） -->
  <section class="axis-main">
    <Container>
      <IntegratedProfileViewer client:load axis="friend" singleAxisMode={true} />
    </Container>
  </section>

  <!-- ScienceNote -->
  <Container>
    <ScienceNote
      basisText="対人的知能: Howard Gardner「Frames of Mind」（1983年・Harvard大）の8知能の1つ。他者の感情・意図・動機を読み取り、効果的に対人関係を築く能力を指す。DiSC: William Moulton Marston（1928年）の行動スタイル理論。"
      basisUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
      basisLabel="Harvard University Project Zero"
      notMedical={true}
      updatedAt="2026-05-21"
    />
  </Container>

  <!-- 関連診断 -->
  <section class="axis-related">
    <Container>
      <h2 class="axis-section-title">
        <span aria-hidden="true">🔗</span>
        友人軸に関わる診断
      </h2>
      <div class="axis-diag-grid">
        <a href="/diagnosis/friend-compat/" class="axis-diag-card">
          <span aria-hidden="true">👥</span>
          <div>
            <strong>友達相性タイプ診断</strong>
            <span>ムードメーカー・傾聴型など6タイプ</span>
          </div>
        </a>
        <a href="/diagnosis/multi-int/" class="axis-diag-card">
          <span aria-hidden="true">🎓</span>
          <div>
            <strong>多重知能診断</strong>
            <span>対人的知能タイプの友人関係傾向</span>
          </div>
        </a>
        <a href="/diagnosis/disc/" class="axis-diag-card">
          <span aria-hidden="true">📊</span>
          <div>
            <strong>DiSC診断</strong>
            <span>友人関係での行動スタイルパターン</span>
          </div>
        </a>
        <a href="/profile/" class="axis-diag-card">
          <span aria-hidden="true">🎯</span>
          <div>
            <strong>統合プロファイル</strong>
            <span>8診断統合で全シーン軸を確認</span>
          </div>
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .axis-header {
    padding-block: var(--sn-space-10, 2.5rem) var(--sn-space-8, 2rem);
    border-bottom: 1px solid var(--line, #ece9f5);
    position: relative;
    overflow: hidden;
  }
  .axis-header--friend {
    background: linear-gradient(135deg, #f0fbf4 0%, #c8f0d8 60%, #e4f9ec 100%);
    position: relative;
    overflow: hidden;
  }
  .axis-header-inner { display: flex; align-items: flex-start; gap: var(--sn-space-4, 1rem); }
  .axis-icon { font-size: 2.5rem; flex-shrink: 0; line-height: 1; }
  .axis-title { font-family: var(--sn-font-rounded, sans-serif); font-size: clamp(1.25rem, 4vw, 1.75rem); font-weight: 900; color: var(--sn-text, #111827); margin: 0 0 var(--sn-space-2, 0.5rem); }
  .axis-lead { font-size: var(--sn-text-sm, 0.875rem); color: var(--sn-text-soft, #6b7280); line-height: 1.7; margin: 0; }
  .axis-main { padding-block: var(--sn-space-8, 2rem); }
  .axis-related { padding-block: var(--sn-space-8, 2rem); background: var(--sn-bg-soft, #f9fafb); border-top: 1px solid var(--sn-border, #e5e7eb); }
  .axis-section-title { display: flex; align-items: center; gap: var(--sn-space-2, 0.5rem); font-family: var(--sn-font-rounded, sans-serif); font-size: var(--sn-text-lg, 1.125rem); font-weight: 900; color: var(--sn-text, #111827); margin: 0 0 var(--sn-space-4, 1rem); }
  .axis-diag-grid { display: flex; flex-direction: column; gap: var(--sn-space-2, 0.5rem); }
  .axis-diag-card { display: flex; align-items: center; gap: var(--sn-space-3, 0.75rem); padding: var(--sn-space-4, 1rem); background: var(--sn-bg-white, #fff); border-radius: var(--sn-radius-md, 12px); border: 1px solid var(--sn-border, #e5e7eb); text-decoration: none; transition: border-color 0.15s ease; }
  .axis-diag-card:hover { border-color: var(--sn-scene-friend, #10b981); }
  .axis-diag-card > span:first-child { font-size: 1.5rem; flex-shrink: 0; }
  .axis-diag-card strong { display: block; font-size: var(--sn-text-sm, 0.875rem); font-weight: 700; color: var(--sn-text, #111827); }
  .axis-diag-card span:last-child { font-size: var(--sn-text-xs, 0.75rem); color: var(--sn-muted, #9ca3af); }

  /* axis スパークル */
  .axis-sparkle {
    position: absolute;
    pointer-events: none;
    color: var(--s-friend, #7ec79b);
    font-style: normal;
    user-select: none;
    opacity: 0;
    animation: axis-sparkle 3.5s ease-in-out infinite;
  }
  .axis-sparkle-1 { top: 12%; right: 8%;  font-size: 1rem;   animation-delay: 0s;    animation-duration: 4s; }
  .axis-sparkle-2 { top: 60%; right: 4%;  font-size: 0.7rem; animation-delay: 1.2s;  animation-duration: 3.5s; }
  .axis-sparkle-3 { bottom: 20%; left: 6%; font-size: 0.8rem; animation-delay: 2s;   animation-duration: 4.2s; }
  @keyframes axis-sparkle {
    0%, 100% { opacity: 0;    transform: scale(1) rotate(0deg); }
    40%       { opacity: 0.55; transform: scale(1.2) rotate(18deg); }
    60%       { opacity: 0.7;  transform: scale(1.1) rotate(12deg); }
  }
  .axis-header::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 80% 20%, rgba(255,255,255,.35), transparent 60%),
      radial-gradient(40% 30% at 10% 80%, rgba(255,255,255,.25), transparent 50%);
    pointer-events: none;
  }
</style>
