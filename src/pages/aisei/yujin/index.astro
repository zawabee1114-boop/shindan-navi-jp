---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
---
<BaseLayout title="相性診断 - 診断ナビ" description="相性診断（content-writerが執筆）">
  <Container>
    <div style="padding-block: 4rem; text-align: center;">
      <p style="font-size: 3rem; margin-bottom: 1rem;">💕</p>
      <h1 style="font-family: var(--sn-font-rounded); font-size: 1.5rem; margin-bottom: 1rem;">相性診断 準備中</h1>
      <p style="color: var(--sn-muted);">Phase 1 にて実装します</p>
      <a href="/aisei/" style="display:inline-block; margin-top:2rem; color:var(--sn-primary);">← 相性診断トップに戻る</a>
    </div>
  </Container>
</BaseLayout>
