---
/**
 * /aisei/shokuba/ - 職場相性ハブページ（仕事軸統合プロファイル接続版）
 * Phase 1: 統合プロファイルの仕事軸を表示
 *
 * 仕事軸: DiSC + 多重知能 + 完璧主義 の組み合わせを統合表示
 * YMYL回避: 採用・昇格・雇用判断への使用を推奨しない旨を明記
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import IntegratedProfileViewer from '../../../components/IntegratedProfileViewer';

const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/aisei/shokuba/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '相性診断', item: `${siteUrl}/aisei/` },
    { '@type': 'ListItem', position: 3, name: '職場相性', item: pageUrl },
  ],
};
---

<BaseLayout
  title="職場・仕事の特性 | 統合プロファイル - 診断ナビ"
  description="8診断を統合した仕事軸のプロファイル。リーダーシップ・チームワーク・実行力など、職場での特性と傾向を確認できます。"
  canonical={pageUrl}
  jsonLd={jsonLd}
  noindex={true}
  breadcrumbs={[
    { name: '相性診断', url: '/aisei/' },
    { name: '職場相性', url: '/aisei/shokuba/' },
  ]}
>
  <!-- ヘッダー -->
  <section class="axis-header axis-header--work">
    <Container>
      <div class="axis-header-inner">
        <div class="axis-icon" aria-hidden="true">💼</div>
        <div>
          <h1 class="axis-title">仕事・職場での特性</h1>
          <p class="axis-lead">
            8診断を統合した、あなたの仕事軸プロファイルです。<br>
            採用・評価・雇用判断の目的には使用しないでください。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- 統合プロファイル（仕事軸） -->
  <section class="axis-main">
    <Container>
      <IntegratedProfileViewer client:load axis="work" singleAxisMode={true} />
    </Container>
  </section>

  <!-- 関連診断 -->
  <section class="axis-related">
    <Container>
      <h2 class="axis-section-title">
        <span aria-hidden="true">🔗</span>
        仕事軸に関わる診断
      </h2>
      <div class="axis-diag-grid">
        <a href="/diagnosis/disc/" class="axis-diag-card">
          <span aria-hidden="true">📊</span>
          <div>
            <strong>DiSC行動スタイル診断</strong>
            <span>主導・感化・安定・慎重の4タイプ</span>
          </div>
        </a>
        <a href="/diagnosis/multi-int/" class="axis-diag-card">
          <span aria-hidden="true">🎓</span>
          <div>
            <strong>多重知能診断</strong>
            <span>8種の知能パターンから向く職種を知る</span>
          </div>
        </a>
        <a href="/diagnosis/perfectionism/" class="axis-diag-card">
          <span aria-hidden="true">⭐</span>
          <div>
            <strong>完璧主義タイプ診断</strong>
            <span>仕事への向き合い方・強みと注意点</span>
          </div>
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .axis-header {
    padding-block: var(--sn-space-8, 2rem);
    border-bottom: 1px solid var(--sn-border, #e5e7eb);
  }
  .axis-header--work {
    background: linear-gradient(135deg, #eff6ff 0%, var(--sn-bg-soft, #f9fafb) 100%);
  }
  .axis-header-inner {
    display: flex;
    align-items: flex-start;
    gap: var(--sn-space-4, 1rem);
  }
  .axis-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .axis-title {
    font-family: var(--sn-font-rounded, sans-serif);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    font-weight: 900;
    color: var(--sn-text, #111827);
    margin: 0 0 var(--sn-space-2, 0.5rem);
  }
  .axis-lead {
    font-size: var(--sn-text-sm, 0.875rem);
    color: var(--sn-text-soft, #6b7280);
    line-height: 1.7;
    margin: 0;
  }
  .axis-main {
    padding-block: var(--sn-space-8, 2rem);
  }
  .axis-related {
    padding-block: var(--sn-space-8, 2rem);
    background: var(--sn-bg-soft, #f9fafb);
    border-top: 1px solid var(--sn-border, #e5e7eb);
  }
  .axis-section-title {
    display: flex;
    align-items: center;
    gap: var(--sn-space-2, 0.5rem);
    font-family: var(--sn-font-rounded, sans-serif);
    font-size: var(--sn-text-lg, 1.125rem);
    font-weight: 900;
    color: var(--sn-text, #111827);
    margin: 0 0 var(--sn-space-4, 1rem);
  }
  .axis-diag-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sn-space-2, 0.5rem);
  }
  .axis-diag-card {
    display: flex;
    align-items: center;
    gap: var(--sn-space-3, 0.75rem);
    padding: var(--sn-space-4, 1rem);
    background: var(--sn-bg-white, #fff);
    border-radius: var(--sn-radius-md, 12px);
    border: 1px solid var(--sn-border, #e5e7eb);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .axis-diag-card:hover {
    border-color: var(--sn-scene-work, #3b82f6);
    text-decoration: none;
  }
  .axis-diag-card > span:first-child { font-size: 1.5rem; flex-shrink: 0; }
  .axis-diag-card strong {
    display: block;
    font-size: var(--sn-text-sm, 0.875rem);
    font-weight: 700;
    color: var(--sn-text, #111827);
  }
  .axis-diag-card span:last-child {
    font-size: var(--sn-text-xs, 0.75rem);
    color: var(--sn-muted, #9ca3af);
  }
</style>
