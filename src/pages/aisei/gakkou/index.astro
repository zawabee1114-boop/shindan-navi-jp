      <p class="gk-lead">
        学校軸を最大限に活用するには、以下のフローで順に読み進めることをお勧めします。
        各ページは独立して読むこともできます。
      </p>
      <ol class="gk-flow-steps">
        {diagnosisFlow.map((step) => (
          <li class="gk-flow-step" style={`--step-color: ${step.color}`}>
            <div class="gk-flow-num" aria-hidden="true">{step.step}</div>
            <div class="gk-flow-body">
              <div class="gk-flow-icon" aria-hidden="true">{step.icon}</div>
              <div>
                <h3 class="gk-flow-title">{step.title}</h3>
                <p class="gk-flow-desc">{step.desc}</p>
