                <span class="gk-sub-target">対象: {page.target}</span>
              </div>
            </div>
            <p class="gk-sub-desc">{page.desc}</p>
            <span class="gk-sub-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    {/* ========== 3視点の整理 ========== */}
    <section class="gk-section" aria-labelledby="gk-perspectives-h2">
      <h2 id="gk-perspectives-h2" class="gk-h2">3つの視点からの活用ガイド</h2>
      <p class="gk-lead">
        学校軸は「学生」「保護者」「教員」の3視点で活用できます。
        あなたの立場に合った使い方のガイドです。
      </p>
      <div class="gk-perspectives-grid">
        {perspectives.map((p) => (
          <div class="gk-perspective" style={`--p-color: ${p.color}`}>
            <div class="gk-perspective-header">
              <span class="gk-perspective-icon" aria-hidden="true">{p.icon}</span>
              <h3 class="gk-perspective-title">{p.title}</h3>
            </div>
            <ul class="gk-perspective-list">
              {p.points.map((point) => (
                <li class="gk-perspective-item">{point}</li>
              ))}
            </ul>
            <a href={p.startPage.href} class="gk-perspective-cta">
              {p.startPage.label} →
            </a>
          </div>
        ))}
      </div>
    </section>

    {/* ========== ScienceNote ========== */}
    <ScienceNote
      basisText="多重知能理論: Howard Gardner（1983）「Frames of Mind」（Basic Books）。VARKモデル: Fleming, N.D.（1995）（vark-learn.com参照）。いずれも自己理解・学習参考ツールとして活用し、医学的評価・能力の断定には使用しない。"
      basisUrl="https://www.pz.harvard.edu/projects/multiple-intelligences"
      basisLabel="Harvard Project Zero 公式（2026-05-21確認）"
      notMedical={true}
      updatedAt={UPDATED_AT}
      additionalNote="本ページの全情報は傾向の参考情報です。学習障害・発達障害等の医学的評価、育て方・進路の断定には使用できません。"
    />

    {/* ========== 推奨フロー ========== */}
