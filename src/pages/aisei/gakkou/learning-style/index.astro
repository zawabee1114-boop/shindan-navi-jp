---
/**
 * /aisei/gakkou/learning-style/ - 学習スタイル診断
 * ターゲットKW: 学習スタイル診断（VOL210/SD15・穴場）
 * 理論: VARK（Fleming 1995）+ 多重知能（Gardner 1983）融合
 * 確認日: 2026-05-21
 *
 * 絶対NG: 学習障害・発達障害判定言及 / YMYL違反
 * 注意: Pashler 2008 批判論文を科学的位置付けに明記
 */
import BaseLayout from '../../../../layouts/BaseLayout.astro';
