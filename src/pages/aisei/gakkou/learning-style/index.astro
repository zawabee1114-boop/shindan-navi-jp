// JSON-LD: FAQPage
const faqs = [
  {
    question: '学習スタイル診断とは何ですか？',
    answer:
      '学習スタイル診断とは、どのような感覚チャンネル（視覚・聴覚・読み書き・運動感覚など）を通じて最も効率よく学べるかを把握するためのツールです。Neil Fleming（1995）が提唱したVARKモデルを参考に設計されています（出典: https://vark-learn.com/ 2026-05-21確認）。自分に合った勉強法を見つける参考として活用できます。',
  },
  {
    question: 'VARKモデルとは何ですか？',
    answer:
      'VARKモデルとは、学習者の好む情報インプット形式を Visual（視覚）・Auditory（聴覚）・Reading/Writing（読み書き）・Kinesthetic（運動感覚）の4モードで分類するフレームワークです。Fleming, N.D.（1995）が提唱し、公式サイト vark-learn.com で無料診断が公開されています。ただし学習スタイル固定論には批判もあり（Pashler et al., 2008）、「傾向の参考」として活用することが推奨されています。',
  },
  {
    question: '学習スタイル理論には科学的批判があると聞きましたが？',
    answer:
      '正しい指摘です。Pashler H, et al.（2008）「Learning Styles: Concepts and Evidence」（Psychological Science in the Public Interest）は、「学習スタイルに合わせた指導で成績が向上するという証拠は不十分」と指摘しています。本診断はあくまで「自分が学びやすい方法の傾向を探る参考ツール」であり、固定的な能力分類ではありません。',
  },
  {
    question: 'VARKと多重知能の違いは何ですか？',
    answer:
      'VARKは「どのモード（感覚）で情報を受け取るか」という学習インプットの好みを分類します。一方、多重知能（Gardner 1983）は「どの知能領域が得意か」という才能の方向性を測定します。本診断はこの2つを融合し、8タイプで学習スタイルを整理しています。多重知能テストは /diagnosis/multi-int/ で受けられます。',
  },
  {
    question: '診断結果は何歳から参考にできますか？',
    answer:
      '中学生以上を想定しています。小学生のお子さんについては保護者の方が「子どもの様子を観察しながら回答する」使い方もできます。ただし本診断は医学的・教育心理学的な評価ではなく、「日常の学習で何が使いやすいか」を探る参考ツールです。',
  },
  {
    question: '視覚学習型に向いている具体的な教材はありますか？',
    answer:
      '視覚学習型に向いている教材の例としては、マインドマップアプリ（MindMeister・Xmindなど）・図解教科書・インフォグラフィック付きの参考書・YouTube教育チャンネルの図解動画などが挙げられます。ノートは色分けとイラストを積極的に使うと定着率が高まる傾向があります。',
  },
  {
    question: '聴覚学習型の人はどんな勉強環境が向いていますか？',
    answer:
      '聴覚学習型の人には、音声教材（ポッドキャスト・録音した自分の声）・グループ討論・音読学習が効果的です。適度な環境音（カフェのBGMレベル）がある環境の方が集中できる場合があります。完全な無音より適度な雑音が生産性を高めるという研究も存在します（Mehta R, et al., 2012 参照）。',
  },
  {
    question: '運動感覚学習型の人は座学が向いていないのですか？',
    answer:
      'そうとは限りません。運動感覚学習型の人は「長時間の座学のみ」では集中が続きにくい傾向がありますが、手を動かす（ノート・ドローイング・タイピング）・立ちながら学習するなどの工夫で座学でも効果的に学べます。全ての学習環境を捨てる必要はなく、体を動かせる工夫を取り入れることが大切です。',
  },
  {
    question: 'マルチモーダル型とはどういうタイプですか？',
    answer:
      'マルチモーダル型は複数の学習モードをバランスよく使えるタイプです。VARKの公式サイトでも「多くの人はマルチモーダルに分類される」と記載されています（https://vark-learn.com/ 2026-05-21確認）。特定のスタイルに縛られないため、状況に応じて方法を変える柔軟性が強みです。',
  },
  {
    question: '診断結果を学校の先生に伝えても良いですか？',
    answer:
      'はい、参考情報として共有することは有用です。ただし「この診断通りに教えてください」と要求するのではなく、「私はこういった方法で理解が深まりやすいです」という傾向の情報として伝えることをお勧めします。学習スタイルの固定論には批判もあるため（Pashler 2008）、柔軟に複数の方法を試すことも重要です。',
  },
  {
    question: '学習スタイルは変わりますか？',
    answer:
      'はい、経験・年齢・環境によって変化します。多重知能理論（Gardner 1983）でも「知能は経験・学習で発達する」と述べています。半年から1年に1回診断し直すことで、自分の学習スタイルの変化を追うことができます。固定的に「自分はこのタイプだから」と決めつけず、複数の方法を試し続けることが重要です。',
  },
  {
    question: 'この診断は学習障害の判定に使えますか？',
    answer:
      'できません。本診断は学習スタイルの傾向を自己理解するための参考ツールです。学習障害（LD）・注意欠如多動症（ADHD）・発達障害等の医学的判定は専門機関（医師・臨床心理士）にお願いします。学習に著しい困難を感じている場合は、学校の支援センターや専門医への相談をお勧めします。',
  },
];

const jsonLdFAQ = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ question, answer }) => ({
    '@type': 'Question',
    name: question,
    acceptedAnswer: { '@type': 'Answer', text: answer },
  })),
};

const jsonLdBreadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: '相性・学習ハブ', item: `${SITE_URL}/aisei/` },
    { '@type': 'ListItem', position: 3, name: '学校軸', item: `${SITE_URL}/aisei/gakkou/` },
    { '@type': 'ListItem', position: 4, name: '学習スタイル診断', item: PAGE_URL },
  ],
};

const jsonLdAll = [jsonLdWebApp, jsonLdQuiz, jsonLdHowTo, jsonLdArticle, jsonLdFAQ, jsonLdBreadcrumb];

const references = [
  {
    title: 'I\'m different; not dumb. Modes of presentation (VARK) in the tertiary classroom',
    author: 'Fleming, N.D.',
    year: 1995,
    journal: 'Annual Conference of the Higher Education and Research Development Society of Australasia (HERDSA)',
    url: 'https://vark-learn.com/',
  },
  {
    title: 'Frames of Mind: The Theory of Multiple Intelligences',
    author: 'Gardner, H.',
    year: 1983,
    publisher: 'Basic Books',
    url: 'https://www.basicbooks.com/titles/howard-gardner/frames-of-mind/9780465024339/',
  },
  {
    title: 'Teaching Students Through Their Individual Learning Styles',
    author: 'Dunn, R. & Dunn, K.',
    year: 1978,
    publisher: 'Reston Publishing',
  },
  {
    title: 'Learning Styles: Concepts and Evidence（学習スタイルの概念と証拠・批判論文）',
    author: 'Pashler, H., McDaniel, M., Rohrer, D., & Bjork, R.',
    year: 2008,
    journal: 'Psychological Science in the Public Interest',
    volume: '9(3), 105-119',
    url: 'https://doi.org/10.1111/j.1539-6053.2009.01038.x',
  },
  {
    title: 'Multiple Intelligences（Project Zero 公式）',
    author: 'Harvard Project Zero',
    year: 2024,
    url: 'https://www.pz.harvard.edu/projects/multiple-intelligences',
  },
];
---

<BaseLayout
  title="学習スタイル診断【無料・10問】VARKモデルで最適な勉強法を発見"
  description="視覚・聴覚・読み書き・運動感覚など8タイプの学習スタイルを10問で無料診断。VARKモデルと多重知能理論に基づき、あなたに合った効果的な勉強法を提案します。2026-05-21確認。"
  canonical={PAGE_URL}
  jsonLd={jsonLdAll}
  ogType="website"
  publishDate={UPDATED_AT}
  lastUpdated={UPDATED_AT}
  breadcrumbs={[
    { name: '相性・学習ハブ', url: '/aisei/' },
    { name: '学校軸', url: '/aisei/gakkou/' },
    { name: '学習スタイル診断', url: '/aisei/gakkou/learning-style/' },
  ]}
>
  {/* ========== ヒーロー ========== */}
  <section class="page-hero page-hero--navy" aria-labelledby="ls-h1">
    <Container>
      <div class="ls-hero-inner">
        <div class="ls-hero-badge">VARK × 多重知能 融合診断</div>
        <h1 id="ls-h1" class="ls-hero-h1">
          学習スタイル診断<br />
          <span class="ls-hero-meta">【無料・10問・登録不要】</span>
        </h1>
        <p class="ls-hero-catch">
          あなたはどのタイプで学ぶと最も効率的？<br />
          視覚・聴覚・読み書き・運動感覚など8タイプから<br />
          最適な勉強法を発見しよう
        </p>
        <div class="ls-hero-stats">
          <span class="ls-stat"><strong>10</strong>問</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat">約<strong>3</strong>分</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat"><strong>8</strong>タイプ</span>
          <span class="ls-stat-sep">・</span>
          <span class="ls-stat">完全無料</span>
        </div>
        <a href="#quiz-section" class="ls-cta-btn">
          診断を始める
          <span aria-hidden="true"> ↓</span>
        </a>
        <p class="ls-hero-sub">登録不要・所要時間3分・結果即表示</p>
      </div>
    </Container>
  </section>

  <Container>
    {/* ========== TL;DRブロック ========== */}
    <TldrBlock
      title="このページでわかること"
      points={[
        "学習スタイルとは「どの感覚を通じて情報を受け取るのが得意か」の傾向で、VARKモデル（Fleming 1995）では視覚・聴覚・読み書き・運動感覚の4軸で分類します（出典: vark-learn.com 2026-05-21確認）",
        "本診断はVARKと多重知能（Gardner 1983）を融合した8タイプ設計で、結果ページに即実践できる勉強法5つを提示します（登録不要・完全無料）",
        "学習スタイル固定論への科学的批判（Pashler 2008）を明記し、「参考傾向ツール」として正しく活用する方法を解説します"
      ]}
      updatedAt={UPDATED_AT}
      sourceLabel="VARK-Learn.com 公式（Fleming 1995）"
      sourceUrl="https://vark-learn.com/"
    />

    {/* ========== 診断フロー ========== */}
    <section id="quiz-section" class="ls-section" aria-labelledby="ls-quiz-h2">
      <h2 id="ls-quiz-h2" class="ls-h2">学習スタイル診断を始める（10問）</h2>
      <p class="ls-lead">
        各質問で「あなたに一番当てはまる選択肢」を1つ選んでください。正解・不正解はありません。直感で答えると最も正確な結果が出ます。
      </p>
      <div class="ls-quiz-wrapper">
        <LearningStyleQuiz client:load />
      </div>
    </section>

    {/* ========== ScienceNote ========== */}
    <ScienceNote
      basisText="VARKモデル: Fleming, N.D.（1995）が提唱した視覚（V）・聴覚（A）・読み書き（R）・運動感覚（K）の4モード学習スタイル分類。多重知能: Gardner, H.（1983）「Frames of Mind」（Basic Books）。なお、Pashler et al.（2008）はランダム化比較試験による強力な証拠が不十分と指摘しており、固定的な能力分類としては使用しない。"
      basisUrl="https://vark-learn.com/"
      basisLabel="VARK-Learn.com 公式（2026-05-21確認）"
      notMedical={true}
      updatedAt={UPDATED_AT}
      additionalNote="本診断は学習スタイルの傾向把握ツールです。学習障害・発達障害等の医学的評価には使用できません。"
    />

    {/* ========== VARKとは ========== */}
    <section class="ls-section" aria-labelledby="ls-what-h2">
      <h2 id="ls-what-h2" class="ls-h2">VARKモデルとは？4つの学習モード</h2>
      <p class="ls-lead">
        VARKモデルとは、Neil Fleming（1995）が提唱した学習スタイルの分類体系です。
        「どの感覚チャンネルを通じて情報を受け取るのが得意か」を4軸で整理します
        （<a href="https://vark-learn.com/" target="_blank" rel="noopener noreferrer">VARK-Learn.com 公式</a>、2026-05-21確認）。
      </p>

      <div class="ls-vark-grid">
        <div class="ls-vark-card ls-vark-v">
          <div class="ls-vark-icon" aria-hidden="true">👁️</div>
          <h3 class="ls-vark-name">Visual（視覚）</h3>
          <p class="ls-vark-desc">
            図・グラフ・フローチャート・動画で情報を整理する。テキストより視覚情報で理解が深まる。
          </p>
          <ul class="ls-vark-tips">
            <li>マインドマップ・図解ノートを作る</li>
            <li>カラーマーカーで色分けする</li>
          </ul>
        </div>
        <div class="ls-vark-card ls-vark-a">
          <div class="ls-vark-icon" aria-hidden="true">👂</div>
          <h3 class="ls-vark-name">Auditory（聴覚）</h3>
          <p class="ls-vark-desc">
            声に出す・聞く・話し合うことで定着する。音読・グループ討論・音声教材が効果的。
          </p>
          <ul class="ls-vark-tips">
            <li>声に出して読む（音読）</li>
            <li>ポッドキャスト・録音教材を活用</li>
          </ul>
        </div>
        <div class="ls-vark-card ls-vark-r">
          <div class="ls-vark-icon" aria-hidden="true">📝</div>
          <h3 class="ls-vark-name">Reading/Writing（読み書き）</h3>
          <p class="ls-vark-desc">
            読む・書くことで記憶が定着する。ノートを取り、要約を書き、参考書を読み込む。
          </p>
          <ul class="ls-vark-tips">
            <li>ノートを整理・清書する習慣をつける</li>
            <li>要約文を自分の言葉で書く</li>
          </ul>
        </div>
        <div class="ls-vark-card ls-vark-k">
          <div class="ls-vark-icon" aria-hidden="true">🤲</div>
          <h3 class="ls-vark-name">Kinesthetic（運動感覚）</h3>
          <p class="ls-vark-desc">
            実際に体験・体を動かすことで理解が深まる。実験・実習・ロールプレイが得意。
          </p>
          <ul class="ls-vark-tips">
            <li>実験・実習・フィールドワークを積極活用</li>
            <li>手を動かしながら（書き・作り）学ぶ</li>
          </ul>
        </div>
      </div>

      <div class="ls-note-box">
        <h3 class="ls-note-title">科学的批判の立場も参考に（Pashler 2008）</h3>
        <p class="ls-note-body">
          Pashler H, et al.（2008）「Learning Styles: Concepts and Evidence」
          （Psychological Science in the Public Interest, 9(3)）は、
          「学習スタイルに合わせた指導で成績が向上するという証拠が不十分」と指摘しています
          （<a href="https://doi.org/10.1111/j.1539-6053.2009.01038.x" target="_blank" rel="noopener noreferrer">論文DOI</a>、2026-05-21確認）。
          本診断は「絶対的な能力分類」ではなく、「日常学習で使いやすい方法の参考傾向」として活用することを推奨します。
        </p>
      </div>
    </section>

    {/* ========== 8タイプ一覧テーブル ========== */}
    <section class="ls-section" aria-labelledby="ls-types-h2">
