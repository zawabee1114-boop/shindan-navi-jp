---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const types = [
  { title: '恋愛相性診断', icon: '💕', href: '/aisei/renai/', desc: 'MBTI×血液型で恋愛相性をチェック' },
  { title: '友達相性診断', icon: '👥', href: '/aisei/yujin/', desc: '友人関係の相性を4モードで診断' },
  { title: '職場相性診断', icon: '💼', href: '/aisei/shokuba/', desc: 'DiSC×MBTIで職場の相性を確認' },
  { title: '夫婦相性診断', icon: '👫', href: '/aisei/kazoku/fufu/', desc: 'パートナーとの性格相性をチェック' },
  { title: '親子相性診断', icon: '👪', href: '/aisei/kazoku/oyako/', desc: '親子の性格タイプ別相互理解ガイド' },
];
---
<BaseLayout
  title="相性診断 - 友達・恋愛・夫婦・親子"
  description="友達相性診断・MBTI恋愛相性・夫婦相性・親子相性。4つのプライバシーモード対応。こっそりモードなら相手にバレず即チェック。全て無料。"
  breadcrumbs={[{ name: '相性診断', url: '/aisei/' }]}
>
  <section style="background: linear-gradient(135deg, var(--sn-secondary-bg) 0%, var(--sn-primary-bg) 100%); padding-block: 3rem 2rem; text-align:center;">
    <Container>
      <h1 style="font-family: var(--sn-font-rounded); font-size: 2rem; font-weight:900; margin-bottom:1rem;">💕 相性診断</h1>
      <p style="color:var(--sn-muted); max-width:480px; margin:0 auto;">友達・恋愛・職場・夫婦・親子。4つのプライバシーモード対応。こっそりモードなら相手にバレません。</p>
    </Container>
  </section>
  <section style="padding-block:3rem;">
    <Container>
      <div style="display:grid; grid-template-columns:1fr; gap:1rem;">
        {types.map((t) => (
          <a href={t.href} style="display:flex; align-items:center; gap:1rem; padding:1.25rem; background:var(--sn-bg-white); border-radius:var(--sn-radius-md); border:1px solid var(--sn-border); text-decoration:none; transition:transform 0.15s;">
            <span style="font-size:2rem;">{t.icon}</span>
            <div>
              <p style="font-weight:700; color:var(--sn-text);">{t.title}</p>
              <p style="font-size:0.875rem; color:var(--sn-muted);">{t.desc}</p>
            </div>
            <span style="margin-left:auto; color:var(--sn-primary); font-size:1.25rem;">→</span>
          </a>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
