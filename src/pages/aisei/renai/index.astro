---
/**
 * /aisei/renai/ - 恋愛相性ページ（恋愛軸統合プロファイル接続版）
 * Phase 1: 統合プロファイルの恋愛軸を表示
 *
 * 恋愛軸: 恋愛スタイル + MBTI + 血液型 の組み合わせを統合表示
 * YMYL回避: 医療・精神的アドバイスは行わない
 * LGBTQ+配慮: 「パートナー」表記を使用
 *
 * 確認日: 2026-05-21
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Container from '../../../components/Container.astro';
import IntegratedProfileViewer from '../../../components/IntegratedProfileViewer';

const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/aisei/renai/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: '相性診断', item: `${siteUrl}/aisei/` },
    { '@type': 'ListItem', position: 3, name: '恋愛相性', item: pageUrl },
  ],
};
---

<BaseLayout
  title="恋愛・パートナーシップの特性 | 統合プロファイル - 診断ナビ"
  description="8診断を統合した恋愛軸プロファイル。愛情表現スタイル・コミットメント・コミュニケーション傾向を確認できます。"
  canonical={pageUrl}
  jsonLd={jsonLd}
  noindex={true}
  breadcrumbs={[
    { name: '相性診断', url: '/aisei/' },
    { name: '恋愛相性', url: '/aisei/renai/' },
  ]}
>
  <!-- ヘッダー -->
  <section class="axis-header axis-header--love">
    <Container>
      <div class="axis-header-inner">
        <div class="axis-icon" aria-hidden="true">💕</div>
        <div>
          <h1 class="axis-title">恋愛・パートナーシップでの特性</h1>
          <p class="axis-lead">
            8診断を統合した、あなたの恋愛軸プロファイルです。<br>
            愛情表現スタイルや、パートナーとの関係傾向を確認できます。
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- 統合プロファイル（恋愛軸） -->
  <section class="axis-main">
    <Container>
      <IntegratedProfileViewer client:load axis="love" singleAxisMode={true} />
    </Container>
  </section>

  <!-- 関連診断 -->
  <section class="axis-related">
    <Container>
      <h2 class="axis-section-title">
        <span aria-hidden="true">🔗</span>
        恋愛軸に関わる診断
      </h2>
      <div class="axis-diag-grid">
        <a href="/diagnosis/love/" class="axis-diag-card">
          <span aria-hidden="true">💕</span>
          <div>
            <strong>恋愛スタイル診断</strong>
            <span>Eros・Ludus・Storge等6タイプの恋愛傾向</span>
          </div>
        </a>
        <a href="/diagnosis/multi-int/" class="axis-diag-card">
          <span aria-hidden="true">🎓</span>
          <div>
            <strong>多重知能診断</strong>
            <span>知能タイプ別の恋愛アプローチを知る</span>
          </div>
        </a>
        <a href="/diagnosis/blood/" class="axis-diag-card">
          <span aria-hidden="true">🩸</span>
          <div>
            <strong>血液型性格診断</strong>
            <span>血液型ごとの恋愛傾向（文化的参考値）</span>
          </div>
        </a>
      </div>
    </Container>
  </section>
</BaseLayout>

<style>
  .axis-header {
    padding-block: var(--sn-space-8, 2rem);
    border-bottom: 1px solid var(--sn-border, #e5e7eb);
  }
  .axis-header--love {
    background: linear-gradient(135deg, #fdf2f8 0%, var(--sn-bg-soft, #f9fafb) 100%);
  }
  .axis-header-inner {
    display: flex;
    align-items: flex-start;
    gap: var(--sn-space-4, 1rem);
  }
  .axis-icon {
    font-size: 2.5rem;
    flex-shrink: 0;
    line-height: 1;
  }
  .axis-title {
    font-family: var(--sn-font-rounded, sans-serif);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    font-weight: 900;
    color: var(--sn-text, #111827);
    margin: 0 0 var(--sn-space-2, 0.5rem);
  }
  .axis-lead {
    font-size: var(--sn-text-sm, 0.875rem);
    color: var(--sn-text-soft, #6b7280);
    line-height: 1.7;
    margin: 0;
  }
  .axis-main {
    padding-block: var(--sn-space-8, 2rem);
  }
  .axis-related {
    padding-block: var(--sn-space-8, 2rem);
    background: var(--sn-bg-soft, #f9fafb);
    border-top: 1px solid var(--sn-border, #e5e7eb);
  }
  .axis-section-title {
    display: flex;
    align-items: center;
    gap: var(--sn-space-2, 0.5rem);
    font-family: var(--sn-font-rounded, sans-serif);
    font-size: var(--sn-text-lg, 1.125rem);
    font-weight: 900;
    color: var(--sn-text, #111827);
    margin: 0 0 var(--sn-space-4, 1rem);
  }
  .axis-diag-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sn-space-2, 0.5rem);
  }
  .axis-diag-card {
    display: flex;
    align-items: center;
    gap: var(--sn-space-3, 0.75rem);
    padding: var(--sn-space-4, 1rem);
    background: var(--sn-bg-white, #fff);
    border-radius: var(--sn-radius-md, 12px);
    border: 1px solid var(--sn-border, #e5e7eb);
    text-decoration: none;
    transition: border-color 0.15s ease;
  }
  .axis-diag-card:hover {
    border-color: var(--sn-scene-love, #ec4899);
    text-decoration: none;
  }
  .axis-diag-card > span:first-child { font-size: 1.5rem; flex-shrink: 0; }
  .axis-diag-card strong {
    display: block;
    font-size: var(--sn-text-sm, 0.875rem);
    font-weight: 700;
    color: var(--sn-text, #111827);
  }
  .axis-diag-card span:last-child {
    font-size: var(--sn-text-xs, 0.75rem);
    color: var(--sn-muted, #9ca3af);
  }
</style>
