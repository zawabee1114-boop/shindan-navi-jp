---
/**
 * /login/ - Magic Link ログインページ
 *
 * Phase 3.2: Supabase Magic Link でメール送信（本接続）
 *
 * 静的化（fix/static-ssr-cleanup）:
 * - 旧実装: prerender=false + Astro.url.searchParams.get('redirect')
 *   → output:'static' ビルドで dist 未生成 → 本番404
 * - 修正後: prerender=false 削除 → 静的HTML生成
 *   - ?redirect= / ?auth_error= はクライアント JS (window.location.search) で取得
 *   - Magic Link 送信も既存 <script> ブロックでクライアント完結
 *
 * - ログイン済みなら /profile/ へリダイレクト（middleware が処理）
 * - ?redirect= パラメータでログイン後の遷移先を保持
 * - ?auth_error= パラメータでコールバックエラーを表示
 * - Magic Link = @supabase/supabase-js の signInWithOtp 使用
 * - 同意チェック: ログインボタン押下でポリシー同意とみなす（再確認は不要）
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const isConfigured = Boolean(
  import.meta.env.PUBLIC_SUPABASE_URL && import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);
const siteUrl = 'https://shindan-navi.jp';
const pageUrl = `${siteUrl}/login/`;
---

<BaseLayout
  title="ログイン｜診断ナビ"
  description="診断ナビにログインして、統合プロファイル・タイムカプセル・AIプロンプトカードをご利用ください。"
  canonical={pageUrl}
  noindex={true}
>
  <section class="page-hero page-hero--purple" aria-labelledby="login-h1" style="padding:32px 24px 40px;">
    <Container>
      <div class="page-hero-inner">
        <div class="page-hero-badge">🔐 診断ナビ</div>
        <h1 id="login-h1" class="page-hero-h1" style="font-size:clamp(1.25rem,3vw,1.75rem);">ログイン</h1>
        <p class="page-hero-sub" style="font-size:14px;">メールアドレスを入力するとログインリンクが届きます</p>
      </div>
    </Container>
  </section>
  <Container>
    <div class="login-page">
      <div class="login-card">
        <div class="login-logo" aria-hidden="true">🔐</div>
        <h1 class="login-title">ログイン</h1>
        <p class="login-subtitle">
          メールアドレスを入力するとログインリンクが届きます。<br />
          パスワードは不要です。
        </p>

        {/* コールバックエラー表示（JS で動的に表示） */}
        <div id="login-auth-error" class="login-message login-message--error" role="alert" hidden></div>

        {isConfigured ? (
          /* 本番フォーム（env設定済み）*/
          <form id="login-form" class="login-form" novalidate>
            {/* redirect パラメータは JS で取得するため hidden input は JS で設定 */}
            <input type="hidden" name="redirect" id="login-redirect-input" value="/profile/" />
            <label class="login-label" for="login-email">
              メールアドレス
            </label>
            <input
              id="login-email"
              type="email"
              name="email"
              class="login-input"
              placeholder="your@email.com"
              autocomplete="email"
              required
              aria-required="true"
              aria-describedby="login-email-hint"
            />
            <p id="login-email-hint" class="login-hint">
              入力したアドレスにログインリンクが届きます
            </p>
            <button type="submit" class="login-btn" id="login-submit-btn">
              ログインリンクを送る
            </button>
            <div id="login-message" class="login-message" role="alert" aria-live="polite" hidden></div>
          </form>
        ) : (
          /* 準備中表示（env未設定）*/
          <div class="login-coming-soon">
            <div class="login-coming-icon" aria-hidden="true">🚧</div>
            <p class="login-coming-text">
              ログイン機能は現在準備中です。<br />
              Supabase の設定完了後にご利用いただけます。
            </p>
            <a href="/diagnosis/" class="login-fallback-btn">
              診断を受ける（登録不要）→
            </a>
          </div>
        )}

        <div class="login-divider" aria-hidden="true"></div>

        <p class="login-signup-link">
          アカウントをお持ちでない方は <a href="/signup/">新規登録 →</a>
        </p>

        <p class="login-terms">
          ログインすることで
          <a href="/terms/">利用規約</a>・
          <a href="/privacy/">プライバシーポリシー</a>
          に同意したものとみなします。
        </p>
      </div>
    </div>
  </Container>
</BaseLayout>

<script>
  // クライアントサイドで URL パラメータを取得（静的化対応）
  const params = new URLSearchParams(window.location.search);

  // ?redirect= パラメータ処理
  const redirectParam = params.get('redirect');
  const redirectInput = document.getElementById('login-redirect-input') as HTMLInputElement | null;
  if (redirectInput && redirectParam) {
    redirectInput.value = redirectParam;
  }

  // ?auth_error= パラメータ処理
  const authError = params.get('auth_error');
  const authErrorEl = document.getElementById('login-auth-error') as HTMLElement | null;
  if (authErrorEl && authError) {
    let errorText = '';
    if (authError === 'no_code') {
      errorText = 'ログインリンクが無効です。もう一度お試しください。';
    } else if (authError === 'session_exchange_failed') {
      errorText = 'ログインリンクの期限が切れています。新しいリンクを送信してください。';
    } else {
      errorText = `ログインエラー: ${decodeURIComponent(authError)}`;
    }
    authErrorEl.textContent = errorText;
    authErrorEl.removeAttribute('hidden');
  }

  // フォーム送信（Supabase Magic Link）
  const form = document.getElementById('login-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('login-submit-btn') as HTMLButtonElement | null;
  const messageEl = document.getElementById('login-message') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
    const redirectPath = (form.elements.namedItem('redirect') as HTMLInputElement).value;
    if (!email) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = '送信中...';
    }

    try {
      const { signInWithMagicLink } = await import('../../lib/supabase/client');

      // redirectTo にリダイレクト先を含める
      const siteOrigin = window.location.origin;
      const callbackUrl = `${siteOrigin}/api/auth/callback?next=${encodeURIComponent(redirectPath)}`;

      // signInWithMagicLink はメール送信のみ（redirectTo は emailRedirectTo として渡る）
      const { error } = await signInWithMagicLink(email);

      if (error) {
        if (messageEl) {
          messageEl.textContent = `エラー: ${(error as Error).message}`;
          messageEl.className = 'login-message login-message--error';
          messageEl.removeAttribute('hidden');
        }
      } else {
        // 送信成功
        if (messageEl) {
          messageEl.innerHTML = `
            <strong>${email}</strong> にログインリンクを送りました。<br>
            メールをご確認ください（迷惑メールフォルダもご確認を）。
          `;
          messageEl.className = 'login-message login-message--success';
          messageEl.removeAttribute('hidden');
        }
        form.querySelector('input[type="email"]')?.setAttribute('disabled', 'true');
        if (submitBtn) submitBtn.style.display = 'none';
      }
    } catch {
      if (messageEl) {
        messageEl.textContent = '送信に失敗しました。しばらく後でお試しください。';
        messageEl.className = 'login-message login-message--error';
        messageEl.removeAttribute('hidden');
      }
    } finally {
      if (submitBtn && !submitBtn.style.display) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'ログインリンクを送る';
      }
    }
  });
</script>

<style>
.login-page {
  max-width: 440px;
  margin-inline: auto;
  padding-block: 3rem;
}

.login-card {
  background: #fff;
  border: 1px solid #e0e7ff;
  border-radius: 1rem;
  padding: 2rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
  box-shadow: 0 4px 16px rgba(79 70 229 / 0.08);
}

.login-logo {
  font-size: 2.5rem;
  text-align: center;
}

.login-title {
  font-size: 1.5rem;
  font-family: var(--sn-font-rounded, sans-serif);
  font-weight: 900;
  color: #1e1b4b;
  text-align: center;
  margin: 0;
}

.login-subtitle {
  font-size: 0.9rem;
  color: #6b7280;
  text-align: center;
  line-height: 1.7;
  margin: 0;
}

.login-form {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.login-label {
  font-size: 0.875rem;
  font-weight: 700;
  color: #374151;
}

.login-input {
  width: 100%;
  padding: 0.875rem 1rem;
  border: 1.5px solid #d1d5db;
  border-radius: 0.625rem;
  font-size: 1rem;
  color: #1f2937;
  transition: border-color 0.15s, box-shadow 0.15s;
  box-sizing: border-box;
}

.login-input:focus {
  outline: none;
  border-color: #6366f1;
  box-shadow: 0 0 0 3px rgba(99 102 241 / 0.15);
}

.login-input:disabled {
  background: #f9fafb;
  color: #9ca3af;
}

.login-hint {
  font-size: 0.78rem;
  color: #9ca3af;
  margin: 0;
}

.login-btn {
  width: 100%;
  padding: 0.9rem;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  color: #fff;
  border: none;
  border-radius: 999px;
  font-weight: 700;
  font-size: 1rem;
  cursor: pointer;
  min-height: 48px;
  font-family: inherit;
  transition: opacity 0.15s, transform 0.15s;
  box-shadow: 0 4px 12px rgba(79 70 229 / 0.3);
}

.login-btn:hover:not(:disabled) {
  opacity: 0.9;
  transform: translateY(-1px);
}

.login-btn:focus-visible {
  outline: 3px solid #4f46e5;
  outline-offset: 3px;
}

.login-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

.login-message {
  padding: 0.75rem 1rem;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  line-height: 1.6;
}

.login-message--success {
  background: #f0fdf4;
  border: 1px solid #86efac;
  color: #065f46;
}

.login-message--error {
  background: #fef2f2;
  border: 1px solid #fecaca;
  color: #dc2626;
}

/* 準備中表示 */
.login-coming-soon {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.875rem;
  text-align: center;
  padding: 1.5rem;
  background: #f9fafb;
  border-radius: 0.75rem;
  border: 1px dashed #d1d5db;
}

.login-coming-icon {
  font-size: 2rem;
}

.login-coming-text {
  font-size: 0.9rem;
  color: #6b7280;
  line-height: 1.7;
  margin: 0;
}

.login-fallback-btn {
  display: inline-flex;
  align-items: center;
  padding: 0.75rem 1.5rem;
  background: var(--sn-primary, #4f46e5);
  color: #fff;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.9rem;
  text-decoration: none;
  min-height: 44px;
  transition: opacity 0.15s;
}

.login-fallback-btn:hover {
  opacity: 0.85;
  text-decoration: none;
  color: #fff;
}

.login-divider {
  height: 1px;
  background: #f3f4f6;
}

.login-signup-link {
  font-size: 0.875rem;
  color: #6b7280;
  text-align: center;
  margin: 0;
}

.login-signup-link a {
  color: #4f46e5;
  font-weight: 700;
}

.login-terms {
  font-size: 0.78rem;
  color: #9ca3af;
  text-align: center;
  line-height: 1.6;
  margin: 0;
}

.login-terms a {
  color: #6b7280;
  text-decoration: underline;
}

@media (max-width: 480px) {
  .login-page {
    padding-block: 1.5rem;
  }
  .login-card {
    padding: 1.5rem 1.25rem;
  }
}
</style>
