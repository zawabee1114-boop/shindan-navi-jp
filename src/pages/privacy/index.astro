---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';

const pageUrl = 'https://shindan-navi.jp/privacy/';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': pageUrl,
    url: pageUrl,
    name: 'プライバシーポリシー | 診断ナビ',
    description: '診断ナビのプライバシーポリシー。LocalStorage利用・データ収集ゼロ宣言・Google Analytics・AdSense利用についての詳細説明。',
    datePublished: '2026-05-20',
    dateModified: '2026-05-21',
    isPartOf: {
      '@type': 'WebSite',
      '@id': 'https://shindan-navi.jp/#website',
      url: 'https://shindan-navi.jp',
    },
    publisher: {
      '@type': 'Organization',
      '@id': 'https://shindan-navi.jp/#organization',
      name: '診断ナビ編集部',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://shindan-navi.jp/' },
      { '@type': 'ListItem', position: 2, name: 'プライバシーポリシー', item: pageUrl },
    ],
  },
];
---

<BaseLayout
  title="プライバシーポリシー | 診断ナビ"
  description="診断ナビのプライバシーポリシー。LocalStorage利用・データ収集ゼロ宣言・Google Analytics・AdSense利用についての詳細説明。"
  canonical={pageUrl}
  jsonLd={jsonLd}
  breadcrumbs={[{ name: 'プライバシーポリシー', url: '/privacy/' }]}
  lastUpdated="2026-05-21"
>
  <Container size="content">
    <div class="privacy-wrap">

      <div class="privacy-hero">
        <h1>🔒 プライバシーポリシー</h1>
        <p>診断ナビにおける個人情報の取り扱いについて説明します</p>
        <div class="privacy-date">
          制定: 2026-05-20 ｜ 最終更新: <time datetime="2026-05-21">2026-05-21</time>
        </div>
      </div>

      <!-- TL;DR（AIO引用最適化）-->
      <div class="privacy-tldr" role="note">
        <p class="privacy-tldr__title">このページのポイント（要約）</p>
        <ul class="privacy-tldr__list">
          <li>アカウント未登録のユーザーの診断データはサーバーに送信されない（LocalStorageのみ）</li>
          <li>「こっそりモード」で入力した相手の情報は外部に送信されない</li>
          <li>Google Analytics（GA4）・Google AdSense を使用している（匿名の集計データのみ）</li>
          <li>データ削除要求は zawalab.info@gmail.com へ（速やかに対応）</li>
        </ul>
        <p class="privacy-tldr__meta"><time datetime="2026-05-21">2026-05-21</time> 時点の情報。</p>
      </div>

      <!-- 1. データ収集ゼロ宣言 -->
      <section class="privacy-section">
        <h2 class="privacy-h2">1. データ収集ゼロ宣言（未登録ユーザー向け）</h2>
        <div class="privacy-highlight">
          <p>
            <strong>診断ナビは、アカウント登録なしで診断を受けるユーザーの診断データを一切サーバーに送信・収集しません。</strong>
            入力した回答・診断結果はすべてお使いのブラウザの「LocalStorage」に保存されます。
            ブラウザデータを削除すると結果も消えます。これは意図した設計です。
          </p>
        </div>
        <div class="privacy-box">
          <div class="privacy-box__title">LocalStorage（ローカルストレージ）とは</div>
          <p class="privacy-box__text">
            LocalStorage とは、ブラウザ内部にデータを保存する仕組みです。
            クッキー（Cookie）と似ていますが、通常の通信ではサーバーに自動送信されない点が異なります。
            あなたの診断回答・結果は「あなたのブラウザ内にのみ存在」し、診断ナビのサーバーには届きません。
          </p>
        </div>
      </section>

      <!-- 2. 収集する情報 -->
      <section class="privacy-section">
        <h2 class="privacy-h2">2. 収集する情報（アカウント登録ユーザー）</h2>
        <p class="privacy-text">会員登録（無料）を行った場合、以下の情報を収集します。</p>
        <table class="privacy-table">
          <thead>
            <tr><th>収集情報</th><th>用途</th><th>保存場所</th></tr>
          </thead>
          <tbody>
            <tr><td>メールアドレス</td><td>ログイン・通知送信</td><td>Supabase（暗号化済み）</td></tr>
            <tr><td>診断回答・結果</td><td>統合プロファイル生成・変化記録</td><td>Supabase（暗号化済み）</td></tr>
            <tr><td>相性診断の記録</td><td>過去相性の確認</td><td>Supabase（暗号化済み）</td></tr>
            <tr><td>プラン情報（PASS/PRO）</td><td>機能制限の管理</td><td>Supabase</td></tr>
          </tbody>
        </table>
        <p class="privacy-text" style="margin-top: 1rem;">
          ※ パスワードは暗号化されサーバーには平文で保存されません（Supabase Auth 標準）。
        </p>
      </section>

      <!-- 3. こっそりモード -->
      <section class="privacy-section">
        <h2 class="privacy-h2">3.「こっそりモード」のプライバシー保護</h2>
        <p class="privacy-text">
          相性診断の「こっそりモード」で相手の情報を入力する際、<strong>相手への通知は一切行いません。</strong>
          入力したデータはあなたのブラウザ内でのみ処理されます。
          ただし、アカウント登録済みの場合、相性記録はあなたのアカウントに保存されます（相手には見えません）。
        </p>
      </section>

      <!-- 4. Google Analytics -->
      <section class="privacy-section">
        <h2 class="privacy-h2">4. Google Analytics（GA4）の利用</h2>
        <p class="privacy-text">
          当サービスはサイト改善・ユーザー体験向上のため、Google Analytics 4（GA4）を使用しています。
          GA4 は Cookie を使用し、匿名のアクセス統計（ページビュー・滞在時間・デバイス種別等）を収集します。
          個人を特定する情報は収集しません。
        </p>
        <p class="privacy-text">
          Google のデータ処理に関する詳細: <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Google プライバシーポリシー</a>
        </p>
        <p class="privacy-text">
          GA4 のデータ収集を停止するには: <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics オプトアウトアドオン</a> をご利用ください。
        </p>
      </section>

      <!-- 5. Google AdSense -->
      <section class="privacy-section">
        <h2 class="privacy-h2">5. Google AdSense（広告）の利用</h2>
        <p class="privacy-text">
          当サービスはGoogle AdSenseによる広告を掲載しています。AdSense は Cookie を使用して、あなたに関連性の高い広告を表示することがあります。
          ¥590/月 PRO 会員は広告が完全非表示になります。
        </p>
        <p class="privacy-text">
          広告のパーソナライズ設定変更: <a href="https://adssettings.google.com/" target="_blank" rel="noopener">Google 広告設定</a>
        </p>
      </section>

      <!-- 6. データの保存期間・削除 -->
      <section class="privacy-section">
        <h2 class="privacy-h2">6. データの保存期間と削除</h2>
        <table class="privacy-table">
          <thead>
            <tr><th>データ</th><th>無料会員</th><th>¥390 PASS</th><th>¥590/月 PRO</th></tr>
          </thead>
          <tbody>
            <tr><td>診断結果履歴</td><td>3ヶ月</td><td>1年</td><td>永久</td></tr>
            <tr><td>相性診断履歴</td><td>3ヶ月</td><td>1年</td><td>永久</td></tr>
            <tr><td>Big5変化グラフ</td><td>3ヶ月</td><td>6ヶ月</td><td>全期間</td></tr>
          </tbody>
        </table>
        <div class="privacy-box" style="margin-top: 1.5rem;">
          <div class="privacy-box__title">データ削除のご要望</div>
          <p class="privacy-box__text">
            アカウント削除・全データ削除は /me/ の設定画面から行えます。削除後は速やかにデータを消去します（復元不可）。
            ご不明な点は <a href="mailto:zawalab.info@gmail.com">zawalab.info@gmail.com</a> までご連絡ください。
          </p>
        </div>
      </section>

      <!-- 7. 第三者提供 -->
      <section class="privacy-section">
        <h2 class="privacy-h2">7. 第三者への情報提供</h2>
        <p class="privacy-text">
          診断ナビは、以下の場合を除き、収集した個人情報を第三者に提供・販売しません。
        </p>
        <ul class="privacy-list">
          <li>法令に基づく場合（裁判所・警察等からの要請）</li>
          <li>ユーザー自身の同意がある場合</li>
          <li>生命・身体・財産の保護のため緊急に必要な場合</li>
        </ul>
      </section>

      <!-- 8. Cookie -->
      <section class="privacy-section">
        <h2 class="privacy-h2">8. Cookie（クッキー）の利用</h2>
        <p class="privacy-text">
          当サービスでは以下の Cookie を使用しています。
        </p>
        <table class="privacy-table">
          <thead>
            <tr><th>Cookie の種類</th><th>用途</th><th>無効化方法</th></tr>
          </thead>
          <tbody>
            <tr><td>セッション Cookie（Supabase Auth）</td><td>ログイン状態の維持</td><td>ブラウザの Cookie 設定</td></tr>
            <tr><td>Google Analytics Cookie（_ga等）</td><td>匿名のアクセス統計</td><td>GA オプトアウトアドオン</td></tr>
            <tr><td>Google AdSense Cookie</td><td>広告のパーソナライズ</td><td>Google 広告設定</td></tr>
          </tbody>
        </table>
      </section>

      <!-- 9. お問い合わせ -->
      <section class="privacy-section">
        <h2 class="privacy-h2">9. プライバシーに関するお問い合わせ</h2>
        <div class="privacy-contact">
          <div class="privacy-contact__row">
            <span class="privacy-contact__label">運営者</span>
            <span>診断ナビ編集部</span>
          </div>
          <div class="privacy-contact__row">
            <span class="privacy-contact__label">メール</span>
            <span><a href="mailto:zawalab.info@gmail.com">zawalab.info@gmail.com</a></span>
          </div>
          <div class="privacy-contact__row">
            <span class="privacy-contact__label">フォーム</span>
            <span><a href="/contact/">お問い合わせページ</a></span>
          </div>
          <div class="privacy-contact__row">
            <span class="privacy-contact__label">対応時間</span>
            <span>3〜5営業日以内（土日祝を除く）</span>
          </div>
        </div>
      </section>

      <!-- 更新履歴 -->
      <section class="privacy-section">
        <div class="privacy-history">
          <div class="privacy-history__title">更新履歴</div>
          <div class="privacy-history__item">
            <time datetime="2026-05-21">2026-05-21</time>: LocalStorage説明・データ保存期間表を追加。第3巡AIO/LLMO強化版。
          </div>
          <div class="privacy-history__item">
            <time datetime="2026-05-20">2026-05-20</time>: 初版制定・公開
          </div>
        </div>
      </section>

      <!-- 関連リンク -->
      <div class="privacy-links">
        <a href="/about/">🏢 運営者情報</a>
        <a href="/editorial-policy/">📋 編集ポリシー</a>
        <a href="/terms/">📄 利用規約</a>
        <a href="/contact/">📬 お問い合わせ</a>
        <a href="/faq/">❓ よくある質問</a>
      </div>

    </div>
  </Container>
</BaseLayout>

<style>
.privacy-wrap { padding-block: 3rem; }
.privacy-hero { text-align: center; margin-bottom: 2rem; }
.privacy-hero h1 { font-family: var(--sn-font-rounded); font-size: var(--sn-text-3xl); font-weight: 700; margin-bottom: 0.5rem; }
.privacy-hero p { color: var(--sn-muted); font-size: var(--sn-text-sm); margin-bottom: 0.5rem; }
.privacy-date { font-size: var(--sn-text-xs); color: var(--sn-muted); }

.privacy-tldr { background: #f0f4ff; border-left: 4px solid var(--sn-primary); border-radius: 0 0.5rem 0.5rem 0; padding: 1.25rem 1.5rem; margin-bottom: 2.5rem; }
.privacy-tldr__title { font-weight: 700; font-size: var(--sn-text-sm); color: var(--sn-primary); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.75rem; }
.privacy-tldr__list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; padding-left: 1rem; }
.privacy-tldr__list li { font-size: 0.9rem; line-height: 1.6; color: #1f2937; }
.privacy-tldr__list li::before { content: "✓ "; color: var(--sn-primary); font-weight: 700; }
.privacy-tldr__meta { font-size: var(--sn-text-xs); color: var(--sn-muted); margin-top: 0.75rem; }

.privacy-section { margin-bottom: 2.5rem; }
.privacy-h2 { font-family: var(--sn-font-rounded); font-size: var(--sn-text-xl); font-weight: 700; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid var(--sn-primary-bg); }
.privacy-text { font-size: var(--sn-text-sm); color: var(--sn-text-soft); line-height: var(--sn-leading-relaxed); margin-bottom: 0.75rem; }
.privacy-text a { color: var(--sn-primary); }
.privacy-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; padding-left: 1rem; margin-bottom: 1rem; }
.privacy-list li { font-size: var(--sn-text-sm); color: var(--sn-text-soft); line-height: var(--sn-leading-relaxed); }
.privacy-list li::before { content: "・ "; color: var(--sn-primary); }

.privacy-highlight { background: #ecfdf5; border: 1px solid #a7f3d0; border-left: 4px solid #059669; border-radius: 0 0.5rem 0.5rem 0; padding: 1.25rem 1.5rem; margin-bottom: 1rem; }
.privacy-highlight p { font-size: var(--sn-text-sm); color: #065f46; line-height: var(--sn-leading-relaxed); }
.privacy-highlight strong { color: #047857; }

.privacy-box { background: var(--sn-primary-bg); border-radius: var(--sn-radius); padding: 1rem 1.25rem; margin-bottom: 1rem; }
.privacy-box__title { font-weight: 700; font-size: var(--sn-text-sm); margin-bottom: 0.5rem; color: var(--sn-primary); }
.privacy-box__text { font-size: var(--sn-text-sm); color: var(--sn-text-soft); line-height: var(--sn-leading-relaxed); }
.privacy-box__text a { color: var(--sn-primary); }

.privacy-table { width: 100%; border-collapse: collapse; font-size: var(--sn-text-sm); }
.privacy-table th { background: var(--sn-primary-bg); color: var(--sn-primary); font-weight: 700; padding: 0.6rem 0.75rem; text-align: left; border: 1px solid var(--sn-border); }
.privacy-table td { padding: 0.6rem 0.75rem; border: 1px solid var(--sn-border); color: var(--sn-text-soft); vertical-align: top; }
.privacy-table tr:nth-child(even) td { background: var(--sn-bg-soft); }

.privacy-contact { background: var(--sn-bg-white); border: 1px solid var(--sn-border); border-radius: var(--sn-radius); padding: 1.25rem 1.5rem; }
.privacy-contact__row { display: flex; gap: 1rem; padding: 0.5rem 0; border-bottom: 1px solid var(--sn-border-soft); font-size: var(--sn-text-sm); }
.privacy-contact__row:last-child { border-bottom: none; }
.privacy-contact__label { font-weight: 700; min-width: 5rem; flex-shrink: 0; }
.privacy-contact a { color: var(--sn-primary); }

.privacy-history { background: var(--sn-bg-soft); border-radius: var(--sn-radius); padding: 1rem 1.25rem; }
.privacy-history__title { font-weight: 700; font-size: var(--sn-text-sm); margin-bottom: 0.5rem; }
.privacy-history__item { font-size: var(--sn-text-xs); color: var(--sn-muted); margin-bottom: 0.25rem; }

.privacy-links { display: flex; flex-wrap: wrap; gap: 1rem; padding-top: 1rem; border-top: 1px solid var(--sn-border); margin-top: 2rem; }
.privacy-links a { color: var(--sn-primary); font-size: var(--sn-text-sm); text-decoration: none; }
.privacy-links a:hover { text-decoration: underline; }
</style>
