        "isPartOf": {
          "@type": "WebSite",
          "url": "https://shindan-navi.jp"
        }
      },
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "@id": "https://shindan-navi.jp/#organization",
        "name": "診断ナビ編集部",
        "url": "https://shindan-navi.jp",
        "email": "zawalab.info@gmail.com",
        "sameAs": ["https://keisan-navi.jp", "https://template-free.jp"],
        "description": "8診断統合自己理解プラットフォーム「診断ナビ」を運営する編集部"
      },
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "@id": "https://shindan-navi.jp/about/#editor",
        "name": "診断ナビ編集長",
