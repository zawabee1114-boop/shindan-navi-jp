---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
// 診断ナビ about ページ（E-E-A-T 4要素完全実装・第3巡AIO/LLMO最終強化）
// 2026-05-21 時点の情報
// 架空監修者・架空著者 絶対禁止
const title = "運営者情報・編集方針 | 診断ナビ";
const description = "診断ナビの運営者情報、編集体制、科学的根拠、プライバシー方針について説明します。8診断統合サービスの品質と信頼性の基盤をご確認ください。";
const canonicalURL = "https://shindan-navi.jp/about/";

const principles = [
  {
    num: "01",
    title: "占いではない",
    icon: "🔬",
    desc: "当サービスは性格心理学・行動経済学・多重知能理論（Howard Gardner）などの学術的知見をベースにしています。未来予測・運勢・霊的解釈は一切扱いません。あくまで「今のあなたの性格傾向」を分類・整理するツールです。",
    note: "Myers-Briggs Type Indicator（MBTI）・性格心理学（Big Five）・DiSC理論・Howard Gardnerの多重知能理論を参照しています。",
  },
  {
    num: "02",
    title: "YMYL（Your Money or Your Life）は扱わない",
    icon: "🛡️",
    desc: "メンタル疾患の診断・育児ストレス対処の医療的アドバイス・介護の医療判断・法的なアドバイスは一切提供しません。「診断結果」はあくまで性格タイプの分類であり、医師や専門家の判断の代替にはなりません。",
    note: "心身の不調を感じる場合は、必ず医療機関・専門家にご相談ください。",
  },
  {
    num: "03",
    title: "プライバシー優先",
    icon: "🔒",
    desc: "「こっそりモード」では、相手の情報を第三者に送信しません。相性チェックのためにあなたが入力した相手の情報は、あなたのブラウザ内でのみ処理されます。アカウント登録なしで診断を受けた場合、結果データは外部に送信されません。",
    note: "詳細はプライバシーポリシーをご覧ください。",
  },
];

const editorialTeam = [
  {
    role: "編集長（運営者）",
    desc: "ITエンジニア出身。10年以上のソフトウェア開発・Webサービス運営の実務経験を持ち、現在は複数の事業責任者として従事。学生時代から心理学・人間行動に強い関心を持ち、特に性格類型論が職場・恋愛・学習における行動予測にどう機能するかを実践的に研究してきた。「診断サービスは多数あるが、複数の視点を統合するサービスがない」という課題感から診断ナビを立ち上げ。自身もMBTI・性格心理学の診断を業務・採用・チームビルディングに活用している。",
  },
  {
    role: "専門ライター",
    desc: "心理学・行動科学の知見を持つ複数のライターが各診断コンテンツの執筆を担当。各診断の一次情報（Howard Gardner著作・Myers-Briggs理論文献・DiSC公式資料等）を参照しながらコンテンツを作成しています。",
  },
  {
    role: "AI支援（透明化）",
    desc: "一部のコンテンツ作成にAI（大規模言語モデル）を支援ツールとして使用しています。AI出力はそのまま使用せず、必ず編集長・ライターが一次情報と照合し、事実確認・品質チェックを行った上で公開しています。",
  },
];

const scientificBases = [
  {
    name: "性格心理学（Big Five / OCEAN）",
    desc: "現代心理学で最も広く採用されている性格モデル。開放性・誠実性・外向性・協調性・情緒安定性の5因子で性格を分類する。Costa & McCrae（1992）らによる研究が基盤。当サービスは8診断の結果を5因子スコアに内部換算することで、診断間の統合を実現しています。",
    ref: "American Psychological Association（APA）: https://www.apa.org/",
  },
  {
    name: "Howard Gardnerの多重知能理論（Multiple Intelligences）",
    desc: "1983年にHarvard Universityのガードナー教授が提唱。知能を8種類（言語的・論理数学的・空間的・音楽的・身体運動的・対人的・内省的・博物的）に分類するフレームワーク。参照元: Harvard University Project Zero（https://www.pz.harvard.edu/）",
    ref: "Harvard University Project Zero: https://www.pz.harvard.edu/projects/multiple-intelligences",
  },
  {
    name: "Myers-Briggs Type Indicator（MBTI）",
    desc: "Katharine Cook BriggsとIsabel Briggs Myersが発展させた性格類型論。Jung心理類型論をベースに16タイプに分類する。世界で最も広く使われている性格診断モデルのひとつ。参照元: The Myers & Briggs Foundation（https://www.myersbriggs.org/）",
    ref: "The Myers & Briggs Foundation: https://www.myersbriggs.org/",
  },
  {
    name: "DiSC理論",
    desc: "行動心理学者William Moulton Marstonが提唱（「Emotions of Normal People」1928年）。Dominance・Influence・Steadiness・Conscientiousnessの4特性で仕事・コミュニケーションスタイルを分類。参照元: DiSC Profile（https://www.discprofile.com/）",
    ref: "DiSC Profile: https://www.discprofile.com/",
  },
  {
    name: "J.A. Leeの恋愛類型（Love Styles）",
    desc: "社会学者John Alan Leeが1973年に発表した6つの恋愛スタイル（Eros・Ludus・Storge・Pragma・Mania・Agape）の分類。Hendrick & Hendrick（1986）がLove Attitudes Scaleを開発・信頼性検証。",
    ref: "Journal of Personality and Social Psychology, 50(2), 392-402",
  },
  {
    name: "行動経済学（Behavioral Economics）",
    desc: "Daniel Kahnemanらの研究（ノーベル経済学賞2002）をベースに、金銭感覚・意思決定パターンの傾向分析に活用。Klontz et al.（2011）「Money beliefs and financial behaviors」なども参照。",
    ref: "Journal of Financial Therapy 2(1), doi:10.4148/jft.v2i1.451",
  },
];

const trademarkNotes = [
  "Myers-Briggs Type Indicator® は The Myers & Briggs Foundation の登録商標です。当サービスは同 Foundation とは無関係の独自実装です。",
  "DiSC® は Wiley 社の登録商標です。当サービスは Wiley 社の公式アセスメントではありません。",
  "Gallup® の「ストレングスファインダー」は当サービスでは扱っていません。/strengths/ ページは「強み発見診断（多重知能派生）」として独自に提供しています。",
  "Big Five・OCEAN は特定企業の商標ではなく学術的な概念です。",
];

const sisterSites = [
  { name: "計算ナビ", url: "https://keisan-navi.jp", desc: "無料の計算ツール集" },
  { name: "テンプレート無料", url: "https://template-free.jp", desc: "ビジネス・日常テンプレート" },
];

const faqItems = [
  { q: "診断ナビはどんな組織が運営していますか？", a: "ITエンジニア出身の編集長と複数の専門ライターで構成する「診断ナビ編集部」が運営しています。2026年5月開設。10年以上のWebサービス運営経験を持つ編集長が監修・品質管理を担当しています。" },
  { q: "参照している学術論文・機関はどこですか？", a: "Howard Gardner（Harvard大・多重知能理論）、Myers & Briggs Foundation（MBTI）、DiSC公式（Wiley社）、American Psychological Association（APA・Big Five）、Hendrick & Hendrick（恋愛スタイル）、Klontz et al.（金銭感覚）などの研究・機関を参照しています。詳細はページ内「科学的根拠」セクションをご確認ください。" },
  { q: "監修者はいますか？", a: "編集長・専門ライターが一次情報と照合の上でコンテンツを作成しています。外部の大学教授・臨床心理士等による正式な監修体制は現在設けていません。各理論の公式機関・学術論文を一次参照源としてコンテンツの正確性を担保しています。" },
  { q: "誤情報を見つけた場合はどうすれば良いですか？", a: "zawalab.info@gmail.com または /contact/ からご報告ください。原則7営業日以内に確認・修正します。重大な誤りは即時対応します。ご報告は大変ありがたく、サービスの品質向上に役立てています。" },
];

const pageJsonLd = [
