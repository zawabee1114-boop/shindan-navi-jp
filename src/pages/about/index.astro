    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://shindan-navi.jp/about/",
    "url": "https://shindan-navi.jp/about/",
    "name": "運営者情報・編集方針 | 診断ナビ",
    "description": "診断ナビの運営者情報、編集体制、科学的根拠、プライバシー方針",
    "dateModified": "2026-05-21",
    "isPartOf": {
      "@type": "WebSite",
      "@id": "https://shindan-navi.jp/#website",
      "url": "https://shindan-navi.jp"
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": [".tldr-block", ".eeat-trust-summary", ".about-lead"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://shindan-navi.jp/#organization",
    "name": "診断ナビ編集部",
    "url": "https://shindan-navi.jp",
    "email": "zawalab.info@gmail.com",
    "foundingDate": "2026-05",
    "description": "8診断統合自己理解プラットフォーム「診断ナビ」を運営する編集部。性格心理学・行動科学の学術的知見に基づく診断コンテンツを提供する。",
    "sameAs": ["https://keisan-navi.jp", "https://template-free.jp"],
    "knowsAbout": [
      "性格心理学（Big Five）",
      "多重知能理論（Howard Gardner）",
      "Myers-Briggs Type Indicator",
      "DiSC理論",
      "恋愛スタイル理論（J.A.Lee）",
      "行動経済学（マネースクリプト）",
      "西洋占星術（文化的性格分類）",
      "血液型性格傾向（日本文化的モデル）"
    ],
    "memberOf": {
      "@type": "Organization",
      "name": "診断ナビ編集部"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://shindan-navi.jp/about/#editor",
