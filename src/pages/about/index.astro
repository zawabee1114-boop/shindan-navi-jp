---
// 診断ナビ about ページ（E-E-A-T強化・運営者情報）
// 2026-05-20 時点の情報・content-writer 執筆
// 架空監修者・架空著者 絶対禁止
const title = "運営者情報・編集方針 | 診断ナビ";
const description = "診断ナビの運営者情報、編集体制、科学的根拠、プライバシー方針について説明します。8診断統合サービスの品質と信頼性の基盤をご確認ください。";
const canonicalURL = "https://shindan-navi.jp/about/";

// 3つの原則
const principles = [
  {
    num: "01",
    title: "占いではない",
    icon: "🔬",
    desc: "当サービスは性格心理学・行動経済学・多重知能理論（Howard Gardner）などの学術的知見をベースにしています。未来予測・運勢・霊的解釈は一切扱いません。あくまで「今のあなたの性格傾向」を分類・整理するツールです。",
    note: "Myers-Briggs Type Indicator（MBTI）・Big Five（ビッグファイブ）・DiSC理論・Howard Gardnerの多重知能理論を参照しています。",
  },
  {
    num: "02",
    title: "YMYL（Your Money or Your Life）は扱わない",
    icon: "🛡️",
    desc: "メンタル疾患の診断・育児ストレス対処の医療的アドバイス・介護の医療判断・法的なアドバイスは一切提供しません。「診断結果」はあくまで性格タイプの分類であり、医師や専門家の判断の代替にはなりません。",
    note: "心身の不調を感じる場合は、必ず医療機関・専門家にご相談ください。",
  },
  {
    num: "03",
    title: "プライバシー優先",
    icon: "🔒",
    desc: "「こっそりモード」では、相手の情報を第三者に送信しません。相性チェックのためにあなたが入力した相手の情報は、あなたのブラウザ内でのみ処理されます。アカウント登録なしで診断を受けた場合、結果データは外部に送信されません。",
    note: "詳細はプライバシーポリシーをご覧ください。",
  },
];

// 編集体制
const editorialTeam = [
  {
    role: "編集長（運営者）",
    desc: "ITエンジニア出身。10年以上のソフトウェア開発・Webサービス運営の実務経験を持ち、現在は複数の事業責任者として従事。学生時代から心理学・人間行動に強い関心を持ち、特に性格類型論が職場・恋愛・学習における行動予測にどう機能するかを実践的に研究してきた。「診断サービスは多数あるが、複数の視点を統合するサービスがない」という課題感から診断ナビを立ち上げ。自身もMBTI・Big5診断を業務・採用・チームビルディングに活用している。",
  },
  {
    role: "専門ライター",
    desc: "心理学・行動科学の知見を持つ複数のライターが各診断コンテンツの执筆を担当。各診断の一次情報（Howard Gardner著作・Myers-Briggs理論文献・DiSC公式資料等）を参照しながらコンテンツを作成しています。",
  },
  {
    role: "AI支援（透明化）",
    desc: "一部のコンテンツ作成にAI（大規模言語モデル）を支援ツールとして使用しています。AI出力はそのまま使用せず、必ず編集長・ライターが一次情報と照合し、事実確認・品質チェックを行った上で公開しています。",
  },
];

// 姉妹サイト
const sisterSites = [
  { name: "計算ナビ", url: "https://keisan-navi.jp", desc: "無料の計算ツール集" },
  { name: "テンプレート無料", url: "https://template-free.jp", desc: "ビジネス・日常テンプレート" },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="診断ナビ" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=M+PLUS+Rounded+1c:wght@700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/src/styles/design-tokens.css" />

  <!-- 構造化データ: Person + Organization + AboutPage -->
  <script type="application/ld+json">
    {JSON.stringify([
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "@id": "https://shindan-navi.jp/about/",
