---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
  <link rel="canonical" href={canonicalURL} />

  <!-- hreflang（日本語単一言語サイト）-->
  <link rel="alternate" hreflang="ja" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- OGP -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content="https://shindan-navi.jp/ogp-default.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="診断ナビ - 8診断統合自己理解プラットフォーム" />
  <meta property="og:site_name" content="診断ナビ" />
  <meta property="og:locale" content="ja_JP" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@shindan_navi" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://shindan-navi.jp/ogp-default.png" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=M+PLUS+Rounded+1c:wght@700&display=swap"
    rel="stylesheet"
  />

  <!-- デザイントークン -->
  <link rel="stylesheet" href="/src/styles/design-tokens.css" />

  <!-- 構造化データ: Organization（@id連結の基盤・E-E-A-T強化）-->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": "https://shindan-navi.jp/#organization",
      "name": "診断ナビ編集部",
      "alternateName": "診断ナビ",
      "url": "https://shindan-navi.jp",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://shindan-navi.jp/#logo",
        "url": "https://shindan-navi.jp/favicon.svg",
        "width": 32,
        "height": 32
      },
      "foundingDate": "2026",
      "areaServed": { "@type": "Country", "name": "日本" },
      "sameAs": []
    })}
  </script>

  <!-- 構造化データ: WebSite（@id連結・SearchAction）-->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://shindan-navi.jp/#website",
      "name": "診断ナビ",
      "url": "https://shindan-navi.jp",
      "description": "8診断統合で、仕事・恋愛・友人・家族・学校の5シーンの行動指針を提供する自己理解プラットフォーム",
      "inLanguage": "ja-JP",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://shindan-navi.jp/search?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      },
      "publisher": {
        "@type": "Organization",
        "@id": "https://shindan-navi.jp/#organization"
      }
    })}
  </script>

  <!-- GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-S4WP0YRDWW"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-S4WP0YRDWW');
  </script>

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3827953973757487" crossorigin="anonymous"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--sn-font-family);
      background: var(--sn-bg);
      color: var(--sn-text);
      line-height: var(--sn-leading-base);
      font-size: var(--sn-text-base);
    }
    .container {
      max-width: var(--sn-max-w);
      margin: 0 auto;
      padding: 0 var(--sn-space-4);
    }
    /* ヘッダー */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--sn-border);
      height: var(--sn-header-h);
    }
    .site-header .inner {
      max-width: var(--sn-max-w);
      margin: 0 auto;
      padding: 0 var(--sn-space-4);
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--sn-font-rounded);
      font-size: var(--sn-text-xl);
      font-weight: 700;
      color: var(--sn-primary);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: var(--sn-space-2);
    }
    .logo-badge {
      font-size: var(--sn-text-xs);
      background: var(--sn-primary-bg);
      color: var(--sn-primary);
      padding: 2px 8px;
      border-radius: var(--sn-radius-pill);
      font-weight: 500;
    }
    .header-cta {
      display: inline-flex;
      align-items: center;
      gap: var(--sn-space-2);
      background: var(--sn-primary);
      color: #fff;
      font-size: var(--sn-text-sm);
      font-weight: 700;
      padding: var(--sn-space-2) var(--sn-space-4);
      border-radius: var(--sn-radius-pill);
      text-decoration: none;
      min-height: var(--sn-tap-min);
      transition: background var(--sn-dur-fast) var(--sn-ease);
    }
    .header-cta:hover { background: var(--sn-primary-dark); }

    /* ヒーローセクション */
    .hero {
      background: linear-gradient(135deg, #f0f4ff 0%, #fdf2f8 50%, #f5f3ff 100%);
      padding: var(--sn-space-16) 0 var(--sn-space-12);
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 50%, rgba(99,102,241,0.06) 0%, transparent 50%),
                  radial-gradient(circle at 70% 30%, rgba(236,72,153,0.06) 0%, transparent 50%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-block;
      background: var(--sn-primary-bg);
      color: var(--sn-primary);
      font-size: var(--sn-text-sm);
      font-weight: 700;
      padding: var(--sn-space-1) var(--sn-space-4);
      border-radius: var(--sn-radius-pill);
      margin-bottom: var(--sn-space-4);
      letter-spacing: 0.05em;
    }
    .hero-title {
      font-family: var(--sn-font-rounded);
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: var(--sn-text);
      line-height: 1.3;
      margin-bottom: var(--sn-space-3);
    }
    .hero-title span {
      background: linear-gradient(135deg, var(--sn-primary) 0%, var(--sn-secondary) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-sub {
      font-size: var(--sn-text-lg);
      color: var(--sn-muted);
      margin-bottom: var(--sn-space-6);
    }
    .hero-concept {
      max-width: 600px;
      margin: 0 auto var(--sn-space-8);
      font-size: var(--sn-text-base);
      color: var(--sn-text-soft);
      line-height: var(--sn-leading-relaxed);
    }
    .hero-cta-group {
      display: flex;
      gap: var(--sn-space-3);
      justify-content: center;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: var(--sn-space-2);
      background: var(--sn-primary);
      color: #fff;
      font-size: var(--sn-text-lg);
      font-weight: 700;
      padding: var(--sn-space-4) var(--sn-space-8);
      border-radius: var(--sn-radius-pill);
      text-decoration: none;
      min-height: var(--sn-tap-min);
      box-shadow: var(--sn-shadow-md);
      transition: all var(--sn-dur-base) var(--sn-ease);
    }
    .btn-primary:hover {
      background: var(--sn-primary-dark);
      box-shadow: var(--sn-shadow-lg);
      transform: translateY(-2px);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: var(--sn-space-2);
      background: #fff;
      color: var(--sn-primary);
      font-size: var(--sn-text-base);
      font-weight: 700;
      padding: var(--sn-space-3) var(--sn-space-6);
      border-radius: var(--sn-radius-pill);
      text-decoration: none;
      border: 2px solid var(--sn-primary);
      min-height: var(--sn-tap-min);
      transition: all var(--sn-dur-base) var(--sn-ease);
    }
    .btn-secondary:hover {
      background: var(--sn-primary-bg);
    }
    .hero-social-proof {
      margin-top: var(--sn-space-8);
      font-size: var(--sn-text-sm);
      color: var(--sn-muted);
    }

    /* セクション共通 */
    .section {
      padding: var(--sn-space-16) 0;
    }
    .section-alt {
      background: var(--sn-primary-bg);
    }
    .section-title {
      font-family: var(--sn-font-rounded);
      font-size: var(--sn-text-2xl);
      font-weight: 700;
      text-align: center;
      margin-bottom: var(--sn-space-2);
    }
    .section-sub {
      text-align: center;
      color: var(--sn-muted);
      margin-bottom: var(--sn-space-8);
    }

    /* 3つの理由 */
    .reasons-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--sn-space-6);
    }
    .reason-card {
      background: var(--sn-bg-white);
      border-radius: var(--sn-radius);
      padding: var(--sn-space-8);
      box-shadow: var(--sn-shadow-sm);
      text-align: center;
    }
    .reason-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--sn-primary);
      color: #fff;
      font-family: var(--sn-font-rounded);
      font-size: var(--sn-text-xl);
      font-weight: 700;
      margin-bottom: var(--sn-space-4);
    }
    .reason-title {
      font-size: var(--sn-text-lg);
      font-weight: 700;
      margin-bottom: var(--sn-space-3);
    }
    .reason-desc {
      font-size: var(--sn-text-sm);
      color: var(--sn-muted);
      line-height: var(--sn-leading-relaxed);
    }

    /* 8診断グリッド */
    .diag-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: var(--sn-space-4);
    }
    .diag-card {
      display: flex;
      align-items: flex-start;
      gap: var(--sn-space-3);
      background: var(--sn-bg-white);
      border-radius: var(--sn-radius);
      padding: var(--sn-space-5);
      text-decoration: none;
      color: inherit;
      box-shadow: var(--sn-shadow-sm);
      border: 1px solid var(--sn-border);
      transition: all var(--sn-dur-base) var(--sn-ease);
    }
    .diag-card:hover {
      box-shadow: var(--sn-shadow-md);
      transform: translateY(-2px);
      border-color: var(--sn-primary-light);
    }
    .diag-icon {
      width: 48px;
      height: 48px;
      border-radius: var(--sn-radius-sm);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      flex-shrink: 0;
    }
    .diag-name {
      font-size: var(--sn-text-base);
      font-weight: 700;
      margin-bottom: 4px;
    }
    .diag-desc {
      font-size: var(--sn-text-sm);
      color: var(--sn-muted);
    }

    /* 5シーン軸 */
    .scenes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: var(--sn-space-4);
    }
    .scene-card {
      border-radius: var(--sn-radius);
      padding: var(--sn-space-6);
      text-align: center;
    }
    .scene-icon {
      font-size: 2rem;
      margin-bottom: var(--sn-space-2);
    }
    .scene-label {
      font-size: var(--sn-text-lg);
      font-weight: 700;
      margin-bottom: var(--sn-space-2);
    }
    .scene-desc {
      font-size: var(--sn-text-sm);
      line-height: var(--sn-leading-relaxed);
    }

    /* 統合プロファイル訴求 */
    .profile-flow {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: var(--sn-space-4);
      margin: var(--sn-space-8) 0;
    }
    .profile-step {
      background: var(--sn-bg-white);
      border-radius: var(--sn-radius);
      padding: var(--sn-space-5) var(--sn-space-6);
      text-align: center;
      box-shadow: var(--sn-shadow-sm);
      min-width: 160px;
    }
    .profile-step-num {
      font-size: var(--sn-text-sm);
      color: var(--sn-muted);
      margin-bottom: var(--sn-space-1);
    }
    .profile-step-label {
      font-size: var(--sn-text-base);
      font-weight: 700;
    }
    .profile-arrow {
      font-size: 1.5rem;
      color: var(--sn-primary);
    }

    /* 料金プラン */
    .plans-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--sn-space-6);
      align-items: start;
    }
    .plan-card {
